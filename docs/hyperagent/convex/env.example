# Convex env vars for Tendso Studio (set in the Convex dashboard → Settings → Environment Variables)

# The Hyperagent agent's Webhook trigger (Agent settings → Triggers → Webhook/API)
HYPERAGENT_WEBHOOK_URL=https://hyperagent.com/api/agents/<agent-id>/webhook
HYPERAGENT_WEBHOOK_TOKEN=<the webhook auth token Hyperagent shows you>

# Shared secret guarding /hyperagent-callback. Must match the skill's TENDSO_CALLBACK_SECRET credential.
TENDSO_CALLBACK_SECRET=<generate a long random string>

# Already set in Tendso, used to resolve photo paths:
# R2_PUBLIC_URL=https://<your-r2-public-domain>
