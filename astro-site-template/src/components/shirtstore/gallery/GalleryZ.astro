---
interface Props { content: any; layout: any; }
const { content } = Astro.props;
const gallery = content.gallery || {};
const tag = gallery.tag || '';
const headline = gallery.headline || '';
const sub = gallery.sub || '';
type Tile = { image?: string; caption?: string };
const rawItems: Tile[] = Array.isArray(gallery.items) ? gallery.items : (Array.isArray(content.gallery) ? content.gallery : []);
const items = rawItems.filter((it: Tile) => it && it.image);
---
{items.length > 0 && (
  <section class="gal" id="gallery">
    <div class="wrap">
      <div class="gal-head">
        <div>
          {tag && <p class="eyebrow reveal" data-field="gallery.tag">{tag}</p>}
          {headline && <h2 class="reveal" data-field="gallery.headline" set:html={headline}></h2>}
        </div>
        {sub && <p class="gal-sub" data-field="gallery.sub">{sub}</p>}
      </div>
      <div class="gal-grid">
        {items.map((item, i) => (
          <figure class={`gi gi-${(i % 6) + 1} reveal`}>
            <div class="bg-img" data-image-field={`gallery.items.${i}.image`} style={`background-image:url('${item.image}');`}></div>
            {item.caption && (
              <div class="cap">
                <span class="t" data-field={`gallery.items.${i}.caption`}>{item.caption}</span>
                <span class="x">{String(i + 1).padStart(2, '0')}</span>
              </div>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>
)}
<style>
  .gal { padding: clamp(56px, 8vw, 120px) 0; }
  .gal-head { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 30px; }
  .gal-head .eyebrow { color: var(--accent); }
  .gal-head h2 { font-size: clamp(34px, 4.4vw, 64px); margin-top: 8px; }
  .gal-sub { color: var(--ink-2, var(--muted)); }
  .gal-grid { display: grid; grid-template-columns: repeat(12, 1fr); grid-auto-rows: 120px; gap: 16px; }
  .gi { position: relative; overflow: hidden; margin: 0; }
  .gi .bg-img { width: 100%; height: 100%; transition: transform .8s cubic-bezier(.2,.8,.1,1); }
  .gi:hover .bg-img { transform: scale(1.06); }
  .gi::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.45), transparent 60%); opacity: 0; transition: .45s; }
  .gi:hover::after { opacity: 1; }
  .gi .cap {
    position: absolute; left: 16px; bottom: 14px; right: 16px;
    display: flex; justify-content: space-between; align-items: flex-end;
    color: #fff; opacity: 0; transform: translateY(8px); transition: .45s; z-index: 2;
  }
  .gi:hover .cap { opacity: 1; transform: none; }
  .gi .cap .t { font-family: var(--serif); font-size: 19px; }
  .gi .cap .x { font-family: var(--sans); font-size: 11px; letter-spacing: .2em; }
  .gi-1 { grid-column: span 7; grid-row: span 4; }
  .gi-2 { grid-column: span 5; grid-row: span 2; }
  .gi-3 { grid-column: span 5; grid-row: span 2; }
  .gi-4 { grid-column: span 4; grid-row: span 3; }
  .gi-5 { grid-column: span 4; grid-row: span 3; }
  .gi-6 { grid-column: span 4; grid-row: span 3; }
  @media (max-width: 860px) {
    .gal-grid { grid-template-columns: 1fr 1fr; grid-auto-rows: 140px; }
    .gi-1 { grid-column: span 2; grid-row: span 3; }
    .gi-2, .gi-3, .gi-4, .gi-5, .gi-6 { grid-column: span 1; grid-row: span 2; }
  }
</style>
