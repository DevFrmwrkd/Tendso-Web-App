---
/**
 * shirtstore / HeroAD — Kinetic. Type-left / image-right split hero with a hard
 * divider. Big uppercase Syne headline (outline + accent line accents), copy
 * and CTAs stacked below; full-bleed hero photo on the right with a mono meta
 * caption bar. Reads content.hero (shared shape across the shirtstore family so
 * content stays portable when admin swaps variant). Hero image comes from
 * content.hero.image → Hyperagent enhanced image, with a striped placeholder
 * fallback.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const hero = content.hero || {};
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';
const kicker = hero.kicker || hero.locality || '';
const headlineLines: string[] = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0
  ? hero.headlineLines
  : (hero.headline ? [hero.headline] : []);
const sub = hero.sub || '';
const cta1Text = hero.cta1?.text || '';
const cta1Href = hero.cta1?.href || '#services';
const cta2Text = hero.cta2?.text || '';
const cta2Href = hero.cta2?.href || (layout.contact?.phone ? `tel:${String(layout.contact.phone).replace(/[^0-9+]/g, '')}` : '#visit');
const rating = hero.rating || '';
const tag = hero.tag || '';
---
<section class="heroAD" id="top">
  <div class="heroAD-copy">
    <div class="heroAD-top">
      {kicker && <span class="kicker" data-field="hero.kicker">{kicker}</span>}
      <span class="mono heroAD-index">05 / 05</span>
    </div>
    {headlineLines.length > 0 && (
      <h1 class="heroAD-headline">
        {headlineLines.map((line: string, i: number) => (
          <span class="hl"><span class="hl-in" data-field={`hero.headlineLines.${i}`} set:html={line}></span></span>
        ))}
      </h1>
    )}
    <div class="heroAD-bottom">
      {sub && <p class="heroAD-sub reveal" data-field="hero.sub">{sub}</p>}
      <div class="heroAD-cta reveal">
        {cta1Text && <a class="btn btn--accent" href={cta1Href} data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>}
        {cta2Text && <a class="btn btn--ghost" href={cta2Href} data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>}
      </div>
    </div>
  </div>
  <figure class="heroAD-fig">
    {heroImage
      ? <div class="bg-img" data-image-field="hero.image" style={`background-image:url('${heroImage}');`}></div>
      : <div class="bg-img placeholder" data-image-field="hero.image"></div>}
    {(tag || rating) && (
      <figcaption class="heroAD-meta">
        <span data-field="hero.tag">{tag}</span>
        {rating && <span data-field="hero.rating">{rating}</span>}
      </figcaption>
    )}
  </figure>
</section>
<style>
  .heroAD {
    display: grid;
    grid-template-columns: 1fr 1.04fr;
    min-height: calc(100vh - 64px);
    border-bottom: 1.5px solid var(--ink);
  }
  .heroAD-copy {
    display: flex; flex-direction: column; justify-content: space-between;
    padding: clamp(24px, 3vw, 48px) clamp(20px, 3vw, 52px);
    border-right: 1.5px solid var(--ink);
  }
  .heroAD-top { display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .heroAD-index { color: var(--muted, rgba(var(--ink-rgb), .6)); }
  .heroAD-headline {
    font-family: var(--display);
    font-weight: 800; line-height: .92; letter-spacing: -.02em; text-transform: uppercase;
    font-size: clamp(54px, 8vw, 128px);
    margin: auto 0;
  }
  .heroAD-headline .hl { display: block; overflow: hidden; }
  .heroAD-headline .hl-in { display: block; }
  /* Accent + outline treatments for lines the source styles specially */
  .heroAD-headline .hl:nth-child(2) .hl-in {
    -webkit-text-stroke: 1.5px var(--ink); color: transparent;
  }
  .heroAD-headline .hl:last-child .hl-in { color: var(--accent); }
  .heroAD-bottom .heroAD-sub {
    font-size: 16px; color: var(--muted, rgba(var(--ink-rgb), .78));
    max-width: 40ch; margin-bottom: 20px;
  }
  .heroAD-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .heroAD-fig { position: relative; overflow: hidden; }
  .heroAD-fig .bg-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    background-size: cover; background-position: center;
  }
  .heroAD-fig .placeholder {
    background: repeating-linear-gradient(45deg, var(--paper-2, #f1f1f1) 0 14px, var(--paper) 14px 28px);
  }
  .heroAD-meta {
    position: absolute; left: 0; right: 0; bottom: 0;
    display: flex; justify-content: space-between; gap: 12px;
    padding: 16px 20px;
    font-family: var(--mono); font-size: 12px; text-transform: uppercase; letter-spacing: .06em;
    color: #fff; background: linear-gradient(to top, rgba(0,0,0,.55), transparent);
  }
  @media (max-width: 860px) {
    .heroAD { grid-template-columns: 1fr; min-height: 0; }
    .heroAD-copy { border-right: 0; border-bottom: 1.5px solid var(--ink); min-height: 78vh; }
    .heroAD-headline { font-size: clamp(52px, 15vw, 96px); }
    .heroAD-fig { min-height: 60vh; }
  }
</style>
