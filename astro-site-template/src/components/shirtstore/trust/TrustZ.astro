---
interface Props { content: any; }
const { content } = Astro.props;
const trust = content.trust || {};
const cells: Array<{ num: string; label: string }> = Array.isArray(trust.cells) ? trust.cells : [];
---
{cells.length > 0 && (
  <section class="trust">
    <div class="wrap trust-row">
      {cells.map((cell, i) => (
        <div class="trust-cell reveal">
          <div class="n" data-field={`trust.cells.${i}.num`} set:html={cell.num}></div>
          <div class="t" data-field={`trust.cells.${i}.label`}>{cell.label}</div>
        </div>
      ))}
    </div>
  </section>
)}
<style>
  .trust { border-block: 1px solid var(--line); margin-top: clamp(40px, 6vw, 80px); }
  .trust-row { display: grid; grid-template-columns: repeat(4, 1fr); }
  .trust-cell { padding: 26px clamp(12px, 2vw, 28px); border-left: 1px solid var(--line); }
  .trust-cell:first-child { border-left: 0; }
  .trust-cell .n { font-family: var(--serif); font-weight: 400; font-size: clamp(30px, 3.4vw, 46px); color: var(--ink); line-height: 1; }
  .trust-cell .t {
    font-family: var(--sans); font-size: 11px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-2, var(--muted)); margin-top: 6px;
  }
  @media (max-width: 720px) {
    .trust-row { grid-template-columns: 1fr 1fr; }
    .trust-cell:nth-child(3) { border-left: 0; }
    .trust-cell:nth-child(n+3) { border-top: 1px solid var(--line); }
  }
</style>
