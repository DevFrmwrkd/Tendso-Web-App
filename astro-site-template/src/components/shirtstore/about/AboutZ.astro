---
interface Props { content: any; }
const { content } = Astro.props;
const about = content.about || {};
const tag = about.tag || '';
const headline = about.headline || '';
const paragraphs: string[] = Array.isArray(about.paragraphs) ? about.paragraphs : (about.body ? [about.body] : []);
const image = about.image || (Array.isArray(about.images) && about.images[0]) || '';
const quote = about.quote || '';
---
<section class="about" id="about">
  <div class="wrap about-grid">
    <figure class="about-fig reveal">
      {image
        ? <div class="bg-img" data-image-field="about.image" style={`background-image:url('${image}');`}></div>
        : <div class="bg-img placeholder" data-image-field="about.image"></div>}
    </figure>
    <div class="about-copy reveal">
      {tag && <p class="eyebrow" data-field="about.tag">{tag}</p>}
      {headline && <h2 data-field="about.headline" set:html={headline}></h2>}
      {paragraphs.map((p: string, i: number) => (
        <p class="about-p" data-field={`about.paragraphs.${i}`} set:html={p}></p>
      ))}
      {quote && <div class="sig" data-field="about.quote">{quote}</div>}
    </div>
  </div>
</section>
<style>
  .about { padding: clamp(64px, 10vw, 150px) 0; }
  .about-grid {
    display: grid; grid-template-columns: 1.15fr .85fr; gap: clamp(30px, 5vw, 80px);
    align-items: center;
  }
  .about-fig { margin: 0; overflow: hidden; }
  .about-fig .bg-img { width: 100%; height: min(74vh, 680px); }
  .about-copy .eyebrow { color: var(--accent); }
  .about h2 { font-size: clamp(34px, 4.4vw, 64px); margin-top: 14px; }
  .about-p { font-size: 18px; color: var(--ink-2, var(--muted)); margin-top: 22px; max-width: 46ch; line-height: 1.6; }
  .about .sig { font-family: var(--serif); font-style: italic; font-size: 24px; margin-top: 26px; color: var(--ink); }
  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-fig .bg-img { height: 60vh; }
  }
</style>
