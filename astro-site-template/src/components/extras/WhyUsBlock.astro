---
/**
 * WhyUsBlock — three reasons, each a short paragraph.
 *
 * Per v01 spec WHY.v1/v2: 3 evidence-based reasons. Brief explicitly
 * bans the icon-circle-feature-card pattern — this uses serif numbers + body.
 */
interface Props {
    items?: { title: string; body: string }[];
    visibility?: Record<string, boolean>;
    /**
     * Variant style — picked from Template tab.
     * - M1: Three Pillars (editorial 3-column, current)
     * - M2: Numbered Cards (big serif numbers on raised cards)
     */
    variantStyle?: string;
}

const { items = [], visibility, variantStyle = 'M1' } = Astro.props;
const show = visibility?.whyUsBlock !== false && items.length > 0;
const isM2 = String(variantStyle).toUpperCase() === 'M2';
---

{show && (
    <section
        id="why-us"
        class:list={["bg-[var(--surface)] py-20 md:py-28 whyus-block", isM2 && "is-m2"]}
        data-variant={variantStyle}
        data-component="WHY-US"
    >
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="mb-12 max-w-3xl">
                <p
                    class="text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-3"
                    style="font-family: var(--body-font, inherit);"
                >
                    Why choose us
                </p>
                <h2
                    class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-[var(--text)]"
                    style="font-family: var(--heading-font, inherit);"
                    data-field="whyUs.heading"
                >
                    Choose us because of the work.
                </h2>
            </div>
            <ol class="whyus-grid grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 m-0 p-0 list-none">
                {items.map((it, i) => (
                    <li class="whyus-item flex flex-col gap-3">
                        <span
                            class="whyus-num text-3xl text-[var(--primary)] font-bold tabular-nums"
                            style="font-family: var(--heading-font, inherit);"
                        >
                            {String(i + 1).padStart(2, '0')}
                        </span>
                        <h3
                            class="text-xl font-bold text-[var(--text)] leading-tight"
                            style="font-family: var(--heading-font, inherit);"
                            data-field={`whyUs.item.${i}.title`}
                            set:html={it.title}
                        ></h3>
                        <p
                            class="text-[var(--text-muted)] text-base leading-relaxed"
                            style="font-family: var(--body-font, inherit);"
                            data-field={`whyUs.item.${i}.body`}
                            set:html={it.body}
                        ></p>
                    </li>
                ))}
            </ol>
        </div>
    </section>
)}

<style>
    /* M2 — Numbered Cards: each reason becomes a raised card with a giant
       serif number on top, body content inside, subtle accent border. */
    .whyus-block.is-m2 .whyus-item {
        padding: 28px 24px 24px;
        background: var(--bg);
        border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
        border-radius: 18px;
        box-shadow: 0 12px 32px color-mix(in srgb, var(--text) 6%, transparent);
        gap: 12px;
        position: relative;
    }
    .whyus-block.is-m2 .whyus-num {
        font-size: clamp(36px, 4vw, 56px);
        line-height: 1;
        opacity: 0.95;
    }
    .whyus-block.is-m2 .whyus-item::before {
        content: "";
        position: absolute;
        top: 0;
        left: 24px;
        right: 24px;
        height: 3px;
        background: var(--primary);
        border-radius: 0 0 6px 6px;
    }
</style>
