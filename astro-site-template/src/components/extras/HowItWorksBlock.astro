---
/**
 * HowItWorksBlock — numbered steps from first contact to outcome.
 *
 * Per v01 spec HOW.v1: 3-4 numbered steps. Removes "what happens if I
 * contact them?" friction — biggest hidden conversion blocker for trades
 * and local services.
 */
interface Props {
    items?: { step: string; title: string; body: string }[];
    visibility?: Record<string, boolean>;
    /** M1: Step Ribbon (default 4-up grid) · M2: Vertical Path */
    variantStyle?: string;
}

const { items = [], visibility, variantStyle = 'M1' } = Astro.props;
const show = visibility?.howItWorksBlock !== false && items.length > 0;
const isM2 = String(variantStyle).toUpperCase() === 'M2';
---

{show && (
    <section
        id="how-it-works"
        class:list={["bg-[var(--bg)] py-20 md:py-28 how-block", isM2 && "is-m2"]}
        data-variant={variantStyle}
        data-component="HOW-IT-WORKS"
    >
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="mb-12 max-w-3xl">
                <p
                    class="text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-3"
                    style="font-family: var(--body-font, inherit);"
                >
                    How it works
                </p>
                <h2
                    class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-[var(--text)]"
                    style="font-family: var(--heading-font, inherit);"
                    data-field="howItWorks.heading"
                >
                    From first call to the work done.
                </h2>
            </div>
            <ol class="how-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 m-0 p-0 list-none">
                {items.map((it, i) => (
                    <li class="how-item rounded-2xl border border-[var(--text)]/10 bg-[var(--surface)] p-6 lg:p-7 flex flex-col gap-3">
                        <span
                            class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--primary)] tabular-nums"
                            style="font-family: var(--body-font, inherit);"
                            data-field={`howItWorks.item.${i}.step`}
                            set:html={it.step}
                        ></span>
                        <h3
                            class="text-lg font-bold text-[var(--text)] leading-tight"
                            style="font-family: var(--heading-font, inherit);"
                            data-field={`howItWorks.item.${i}.title`}
                            set:html={it.title}
                        ></h3>
                        <p
                            class="text-[var(--text-muted)] text-sm leading-relaxed"
                            style="font-family: var(--body-font, inherit);"
                            data-field={`howItWorks.item.${i}.body`}
                            set:html={it.body}
                        ></p>
                    </li>
                ))}
            </ol>
        </div>
    </section>
)}

<style>
    /* M2 — Vertical Path: single column with a connector spine + dot markers.
       Each step indents and the step number becomes a circular badge on the spine. */
    .how-block.is-m2 .how-grid {
        grid-template-columns: 1fr;
        max-width: 720px;
        margin: 0 auto;
        gap: 0;
        position: relative;
    }
    .how-block.is-m2 .how-grid::before {
        content: "";
        position: absolute;
        left: 22px;
        top: 16px;
        bottom: 16px;
        width: 2px;
        background: color-mix(in srgb, var(--primary) 35%, transparent);
    }
    .how-block.is-m2 .how-item {
        margin-left: 56px;
        margin-bottom: 16px;
        position: relative;
        background: transparent;
        border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    }
    .how-block.is-m2 .how-item::before {
        content: "";
        position: absolute;
        left: -42px;
        top: 24px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--primary);
        box-shadow: 0 0 0 4px var(--bg);
    }
</style>
