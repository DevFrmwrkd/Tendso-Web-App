---
/**
 * ClickToMessage — floating WhatsApp + Messenger deep-link FAB.
 *
 * Per v01 spec MSG.v1: "fixed bottom-right deep-link button" — the lowest-
 * friction contact path on mobile, especially in PH where WhatsApp /
 * Messenger are the default channels.
 *
 * Both targets are optional; the block silently renders nothing if neither
 * is set. WhatsApp link is auto-derived from the business phone in the
 * build pipeline (strip non-digits + ensure +63 prefix) when no explicit
 * `whatsapp` value is provided.
 */
interface Props {
    whatsapp?: string;
    messenger?: string;
    visibility?: Record<string, boolean>;
    /** M1: FAB Pair (default floating bottom-right) · M2: Inline Strip (sticky bottom) */
    variantStyle?: string;
}

const { whatsapp, messenger, visibility, variantStyle = 'M1' } = Astro.props;
const show = visibility?.clickToMessage !== false && (whatsapp || messenger);
const isM2 = String(variantStyle).toUpperCase() === 'M2';

// WhatsApp deeplink shape: https://wa.me/<digits-only-international>
const waDigits = whatsapp ? whatsapp.replace(/[^0-9]/g, '') : '';
const waUrl = waDigits ? `https://wa.me/${waDigits}` : '';
const msgUrl = messenger || '';
---

{show && (
    <div
        id="ctm-floating"
        class:list={[
            "z-[9999] ctm-block",
            isM2
                ? "fixed bottom-0 left-0 right-0 flex justify-center gap-2 px-4 py-3 ctm-strip"
                : "fixed bottom-5 right-5 flex flex-col gap-3 items-end",
        ]}
        data-variant={variantStyle}
        data-component="CLICK-TO-MESSAGE"
        data-field="messaging"
        style={isM2
            ? "background: color-mix(in srgb, var(--text) 96%, var(--bg)); backdrop-filter: blur(6px); border-top: 1px solid color-mix(in srgb, var(--text) 30%, transparent);"
            : undefined}
    >
        {waUrl && (
            <a
                href={waUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Message us on WhatsApp"
                class="flex items-center gap-2 rounded-full px-5 py-3 shadow-[0_8px_24px_-6px_rgba(0,0,0,0.3)] transition-transform duration-200 hover:scale-105"
                style="background: #25D366; color: #fff; font-family: var(--body-font, system-ui, sans-serif);"
            >
                <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"
                    />
                </svg>
                <span class="text-sm font-semibold">WhatsApp</span>
            </a>
        )}
        {msgUrl && (
            <a
                href={msgUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Message us on Messenger"
                class="flex items-center gap-2 rounded-full px-5 py-3 shadow-[0_8px_24px_-6px_rgba(0,0,0,0.3)] transition-transform duration-200 hover:scale-105"
                style="background: #0084FF; color: #fff; font-family: var(--body-font, system-ui, sans-serif);"
            >
                <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M12 2C6.486 2 2 6.262 2 11.5c0 2.665 1.193 5.073 3.117 6.762v3.738l2.829-1.554c.972.27 2.001.417 3.054.417 5.514 0 10-4.262 10-9.363S17.514 2 12 2zm.875 12.625l-2.5-2.625-4.875 2.625L11.125 9l2.625 2.625 4.75-2.625-5.625 5.625z"
                    />
                </svg>
                <span class="text-sm font-semibold">Messenger</span>
            </a>
        )}
    </div>
)}
