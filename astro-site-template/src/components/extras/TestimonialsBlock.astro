---
/**
 * TestimonialsBlock — 2-3 quotes with names + context.
 *
 * Per v01 spec TEST.v1: quotes column. Social proof — "someone else
 * took the risk, it worked."
 *
 * Brief constraint: "no staff names/dates" — but customer testimonials
 * with first name + context are fine (and the standard pattern).
 */
interface Props {
    items?: { quote: string; name: string; context?: string }[];
    visibility?: Record<string, boolean>;
    /** M1: Quote Cards (3-up grid) · M2: Editorial Pull (single hero quote) */
    variantStyle?: string;
}

const { items = [], visibility, variantStyle = 'M1' } = Astro.props;
const show = visibility?.testimonialsBlock !== false && items.length > 0;
const isM2 = String(variantStyle).toUpperCase() === 'M2';
---

{show && (
    <section
        id="testimonials"
        class:list={["bg-[var(--surface)] py-20 md:py-28 testimonials-block", isM2 && "is-m2"]}
        data-variant={variantStyle}
        data-component="TESTIMONIALS"
    >
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="mb-12 max-w-3xl">
                <p
                    class="text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-3"
                    style="font-family: var(--body-font, inherit);"
                >
                    What customers say
                </p>
                <h2
                    class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-[var(--text)]"
                    style="font-family: var(--heading-font, inherit);"
                    data-field="testimonials.heading"
                >
                    In their own words.
                </h2>
            </div>
            <div class="testimonials-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
                {items.map((it, i) => (
                    <figure
                        class="testimonials-item rounded-2xl border border-[var(--text)]/10 bg-[var(--bg)] p-7 flex flex-col gap-5 m-0"
                    >
                        <blockquote
                            class="text-[var(--text)] text-lg leading-snug m-0 italic"
                            style="font-family: var(--heading-font, inherit);"
                            data-field={`testimonials.item.${i}.quote`}
                        >
                            <span set:html={`“${it.quote}”`}></span>
                        </blockquote>
                        <figcaption class="flex flex-col gap-1">
                            <span
                                class="text-[var(--text)] text-sm font-semibold"
                                style="font-family: var(--body-font, inherit);"
                                data-field={`testimonials.item.${i}.name`}
                                set:html={it.name}
                            ></span>
                            {it.context && (
                                <span
                                    class="text-[var(--text-muted)] text-xs"
                                    style="font-family: var(--body-font, inherit);"
                                    data-field={`testimonials.item.${i}.context`}
                                    set:html={it.context}
                                ></span>
                            )}
                        </figcaption>
                    </figure>
                ))}
            </div>
        </div>
    </section>
)}

<style>
    /* M2 — Editorial Pull: turns the grid into a stacked single column of
       hero-sized pull-quotes with hanging serif quote mark + big byline. */
    .testimonials-block.is-m2 .testimonials-grid {
        display: flex;
        flex-direction: column;
        gap: 32px;
        max-width: 820px;
        margin: 0 auto;
    }
    .testimonials-block.is-m2 .testimonials-item {
        background: transparent;
        border: 0;
        border-top: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
        border-radius: 0;
        padding: 32px 0 0;
        position: relative;
        gap: 18px;
    }
    .testimonials-block.is-m2 .testimonials-item blockquote {
        font-size: clamp(22px, 2.6vw, 32px);
        line-height: 1.25;
        font-style: italic;
        max-width: 64ch;
    }
    .testimonials-block.is-m2 .testimonials-item::before {
        content: "“";
        position: absolute;
        top: 8px;
        left: -8px;
        font-family: var(--heading-font, serif);
        font-size: 96px;
        line-height: 1;
        color: var(--primary);
        opacity: 0.18;
        pointer-events: none;
    }
</style>
