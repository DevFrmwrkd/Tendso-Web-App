---
/**
 * CredentialsBlock — list of marks (licence numbers, certifications,
 * memberships, insurance).
 *
 * Per v01 spec CRED.v1. Decisive for medical, trades, education
 * (anything YMYL). Renders nothing if empty.
 */
interface Props {
    items?: { label: string; detail: string }[];
    visibility?: Record<string, boolean>;
    /** M1: Dotted DL (default) · M2: Marks Grid */
    variantStyle?: string;
}

const { items = [], visibility, variantStyle = 'M1' } = Astro.props;
const show = visibility?.credentialsBlock !== false && items.length > 0;
const isM2 = String(variantStyle).toUpperCase() === 'M2';
---

{show && (
    <section
        id="credentials"
        class:list={["bg-[var(--surface)] py-16 md:py-20 border-y border-[var(--text)]/8 cred-block", isM2 && "is-m2"]}
        data-variant={variantStyle}
        data-component="CREDENTIALS"
    >
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <p
                class="text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-6"
                style="font-family: var(--body-font, inherit);"
            >
                Credentials &amp; licences
            </p>
            <dl class="cred-list grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-5 m-0">
                {items.map((it, i) => (
                    <div class="cred-item flex flex-col gap-1 py-3 border-b border-[var(--text)]/10" data-field={`credentials.item.${i}`}>
                        <dt
                            class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)]"
                            style="font-family: var(--body-font, inherit);"
                            data-field={`credentials.item.${i}.label`}
                            set:html={it.label}
                        ></dt>
                        <dd
                            class="text-[var(--text)] text-sm font-semibold m-0"
                            style="font-family: var(--body-font, inherit);"
                            data-field={`credentials.item.${i}.detail`}
                            set:html={it.detail}
                        ></dd>
                    </div>
                ))}
            </dl>
        </div>
    </section>
)}

<style>
    /* M2 — Marks Grid: items become bordered tile cards with the label
       at top and detail centered, mimicking logo/award tiles. */
    .cred-block.is-m2 .cred-item {
        border: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
        background: var(--bg);
        border-radius: 12px;
        padding: 22px 16px;
        text-align: center;
        align-items: center;
        gap: 8px;
    }
    .cred-block.is-m2 .cred-item dt {
        color: var(--primary);
        font-size: 9px;
    }
    .cred-block.is-m2 .cred-item dd {
        font-size: 15px;
    }
</style>
