---
/**
 * CtaBandBlock — full-width tinted band, re-offers the action.
 *
 * Per v01 spec CTA.v1/v2/v3. Last conversion lever — keeps user from
 * scrolling back to hero. Defaults to high-contrast primary tint.
 */
interface Props {
    heading?: string;
    body?: string;
    primaryLabel?: string;
    primaryLink?: string;
    secondaryLabel?: string;
    secondaryLink?: string;
    visibility?: Record<string, boolean>;
    /** M1: Dark Band (primary fill) · M2: Soft Banner (paper surface) */
    variantStyle?: string;
}

const {
    heading,
    body,
    primaryLabel,
    primaryLink,
    secondaryLabel,
    secondaryLink,
    visibility,
    variantStyle = 'M1',
} = Astro.props;

const show = visibility?.ctaBandBlock !== false && (heading || body || primaryLabel);
const isM2 = String(variantStyle).toUpperCase() === 'M2';
---

{show && (
    <section
        id="cta"
        class:list={["py-16 md:py-20 cta-block", isM2 && "is-m2"]}
        data-variant={variantStyle}
        data-component="CTA-BAND"
        style={isM2
            ? "background: var(--surface); color: var(--text);"
            : "background: var(--primary); color: var(--text-inverse);"}
    >
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
                <div class="max-w-2xl">
                    {heading && (
                        <h2
                            class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight"
                            style="font-family: var(--heading-font, inherit);"
                            data-field="ctaBand.heading"
                            set:html={heading}
                        ></h2>
                    )}
                    {body && (
                        <p
                            class="mt-4 text-base lg:text-lg leading-relaxed opacity-90"
                            style="font-family: var(--body-font, inherit);"
                            data-field="ctaBand.body"
                            set:html={body}
                        ></p>
                    )}
                </div>
                <div class="flex flex-wrap gap-3 flex-shrink-0">
                    {primaryLabel && (
                        <a
                            href={primaryLink || '#contact'}
                            class="cta-primary inline-flex items-center gap-2 px-7 py-4 rounded-full font-bold text-sm uppercase tracking-wide hover:scale-105 transition-transform"
                            style={isM2
                                ? "background: var(--primary); color: var(--text-inverse); font-family: var(--body-font, inherit);"
                                : "background: #fff; color: var(--primary); font-family: var(--body-font, inherit);"}
                            data-field="ctaBand.primary"
                            set:html={primaryLabel}
                        ></a>
                    )}
                    {secondaryLabel && (
                        <a
                            href={secondaryLink || '#location'}
                            class="cta-secondary inline-flex items-center gap-2 px-7 py-4 rounded-full font-bold text-sm uppercase tracking-wide transition-colors"
                            style={isM2
                                ? "background: transparent; border: 1px solid color-mix(in srgb, var(--text) 30%, transparent); color: var(--text); font-family: var(--body-font, inherit);"
                                : "background: transparent; border: 1px solid rgba(255,255,255,0.4); color: var(--text-inverse); font-family: var(--body-font, inherit);"}
                            data-field="ctaBand.secondary"
                            set:html={secondaryLabel}
                        ></a>
                    )}
                </div>
            </div>
        </div>
    </section>
)}
