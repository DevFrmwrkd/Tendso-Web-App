---
/**
 * LocationBlock — NAP (Name/Address/Phone) + Leaflet map pin.
 *
 * Renders on EVERY variant via index.astro. Visibility-toggle controlled.
 * Designed per docs/Landing Pages v01/COMPONENTS.md LOC.v1:
 *   "NAP + hours + map block — name/address/phone + GBP hours slot + map placeholder."
 *
 * Why this exists:
 * - Local-SEO backbone — the NAP triple is the single biggest ranking signal
 *   for "near me" searches when consistent across the site, GBP, and citations.
 * - Static fallback: the address renders as plain text whether the Leaflet
 *   script runs or not (JS-off readable per the brief's static-file principle).
 *
 * Coordinates come from `submissions.coordinates` (if present) or get
 * geocoded client-side from the address via Nominatim. Static markup never
 * blocks on geocoding — the map appears once the JS resolves coords.
 */
interface Props {
    businessName: string;
    address?: string;
    phone?: string;
    phoneDisplay?: string;
    email?: string;
    lat?: number;
    lng?: number;
    googleMapsUrl?: string;
    visibility?: Record<string, boolean>;
}

const {
    businessName,
    address,
    phone,
    phoneDisplay,
    email,
    lat,
    lng,
    googleMapsUrl,
    visibility,
} = Astro.props;

const show = visibility?.locationBlock !== false;
const hasMap = !!(lat && lng) || !!address;
const phoneTel = phone ? phone.replace(/[^0-9+]/g, '') : '';
const phoneText = phoneDisplay || phone || '';
---

{show && (address || phone || email) && (
    <section id="location" class="bg-[var(--surface)] py-20 md:py-28">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="mb-10 flex items-end justify-between gap-6 flex-wrap">
                <div>
                    <p
                        class="text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-3"
                        style="font-family: var(--body-font, inherit);"
                    >
                        Visit / Contact
                    </p>
                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-[var(--text)]"
                        style="font-family: var(--heading-font, inherit);"
                        data-field="location.heading"
                    >
                        Find <span data-field="business.name" set:html={businessName}></span>
                    </h2>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-6 lg:gap-10">
                {/* NAP card */}
                <div class="rounded-2xl border border-[var(--text)]/10 bg-[var(--bg)] p-6 lg:p-8 flex flex-col gap-5">
                    {address && (
                        <div>
                            <p
                                class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-1.5"
                                style="font-family: var(--body-font, inherit);"
                            >
                                Address
                            </p>
                            <p
                                class="text-[var(--text)] text-base leading-relaxed"
                                data-field="contact.address"
                                set:html={address}
                            ></p>
                        </div>
                    )}
                    {phoneText && (
                        <div>
                            <p
                                class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-1.5"
                                style="font-family: var(--body-font, inherit);"
                            >
                                Phone
                            </p>
                            <a
                                href={`tel:${phoneTel}`}
                                class="text-[var(--text)] text-base font-medium hover:text-[var(--primary)] transition-colors"
                            >
                                <span data-field="contact.phone" set:html={phoneText}></span>
                            </a>
                        </div>
                    )}
                    {email && (
                        <div>
                            <p
                                class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-1.5"
                                style="font-family: var(--body-font, inherit);"
                            >
                                Email
                            </p>
                            <a
                                href={`mailto:${email}`}
                                class="text-[var(--text)] text-base font-medium hover:text-[var(--primary)] transition-colors break-all"
                            >
                                <span data-field="contact.email" set:html={email}></span>
                            </a>
                        </div>
                    )}
                    {/* Hours slot — owner edits in Google. We surface a deeplink
                        so visitors see the live Google-maintained hours instead
                        of a stale typed-in schedule. Per the brief: "Hours /
                        rating pulled from Google, not typed in". */}
                    <div class="pt-2 border-t border-[var(--text)]/10">
                        <p
                            class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] mb-1.5"
                            style="font-family: var(--body-font, inherit);"
                        >
                            Hours
                        </p>
                        {googleMapsUrl ? (
                            <a
                                href={googleMapsUrl}
                                target="_blank"
                                rel="noopener"
                                class="inline-flex items-center gap-2 text-[var(--text)] text-sm font-medium hover:text-[var(--primary)] transition-colors"
                            >
                                <span data-field="location.hours_label">See latest hours on Google</span>
                                <span aria-hidden="true">→</span>
                            </a>
                        ) : (
                            <p class="text-[var(--text-muted)] text-sm italic">
                                See latest hours on Google
                            </p>
                        )}
                    </div>
                </div>

                {/* Map — Google Maps embed iframe.
                    Previous Leaflet + Nominatim approach was unreliable in
                    production: Nominatim couldn't geocode informal Philippine
                    addresses (returned 0 hits → empty map), and the external
                    leaflet.js with integrity hash occasionally failed to load
                    on edge networks. Google's no-key embed handles raw
                    address strings natively and never blanks out. */}
                {hasMap && (() => {
                    const mapQuery = lat && lng
                        ? `${lat},${lng}`
                        : (address || businessName || '');
                    const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=15&output=embed`;
                    const directionsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapQuery)}`;
                    return (
                        <div
                            class="rounded-2xl border border-[var(--text)]/10 bg-[var(--bg)] overflow-hidden min-h-[320px] lg:min-h-[420px] relative"
                        >
                            <iframe
                                src={mapSrc}
                                title={`Map · ${businessName ?? 'Location'}`}
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                allowfullscreen
                                class="w-full h-full min-h-[320px] lg:min-h-[420px] border-0"
                                style="background: var(--bg); display: block;"
                            ></iframe>
                            {/* Directions overlay — always-visible deeplink */}
                            <a
                                href={directionsHref}
                                target="_blank"
                                rel="noopener"
                                class="absolute bottom-3 right-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-white text-[var(--text)] shadow-md hover:shadow-lg transition-shadow"
                            >
                                Directions →
                            </a>
                        </div>
                    );
                })()}
            </div>
        </div>

    </section>
)}
