---
/**
 * TrustBlock — credential ribbon (years/licenses/memberships).
 *
 * Per v01 spec TRUST.v1: "horizontal strip of established-since,
 * license numbers, association marks; GBP rating slot empty/commented."
 *
 * Trust signals are content-not-chrome on YMYL local sites (medical,
 * trades). Renders nothing if all three arrays are empty so the block
 * is opt-in via content alone.
 */
interface Props {
    years?: string;
    licenses?: string[];
    memberships?: string[];
    visibility?: Record<string, boolean>;
    /**
     * Variant style — picked from the Template tab.
     * - M1 (default): horizontal Ribbon Row
     * - M2:           Stacked Badges with paper backing
     */
    variantStyle?: string;
}

const {
    years, licenses = [], memberships = [], visibility, variantStyle = 'M1',
} = Astro.props;
const items: { label: string; value: string }[] = [];
if (years) items.push({ label: 'Established', value: years });
licenses.forEach((l) => items.push({ label: 'Licensed', value: l }));
memberships.forEach((m) => items.push({ label: 'Member', value: m }));

const show = visibility?.trustBlock !== false && items.length > 0;
const isM2 = String(variantStyle).toUpperCase() === 'M2';
---

{show && (
    <section
        id="trust"
        class:list={[
            "bg-[var(--bg)] py-10 md:py-14 border-y border-[var(--text)]/8 trust-block",
            isM2 && "is-m2",
        ]}
        data-variant={variantStyle}
        data-component="TRUST"
    >
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <ul class="trust-list m-0 p-0 list-none">
                {items.map((it, i) => (
                    <li
                        class="trust-item"
                        data-field={`trust.item.${i}`}
                    >
                        <span
                            class="trust-label text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)]"
                            style="font-family: var(--body-font, inherit);"
                        >
                            {it.label}
                        </span>
                        <span
                            class="trust-value text-[var(--text)] text-sm font-semibold"
                            style="font-family: var(--body-font, inherit);"
                            set:html={it.value}
                        ></span>
                    </li>
                ))}
            </ul>
        </div>
    </section>
)}

<style>
    /* M1 — Ribbon Row (default, current layout). Horizontal flex strip. */
    .trust-list {
        display: flex;
        flex-wrap: wrap;
        gap: 24px 40px;
        align-items: center;
        justify-content: center;
    }
    @media (min-width: 768px) {
        .trust-list { justify-content: space-between; }
    }
    .trust-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }

    /* M2 — Stacked Badges. Each item becomes a rounded paper card with the
       label as a chip above the value. Centered grid layout. */
    .trust-block.is-m2 .trust-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        justify-content: center;
    }
    .trust-block.is-m2 .trust-item {
        padding: 14px 18px;
        background: color-mix(in srgb, var(--text) 4%, var(--bg));
        border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
        border-radius: 14px;
        align-items: center;
        text-align: center;
        gap: 6px;
    }
    .trust-block.is-m2 .trust-label {
        background: color-mix(in srgb, var(--primary) 14%, transparent);
        color: var(--primary);
        padding: 3px 10px;
        border-radius: 999px;
        letter-spacing: 0.18em;
    }
    .trust-block.is-m2 .trust-value {
        font-size: 15px;
    }
</style>
