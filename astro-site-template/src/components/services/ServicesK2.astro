---
/**
 * ServicesK2 - Barber Shop / Chalkboard Menu
 * Chalkboard-style menu with chalk-white text on deep green/black surface.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Today\'s Board',
  subheadline = 'Hand-written every morning. Sharpest cuts in town.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaultPrices = ['250', '350', '450', '550', '650', '750'];
---

<section
  id="services"
  class="relative w-full bg-[var(--text)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-12">
      <div class="barber-fade-up inline-flex items-center gap-4 mb-4">
        <span class="h-px w-12 bg-[var(--accent)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--accent)]">— Hand-written —</span>
        <span class="h-px w-12 bg-[var(--accent)]"></span>
      </div>

      {showHeadline && (
        <h2 class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--bg)] mb-4" style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;">
          {headline}
        </h2>
      )}
      {showSubheadline && (
        <p class="barber-fade-up text-[var(--accent)] italic" style="font-size: 1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {/* Chalkboard */}
    {showList && (
      <div class="barber-board relative bg-gradient-to-br from-[#0a1f1a] to-[#0d2a22] border-[12px] border-[#3a2517] shadow-[0_40px_80px_-20px_rgba(0,0,0,0.7),inset_0_0_60px_rgba(0,0,0,0.4)] p-10 sm:p-14 md:p-16">
        {/* Wood grain on frame edges */}
        <div class="absolute inset-0 pointer-events-none" style="background: repeating-linear-gradient(135deg, transparent 0 30px, rgba(58,37,23,0.05) 30px 32px);"></div>

        {/* Chalk dust streaks */}
        <div class="absolute inset-0 pointer-events-none opacity-30" style="background: radial-gradient(ellipse at 30% 20%, rgba(245,233,211,0.08), transparent 40%), radial-gradient(ellipse at 70% 80%, rgba(245,233,211,0.08), transparent 40%);"></div>

        {/* Top banner */}
        <div class="relative text-center mb-10">
          <h3 class="text-[var(--bg)] font-bold italic" style="font-size: clamp(1.5rem, 3vw, 2.25rem); text-shadow: 0 2px 4px rgba(0,0,0,0.3);">
            ✂  Cuts &amp; Shaves  ✂
          </h3>
          <div class="flex items-center justify-center gap-2 mt-2">
            <span class="h-0.5 w-16 bg-[var(--bg)]/60"></span>
            <span class="text-[var(--accent)]">●</span>
            <span class="h-0.5 w-16 bg-[var(--bg)]/60"></span>
          </div>
        </div>

        {/* Items */}
        <ul class="space-y-5 relative">
          {services.map((service, i) => {
            const price = service.price || defaultPrices[i % defaultPrices.length];
            return (
              <li class="barber-fade-up" style={`animation-delay: ${i * 0.08 + 0.3}s;`}>
                <div class="flex items-baseline gap-3">
                  <span class="text-[var(--accent)] text-lg italic">{i + 1}.</span>
                  <span class="text-[var(--bg)] text-lg sm:text-xl italic font-bold tracking-wide whitespace-nowrap" style="font-size: clamp(1.1rem, 1.5vw, 1.4rem); text-shadow: 0 1px 3px rgba(0,0,0,0.4);">
                    {service.name}
                  </span>
                  <span class="flex-1 border-b border-dashed border-[var(--bg)]/30 translate-y-[-3px]"></span>
                  <span class="text-[var(--accent)] text-lg sm:text-xl italic font-bold whitespace-nowrap">₱{price}</span>
                </div>
                {service.description && (
                  <p class="text-[var(--bg)]/70 italic text-sm leading-relaxed mt-1 pl-7" style="font-size: 0.95rem;">
                    "{service.description}"
                  </p>
                )}
              </li>
            );
          })}
        </ul>

        {/* Bottom footer */}
        <div class="relative mt-10 pt-6 border-t-2 border-dashed border-[var(--bg)]/15 text-center">
          <p class="text-[var(--bg)]/60 italic text-sm" style="font-size: 0.95rem;">— Hot towel & straight razor with every cut —</p>
        </div>

        {/* Chalk piece in corner */}
        <div class="absolute bottom-4 right-6 w-8 h-2 bg-[var(--bg)] shadow-md rotate-12 rounded-sm"></div>
      </div>
    )}

    {services.length === 0 && (
      <div class="text-center py-16 text-[var(--accent)]/40">
        <span class="text-6xl">✂</span>
        <p class="mt-4 italic">Today's board is being written.</p>
      </div>
    )}
  </div>
</section>

<style>
  .barber-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }

  .barber-board {
    opacity: 0;
    transform: translateY(30px) rotate(-1deg);
    animation: barberBoardReveal 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }
  @keyframes barberBoardReveal { to { opacity: 1; transform: translateY(0) rotate(0); } }

  @media (prefers-reduced-motion: reduce) {
    .barber-fade-up, .barber-board { animation: none; opacity: 1; transform: none; }
  }
</style>
