---
/**
 * ServicesO4 - Clinic / Specialist Referral
 * Specialist referral pathway. Each card shows when to see a specialist,
 * what they treat, how the referral works. Pathway-oriented.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Specialist referrals',
  subheadline = 'When you need deeper care, we know exactly where to send you — and we coordinate the visit.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const specialists = [
  { specialty: 'Cardiology', when: 'Persistent chest pain, irregular rhythm, hypertension that won\'t control.', icon: '♥' },
  { specialty: 'Dermatology', when: 'Suspicious moles, persistent skin conditions, complex acne.', icon: '✦' },
  { specialty: 'Orthopedics', when: 'Joint pain that disrupts daily life, fractures, sports injury.', icon: '◇' },
  { specialty: 'Endocrinology', when: 'Diabetes complexity, thyroid issues, hormone imbalance.', icon: '◐' },
];

const items = services.length > 0
  ? services.slice(0, 4).map((s, i) => ({
      specialty: s.name,
      when: s.description || specialists[i % 4].when,
      icon: specialists[i % 4].icon,
    }))
  : specialists;

const steps = [
  { num: '01', label: 'Visit your primary provider' },
  { num: '02', label: 'We coordinate the referral' },
  { num: '03', label: 'Specialist sees you within 7 days' },
  { num: '04', label: 'Results return to your record' },
];
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-12 max-w-3xl mx-auto">
      <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— Care pathway —</p>
      {showHeadline && (
        <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {/* Referral flow */}
    <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl p-7 mb-10 border border-[var(--text)]/10" style="animation-delay: 0.3s">
      <p class="text-center text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--accent)] mb-5">— How a referral works —</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        {steps.map((s, i) => (
          <div class="relative flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-[var(--primary)] text-[var(--bg)] flex items-center justify-center font-bold mb-2" style="font-family: var(--heading-font);">{s.num}</div>
            <p class="text-xs text-[var(--text)] leading-tight font-medium">{s.label}</p>
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-6 left-[calc(50%+24px)] right-[calc(-50%+24px)] h-px bg-[var(--text)]/15"></div>
            )}
          </div>
        ))}
      </div>
    </div>

    {/* Specialist cards */}
    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {items.map((s, i) => (
          <div class="clinic-fade-up bg-[var(--surface)] rounded-2xl p-6 border border-[var(--text)]/10 hover:border-[var(--primary)]/30 hover:-translate-y-1 transition-all" style={`animation-delay: ${0.4 + i * 0.08}s`}>
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 rounded-2xl bg-[var(--accent)]/15 flex items-center justify-center text-2xl shrink-0">{s.icon}</div>
              <div class="flex-1">
                <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[var(--accent)] mb-1">Referral · {String(i + 1).padStart(2, '0')}</p>
                <h3 class="text-xl font-bold text-[var(--text)]" style="font-family: var(--heading-font);">{s.specialty}</h3>
              </div>
            </div>
            <div class="pt-4 border-t border-[var(--text)]/10">
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[var(--primary)] mb-2">— When to refer —</p>
              <p class="text-sm text-[var(--text-muted)] leading-[1.65]">{s.when}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
