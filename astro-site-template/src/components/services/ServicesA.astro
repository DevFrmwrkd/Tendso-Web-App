---
/**
 * ServicesA - Accordion with Image
 * White background. 2-column layout: sticky image left + accordion service list right.
 * Badge pill, headline, expandable service items with SVG icons.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Services',
  subheadline,
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.servicesBadge !== false;
const showHeadline = visibility?.servicesHeadline !== false;
const showImage = visibility?.servicesImage !== false;
const showList = visibility?.servicesList !== false;

// 6 inline SVG icons (24x24 viewBox) cycled per service
const serviceIcons: string[] = [
  // 1. Wrench/tool
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  // 2. Star
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  // 3. Lightning/bolt
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  // 4. Heart
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  // 5. Shield
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  // 6. Gear/settings
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
];
---

<section id="services" class="reveal bg-[var(--bg)] py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-start gap-16 lg:grid-cols-2 lg:gap-24">

      {/* LEFT - Sticky Image */}
      {showImage && (
        <div class="reveal order-2 lg:order-1 lg:sticky lg:top-32">
          <div class="overflow-hidden rounded-[2.5rem] lg:rounded-[4rem] bg-[var(--surface)] border border-[var(--text)]/5 shadow-2xl">
            {mainPhoto ? (
              <img
                src={mainPhoto}
                alt="Our services"
                class="h-auto w-full object-cover transition-transform duration-[1.5s] hover:scale-110"
                style="aspect-ratio: 4 / 3;"
              />
            ) : (
              <div class="flex aspect-[4/3] w-full items-center justify-center bg-[var(--surface)]">
                <span class="text-[var(--fs-xs)] font-bold uppercase tracking-widest text-[var(--text-muted)]">Visual Presence</span>
              </div>
            )}
          </div>
        </div>
      )}

      {/* RIGHT - Accordion */}
      <div class={`order-1 lg:order-2 ${!showImage ? 'lg:col-span-2 lg:max-w-3xl lg:mx-auto' : ''}`}>

        {showBadge && (
          <div class="reveal mb-8">
            <span class="inline-block rounded-full px-6 py-2 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] bg-[var(--primary)] text-[var(--text-inverse)] shadow-lg shadow-[var(--primary)]/20">
              Expertise
            </span>
          </div>
        )}

        {showHeadline && (
          <h2
            class="reveal-delay-1 reveal mb-16 font-bold leading-tight tracking-tight text-[var(--text)]"
            style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
            data-field="services_headline"
            set:html={headline}
          >
          </h2>
        )}

        {showList && (
          <div class="reveal-delay-2 reveal services-accordion space-y-4" id="services-accordion">
            {services.map((service, index) => (
              <div
                class="services-accordion-item rounded-[2rem] border border-[var(--text)]/5 bg-[var(--surface)] transition-all duration-500 hover:shadow-xl"
                data-index={index}
              >
                <button
                  type="button"
                  class="services-accordion-trigger flex w-full items-center gap-6 p-6 text-left transition-colors md:p-8"
                  aria-expanded={index === 0 ? 'true' : 'false'}
                >
                  {/* Icon */}
                  <span
                    class="services-icon-box flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--primary)] text-[var(--text-inverse)] shadow-lg shadow-[var(--primary)]/20 transition-transform duration-500"
                    set:html={serviceIcons[index % serviceIcons.length]}
                  />
                  {/* Name */}
                  <span
                    class="flex-1 text-[var(--fs-lg)] font-bold text-[var(--text)] tracking-tight"
                    data-field={`services.${index}.name`}
                    set:html={service.name}
                  >
                  </span>
                  {/* Toggle icon */}
                  <span class="services-toggle-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--text)]/10 text-[var(--fs-xs)] transition-all duration-300 group-hover:border-[var(--primary)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="services-icon-plus">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="services-icon-minus hidden">
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                  </span>
                </button>
                <div
                  class="services-accordion-content overflow-hidden transition-all duration-500 ease-in-out"
                  style={index === 0 ? 'max-height: 400px;' : 'max-height: 0;'}
                >
                  <div class="pb-8 pl-24 pr-8 md:pl-28">
                    <p
                      class="leading-relaxed text-[var(--text-muted)] font-medium"
                      style="font-size: var(--fs-base);"
                      data-field={`services.${index}.description`}
                      set:html={service.description}
                    >
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .services-accordion-item[aria-expanded="true"] {
    border-color: var(--primary);
  }
</style>

<script>
  function initServicesAccordion() {
    const accordion = document.getElementById('services-accordion');
    if (!accordion) return;

    const items = accordion.querySelectorAll('.services-accordion-item');

    items.forEach((item) => {
      const trigger = item.querySelector('.services-accordion-trigger');
      const content = item.querySelector('.services-accordion-content') as HTMLElement;
      const iconPlus = item.querySelector('.services-icon-plus') as HTMLElement;
      const iconMinus = item.querySelector('.services-icon-minus') as HTMLElement;

      if (!trigger || !content || !iconPlus || !iconMinus) return;

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';

        // Close all
        items.forEach((otherItem) => {
          const otherTrigger = otherItem.querySelector('.services-accordion-trigger');
          const otherContent = otherItem.querySelector('.services-accordion-content') as HTMLElement;
          const otherPlus = otherItem.querySelector('.services-icon-plus') as HTMLElement;
          const otherMinus = otherItem.querySelector('.services-icon-minus') as HTMLElement;

          if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
          if (otherContent) otherContent.style.maxHeight = '0';
          if (otherPlus) otherPlus.classList.remove('hidden');
          if (otherMinus) otherMinus.classList.add('hidden');
        });

        // Toggle current
        if (!isOpen) {
          trigger.setAttribute('aria-expanded', 'true');
          content.style.maxHeight = content.scrollHeight + 'px';
          iconPlus.classList.add('hidden');
          iconMinus.classList.remove('hidden');
        }
      });
    });
  }

  // Run on load and on Astro page transitions
  initServicesAccordion();
  document.addEventListener('astro:after-swap', initServicesAccordion);
</script>
