---
/**
 * ServicesL - Automobile Shop / Service Bay Grid
 * Technical service cards in a 2-3 col grid.
 * Each card: SVG service icon, name, technical description, price tag.
 * Hover: corner markers animate in, blueprint overlay.
 * Vibe: workshop service menu, technical pricing.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    price?: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Service Bay',
  subheadline = 'Diagnostic-driven repairs. Honest estimates. No surprises on the invoice.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

// SVG icons cycled by index
const serviceIcons = [
  // Gear
  '<path d="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65a.5.5 0 00.12-.64l-2-3.46a.5.5 0 00-.61-.22l-2.49 1a7.03 7.03 0 00-1.69-.98l-.38-2.65A.5.5 0 0014 2h-4a.5.5 0 00-.49.42l-.38 2.65c-.61.25-1.17.58-1.69.98l-2.49-1a.5.5 0 00-.61.22l-2 3.46a.5.5 0 00.12.64l2.11 1.65c-.04.32-.07.64-.07.98s.03.66.07.98l-2.11 1.65a.5.5 0 00-.12.64l2 3.46a.5.5 0 00.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.05.24.25.42.49.42h4c.24 0 .44-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1a.5.5 0 00.61-.22l2-3.46a.5.5 0 00-.12-.64l-2.11-1.65zM12 15.5A3.5 3.5 0 0112 8.5a3.5 3.5 0 010 7z"/>',
  // Wrench
  '<path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1 .1-1.4z"/>',
  // Oil drop
  '<path d="M12 2C8 6 6 9.5 6 13a6 6 0 0012 0c0-3.5-2-7-6-11z"/>',
  // Tire
  '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" stroke="currentColor" stroke-width="1.5"/>',
  // Battery
  '<path d="M17 4h-3V2h-4v2H7c-.55 0-1 .45-1 1v16c0 .55.45 1 1 1h10c.55 0 1-.45 1-1V5c0-.55-.45-1-1-1zM11 17h-2v-3H7v-2h2V9h2v3h2v2h-2v3z"/>',
  // Shield (warranty)
  '<path d="M12 2L4 5v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5l-8-3z"/>',
];

// Default prices in PHP
const defaultPrices = ['1,500', '2,500', '3,500', '4,500', '5,500', '6,500'];
---

<section
  id="services"
  class="relative w-full bg-[var(--surface)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Blueprint grid */}
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: linear-gradient(rgba(74,107,138,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(74,107,138,0.5) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  {/* Safety stripe top */}
  <div class="absolute top-0 inset-x-0 h-1.5"
       style="background-image: repeating-linear-gradient(135deg, var(--primary) 0 10px, var(--bg) 10px 20px);">
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="auto-fade-up inline-flex items-center gap-3 mb-6">
        <span class="h-px w-10 bg-[var(--primary)]"></span>
        <span class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--primary)]">// SERVICES.LIST</span>
        <span class="h-px w-10 bg-[var(--primary)]"></span>
      </div>

      {showHeadline && (
        <h2
          class="auto-fade-up font-black leading-[0.95] tracking-tight text-[var(--text)] uppercase mb-5"
          style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="auto-fade-up max-w-2xl mx-auto text-[var(--text-muted)] leading-relaxed"
          style="animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Service grid */}
    {showList && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-[var(--accent)]/20 border border-[var(--accent)]/30">
        {services.map((service, i) => {
          const price = service.price || defaultPrices[i % defaultPrices.length];
          const iconPath = serviceIcons[i % serviceIcons.length];
          return (
            <div
              class="service-card group relative bg-[var(--bg)] p-7 lg:p-8 transition-all duration-300 hover:bg-[var(--surface)]"
              style={`animation-delay: ${0.3 + i * 0.08}s;`}
            >
              {/* Hover corner markers */}
              <div class="absolute top-3 left-3 w-4 h-4 border-t border-l border-[var(--primary)] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute top-3 right-3 w-4 h-4 border-t border-r border-[var(--primary)] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute bottom-3 left-3 w-4 h-4 border-b border-l border-[var(--primary)] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute bottom-3 right-3 w-4 h-4 border-b border-r border-[var(--primary)] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

              {/* Index number */}
              <div class="flex items-start justify-between mb-6">
                <div class="w-14 h-14 bg-[var(--primary)]/10 border border-[var(--primary)]/30 flex items-center justify-center text-[var(--primary)] transition-all group-hover:bg-[var(--primary)] group-hover:text-[var(--bg)] group-hover:rotate-12">
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" set:html={iconPath}></svg>
                </div>
                <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)]">
                  // {(i + 1).toString().padStart(2, '0')}
                </span>
              </div>

              {/* Name */}
              <h3 class="text-lg font-black uppercase tracking-tight text-[var(--text)] mb-3 leading-tight">
                {service.name}
              </h3>

              {/* Description */}
              <p class="text-sm text-[var(--text-muted)] leading-relaxed mb-6 min-h-[3rem]">
                {service.description}
              </p>

              {/* Price tag */}
              <div class="flex items-baseline justify-between pt-4 border-t border-[var(--accent)]/20">
                <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)]">Starting at</span>
                <span class="text-xl font-black text-[var(--primary)]">₱{price}</span>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {services.length === 0 && (
      <div class="text-center py-20 border border-dashed border-[var(--accent)]/30">
        <span class="text-6xl text-[var(--accent)]/40">⚙</span>
        <p class="mt-4 text-[var(--text-muted)]">Service catalogue coming soon.</p>
      </div>
    )}

    {/* CTA */}
    <div class="text-center mt-14">
      <a
        href="#contact"
        class="inline-flex items-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-10 py-4 text-xs font-black uppercase tracking-[0.3em] transition-all hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(245,200,66,0.5)]"
      >
        Get a free estimate →
      </a>
    </div>
  </div>

  {/* Safety stripe bottom */}
  <div class="absolute bottom-0 inset-x-0 h-1.5"
       style="background-image: repeating-linear-gradient(135deg, var(--primary) 0 10px, var(--bg) 10px 20px);">
  </div>
</section>

<style>
  .auto-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }

  .service-card {
    opacity: 0;
    transform: translateY(20px);
    animation: autoFadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .auto-fade-up, .service-card { animation-duration: 0.01ms; opacity: 1; transform: none; }
  }
</style>
