---
/**
 * ServicesN - Restaurant / The Menu
 * Cream parchment menu card with dotted-leader pricing,
 * organized by sections (no sections defined? auto-distribute).
 * Plate slide-in for each item.
 * Vibe: an actual restaurant menu, hand-printed feel.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    price?: string;
    category?: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'The Menu',
  subheadline = 'Crafted in our kitchen — served with care',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

// Distribute services into menu sections
const sectionLabels = ['Appetizers', 'Mains', 'Sides & Drinks', 'Desserts'];
const sectionSize = Math.max(1, Math.ceil(services.length / sectionLabels.length));
const sections = sectionLabels.map((label, i) => ({
  label,
  items: services.slice(i * sectionSize, (i + 1) * sectionSize),
})).filter(s => s.items.length > 0);

// Default prices (PHP)
const defaultPrices = ['180', '250', '320', '420', '480', '550', '620', '780', '850'];
---

<section
  id="services"
  class="relative w-full bg-[var(--text)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Warm subtle pattern */}
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: radial-gradient(circle at 1px 1px, var(--bg) 1px, transparent 0); background-size: 30px 30px;"
  ></div>

  {/* Top warm rule */}
  <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-transparent via-[var(--accent)] to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-4xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="rest-fade-up inline-flex items-center gap-3 mb-6">
        <span class="h-px w-16 bg-[var(--accent)]/40"></span>
        <span class="text-[var(--accent)]">✦</span>
        <span class="text-[11px] uppercase tracking-[0.45em] text-[var(--accent)] italic">— Carte du jour —</span>
        <span class="text-[var(--accent)]">✦</span>
        <span class="h-px w-16 bg-[var(--accent)]/40"></span>
      </div>

      {showHeadline && (
        <h2
          class="rest-fade-up font-normal leading-[0.95] tracking-tight text-[var(--bg)] mb-6"
          style="font-size: clamp(3rem, 6vw, 5.5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="rest-fade-up max-w-2xl mx-auto text-[var(--bg)]/70 italic font-light"
          style="font-size: 1.15rem; animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Menu card */}
    {showList && (
      <div class="rest-menu-card relative bg-[var(--bg)] p-8 sm:p-12 md:p-16 lg:p-20">

        {/* Decorative corners */}
        <div class="absolute top-3 left-3 w-8 h-8 border-t-2 border-l-2 border-[var(--primary)]"></div>
        <div class="absolute top-3 right-3 w-8 h-8 border-t-2 border-r-2 border-[var(--primary)]"></div>
        <div class="absolute bottom-3 left-3 w-8 h-8 border-b-2 border-l-2 border-[var(--primary)]"></div>
        <div class="absolute bottom-3 right-3 w-8 h-8 border-b-2 border-r-2 border-[var(--primary)]"></div>

        {/* Menu sections */}
        <div class="space-y-12 md:space-y-16">
          {sections.map((section, sectionIdx) => (
            <div>
              {/* Section header */}
              <div class="text-center mb-8">
                <p class="text-[var(--primary)] text-xl mb-1">❋</p>
                <h3
                  class="text-2xl md:text-3xl text-[var(--text)] italic"
                  style="font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-family: 'Cormorant Garamond', serif;"
                >
                  {section.label}
                </h3>
                <div class="flex items-center justify-center gap-2 mt-3">
                  <span class="h-px w-12 bg-[var(--primary)]/30"></span>
                  <span class="text-[var(--primary)] text-xs">✦</span>
                  <span class="h-px w-12 bg-[var(--primary)]/30"></span>
                </div>
              </div>

              {/* Items */}
              <ul class="space-y-5">
                {section.items.map((service, i) => {
                  const globalIndex = sectionIdx * sectionSize + i;
                  const price = service.price || defaultPrices[globalIndex % defaultPrices.length];
                  return (
                    <li
                      class="rest-menu-item"
                      style={`animation-delay: ${globalIndex * 0.08 + 0.3}s;`}
                    >
                      <div class="flex items-baseline gap-3">
                        <h4
                          class="text-lg md:text-xl text-[var(--text)] whitespace-nowrap"
                          style="font-size: clamp(1.1rem, 1.6vw, 1.3rem); font-weight: 500;"
                        >
                          {service.name}
                        </h4>
                        <span class="flex-1 border-b border-dotted border-[var(--primary)]/40 translate-y-[-3px]"></span>
                        <span
                          class="text-lg md:text-xl text-[var(--primary)] italic whitespace-nowrap"
                          style="font-size: clamp(1.1rem, 1.6vw, 1.3rem); font-weight: 500;"
                        >
                          ₱{price}
                        </span>
                      </div>
                      {service.description && (
                        <p
                          class="text-[var(--text-muted)]/85 leading-relaxed mt-2 italic font-light pr-16 md:pr-24"
                          style="font-size: 1rem;"
                        >
                          {service.description}
                        </p>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}

          {services.length === 0 && (
            <div class="text-center py-12">
              <span class="text-6xl text-[var(--primary)]/30">✦</span>
              <p class="mt-4 text-[var(--text-muted)]/70 italic">The menu is being prepared. Check back soon.</p>
            </div>
          )}
        </div>

        {/* Bottom footer */}
        <div class="mt-12 pt-8 border-t border-[var(--primary)]/20 text-center">
          <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)]/80 italic">
            ✦ All prices include local taxes ✦
          </p>
        </div>
      </div>
    )}

    {/* CTA */}
    <div class="text-center mt-14">
      <a
        href="#contact"
        class="inline-flex items-center gap-3 bg-[var(--accent)] hover:bg-[#b88a32] text-[var(--text)] px-12 py-4 text-xs font-medium uppercase tracking-[0.4em] transition-all hover:-translate-y-1 hover:shadow-[0_20px_40px_-12px_rgba(212,164,67,0.5)]"
        style="border-radius: 999px;"
      >
        <span>✦</span> Reserve a table
      </a>
    </div>
  </div>

  {/* Bottom warm rule */}
  <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-r from-transparent via-[var(--accent)] to-transparent"></div>
</section>

<style>
  .rest-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: restFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes restFadeUp { to { opacity: 1; transform: translateY(0); } }

  .rest-menu-card {
    opacity: 0;
    transform: translateY(40px);
    animation: restFadeUp 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    box-shadow: 0 50px 100px -25px rgba(0, 0, 0, 0.5);
  }

  .rest-menu-item {
    opacity: 0;
    transform: translateY(15px);
    animation: restFadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .rest-fade-up, .rest-menu-card, .rest-menu-item {
      animation-duration: 0.01ms;
      opacity: 1;
      transform: none;
    }
  }
</style>
