---
/**
 * ServicesO2 - Clinic / Service Lines
 * Department-style service-line organization. Group services into specialty
 * "lines" (cardiology, pediatrics, etc.) with sub-services beneath.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Service lines',
  subheadline = 'Specialty departments under one roof. Care that scales to your need.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const lines = [
  {
    code: 'PRIM',
    name: 'Primary care',
    icon: '⚕',
    subs: ['Annual physical', 'Sick visits', 'Chronic management', 'Vaccinations'],
  },
  {
    code: 'PED',
    name: 'Pediatrics',
    icon: '🧒',
    subs: ['Well-child visits', 'Immunizations', 'Developmental screening', 'School physicals'],
  },
  {
    code: 'WOM',
    name: "Women's health",
    icon: '✦',
    subs: ['Annual wellness', 'Prenatal care', 'Family planning', 'Screening'],
  },
  {
    code: 'CHR',
    name: 'Chronic care',
    icon: '◐',
    subs: ['Diabetes', 'Hypertension', 'Asthma', 'Cardiac follow-up'],
  },
];

const items = services.length > 0
  ? services.slice(0, 4).map((s, i) => ({
      code: lines[i].code,
      name: s.name,
      icon: lines[i].icon,
      subs: s.description ? s.description.split(/[.,;]+/).map(x => x.trim()).filter(Boolean).slice(0, 4) : lines[i].subs,
    }))
  : lines;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-14 max-w-3xl mx-auto">
      <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— Departments —</p>
      {showHeadline && (
        <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {items.map((line, i) => (
          <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl overflow-hidden border border-[var(--text)]/10 hover:border-[var(--primary)]/30 hover:shadow-xl transition-all duration-500" style={`animation-delay: ${0.3 + i * 0.1}s`}>
            {/* Line header */}
            <div class="bg-[var(--primary)] text-[var(--bg)] px-6 py-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-2xl">{line.icon}</span>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-[0.3em] opacity-70">Line · {line.code}</p>
                  <h3 class="text-xl font-bold" style="font-family: var(--heading-font);">{line.name}</h3>
                </div>
              </div>
              <span class="text-2xl opacity-50">→</span>
            </div>

            {/* Sub-services */}
            <div class="p-6">
              <ul class="space-y-2.5">
                {line.subs.map((sub) => (
                  <li class="flex items-start gap-3 text-sm">
                    <svg class="w-4 h-4 text-[var(--accent)] mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-[var(--text-muted)]">{sub}</span>
                  </li>
                ))}
              </ul>
              <a href="#contact" class="block mt-5 pt-4 border-t border-[var(--text)]/10 text-xs font-semibold uppercase tracking-[0.2em] text-[var(--primary)] hover:text-[var(--text)] transition-colors">
                Refer to this line →
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
