---
/**
 * ServicesN5 - Restaurant / Family Style
 * Family-style sharing platters. Big communal portions priced per table.
 * Warm casual layout, "for the whole table" feel.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Family style',
  subheadline = 'Big plates, passed around. Made for sharing the way we eat at home.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaults = [
  { name: 'Roast lechon platter', body: 'Whole-roasted pork shoulder · liver sauce · pickled veg', serves: 'Serves 6-8', price: '₱3,850' },
  { name: 'Adobo trio', body: 'Chicken · pork · squid adobo · steamed rice', serves: 'Serves 4-6', price: '₱2,450' },
  { name: 'Grilled seafood basket', body: 'Whole grilled fish · prawns · squid · garlic rice', serves: 'Serves 4-6', price: '₱3,250' },
  { name: 'Kare-kare feast', body: 'Oxtail stew · peanut sauce · bagoong · seasonal veg', serves: 'Serves 6-8', price: '₱2,950' },
  { name: 'Salad & sides spread', body: 'Garden greens · pickles · grilled veg · house bread', serves: 'For the table', price: '₱1,350' },
  { name: 'Dessert sampler', body: 'Halo-halo · leche flan · biko · cassava', serves: 'Serves 4-6', price: '₱1,150' },
];

const platters = services.length > 0
  ? services.slice(0, 6).map((s, i) => ({
      name: s.name,
      body: s.description || defaults[i % 6].body,
      serves: defaults[i % 6].serves,
      price: s.price || defaults[i % 6].price,
    }))
  : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -right-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <div class="resto-fade-up inline-flex items-center gap-3 mb-5">
        <span class="text-[var(--primary)] text-xl">🍽</span>
        <span class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic">— Sharing platters —</span>
        <span class="text-[var(--primary)] text-xl">🍽</span>
      </div>
      {showHeadline && (
        <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {platters.map((p, i) => (
          <div class="resto-fade-up bg-[var(--surface)] p-7 lg:p-8 hover:-translate-y-1 transition-all duration-500 border border-[var(--text)]/15 hover:border-[var(--primary)] hover:shadow-[0_25px_50px_-15px_rgba(196,90,58,0.25)]" style={`animation-delay: ${0.3 + i * 0.08}s`}>
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-2">— Platter No. 0{i + 1} —</p>
                <h3 class="text-2xl italic text-[var(--primary)] tracking-tight" style="font-family: var(--heading-font);">{p.name}</h3>
              </div>
              <div class="bg-[var(--primary)] text-[var(--bg)] px-3 py-1.5 rounded-full text-[9px] uppercase tracking-[0.3em] italic whitespace-nowrap">{p.serves}</div>
            </div>
            <p class="text-sm text-[var(--text-muted)] italic leading-[1.7] mb-5 pb-5 border-b border-dashed border-[var(--text)]/20">{p.body}</p>
            <div class="flex items-baseline justify-between gap-3">
              <span class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic">— Per platter —</span>
              <span class="text-3xl font-bold italic text-[var(--primary)]" style="font-family: var(--heading-font);">{p.price}</span>
            </div>
          </div>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-12">— Best enjoyed with company. Bring everyone. —</p>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
