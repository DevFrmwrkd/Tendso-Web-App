---
/**
 * ServicesL5 - Automobile Shop / Specialty List
 * Numbered specialty list — emphasis on what the shop is KNOWN for.
 * Big numeric markers, short specialty descriptions, like a featured-services manifest.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'What we\'re known for',
  subheadline = 'Anyone can change oil. These are the jobs that built our name.',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const sidePhoto = photos[0] || '';

const defaults = [
  { name: 'Engine rebuilds', description: 'Full top-end and short-block work. Most rigs back on the road in 3 days.' },
  { name: 'Transmission service', description: 'Fluid flush, sensor recalibration, slipping diagnosis. Manual or automatic.' },
  { name: 'Electrical fault tracing', description: 'Mystery dash lights, parasitic drains, wiring shorts. We trace it to the source.' },
  { name: 'AC system rebuild', description: 'Compressor swap, evap coil clean, leak hunt. Pin-cold air by the end of day.' },
  { name: 'Brake & suspension', description: 'Pads, rotors, calipers, struts, control arms. OEM or upgrade parts.' },
];

const items = services.length > 0 ? services.slice(0, 5) : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-16 items-start mb-12">
      {/* LEFT — Title + image */}
      <div class="lg:sticky lg:top-24">
        <div class="auto-fade-up flex items-center gap-3 mb-5">
          <span class="h-px w-10 bg-[var(--primary)]"></span>
          <span class="text-[10px] font-mono font-black uppercase tracking-[0.5em] text-[var(--primary)]">— Specialty list —</span>
        </div>
        {showHeadline && (
          <h2 class="auto-fade-up font-black uppercase leading-[0.92] tracking-tight text-[var(--text)] mb-6" style="font-size: clamp(2.25rem, 5vw, 3.75rem); animation-delay: 0.1s;">{headline}</h2>
        )}
        {showSubheadline && (
          <p class="auto-fade-up text-[var(--text-muted)] leading-[1.75] mb-8" style="font-size: 1.05rem; animation-delay: 0.2s;">{subheadline}</p>
        )}
        {sidePhoto && (
          <div class="auto-fade-up relative aspect-[4/3] overflow-hidden bg-[var(--surface)] border-2 border-[var(--accent)]/40" style="animation-delay: 0.3s">
            <img src={sidePhoto} alt="Shop specialty" class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.15) saturate(0.85);" />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/70 to-transparent"></div>
            <p class="absolute bottom-4 left-4 text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--primary)]">— On the bay —</p>
          </div>
        )}
      </div>

      {/* RIGHT — Numbered specialty list */}
      {showList && (
        <div class="space-y-1">
          {items.map((s, i) => (
            <div class="auto-fade-up group grid grid-cols-[80px_1fr] gap-5 py-6 border-b border-[var(--accent)]/30 hover:bg-[var(--surface)]/50 transition-colors px-3" style={`animation-delay: ${0.4 + i * 0.1}s`}>
              <div class="flex items-start">
                <span class="text-5xl font-black text-[var(--primary)] leading-none font-mono group-hover:scale-110 transition-transform">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div>
                <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--accent)] mb-2">SPECIALTY · 0{i + 1}</p>
                <h3 class="text-2xl font-black uppercase text-[var(--text)] mb-2 tracking-tight">{s.name}</h3>
                <p class="text-sm text-[var(--text-muted)] leading-[1.65]">{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
