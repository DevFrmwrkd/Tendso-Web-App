---
/**
 * ServicesM4 - Salon/Spa / Bridal Bundles
 * Bridal-specific packaging — preview / trial / day-of bundles.
 * Soft elegant card layout with celebratory accents.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; duration?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Bridal bundles',
  subheadline = 'Walk down the aisle feeling like the most rested, radiant version of yourself.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaults = [
  {
    tag: 'TRIAL',
    name: 'The preview',
    duration: '90 min',
    price: '₱2,800',
    items: ['Consultation', 'Trial styling', 'Trial makeup', 'Photo references'],
  },
  {
    tag: 'BUNDLE',
    name: 'The full day',
    duration: 'Full day',
    price: '₱12,500',
    items: ['Bridal hair styling', 'Bridal makeup', 'Lash application', 'On-site touch-ups'],
  },
  {
    tag: 'PARTY',
    name: 'The wedding party',
    duration: 'Per person',
    price: '₱3,200',
    items: ['Hair styling', 'Makeup application', 'Lash addition', 'Group on-site service'],
  },
];

const bundles = services.length >= 3
  ? services.slice(0, 3).map((s, i) => ({
      tag: defaults[i].tag,
      name: s.name,
      duration: s.duration || defaults[i].duration,
      price: s.price || defaults[i].price,
      items: s.description ? s.description.split(/[.,;]+/).map(x => x.trim()).filter(Boolean).slice(0, 5) : defaults[i].items,
    }))
  : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-15 blur-[150px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <div class="salon-fade-up inline-flex items-center gap-3 mb-5">
        <span class="text-[var(--primary)] text-xl">✦</span>
        <span class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic">— For the bride —</span>
        <span class="text-[var(--primary)] text-xl">✦</span>
      </div>
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.25rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {bundles.map((b, i) => (
          <div class="salon-fade-up relative bg-[var(--surface)] rounded-3xl p-8 hover:-translate-y-1 transition-all duration-500 border border-[var(--primary)]/15 hover:border-[var(--primary)]/40 hover:shadow-[0_30px_60px_-15px_rgba(184,123,108,0.2)]" style={`animation-delay: ${0.3 + i * 0.1}s`}>
            {/* Top ribbon */}
            <div class="absolute -top-3 left-8 bg-[var(--accent)] text-[var(--bg)] px-3 py-1 rounded-full text-[9px] uppercase tracking-[0.5em] italic">{b.tag}</div>

            <h3 class="text-3xl italic text-[var(--primary)] mb-3 mt-2" style="font-family: var(--heading-font); font-size: 2rem;">{b.name}</h3>
            <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic mb-5">— {b.duration} —</p>

            <div class="flex items-baseline gap-1 mb-6 pb-6 border-b border-dashed border-[var(--primary)]/30">
              <span class="text-4xl italic text-[var(--text)]" style="font-family: var(--heading-font);">{b.price}</span>
            </div>

            <ul class="space-y-3 mb-8">
              {b.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-[var(--text-muted)] italic">
                  <span class="text-[var(--primary)] mt-1 shrink-0">✦</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <a href="#contact" class="block text-center border border-[var(--primary)]/50 hover:bg-[var(--primary)] hover:text-[var(--bg)] text-[var(--primary)] py-3.5 text-[11px] uppercase tracking-[0.4em] italic transition-all rounded-full">
              Book a consultation →
            </a>
          </div>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-12">— Custom packages available. Reach out and we'll tailor it to you. —</p>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
