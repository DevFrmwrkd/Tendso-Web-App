---
/**
 * ServicesO3 - Clinic / Diagnostic Menu
 * Diagnostic tests catalog with prep instructions, turnaround time, and price ranges.
 * Lab/imaging menu feel.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Diagnostic menu',
  subheadline = 'In-house tests and imaging. Results faster, with the team that ordered them.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaults = [
  { name: 'Complete blood panel', body: 'CBC, lipid panel, A1C', prep: '8-hour fast', time: '24 hours', price: '₱1,200' },
  { name: 'EKG', body: '12-lead resting heart trace', prep: 'No prep', time: 'Same day', price: '₱800' },
  { name: 'Chest x-ray', body: 'Single or two-view', prep: 'No prep', time: '1 hour', price: '₱1,500' },
  { name: 'Ultrasound', body: 'Abdominal, pelvic, or thyroid', prep: 'Varies', time: 'Same day', price: '₱2,200' },
  { name: 'Urinalysis', body: 'Routine with microscopy', prep: 'No prep', time: '30 min', price: '₱350' },
  { name: 'Annual physical', body: 'Vitals, labs, EKG, summary', prep: '8-hour fast', time: 'Same day', price: '₱3,500' },
];

const tests = services.length > 0
  ? services.slice(0, 6).map((s, i) => ({
      name: s.name,
      body: s.description || defaults[i % 6].body,
      prep: defaults[i % 6].prep,
      time: defaults[i % 6].time,
      price: s.price || defaults[i % 6].price,
    }))
  : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-12 max-w-3xl mx-auto">
      <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— Lab & imaging —</p>
      {showHeadline && (
        <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="bg-[var(--surface)] rounded-3xl overflow-hidden border border-[var(--text)]/10">
        {/* Header */}
        <div class="hidden md:grid grid-cols-[1.5fr_1fr_1fr_auto] gap-4 px-6 py-3 bg-[var(--bg)]/40 border-b border-[var(--text)]/10 text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--accent)]">
          <span>Test</span>
          <span>Prep</span>
          <span>Turnaround</span>
          <span class="text-right">Price</span>
        </div>

        {tests.map((t, i) => (
          <div class="clinic-fade-up grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr_auto] gap-3 md:gap-4 px-6 py-5 border-b border-[var(--text)]/10 hover:bg-[var(--bg)]/30 transition-colors items-start md:items-center" style={`animation-delay: ${0.25 + i * 0.06}s`}>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[var(--primary)] mb-1">DX · {String(i + 1).padStart(2, '0')}</p>
              <p class="text-base font-semibold text-[var(--text)] mb-0.5">{t.name}</p>
              <p class="text-xs text-[var(--text-muted)]">{t.body}</p>
            </div>
            <div class="flex md:block items-center gap-2">
              <span class="md:hidden text-[10px] uppercase tracking-wider text-[var(--accent)] font-semibold">Prep:</span>
              <p class="text-sm text-[var(--text-muted)]">{t.prep}</p>
            </div>
            <div class="flex md:block items-center gap-2">
              <span class="md:hidden text-[10px] uppercase tracking-wider text-[var(--accent)] font-semibold">Time:</span>
              <p class="text-sm font-medium text-[var(--accent)]">{t.time}</p>
            </div>
            <div class="text-left md:text-right">
              <p class="text-lg font-bold text-[var(--primary)]" style="font-family: var(--heading-font);">{t.price}</p>
            </div>
          </div>
        ))}

        {/* Footer */}
        <div class="px-6 py-4 bg-[var(--bg)]/40 border-t border-[var(--text)]/10 text-center">
          <p class="text-xs text-[var(--text-muted)]">All tests reviewed and explained by your provider. Insurance accepted on most diagnostics.</p>
        </div>
      </div>
    )}

    <div class="text-center mt-10">
      <a href="#contact" class="clinic-fade-up inline-flex items-center gap-2 bg-[var(--primary)] text-[var(--bg)] px-8 py-3.5 text-sm font-semibold rounded-lg hover:-translate-y-0.5 transition-all" style="animation-delay: 0.8s">
        Schedule a test →
      </a>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
