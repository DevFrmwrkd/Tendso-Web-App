---
/**
 * ServicesM5 - Salon/Spa / Membership
 * Membership-tier comparison. Three monthly tiers with included benefits.
 * Premium feel — like a wellness club brochure.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; duration?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Become a member',
  subheadline = 'Slow days, predictable price. Care that becomes a rhythm, not an event.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const tiers = [
  {
    name: 'Petal',
    price: '₱1,500',
    period: '/ month',
    perks: ['One signature treatment', '10% off any add-ons', 'Priority booking window'],
    cta: 'Start gently',
    featured: false,
  },
  {
    name: 'Bloom',
    price: '₱3,200',
    period: '/ month',
    perks: ['Two treatments monthly', '15% off retail products', 'Complimentary scalp treatment', 'Birthday month upgrade'],
    cta: 'Most popular',
    featured: true,
  },
  {
    name: 'Garden',
    price: '₱5,800',
    period: '/ month',
    perks: ['Unlimited monthly treatments', '20% off everything', 'Personal wellness consult', 'Guest pass quarterly', 'Private booking after hours'],
    cta: 'For the devoted',
    featured: false,
  },
];
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -left-32 w-[400px] h-[400px] rounded-full opacity-15 blur-[120px]" style="background: var(--accent);"></div>
  <div class="absolute bottom-0 -right-32 w-[400px] h-[400px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Salon membership —</p>
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.25rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {tiers.map((t, i) => (
          <div
            class={`salon-fade-up relative bg-[var(--surface)] rounded-3xl overflow-hidden transition-all hover:-translate-y-1 ${t.featured ? 'border-2 border-[var(--primary)] md:scale-105 shadow-[0_35px_70px_-15px_rgba(184,123,108,0.35)]' : 'border border-[var(--primary)]/15 hover:border-[var(--primary)]/40'}`}
            style={`animation-delay: ${0.3 + i * 0.1}s`}
          >
            {t.featured && (
              <div class="bg-[var(--primary)] text-[var(--bg)] py-2 text-center text-[10px] uppercase tracking-[0.5em] italic">— Most chosen —</div>
            )}

            <div class="p-8">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-3">— Tier 0{i + 1} —</p>
              <h3 class="text-4xl italic text-[var(--primary)] mb-5" style="font-family: var(--heading-font); font-size: 2.5rem;">{t.name}</h3>

              <div class="flex items-baseline gap-1 mb-6 pb-6 border-b border-dashed border-[var(--primary)]/30">
                <span class="text-4xl italic text-[var(--text)]" style="font-family: var(--heading-font);">{t.price}</span>
                <span class="text-xs italic text-[var(--text-muted)]">{t.period}</span>
              </div>

              <ul class="space-y-3 mb-8 min-h-[180px]">
                {t.perks.map((p) => (
                  <li class="flex items-start gap-3 text-sm text-[var(--text-muted)] italic">
                    <span class="text-[var(--primary)] mt-0.5 shrink-0">❀</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>

              <a href="#contact" class={`block text-center py-3.5 text-[11px] uppercase tracking-[0.4em] italic transition-all rounded-full ${t.featured ? 'bg-[var(--primary)] text-[var(--bg)] hover:-translate-y-0.5' : 'border border-[var(--primary)]/50 hover:border-[var(--primary)] text-[var(--primary)]'}`}>
                {t.cta} →
              </a>
            </div>
          </div>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-12">— Cancel anytime · No annual commitment —</p>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
