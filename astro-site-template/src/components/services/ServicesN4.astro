---
/**
 * ServicesN4 - Restaurant / Tasting Course
 * Multi-course tasting menu — numbered course progression.
 * Vertical timeline of 5-7 courses with delicate descriptions.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'The tasting course',
  subheadline = 'Seven courses, two hours, one continuous experience from the kitchen to your table.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaults = [
  { name: 'Amuse-bouche', body: 'A first taste · cucumber granita with mint oil', icon: '✦' },
  { name: 'Cold appetizer', body: 'Tuna crudo · yuzu · pickled radish', icon: '❀' },
  { name: 'Soup', body: 'Charred sweet corn velouté · smoked paprika', icon: '◐' },
  { name: 'Pasta', body: 'Hand-rolled tagliatelle · brown butter · sage', icon: '◈' },
  { name: 'Main', body: 'Slow-braised lamb shank · creamy polenta', icon: '◇' },
  { name: 'Cheese', body: 'Aged manchego · honeycomb · candied walnut', icon: '◊' },
  { name: 'Dessert', body: 'Vanilla cremeux · espresso reduction · cocoa nib', icon: '✿' },
];

const courses = services.length > 0
  ? services.slice(0, 7).map((s, i) => ({
      name: s.name,
      body: s.description || defaults[i % 7].body,
      icon: defaults[i % 7].icon,
    }))
  : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Seven courses · two hours —</p>
      {showHeadline && (
        <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {/* Course timeline */}
    {showList && (
      <div class="relative bg-[var(--surface)] p-8 lg:p-12 border border-[var(--text)]/15">
        <div class="absolute left-12 lg:left-16 top-10 bottom-10 w-px bg-[var(--primary)]/30"></div>

        <div class="space-y-7">
          {courses.map((c, i) => (
            <div class="resto-fade-up relative pl-20 lg:pl-28" style={`animation-delay: ${0.3 + i * 0.08}s`}>
              {/* Course node */}
              <div class="absolute left-0 top-1 flex items-center gap-3">
                <span class="text-2xl italic text-[var(--primary)] font-bold leading-none" style="font-family: var(--heading-font);">0{i + 1}</span>
                <div class="w-5 h-5 rounded-full bg-[var(--primary)] border-4 border-[var(--surface)] shadow-[0_0_0_2px_var(--accent)]"></div>
              </div>

              <div class="flex items-baseline gap-3 mb-2">
                <span class="text-[var(--accent)]">{c.icon}</span>
                <p class="text-[9px] uppercase tracking-[0.5em] text-[var(--accent)] italic">— Course 0{i + 1} —</p>
              </div>
              <h3 class="text-xl md:text-2xl italic text-[var(--primary)] mb-1.5" style="font-family: var(--heading-font);">{c.name}</h3>
              <p class="text-sm text-[var(--text-muted)] italic leading-[1.6]">{c.body}</p>
            </div>
          ))}
        </div>

        {/* Total at bottom */}
        <div class="mt-10 pl-20 lg:pl-28 pt-6 border-t-2 border-double border-[var(--text)]/30">
          <div class="flex items-baseline justify-between gap-4 mb-5">
            <span class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic">— Tasting menu —</span>
            <span class="text-4xl font-bold italic text-[var(--primary)]" style="font-family: var(--heading-font);">₱4,500</span>
          </div>
          <a href="#contact" class="block bg-[var(--primary)] text-[var(--bg)] text-center py-4 text-[11px] font-bold uppercase tracking-[0.4em] hover:-translate-y-0.5 transition-all">
            Reserve the tasting →
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
