---
/**
 * ServicesK5 - Barber Shop / Picture Menu
 * Visual cards with thumbnail photo + name + price for each service.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'A Visual Menu',
  subheadline = 'See exactly what you\'re getting.',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaultPrices = ['250', '350', '450', '550', '650', '750'];
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent 0 3px, var(--text) 3px 4px);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <div class="barber-fade-up inline-flex items-center gap-4 mb-6">
        <span class="h-px w-10 bg-[var(--accent)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--primary)]">— Look book —</span>
        <span class="h-px w-10 bg-[var(--accent)]"></span>
      </div>
      {showHeadline && (
        <h2 class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-5" style="font-size: clamp(2.75rem, 6vw, 5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="barber-fade-up text-[var(--primary)] italic" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => {
          const price = service.price || defaultPrices[i % defaultPrices.length];
          const photo = photos[i] || photos[0];
          return (
            <article
              class="picture-card barber-fade-up group bg-[var(--surface)] border border-[var(--primary)]/15 overflow-hidden shadow-[0_15px_30px_-10px_rgba(26,12,16,0.2)] hover:shadow-[0_25px_50px_-15px_rgba(26,12,16,0.35)] hover:-translate-y-2 transition-all duration-500"
              style={`animation-delay: ${i * 0.08 + 0.3}s;`}
            >
              {/* Picture frame */}
              <div class="relative aspect-[4/3] overflow-hidden bg-[var(--text)]">
                {photo ? (
                  <img
                    src={photo}
                    alt={service.name}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    style="filter: sepia(0.35) contrast(1.05) brightness(0.92);"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-6xl">✂</div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/60 via-transparent to-transparent"></div>

                {/* Index ribbon */}
                <div class="absolute top-3 left-0 bg-[var(--primary)] text-[var(--bg)] px-3 py-1">
                  <span class="text-[10px] font-bold uppercase tracking-[0.35em]">№ {(i + 1).toString().padStart(2, '0')}</span>
                </div>

                {/* Price tag */}
                <div class="absolute bottom-3 right-3 bg-[var(--accent)] text-[var(--text)] px-4 py-1 shadow-lg">
                  <span class="text-lg font-bold italic">₱{price}</span>
                </div>
              </div>

              {/* Caption */}
              <div class="p-5 border-t border-[var(--primary)]/15">
                <h3 class="text-xl font-bold text-[var(--text)] mb-1 italic" style="font-size: 1.35rem;">{service.name}</h3>
                {service.description && (
                  <p class="text-sm text-[var(--text-muted)] italic leading-relaxed line-clamp-2" style="font-size: 0.95rem;">{service.description}</p>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}

    {services.length === 0 && (
      <div class="text-center py-16">
        <span class="text-6xl text-[var(--accent)]/30">✂</span>
        <p class="mt-4 text-[var(--text-muted)]/60 italic">Look book being assembled.</p>
      </div>
    )}

    <div class="text-center mt-14">
      <a href="#contact" class="inline-flex items-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-10 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-all hover:-translate-y-1">
        ✂ Reserve your cut
      </a>
    </div>
  </div>
</section>

<style>
  .barber-fade-up { opacity: 0; transform: translateY(20px); animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }
  .picture-card { opacity: 0; transform: translateY(30px); animation: barberFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @media (prefers-reduced-motion: reduce) { .barber-fade-up, .picture-card { animation: none; opacity: 1; transform: none; } }
</style>
