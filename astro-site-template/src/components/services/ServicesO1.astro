---
/**
 * ServicesO - Clinic / Treatments & Services
 * Clean white card grid with medical icons.
 * Each service: icon, name, brief description, optional price/duration.
 * Hover: subtle lift, blue accent border.
 * Vibe: medical service catalog, scannable.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    price?: string;
    duration?: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Services & Treatments',
  subheadline = 'Comprehensive care, delivered with compassion and clinical expertise.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

// Medical SVG icons (line-art)
const serviceIcons = [
  // Heart pulse
  '<path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  // Stethoscope
  '<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/><circle cx="20" cy="10" r="2" stroke="currentColor" stroke-width="2" fill="none"/>',
  // Plus (medical cross)
  '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/><path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  // Microscope
  '<path d="M6 18h8M3 22h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M14 22a7 7 0 1 0 0-14h-1" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M9 14h2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M9 12v-1a4 4 0 0 1 4-4V3a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4a4 4 0 0 1-4 4z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  // Shield with checkmark
  '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" fill="none" stroke-linejoin="round"/><polyline points="9 12 11 14 15 10" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  // Pill / capsule
  '<path d="M10.5 20.5a7 7 0 1 1 0-14l7 7a7 7 0 0 1-7 7z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M8.5 8.5l7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
];
---

<section
  id="services"
  class="relative w-full bg-white py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Soft blue background accent */}
  <div class="absolute top-1/3 right-0 w-1/3 h-1/3 bg-gradient-to-bl from-[#e8f0fa]/40 to-transparent pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="clinic-fade-up inline-flex items-center gap-2 mb-6">
        <span class="w-8 h-px bg-[var(--primary)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.35em] text-[var(--primary)]">— Services —</span>
        <span class="w-8 h-px bg-[var(--primary)]"></span>
      </div>

      {showHeadline && (
        <h2
          class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5"
          style="font-size: clamp(2.5rem, 5vw, 4rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="clinic-fade-up max-w-2xl mx-auto text-[var(--text-muted)] leading-relaxed"
          style="font-size: 1.1rem; animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Service grid */}
    {showList && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {services.map((service, i) => {
          const iconSvg = serviceIcons[i % serviceIcons.length];
          return (
            <div
              class="service-card group relative bg-white rounded-2xl p-7 lg:p-8 border border-[#e5e7eb] transition-all duration-300 hover:border-[var(--primary)]/40 hover:shadow-[0_20px_40px_-15px_rgba(37,99,168,0.2)] hover:-translate-y-1"
              style={`animation-delay: ${0.3 + i * 0.08}s;`}
            >
              {/* Icon */}
              <div class="w-14 h-14 rounded-2xl bg-[#e8f0fa] flex items-center justify-center text-[var(--primary)] mb-5 transition-all duration-300 group-hover:bg-[var(--primary)] group-hover:text-white">
                <svg width="28" height="28" viewBox="0 0 24 24" set:html={iconSvg}></svg>
              </div>

              {/* Name */}
              <h3 class="text-xl font-bold text-[var(--text)] mb-3 leading-tight">
                {service.name}
              </h3>

              {/* Description */}
              <p class="text-sm text-[var(--text-muted)] leading-relaxed mb-5 min-h-[3rem]">
                {service.description}
              </p>

              {/* Footer info */}
              <div class="flex items-center justify-between pt-4 border-t border-[#e5e7eb] text-xs">
                {service.duration ? (
                  <span class="flex items-center gap-1.5 text-[var(--text-muted)] font-medium">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {service.duration}
                  </span>
                ) : (
                  <span class="flex items-center gap-1.5 text-[var(--accent)] font-medium">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Insurance accepted
                  </span>
                )}

                {service.price ? (
                  <span class="font-bold text-[var(--primary)]">₱{service.price}</span>
                ) : (
                  <a
                    href="#contact"
                    class="text-[var(--primary)] font-semibold hover:text-[var(--primary)] transition-colors"
                  >
                    Book →
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    )}

    {services.length === 0 && (
      <div class="text-center py-20 border border-dashed border-[#e5e7eb] rounded-2xl">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" class="mx-auto opacity-40">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
        </svg>
        <p class="mt-4 text-[var(--text-muted)]">Service catalog coming soon.</p>
      </div>
    )}

    {/* CTA + reassurance */}
    <div class="mt-16 text-center">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 bg-[var(--primary)] hover:bg-[var(--primary)] text-white px-8 py-4 text-sm font-semibold rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(37,99,168,0.4)]"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Book an appointment
      </a>
      <p class="mt-4 text-xs text-[var(--text-muted)]">
        Same-day appointments available · Most insurance accepted
      </p>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }

  .service-card {
    opacity: 0;
    transform: translateY(20px);
    animation: clinicFadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .clinic-fade-up, .service-card { animation-duration: 0.01ms; opacity: 1; transform: none; }
  }
</style>
