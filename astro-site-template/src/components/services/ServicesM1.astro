---
/**
 * ServicesM - Salon/Spa / Treatment Menu
 * Elegant treatment cards with duration + price, soft hover with petal flourish.
 * Sage and rose-gold accents, serif typography.
 * Vibe: a refined treatment menu from a destination spa.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    price?: string;
    duration?: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Treatments',
  subheadline = 'A curated menu of treatments crafted to restore and renew. Every session is tailored to you.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

// Default durations and prices
const defaultDurations = ['30 min', '45 min', '60 min', '75 min', '90 min', '120 min'];
const defaultPrices = ['850', '1,200', '1,500', '1,800', '2,200', '2,800'];

// Decorative SVG icons (line-art, soft)
const serviceIcons = [
  // Lotus
  '<path d="M12 2C12 2 9 8 9 13C9 16 10 18 12 18C14 18 15 16 15 13C15 8 12 2 12 2Z" stroke="currentColor" stroke-width="1" fill="none"/><path d="M5 13C5 13 8 17 12 18C12 18 11 14 9 12C7 10 5 13 5 13Z" stroke="currentColor" stroke-width="1" fill="none"/><path d="M19 13C19 13 16 17 12 18C12 18 13 14 15 12C17 10 19 13 19 13Z" stroke="currentColor" stroke-width="1" fill="none"/>',
  // Leaf
  '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.5 2c1 5 .5 12-2 14a7 7 0 0 1-6.5 4z" stroke="currentColor" stroke-width="1" fill="none"/><path d="M2 21c0-3 1.85-5.36 5.08-6" stroke="currentColor" stroke-width="1" fill="none"/>',
  // Spa stone
  '<ellipse cx="12" cy="14" rx="9" ry="6" stroke="currentColor" stroke-width="1" fill="none"/><ellipse cx="10" cy="11" rx="3" ry="2" stroke="currentColor" stroke-width="1" fill="none"/>',
  // Hand massage
  '<path d="M9 11V6a1 1 0 0 1 1-1v0a1 1 0 0 1 1 1v5M11 11V4a1 1 0 0 1 1-1v0a1 1 0 0 1 1 1v7M13 11V5a1 1 0 0 1 1-1v0a1 1 0 0 1 1 1v6M15 12V8a1 1 0 0 1 1-1v0a1 1 0 0 1 1 1v8a5 5 0 0 1-5 5h-2a5 5 0 0 1-5-5v-6a1 1 0 0 1 1-1v0a1 1 0 0 1 1 1v3" stroke="currentColor" stroke-width="1" fill="none"/>',
  // Crystal/gem
  '<path d="M6 3h12l4 6-10 13L2 9z" stroke="currentColor" stroke-width="1" fill="none"/><path d="M11 3 8 9l4 13 4-13-3-6" stroke="currentColor" stroke-width="1" fill="none"/><path d="M2 9h20" stroke="currentColor" stroke-width="1" fill="none"/>',
  // Flower bloom
  '<circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1" fill="none"/><path d="M12 2v6M12 16v6M2 12h6M16 12h6M5 5l4 4M15 15l4 4M5 19l4-4M15 9l4-4" stroke="currentColor" stroke-width="1" fill="none"/>',
];
---

<section
  id="services"
  class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Soft watercolor blobs */}
  <div class="absolute top-1/4 -right-32 w-[450px] h-[450px] rounded-full bg-[#f4d9d0] opacity-40 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 -left-20 w-[400px] h-[400px] rounded-full bg-[#dde5d3] opacity-40 blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="salon-fade-up inline-flex items-center gap-3 mb-6">
        <span class="h-px w-16 bg-[var(--primary)]/40"></span>
        <span class="text-[var(--accent)]">❀</span>
        <span class="text-[11px] uppercase tracking-[0.45em] text-[var(--primary)] italic font-medium">— The Menu —</span>
        <span class="text-[var(--accent)]">❀</span>
        <span class="h-px w-16 bg-[var(--primary)]/40"></span>
      </div>

      {showHeadline && (
        <h2
          class="salon-fade-up font-normal leading-[0.95] tracking-tight text-[var(--text)] mb-6"
          style="font-size: clamp(3rem, 6vw, 5.5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="salon-fade-up max-w-2xl mx-auto text-[var(--text-muted)] leading-relaxed italic font-light"
          style="font-size: 1.15rem; animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Treatment cards */}
    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
        {services.map((service, i) => {
          const duration = service.duration || defaultDurations[i % defaultDurations.length];
          const price = service.price || defaultPrices[i % defaultPrices.length];
          const iconSvg = serviceIcons[i % serviceIcons.length];

          return (
            <div
              class="treatment-card group relative bg-[var(--surface)] rounded-[2rem] p-8 lg:p-10 border border-[var(--primary)]/15 transition-all duration-500 hover:shadow-[0_30px_60px_-15px_rgba(184,123,108,0.25)] hover:-translate-y-1 overflow-hidden"
              style={`animation-delay: ${0.3 + i * 0.08}s;`}
            >
              {/* Hover petal flourish */}
              <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full bg-[#f4d9d0]/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
              <div class="absolute top-4 right-4 text-[var(--primary)]/0 group-hover:text-[var(--primary)]/40 text-2xl transition-all duration-500 group-hover:rotate-45">❀</div>

              {/* Top: Icon */}
              <div class="mb-6 flex items-center justify-between relative z-10">
                <div class="w-14 h-14 rounded-full bg-[#dde5d3]/60 border border-[var(--accent)]/30 flex items-center justify-center text-[var(--accent)] transition-all duration-500 group-hover:bg-[var(--accent)] group-hover:text-[var(--bg)] group-hover:rotate-12">
                  <svg width="26" height="26" viewBox="0 0 24 24" set:html={iconSvg}></svg>
                </div>
                <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--primary)]/60 italic">{duration}</span>
              </div>

              {/* Treatment name */}
              <h3
                class="text-2xl lg:text-[1.65rem] font-normal text-[var(--text)] leading-tight mb-3 italic relative z-10"
                style="font-size: clamp(1.5rem, 2.5vw, 1.85rem);"
              >
                {service.name}
              </h3>

              {/* Decorative rule */}
              <div class="flex items-center gap-2 mb-4 relative z-10">
                <span class="h-px w-8 bg-[var(--primary)]/40"></span>
                <span class="text-[var(--primary)] text-xs">❀</span>
                <span class="h-px flex-1 bg-[var(--primary)]/15"></span>
              </div>

              {/* Description */}
              {service.description && (
                <p class="text-[var(--text-muted)] leading-relaxed text-base italic font-light mb-6 relative z-10" style="font-size: 1.02rem;">
                  {service.description}
                </p>
              )}

              {/* Bottom: price + book */}
              <div class="flex items-end justify-between pt-4 border-t border-[var(--primary)]/15 relative z-10">
                <div>
                  <p class="text-[10px] uppercase tracking-[0.35em] text-[var(--primary)]/70 mb-1">From</p>
                  <p class="text-2xl font-medium text-[var(--primary)]" style="font-size: 1.75rem;">
                    ₱{price}
                  </p>
                </div>
                <a
                  href="#contact"
                  class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.4em] text-[var(--text)] hover:text-[var(--primary)] italic transition-colors border-b border-[var(--text)]/30 hover:border-[var(--primary)] pb-1"
                >
                  Reserve →
                </a>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {services.length === 0 && (
      <div class="text-center py-20">
        <span class="text-6xl text-[var(--primary)]/30">❀</span>
        <p class="mt-4 text-[var(--text-muted)]/60 italic">The treatment menu is being curated. Please check back soon.</p>
      </div>
    )}

    {/* Bottom flourish */}
    <div class="text-center mt-16">
      <div class="inline-flex items-center gap-5">
        <span class="h-px w-20 bg-[var(--primary)]/30"></span>
        <span class="text-[var(--accent)] text-2xl salon-flourish-pulse">❀</span>
        <span class="h-px w-20 bg-[var(--primary)]/30"></span>
      </div>
      <p class="mt-6 text-xs italic text-[var(--text-muted)]/60 tracking-widest">All treatments include welcome tea & robe</p>
    </div>
  </div>
</section>

<style>
  .salon-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }

  .treatment-card {
    opacity: 0;
    transform: translateY(20px);
    animation: salonFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .salon-flourish-pulse {
    display: inline-block;
    animation: salonFlourish 4s ease-in-out infinite;
  }
  @keyframes salonFlourish {
    0%, 100% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(60deg) scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .salon-fade-up, .treatment-card { animation-duration: 0.01ms; opacity: 1; transform: none; }
    .salon-flourish-pulse { animation: none; }
  }
</style>
