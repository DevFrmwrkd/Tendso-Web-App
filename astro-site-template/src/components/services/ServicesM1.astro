---
/**
 * ServicesM1 — Salon · Lumière (rituals 6-grid · dark cards on pink ground)
 *
 * "Rituals tailored to you." — six service cards arranged 3x2 with a small
 * heart/sigil at the top of each, deep ink card with paper text + a "Read more"
 * accent at the bottom.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    price?: string;
    duration?: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "Rituals tailored to you.",
  subheadline = "Eight signature experiences. Endless ways to feel like the truest version of yourself.",
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSub = visibility?.servicesSubheadline !== false;
---

<section id="services" class="lum-services" data-component="SERVICES">
  <div class="lum-services-container">
    <p class="lum-services-eyebrow">— Our Services —</p>
    {showHeadline && (
      <h2 class="lum-services-headline" data-field="services.headline" set:html={headline}></h2>
    )}
    {showSub && (
      <p class="lum-services-sub" data-field="services.subheadline" set:html={subheadline}></p>
    )}

    <div class="lum-services-grid">
      {services.map((svc, i) => (
        <article class="lum-svc-card">
          <div class="lum-svc-sigil" aria-hidden="true">♡</div>
          <h3 class="lum-svc-name" data-field={`services.list.${i}.name`} set:html={svc.name}></h3>
          <p class="lum-svc-desc" data-field={`services.list.${i}.description`} set:html={svc.description}></p>
          <a class="lum-svc-link" href="#contact">Read more →</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .lum-services {
    --ls-paper: color-mix(in srgb, var(--primary) 5%, var(--bg));
    --ls-ink: var(--text);
    --ls-ink-2: color-mix(in srgb, var(--text) 78%, var(--bg));
    --ls-ink-3: color-mix(in srgb, var(--text) 55%, var(--bg));
    --ls-accent: var(--primary);
    --ls-card: var(--text);
    --ls-card-text: color-mix(in srgb, var(--text) 0%, var(--bg));
    --ls-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --ls-sans: var(--body-font, "Inter", system-ui, sans-serif);

    background: var(--ls-paper);
    color: var(--ls-ink);
    font-family: var(--ls-sans);
    padding: clamp(56px, 8vw, 96px) 0;
    text-align: center;
  }
  .lum-services-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .lum-services-eyebrow {
    font-family: var(--ls-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ls-accent);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin: 0 0 18px;
  }
  .lum-services-headline {
    font-family: var(--ls-serif);
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.012em;
    color: var(--ls-ink);
    margin: 0;
    font-weight: 500;
  }
  .lum-services-sub {
    margin: 18px auto 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ls-ink-2);
    max-width: 56ch;
    font-style: italic;
    font-family: var(--ls-serif);
  }
  .lum-services-grid {
    margin-top: clamp(36px, 5vw, 56px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  @media (max-width: 900px) { .lum-services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .lum-services-grid { grid-template-columns: 1fr; } }

  .lum-svc-card {
    background: var(--ls-card);
    color: var(--ls-card-text);
    border-radius: 22px;
    padding: 36px 28px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 240px;
    transition: transform 0.2s ease, background 0.2s ease;
    border: 1px solid color-mix(in srgb, var(--ls-card-text) 8%, transparent);
  }
  .lum-svc-card:hover {
    transform: translateY(-3px);
    background: color-mix(in srgb, var(--ls-accent) 16%, var(--ls-card));
  }
  .lum-svc-sigil {
    font-size: 18px;
    color: var(--ls-accent);
    opacity: 0.95;
  }
  .lum-svc-name {
    font-family: var(--ls-serif);
    font-size: 24px;
    line-height: 1.15;
    margin: 0;
    font-weight: 500;
  }
  .lum-svc-desc {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.55;
    opacity: 0.85;
    flex: 1;
  }
  .lum-svc-link {
    color: inherit;
    opacity: 0.7;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.04em;
    transition: opacity 0.18s;
    margin-top: auto;
  }
  .lum-svc-link:hover { opacity: 1; }
</style>
