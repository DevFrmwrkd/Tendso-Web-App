---
/**
 * ServicesL4 - Automobile Shop / Quick Quote
 * Quote-form aesthetic — service catalog presented as line items with checkbox state.
 * Sticky "Get quote" panel feel, like a shop estimate sheet.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Quick quote',
  subheadline = 'Pick the services you need. We confirm the all-in price before any wrench turns.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaults = [
  { name: 'Oil change & filter', price: '₱799', est: '20 min' },
  { name: 'Brake pad replacement', price: '₱2,200', est: '90 min' },
  { name: 'Engine diagnostic', price: '₱1,200', est: '45 min' },
  { name: 'Tire alignment', price: '₱1,500', est: '60 min' },
  { name: 'Battery replacement', price: '₱3,500', est: '30 min' },
  { name: 'AC service', price: '₱2,800', est: '75 min' },
  { name: 'Transmission flush', price: '₱4,500', est: '120 min' },
  { name: 'Coolant flush', price: '₱1,800', est: '45 min' },
];

const items = services.length > 0
  ? services.slice(0, 8).map((s, i) => ({
      name: s.name,
      price: s.price || defaults[i % 8].price,
      est: defaults[i % 8].est,
    }))
  : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    {/* Quote sheet frame */}
    <div class="auto-fade-up bg-[var(--surface)] border-2 border-[var(--accent)]/50 relative">

      {/* Header */}
      <div class="border-b-2 border-[var(--accent)]/50 px-6 py-5">
        <div class="flex items-center justify-between text-[10px] font-mono uppercase tracking-[0.3em] mb-4">
          <span class="text-[var(--primary)]">// QUOTE-REQUEST</span>
          <span class="text-[var(--text-muted)]">FORM · Q-{new Date().getFullYear()}</span>
        </div>
        {showHeadline && (
          <h2 class="font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-3" style="font-size: clamp(2rem, 4.5vw, 3.25rem);">{headline}</h2>
        )}
        {showSubheadline && (
          <p class="text-[var(--text-muted)] leading-[1.6]" style="font-size: 1rem;">{subheadline}</p>
        )}
      </div>

      {/* Column headers */}
      {showList && (
        <>
          <div class="grid grid-cols-[auto_1fr_100px_80px] gap-4 px-6 py-3 border-b border-[var(--accent)]/30 bg-[var(--bg)]/40 text-[9px] font-mono uppercase tracking-[0.3em] text-[var(--accent)]">
            <span class="w-5">☐</span>
            <span>Service</span>
            <span class="text-right">Price</span>
            <span class="text-right">Time</span>
          </div>

          {items.map((it, i) => (
            <div class="auto-fade-up grid grid-cols-[auto_1fr_100px_80px] gap-4 px-6 py-4 border-b border-[var(--accent)]/20 hover:bg-[var(--bg)]/30 transition-colors items-center" style={`animation-delay: ${0.2 + i * 0.05}s`}>
              <div class="w-5 h-5 border-2 border-[var(--accent)]/50 hover:border-[var(--primary)] hover:bg-[var(--primary)]/20 transition-all"></div>
              <p class="text-sm font-bold text-[var(--text)]">{it.name}</p>
              <p class="text-sm font-black text-[var(--primary)] text-right font-mono">{it.price}</p>
              <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-[var(--text-muted)] text-right">{it.est}</p>
            </div>
          ))}
        </>
      )}

      {/* Bottom — totals + CTA */}
      <div class="p-6 bg-[var(--bg)]/30 border-t-2 border-[var(--accent)]/40">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-center">
          <div>
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)] mb-1">EST. ALL-IN</p>
            <p class="text-3xl font-black text-[var(--text)] font-mono">Confirmed in-shop</p>
            <p class="text-[10px] text-[var(--text-muted)] italic mt-1">Final figure given after a free 15-min look-over.</p>
          </div>
          <a href="#contact" class="inline-flex items-center justify-center gap-3 bg-[var(--primary)] text-[var(--bg)] px-8 py-4 text-[11px] font-black font-mono uppercase tracking-[0.4em] hover:-translate-y-0.5 transition-all whitespace-nowrap">
            Request quote →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
