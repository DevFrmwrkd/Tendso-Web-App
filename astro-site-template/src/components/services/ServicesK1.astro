---
/**
 * ServicesK - Barber Shop / Menu Card
 * Vintage barbershop menu with dotted-leader pricing.
 * Centered narrow column, brass + burgundy on cream.
 * Vibe: handwritten price card from a 1920s barber.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    price?: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'The Menu',
  subheadline = 'All services include a complimentary hot towel & straight-razor finish',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

// Distribute services across columns if many
const half = Math.ceil(services.length / 2);
const col1 = services.slice(0, half);
const col2 = services.slice(half);
const useTwoColumns = services.length > 4;

// Default pricing if not provided (PHP)
const defaultPrices = ['250', '350', '450', '550', '650', '750'];
---

<section
  id="services"
  class="relative w-full bg-[var(--text)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Subtle wood-grain texture */}
  <div
    class="absolute inset-0 opacity-10 pointer-events-none"
    style="background-image: repeating-linear-gradient(90deg, transparent 0 4px, var(--accent) 4px 5px);"
  ></div>

  {/* Top brass rule */}
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--accent)] to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="barber-fade-up inline-flex items-center gap-4 mb-6">
        <span class="h-px w-12 bg-[var(--accent)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--accent)]">— Services & Prices —</span>
        <span class="h-px w-12 bg-[var(--accent)]"></span>
      </div>

      {showHeadline && (
        <h2
          class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--bg)] mb-6"
          style="font-size: clamp(2.75rem, 6vw, 5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="barber-fade-up max-w-xl mx-auto text-[var(--accent)] italic text-sm md:text-base"
          style="animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Menu list — single or two-column */}
    {showList && (
      <div class={`barber-menu-card relative bg-[var(--bg)] p-8 sm:p-12 md:p-16 border-2 border-[var(--accent)]/40`}>
        {/* Corner ornaments */}
        <div class="absolute top-3 left-3 w-6 h-6 border-t border-l border-[var(--primary)]"></div>
        <div class="absolute top-3 right-3 w-6 h-6 border-t border-r border-[var(--primary)]"></div>
        <div class="absolute bottom-3 left-3 w-6 h-6 border-b border-l border-[var(--primary)]"></div>
        <div class="absolute bottom-3 right-3 w-6 h-6 border-b border-r border-[var(--primary)]"></div>

        {/* Menu inner content */}
        <div class={`grid ${useTwoColumns ? 'md:grid-cols-2 md:gap-12' : 'grid-cols-1'} gap-0`}>
          {(useTwoColumns ? [col1, col2] : [services]).map((column, colIndex) => (
            <ul class="divide-y divide-[var(--primary)]/15">
              {column.map((service, i) => {
                const globalIndex = useTwoColumns ? (colIndex === 0 ? i : i + col1.length) : i;
                const price = service.price || defaultPrices[globalIndex % defaultPrices.length];
                return (
                  <li
                    class="barber-menu-item py-5"
                    style={`animation-delay: ${globalIndex * 0.08 + 0.3}s;`}
                  >
                    <div class="flex items-baseline gap-3">
                      <h3 class="text-base sm:text-lg font-bold uppercase tracking-[0.12em] text-[var(--text)] whitespace-nowrap">
                        {service.name}
                      </h3>
                      <span class="flex-1 border-b border-dotted border-[var(--primary)]/40 translate-y-[-3px]"></span>
                      <span class="text-base sm:text-lg font-bold italic text-[var(--primary)] whitespace-nowrap">
                        ₱{price}
                      </span>
                    </div>
                    {service.description && (
                      <p class="text-sm text-[var(--text-muted)]/80 italic leading-relaxed mt-2 pr-16">
                        {service.description}
                      </p>
                    )}
                  </li>
                );
              })}
            </ul>
          ))}
        </div>

        {/* Bottom signature */}
        <div class="mt-10 pt-6 border-t border-[var(--primary)]/20 flex flex-col sm:flex-row items-center justify-between gap-3 text-center sm:text-left">
          <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--primary)]/70">
            ✂ Walk-ins welcome
          </p>
          <p class="text-[10px] italic text-[var(--text-muted)]/60">
            Prices subject to change without notice
          </p>
        </div>
      </div>
    )}

    {/* Bottom CTA */}
    <div class="text-center mt-12">
      <a
        href="#contact"
        class="inline-flex items-center gap-3 bg-[var(--accent)] hover:bg-[var(--accent)] text-[var(--text)] px-10 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-all hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(201,169,97,0.6)]"
      >
        Reserve your chair →
      </a>
    </div>
  </div>

  {/* Bottom brass rule */}
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[var(--accent)] to-transparent"></div>
</section>

<style>
  .barber-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: barberFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .barber-menu-card {
    opacity: 0;
    transform: translateY(40px);
    animation: barberFadeUp 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    box-shadow: 0 40px 80px -20px rgba(26, 12, 16, 0.5);
  }

  .barber-menu-item {
    opacity: 0;
    transform: translateX(-12px);
    animation: barberSlideIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberSlideIn {
    to { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .barber-fade-up, .barber-menu-card, .barber-menu-item {
      animation-duration: 0.01ms;
      opacity: 1;
      transform: none;
    }
  }
</style>
