---
/**
 * ServicesM2 - Salon/Spa / Wellness Packages
 * Three signature wellness packages presented as elegant boxed offers.
 * Each with included treatments listed, featured middle tier with ribbon.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; duration?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Wellness packages',
  subheadline = 'Three thoughtfully crafted journeys. Each one a way to slow down, fully.',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const defaults = [
  {
    tier: 'The escape',
    duration: '60 min',
    price: '₱1,800',
    items: ['Signature facial', 'Hand & foot soak', 'Herbal tea'],
    featured: false,
  },
  {
    tier: 'The retreat',
    duration: '120 min',
    price: '₱3,500',
    items: ['Full-body massage', 'Custom facial', 'Scalp treatment', 'Aromatic ritual'],
    featured: true,
  },
  {
    tier: 'The sanctuary',
    duration: '180 min',
    price: '₱5,500',
    items: ['Hot stone massage', 'Bridal facial', 'Mani & pedi', 'Hair conditioning', 'Champagne service'],
    featured: false,
  },
];

const packages = services.length >= 3
  ? services.slice(0, 3).map((s, i) => ({
      tier: s.name,
      duration: s.duration || defaults[i].duration,
      price: s.price || defaults[i].price,
      items: s.description ? s.description.split(/[.,;]+/).map(x => x.trim()).filter(Boolean).slice(0, 5) : defaults[i].items,
      featured: i === 1,
    }))
  : defaults;
---

<section id="services" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-1/4 -left-32 w-[400px] h-[400px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>
  <div class="absolute bottom-1/4 -right-32 w-[400px] h-[400px] rounded-full opacity-15 blur-[120px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Curated journeys —</p>
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.25rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {packages.map((pkg, i) => (
          <div
            class={`salon-fade-up relative bg-[var(--surface)] rounded-3xl p-8 transition-all hover:-translate-y-1 ${pkg.featured ? 'border-2 border-[var(--primary)] md:scale-105 shadow-[0_30px_60px_-15px_rgba(184,123,108,0.3)]' : 'border border-[var(--primary)]/15 hover:border-[var(--primary)]/40'}`}
            style={`animation-delay: ${0.25 + i * 0.1}s`}
          >
            {pkg.featured && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[var(--primary)] text-[var(--bg)] px-4 py-1.5 rounded-full text-[10px] uppercase tracking-[0.4em] italic shadow-md whitespace-nowrap">— Most loved —</div>
            )}

            <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-3">— {pkg.duration} —</p>
            <h3 class="text-3xl italic text-[var(--primary)] mb-4" style="font-family: var(--heading-font); font-size: 2rem;">{pkg.tier}</h3>

            <div class="flex items-baseline gap-1 mb-6 pb-6 border-b border-dashed border-[var(--primary)]/30">
              <span class="text-4xl italic text-[var(--text)]" style="font-family: var(--heading-font);">{pkg.price}</span>
            </div>

            <ul class="space-y-3 mb-8">
              {pkg.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-[var(--text-muted)] italic">
                  <span class="text-[var(--primary)] mt-0.5 shrink-0">❀</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <a href="#contact" class={`block text-center py-3.5 text-[11px] uppercase tracking-[0.4em] italic transition-all rounded-full ${pkg.featured ? 'bg-[var(--primary)] text-[var(--bg)] hover:-translate-y-0.5' : 'border border-[var(--primary)]/50 hover:border-[var(--primary)] text-[var(--primary)]'}`}>
              Reserve this →
            </a>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
