---
/**
 * ServicesM2 — Salon · Maison Élite (Artistry in Every Detail)
 *
 * Centered eyebrow + serif headline + sub, then a 3x2 grid of service cards.
 * Each card has a photo on top, name + description below, and a small
 * "Read more" link. Restrained ivory background, gold accent.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; price?: string; duration?: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "Artistry in Every Detail",
  subheadline = "Each service is a bespoke experience, crafted with precision and the finest products.",
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSub = visibility?.servicesSubheadline !== false;
---

<section id="services" class="mae-services" data-component="SERVICES">
  <div class="mae-services-container">
    <p class="mae-services-eyebrow">— Our Services —</p>
    {showHeadline && (
      <h2 class="mae-services-headline" data-field="services.headline" set:html={headline}></h2>
    )}
    {showSub && (
      <p class="mae-services-sub" data-field="services.subheadline" set:html={subheadline}></p>
    )}

    <div class="mae-services-grid">
      {services.map((svc, i) => (
        <article class="mae-svc-card">
          {photos[i % Math.max(1, photos.length)] && (
            <div class="mae-svc-thumb">
              <img src={photos[i % photos.length]} alt={svc.name} />
            </div>
          )}
          <div class="mae-svc-body">
            <h3 class="mae-svc-name" data-field={`services.list.${i}.name`} set:html={svc.name}></h3>
            <p class="mae-svc-desc" data-field={`services.list.${i}.description`} set:html={svc.description}></p>
            <a class="mae-svc-link" href="#contact">Read more →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .mae-services {
    --ms-bg: var(--bg);
    --ms-card: color-mix(in srgb, var(--text) 3%, var(--bg));
    --ms-ink: var(--text);
    --ms-ink-2: color-mix(in srgb, var(--text) 68%, var(--bg));
    --ms-ink-3: color-mix(in srgb, var(--text) 48%, var(--bg));
    --ms-accent: var(--primary);
    --ms-rule: color-mix(in srgb, var(--text) 10%, transparent);
    --ms-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --ms-sans: var(--body-font, "Inter", system-ui, sans-serif);

    background: var(--ms-bg);
    color: var(--ms-ink);
    font-family: var(--ms-sans);
    padding: clamp(72px, 10vw, 112px) 0;
    text-align: center;
  }
  .mae-services-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .mae-services-eyebrow {
    font-family: var(--ms-sans);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--ms-accent);
    margin: 0 0 22px;
  }
  .mae-services-headline {
    font-family: var(--ms-serif);
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.1;
    color: var(--ms-ink);
    margin: 0;
    font-weight: 400;
  }
  .mae-services-sub {
    margin: 18px auto 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ms-ink-2);
    max-width: 56ch;
  }
  .mae-services-grid {
    margin-top: clamp(40px, 5vw, 60px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    text-align: left;
  }
  @media (max-width: 900px) { .mae-services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .mae-services-grid { grid-template-columns: 1fr; } }
  .mae-svc-card {
    background: var(--ms-card);
    border: 1px solid var(--ms-rule);
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s;
  }
  .mae-svc-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--ms-accent) 50%, var(--ms-rule));
  }
  .mae-svc-thumb {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--ms-rule);
  }
  .mae-svc-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mae-svc-body { padding: 24px; display: flex; flex-direction: column; gap: 10px; }
  .mae-svc-name {
    font-family: var(--ms-serif);
    font-size: 22px;
    margin: 0;
    color: var(--ms-ink);
    font-weight: 500;
  }
  .mae-svc-desc {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ms-ink-2);
  }
  .mae-svc-link {
    margin-top: 6px;
    color: var(--ms-accent);
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
  }
</style>
