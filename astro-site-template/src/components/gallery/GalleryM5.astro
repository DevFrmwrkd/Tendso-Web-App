---
/**
 * GalleryM5 - Salon/Spa / Editorial
 * Full-bleed editorial style. Big hero with overlay caption, smaller image
 * tiles below in varied widths. Issue-mark stamp, page-number elegance.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Editorial',
  subheadline = 'Stories from the studio · captured slowly.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const year = new Date().getFullYear();
const month = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'][new Date().getMonth()];

const defaultCaptions = [
  'A morning ritual, in soft daylight',
  'Hands at work',
  'The garden through the window',
  'A moment of stillness',
  'Tools of the trade',
];

const editorial = allPhotos.slice(0, 5).map((it: any, i: number) => ({
  image: it.image,
  caption: it.title || defaultCaptions[i],
}));

while (editorial.length < 4) {
  const i = editorial.length;
  editorial.push({ image: undefined, caption: defaultCaptions[i] });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Editorial masthead */}
    <div class="flex items-center justify-between mb-10 pb-6 border-b border-[var(--primary)]/30">
      <div>
        <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-2">— Vol. 01 · {month} {year} —</p>
        {showHeadline && (
          <h2 class="salon-fade-up font-light italic leading-[1] text-[var(--text)]" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6vw, 5rem); animation-delay: 0.1s;">{headline}</h2>
        )}
      </div>
      <div class="text-right hidden md:block">
        <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic" style="animation-delay: 0.15s">— Page 01 —</p>
      </div>
    </div>

    {showSubheadline && (
      <p class="salon-fade-up text-center italic text-[var(--text-muted)] mb-12 max-w-xl mx-auto" style="font-size: 1.05rem; animation-delay: 0.2s">{subheadline}</p>
    )}

    {showItems && (
      <div class="space-y-6">
        {/* Hero spread */}
        <div class="salon-fade-up relative group" style="animation-delay: 0.3s">
          <div class="relative aspect-[16/9] overflow-hidden bg-[var(--surface)]">
            {editorial[0]?.image ? (
              <img src={editorial[0].image} alt={editorial[0].caption} data-field="gallery.tile.0" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">m</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/60 via-transparent to-transparent"></div>

            <div class="absolute bottom-8 left-8 right-8 md:max-w-md">
              <p class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic mb-3">— Cover image —</p>
              <p class="text-3xl md:text-4xl italic text-[var(--text)] leading-[1.15]" style="font-family: var(--heading-font);">{editorial[0].caption}</p>
            </div>

            <div class="absolute top-6 right-6 bg-[var(--bg)]/90 backdrop-blur-sm rounded-full w-16 h-16 flex items-center justify-center border border-[var(--primary)]/40">
              <p class="text-xs text-[var(--primary)] italic" style="font-family: var(--heading-font);">No. 01</p>
            </div>
          </div>
        </div>

        {/* Editorial grid below */}
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
          {/* Tall left */}
          <div class="salon-fade-up md:col-span-5 relative group" style="animation-delay: 0.4s">
            <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)]">
              {editorial[1]?.image ? (
                <img src={editorial[1].image} alt={editorial[1].caption} data-field="gallery.tile.1" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-7xl italic" style="font-family: var(--heading-font);">02</div>
              )}
              <div class="absolute bottom-4 left-4 right-4">
                <p class="text-[9px] uppercase tracking-[0.5em] text-[var(--bg)]/90 italic bg-[var(--text)]/40 backdrop-blur-sm rounded-full px-3 py-1.5 inline-block">{editorial[1].caption}</p>
              </div>
            </div>
          </div>

          {/* Right column with stacked */}
          <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4">
            {editorial.slice(2, 4).map((e, i) => (
              <div class="salon-fade-up relative group" style={`animation-delay: ${0.5 + i * 0.08}s`}>
                <div class="relative aspect-[3/4] overflow-hidden bg-[var(--surface)]">
                  {e.image ? (
                    <img src={e.image} alt={e.caption} data-field={`gallery.tile.${i + 2}`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-6xl italic" style="font-family: var(--heading-font);">{String(i + 3).padStart(2, '0')}</div>
                  )}
                  <div class="absolute bottom-3 left-3 right-3">
                    <p class="text-[9px] uppercase tracking-[0.5em] text-[var(--bg)]/90 italic bg-[var(--text)]/40 backdrop-blur-sm rounded-full px-3 py-1.5 inline-block">{e.caption}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mt-12">— End of issue —</p>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
