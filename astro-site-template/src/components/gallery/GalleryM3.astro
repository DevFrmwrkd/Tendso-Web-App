---
/**
 * GalleryM3 - Salon/Spa / Treatment Rooms
 * Tour of the actual treatment spaces — each room with name, ambience details.
 * Magazine-spread layout with detailed captions per room.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our treatment rooms',
  subheadline = 'Four private spaces, each with its own mood.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaults = [
  { name: 'The Linen Room', mood: 'Soft cotton · sage walls · golden hour light', detail: 'Best for facials and quiet body treatments.' },
  { name: 'The Garden Suite', mood: 'Plants · open window · birdsong audio', detail: 'For couples or close friends booking together.' },
  { name: 'The Apothecary', mood: 'Herb shelves · warm wood · candlelight', detail: 'Aromatherapy and custom blend treatments.' },
  { name: 'The Atelier', mood: 'Bright daylight · mirrors · clean lines', detail: 'Hair, makeup, bridal trials.' },
];

const rooms = allPhotos.slice(0, 4).map((it: any, i: number) => ({
  image: it.image,
  name: it.title || defaults[i].name,
  mood: defaults[i].mood,
  detail: it.description || defaults[i].detail,
}));

while (rooms.length < 3) {
  const i = rooms.length;
  rooms.push({ image: undefined, name: defaults[i].name, mood: defaults[i].mood, detail: defaults[i].detail });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -right-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Inside the studio —</p>
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.25rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {rooms.map((r, i) => {
          const shapes = [
            'rounded-tl-[120px] rounded-br-[120px]',
            'rounded-tr-[120px] rounded-bl-[120px]',
            'rounded-tl-[120px] rounded-tr-[120px]',
            'rounded-bl-[120px] rounded-br-[120px]',
          ];
          return (
            <div class="salon-fade-up group" style={`animation-delay: ${0.25 + i * 0.1}s`}>
              <div class={`relative aspect-[4/3] overflow-hidden bg-[var(--surface)] ${shapes[i]} mb-5 transition-shadow duration-700 hover:shadow-[0_30px_60px_-15px_rgba(184,123,108,0.3)]`}>
                {r.image ? (
                  <img src={r.image} alt={r.name} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">{i + 1}</div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/30 to-transparent"></div>
                <div class="absolute top-4 left-4 bg-[var(--bg)]/90 backdrop-blur-sm rounded-full w-10 h-10 flex items-center justify-center">
                  <span class="text-[var(--primary)] italic text-lg" style="font-family: var(--heading-font);">0{i + 1}</span>
                </div>
              </div>

              <div class="text-center">
                <h3 class="text-2xl italic text-[var(--primary)] mb-2" style="font-family: var(--heading-font);">{r.name}</h3>
                <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-3">— {r.mood} —</p>
                <p class="text-sm text-[var(--text-muted)] italic leading-[1.7] max-w-sm mx-auto">{r.detail}</p>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
