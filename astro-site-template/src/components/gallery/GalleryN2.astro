---
/**
 * GalleryN2 - Restaurant / Plate Carousel
 * Horizontal scrolling plate carousel — circular plate frames in a row.
 * Each plate captioned with dish name, like a degustation lineup.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Plate by plate',
  subheadline = 'A taste of what comes out of our kitchen.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaultTitles = ['Sea-salt scallops', 'Charred octopus', 'Truffle pasta', 'Lamb shoulder', 'Chocolate tart', 'Citrus mille-feuille'];

const plates = allPhotos.slice(0, 6).map((it: any, i: number) => ({
  image: it.image,
  title: it.title || defaultTitles[i],
}));

while (plates.length < 4) {
  const i = plates.length;
  plates.push({ image: undefined, title: defaultTitles[i] });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10">

    <div class="mx-auto max-w-7xl px-6 lg:px-12 mb-12">
      <div class="text-center">
        <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Tonight's plates —</p>
        {showHeadline && (
          <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
        )}
        {showSubheadline && (
          <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
        )}
      </div>
    </div>

    {/* Horizontal scroll row */}
    {showItems && (
      <div class="relative">
        <div class="overflow-x-auto resto-no-scrollbar">
          <div class="flex gap-6 lg:gap-10 px-6 lg:px-16 pb-6">
            {plates.map((p, i) => (
              <div class="resto-fade-up shrink-0 w-64 sm:w-72 lg:w-80 text-center" style={`animation-delay: ${0.3 + i * 0.08}s`}>
                <div class="relative aspect-square rounded-full overflow-hidden bg-[var(--surface)] border-[12px] border-[var(--bg)] mb-5 transition-all duration-500 hover:-translate-y-2 hover:rotate-2" style="box-shadow: 0 30px 60px -15px rgba(42,31,28,0.4);">
                  {p.image ? (
                    <img src={p.image} alt={p.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-7xl">🍽</div>
                  )}
                  <div class="absolute inset-3 rounded-full border border-[var(--bg)]/40 pointer-events-none"></div>
                </div>
                <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-2">— No. 0{i + 1} —</p>
                <p class="text-xl italic text-[var(--primary)]" style="font-family: var(--heading-font);">{p.title}</p>
              </div>
            ))}
          </div>
        </div>

        {/* Scroll cue */}
        <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--text-muted)] italic mt-2">— Scroll to see the lineup → —</p>
      </div>
    )}
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  .resto-no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
  .resto-no-scrollbar::-webkit-scrollbar { display: none; }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
