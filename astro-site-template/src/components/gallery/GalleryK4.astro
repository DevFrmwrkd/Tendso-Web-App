---
/**
 * GalleryK4 - Barber Shop / Cut Catalog
 * Categorized cuts by style type (Classic / Modern / Fade / Beard) shown as tabs.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Cut Catalog',
  subheadline = 'Browse by style.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const all = items.length > 0
  ? items
  : (images.length > 0
      ? images.map((img, i) => ({ image: img, title: `Cut ${i + 1}`, description: '', tags: [] }))
      : photos.slice(0, 8).map((p, i) => ({ image: p, title: `Cut ${i + 1}`, description: '', tags: [] })));

// Group into categories
const categories = ['Classic', 'Modern', 'Fade', 'Beard'];
const grouped = categories.map((cat, idx) => ({
  name: cat,
  items: all.slice(idx * 2, idx * 2 + 3).length > 0 ? all.slice(idx * 2, idx * 2 + 3) : all.slice(0, 3),
}));
---

<section id="gallery" class="relative w-full bg-[var(--text)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <div class="barber-fade-up inline-flex items-center gap-4 mb-6">
        <span class="h-px w-10 bg-[var(--accent)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--accent)]">— Style index —</span>
        <span class="h-px w-10 bg-[var(--accent)]"></span>
      </div>
      {showHeadline && (
        <h2 class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--bg)] mb-5" style="font-size: clamp(2.75rem, 6vw, 5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="barber-fade-up text-[var(--accent)] italic" style="font-size: 1.15rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {/* Category tabs as ribbon labels */}
    {showItems && (
      <div class="space-y-16 lg:space-y-20">
        {grouped.map((group, gIdx) => (
          <section class="barber-fade-up" style={`animation-delay: ${gIdx * 0.15 + 0.3}s;`}>
            {/* Category banner */}
            <div class="flex items-center gap-4 mb-8">
              <span class="h-px flex-1 bg-[var(--accent)]/30"></span>
              <span class="text-[var(--accent)] text-2xl">✂</span>
              <h3 class="text-3xl sm:text-4xl font-bold uppercase tracking-[0.2em] text-[var(--bg)] italic px-4" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
                — {group.name} —
              </h3>
              <span class="text-[var(--accent)] text-2xl">✂</span>
              <span class="h-px flex-1 bg-[var(--accent)]/30"></span>
            </div>

            {/* Items grid */}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {group.items.map((item: any, idx: number) => (
                <article class="catalog-card group relative" style={`animation-delay: ${gIdx * 0.15 + idx * 0.08 + 0.4}s;`}>
                  <div class="absolute -top-2 -left-2 z-10 bg-[var(--primary)] text-[var(--bg)] w-10 h-10 flex items-center justify-center font-bold border-2 border-[var(--accent)] shadow-md">
                    {idx + 1}
                  </div>

                  <div class="relative aspect-[4/5] overflow-hidden bg-[var(--text)] border border-[var(--primary)]/40 hover:border-[var(--accent)] transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_25px_50px_-15px_rgba(201,169,97,0.25)]">
                    {item.image ? (
                      <img
                        src={item.image}
                        alt={item.title}
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        style="filter: sepia(0.35) contrast(1.08) brightness(0.92);"
                        loading="lazy"
                      />
                    ) : (
                      <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-6xl">✂</div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/85 via-transparent to-transparent"></div>

                    {/* Caption */}
                    <div class="absolute bottom-0 inset-x-0 p-5">
                      <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic mb-1">— {group.name} —</p>
                      <h4 class="text-[var(--bg)] font-bold italic" style="font-size: 1.2rem;">{item.title}</h4>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}

    {all.length === 0 && (
      <div class="text-center py-16">
        <span class="text-6xl text-[var(--accent)]/30">✂</span>
        <p class="mt-4 text-[var(--bg)]/60 italic">Catalog being prepared.</p>
      </div>
    )}
  </div>
</section>

<style>
  .barber-fade-up { opacity: 0; transform: translateY(20px); animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }
  .catalog-card { opacity: 0; transform: translateY(20px); animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @media (prefers-reduced-motion: reduce) { .barber-fade-up, .catalog-card { animation: none; opacity: 1; transform: none; } }
</style>
