---
/**
 * GalleryM1 — Salon · Lumière (a taste of our work)
 *
 * Editorial 3x2 photo grid with serif title + "View Instagram" link aligned right.
 * Soft pink ground, large image tiles.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "A taste of our work.",
  items = [],
  images = [],
  ctaText = "View Instagram →",
  ctaLink = "#",
  photos = [],
  visibility,
} = Astro.props;

// Use items.image > images[] > photos[], deduped, capped at 6 tiles.
const tiles = (items.length > 0 ? items.map((it) => it.image).filter(Boolean) as string[] : [])
  .concat(images || [])
  .concat(photos || [])
  .filter((src, i, arr) => src && arr.indexOf(src) === i)
  .slice(0, 6);

const showHeadline = visibility?.galleryHeadline !== false;
---

<section id="gallery" class="lum-gallery" data-component="GALLERY">
  <div class="lum-gallery-container">
    <p class="lum-gallery-eyebrow">— Gallery —</p>
    <div class="lum-gallery-head">
      {showHeadline && (
        <h2 class="lum-gallery-headline" data-field="gallery.headline" set:html={headline}></h2>
      )}
      <a class="lum-gallery-link" href={ctaLink} data-field="gallery.cta_text">{ctaText}</a>
    </div>

    <div class="lum-gallery-grid">
      {tiles.map((src, i) => (
        <figure class="lum-tile" data-field={`gallery.tile.${i}`}>
          <img src={src} alt={items[i]?.title || `Gallery ${i + 1}`} />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .lum-gallery {
    --lg-paper: color-mix(in srgb, var(--primary) 5%, var(--bg));
    --lg-ink: var(--text);
    --lg-accent: var(--primary);
    --lg-rule: color-mix(in srgb, var(--text) 12%, transparent);
    --lg-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --lg-sans: var(--body-font, "Inter", system-ui, sans-serif);

    background: var(--lg-paper);
    color: var(--lg-ink);
    font-family: var(--lg-sans);
    padding: clamp(56px, 8vw, 96px) 0;
  }
  .lum-gallery-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .lum-gallery-eyebrow {
    text-align: center;
    font-family: var(--lg-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--lg-accent);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin: 0 0 18px;
  }
  .lum-gallery-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
  }
  .lum-gallery-headline {
    font-family: var(--lg-serif);
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1;
    margin: 0;
    color: var(--lg-ink);
    font-weight: 500;
  }
  .lum-gallery-link {
    font-size: 13px;
    color: var(--lg-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--lg-accent);
    padding-bottom: 2px;
  }
  .lum-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 900px) { .lum-gallery-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .lum-gallery-grid { grid-template-columns: 1fr; } }
  .lum-tile {
    margin: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px;
    background: var(--lg-rule);
  }
  .lum-tile img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }
  .lum-tile:hover img { transform: scale(1.04); }
</style>
