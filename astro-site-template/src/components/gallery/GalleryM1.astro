---
/**
 * GalleryM - Salon/Spa / Soft Showcase
 * Asymmetric masonry with curved frames, gentle hover lift,
 * rose-gold borders. Treatment captions appear with petal fade.
 * Vibe: a curated mood board of treatment moments.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Moments',
  subheadline = 'Small rituals, small luxuries',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const galleryItems = items.length > 0
  ? items
  : (images.length > 0
      ? images.map((img, i) => ({ image: img, title: `Moment ${i + 1}`, description: '', tags: [] }))
      : photos.slice(0, 6).map((p, i) => ({ image: p, title: `Moment ${i + 1}`, description: '', tags: [] })));

// Vary aspect ratios for masonry feel
const aspects = ['aspect-[4/5]', 'aspect-[3/4]', 'aspect-[4/5]', 'aspect-square', 'aspect-[3/4]', 'aspect-[4/5]'];
// Vary border radius for organic feel
const radii = ['rounded-[2.5rem]', 'rounded-[3rem]', 'rounded-[2rem]'];
---

<section
  id="gallery"
  class="relative w-full bg-[var(--surface)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Soft watercolor blobs */}
  <div class="absolute top-10 -left-32 w-[500px] h-[500px] rounded-full bg-[var(--bg)] opacity-50 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-10 -right-32 w-[450px] h-[450px] rounded-full bg-[#dde5d3] opacity-40 blur-[110px] pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="salon-fade-up inline-flex items-center gap-3 mb-6">
        <span class="h-px w-12 bg-[var(--primary)]/40"></span>
        <span class="text-[var(--accent)] text-sm">❀</span>
        <span class="text-[11px] uppercase tracking-[0.45em] text-[var(--primary)] italic">— Gallery —</span>
        <span class="text-[var(--accent)] text-sm">❀</span>
        <span class="h-px w-12 bg-[var(--primary)]/40"></span>
      </div>

      {showHeadline && (
        <h2
          class="salon-fade-up font-normal leading-[0.95] tracking-tight text-[var(--text)] mb-4"
          style="font-size: clamp(3rem, 6vw, 5.5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="salon-fade-up text-[var(--text-muted)] italic font-light"
          style="font-size: 1.15rem; animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Asymmetric masonry — staggered columns */}
    {showItems && galleryItems.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {galleryItems.slice(0, 9).map((item: any, index: number) => {
          const aspect = aspects[index % aspects.length];
          const radius = radii[index % radii.length];
          // Stagger vertically on lg+
          const offset = index % 3 === 1 ? 'lg:translate-y-12' : (index % 3 === 2 ? 'lg:translate-y-6' : '');

          return (
            <div
              class={`moment-card group relative ${offset}`}
              style={`animation-delay: ${index * 0.1 + 0.3}s;`}
            >
              {/* Rose-gold accent ring */}
              <div class={`absolute -inset-2 ${radius} border border-[var(--primary)]/25 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none`}></div>

              {/* Image frame */}
              <div class={`relative ${aspect} ${radius} overflow-hidden bg-[var(--text)] shadow-[0_20px_40px_-15px_rgba(184,123,108,0.3)] transition-all duration-700 group-hover:shadow-[0_35px_60px_-20px_rgba(184,123,108,0.5)] group-hover:-translate-y-2`}>
                {item.image ? (
                  <img
                    src={item.image}
                    alt={item.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                    style="filter: saturate(0.85) brightness(1.03);"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-6xl">❀</div>
                )}

                {/* Soft gradient at bottom */}
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/70 via-transparent to-transparent"></div>

                {/* Caption — reveals on hover */}
                <div class="absolute inset-x-0 bottom-0 p-6 md:p-7 translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                  <div class="flex items-center gap-2 mb-2 opacity-80 group-hover:opacity-100 transition-opacity">
                    <span class="text-[#f4d9d0] text-xs">❀</span>
                    <span class="text-[9px] uppercase tracking-[0.4em] text-[#f4d9d0] italic">
                      {item.tags && item.tags[0] ? item.tags[0] : 'Treatment'}
                    </span>
                  </div>
                  <h3
                    class="font-normal text-[var(--bg)] italic leading-tight"
                    style="font-size: clamp(1.25rem, 2vw, 1.6rem);"
                  >
                    {item.title}
                  </h3>
                  {item.description && (
                    <p class="text-[#f4d9d0] text-sm italic font-light mt-2 line-clamp-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="font-size: 0.95rem;">
                      {item.description}
                    </p>
                  )}
                </div>

                {/* Top right petal — appears on hover */}
                <div class="absolute top-4 right-4 text-[#f4d9d0] text-2xl opacity-0 group-hover:opacity-90 transition-all duration-500 group-hover:rotate-45">
                  ❀
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {galleryItems.length === 0 && (
      <div class="text-center py-20">
        <span class="text-6xl text-[var(--primary)]/30">❀</span>
        <p class="mt-4 text-[var(--text-muted)]/60 italic">Moments to come.</p>
      </div>
    )}

    {/* Bottom flourish */}
    <div class="text-center mt-20">
      <div class="inline-flex items-center gap-4">
        <span class="h-px w-12 bg-[var(--primary)]/30"></span>
        <span class="text-[var(--accent)] text-xl salon-flourish-pulse">❀</span>
        <span class="h-px w-12 bg-[var(--primary)]/30"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .salon-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }

  .moment-card {
    opacity: 0;
    transform: translateY(30px);
    animation: salonFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .salon-flourish-pulse {
    display: inline-block;
    animation: salonFlourish 4s ease-in-out infinite;
  }
  @keyframes salonFlourish {
    0%, 100% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(60deg) scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .salon-fade-up, .moment-card { animation-duration: 0.01ms; opacity: 1; transform: none; }
    .salon-flourish-pulse { animation: none; }
  }
</style>
