---
/**
 * GalleryL4 - Automobile Shop / Restoration Log
 * Log-book / dossier style. Vertical entries, each like a daily log page.
 * Date stamps, photo on side, narrative entries.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Restoration log',
  subheadline = 'Entries from the bay — projects we kept notes on.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaultEntries = [
  { title: 'Classic resto · panel rework', body: 'Floor pans rusted through. Cut, treated, welded fresh metal. New paint to original spec.', day: '14 / 03' },
  { title: 'Engine swap · 2.5L diesel', body: 'Tired block, rebuilt head, fresh injectors, new turbo. Compression back at factory numbers.', day: '02 / 04' },
  { title: 'Suspension lift kit', body: 'Three-inch lift kit, fresh leaf springs, shocks, alignment to OEM spec. Off-road ready.', day: '21 / 04' },
  { title: 'Brake & rotor full set', body: 'Replaced all four rotors, ceramic pads, flushed lines. Stopping distance down 18%.', day: '08 / 05' },
];

const entries = allPhotos.slice(0, 4).map((it: any, i: number) => ({
  image: it.image,
  title: it.title || defaultEntries[i].title,
  body: it.description || defaultEntries[i].body,
  day: defaultEntries[i].day,
}));

while (entries.length < 3) {
  const i = entries.length;
  entries.push({
    image: undefined,
    title: defaultEntries[i].title,
    body: defaultEntries[i].body,
    day: defaultEntries[i].day,
  });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div
    class="absolute inset-0 z-0 opacity-[0.04] pointer-events-none"
    style="background-image: repeating-linear-gradient(0deg, transparent 0 31px, var(--accent) 31px 32px);"
  ></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="auto-fade-up text-[10px] font-mono font-black uppercase tracking-[0.5em] text-[var(--primary)] mb-4">— DOSSIER · LOG ENTRIES —</p>
      {showHeadline && (
        <h2 class="auto-fade-up font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="auto-fade-up text-[var(--text-muted)] max-w-xl mx-auto leading-[1.7]" style="font-size: 1.05rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="space-y-6">
        {entries.map((e, i) => (
          <div class="auto-fade-up bg-[var(--surface)] border-l-4 border-[var(--primary)] p-6 lg:p-8 grid grid-cols-1 md:grid-cols-[160px_1fr] gap-6 items-start" style={`animation-delay: ${0.25 + i * 0.12}s`}>
            {/* Photo */}
            <div class="relative aspect-square overflow-hidden bg-[var(--bg)] border border-[var(--accent)]/40">
              {e.image ? (
                <img src={e.image} alt={e.title} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.1) saturate(0.85) sepia(0.05);" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-5xl">🔧</div>
              )}
              {/* Date stamp */}
              <div class="absolute -bottom-2 -right-2 bg-[var(--primary)] text-[var(--bg)] px-2 py-1 font-mono font-black text-[10px] tracking-[0.2em]">
                {e.day}
              </div>
            </div>

            {/* Log entry */}
            <div>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-[var(--accent)]">ENTRY · 0{i + 1}</span>
                <span class="h-px flex-1 bg-[var(--accent)]/30"></span>
              </div>
              <h3 class="text-xl md:text-2xl font-black uppercase text-[var(--text)] mb-3 tracking-tight">{e.title}</h3>
              <p class="text-sm text-[var(--text-muted)] leading-[1.7] mb-4">{e.body}</p>
              <div class="flex items-center gap-2 text-[9px] font-mono uppercase tracking-[0.35em] text-[var(--accent)]">
                <span class="w-2 h-2 bg-[var(--primary)]"></span>
                <span>STATUS · COMPLETED</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
