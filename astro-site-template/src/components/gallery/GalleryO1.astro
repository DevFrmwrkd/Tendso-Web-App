---
/**
 * GalleryO - Clinic / Our Practice
 * Clean rectangular grid of facility/team/equipment photos.
 * Hover: subtle blue overlay + caption reveal.
 * Vibe: transparent, professional facility tour.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Inside the Clinic',
  subheadline = 'A look at our facility, equipment, and the care team behind every visit',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const galleryItems = items.length > 0
  ? items
  : (images.length > 0
      ? images.map((img, i) => ({ image: img, title: `Facility view ${i + 1}`, description: '', tags: [] }))
      : photos.slice(0, 6).map((p, i) => ({ image: p, title: `Facility view ${i + 1}`, description: '', tags: [] })));
---

<section
  id="gallery"
  class="relative w-full bg-[var(--surface)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="clinic-fade-up inline-flex items-center gap-2 mb-6">
        <span class="w-8 h-px bg-[var(--primary)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.35em] text-[var(--primary)]">— Facility —</span>
        <span class="w-8 h-px bg-[var(--primary)]"></span>
      </div>

      {showHeadline && (
        <h2
          class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5"
          style="font-size: clamp(2.5rem, 5vw, 4rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="clinic-fade-up max-w-2xl mx-auto text-[var(--text-muted)] leading-relaxed"
          style="font-size: 1.1rem; animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Clean grid — featured large + smaller items */}
    {showItems && galleryItems.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-5 auto-rows-[minmax(180px,auto)]">
        {galleryItems.slice(0, 8).map((item: any, index: number) => {
          // First item gets larger feature treatment on lg+
          const isFeature = index === 0;
          const isWide = index === 3;
          const spanClass = isFeature
            ? 'col-span-2 row-span-2 lg:col-span-2 lg:row-span-2'
            : isWide
              ? 'col-span-2 md:col-span-2 lg:col-span-2'
              : '';

          return (
            <div
              class={`gallery-tile group relative rounded-2xl overflow-hidden bg-[#e8f0fa] shadow-sm border border-[#e5e7eb] transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(31,41,55,0.2)] hover:-translate-y-1 ${spanClass}`}
              style={`animation-delay: ${index * 0.08 + 0.3}s; min-height: 200px;`}
            >
              {item.image ? (
                <img
                  src={item.image}
                  alt={item.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  style="filter: contrast(1.02) saturate(0.95);"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" opacity="0.3">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              )}

              {/* Hover gradient */}
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/80 via-[var(--text)]/0 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-500"></div>

              {/* Caption */}
              <div class="absolute inset-x-0 bottom-0 p-4 md:p-5 transition-transform duration-500 translate-y-2 group-hover:translate-y-0">
                {item.tags && item.tags[0] && (
                  <p class="text-[9px] font-bold uppercase tracking-[0.3em] text-[#a8c8ed] mb-1">
                    {item.tags[0]}
                  </p>
                )}
                <h3
                  class={`font-bold text-white leading-tight ${isFeature ? 'text-xl md:text-2xl' : 'text-base md:text-lg'}`}
                >
                  {item.title}
                </h3>
                {item.description && isFeature && (
                  <p class="text-sm text-white/80 mt-2 line-clamp-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                    {item.description}
                  </p>
                )}
              </div>

              {/* Blue accent corner */}
              <div class="absolute top-3 right-3 w-8 h-8 rounded-lg bg-white/95 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {galleryItems.length === 0 && (
      <div class="text-center py-20 border border-dashed border-[#e5e7eb] rounded-2xl">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" class="mx-auto opacity-40">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        <p class="mt-4 text-[var(--text-muted)]">Photos coming soon.</p>
      </div>
    )}

    {/* Bottom assurance */}
    <div class="mt-16 text-center">
      <p class="text-sm text-[var(--text-muted)]">
        Want to visit before booking?{' '}
        <a href="#contact" class="text-[var(--primary)] font-semibold hover:text-[var(--primary)] underline underline-offset-4 transition-colors">
          Schedule a facility tour →
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }

  .gallery-tile {
    opacity: 0;
    transform: translateY(20px);
    animation: clinicFadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .clinic-fade-up, .gallery-tile { animation-duration: 0.01ms; opacity: 1; transform: none; }
  }
</style>
