---
/**
 * GalleryA - Scroll Reveal Cards with Testimonials
 * Light (#F6F7F5) background. Full-height alternating project cards with testimonial blocks.
 * Ported from the existing "Featured" section.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Work',
  subheadline = 'A showcase of projects we are proud of',
  items = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
---

<section id="gallery" class="relative bg-[var(--bg)] overflow-hidden">
  {/* Header */}
  {(showHeadline || showSubheadline) && (
    <div class="reveal mx-auto max-w-5xl px-6 pt-32 pb-16 text-center md:pt-40 md:pb-24">
      {showHeadline && (
        <h2
          class="reveal mb-8 font-bold leading-tight tracking-tight text-[var(--text)]"
          style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
          data-field="featured_headline"
          set:html={headline}
        >
        </h2>
      )}
      {showSubheadline && (
        <p
          class="reveal-delay-1 reveal mx-auto max-w-3xl leading-relaxed text-[var(--text-muted)] font-medium"
          style="font-size: var(--fs-lg);"
          data-field="featured_subheadline"
          set:html={subheadline}
        >
        </p>
      )}
    </div>
  )}

  {/* Project Cards */}
  {showItems && items.map((item, index) => {
    const isOdd = index % 2 === 0;
    const cardBg = isOdd ? 'bg-[var(--surface)]' : 'bg-[var(--bg)]';
    const textColor = 'text-[var(--text)]';
    const descColor = 'text-[var(--text-muted)]';
    const tagBg = 'bg-[var(--primary)]/10';
    const tagText = 'text-[var(--primary)]';
    const imgSrc = item.image || photos[index] || '';

    return (
      <div class={`reveal ${cardBg} py-24 md:py-32 lg:py-40 border-y border-[var(--text)]/5`}>
        <div class={`mx-auto grid max-w-7xl grid-cols-1 items-center gap-16 px-6 md:grid-cols-2 md:gap-24 lg:px-20`}>
          {/* Image */}
          <div class={`reveal ${isOdd ? 'md:order-1' : 'md:order-2'} group overflow-hidden rounded-[2.5rem] lg:rounded-[4rem] shadow-2xl border border-[var(--text)]/5`}>
            {imgSrc ? (
              <img
                src={imgSrc}
                alt={item.title}
                class="aspect-[4/3] w-full object-cover transition-transform duration-[1.5s] group-hover:scale-110"
                loading="lazy"
              />
            ) : (
              <div class="aspect-[4/3] w-full bg-[var(--surface)]"></div>
            )}
          </div>

          {/* Content */}
          <div class={`reveal-delay-1 reveal ${isOdd ? 'md:order-2' : 'md:order-1'}`}>
            <h3
              class={`mb-6 font-bold leading-tight tracking-tight ${textColor}`}
              style="font-size: var(--fs-xl); font-family: var(--heading-font, inherit);"
              data-field={`featured_products.${index}.title`}
              set:html={item.title}
            >
            </h3>
            <p
              class={`mb-10 leading-[1.6] ${descColor} font-medium`}
              style="font-size: var(--fs-base);"
              data-field={`featured_products.${index}.description`}
              set:html={item.description}
            >
            </p>

            {/* Tags */}
            {item.tags && item.tags.length > 0 && (
              <div class="mb-12 flex flex-wrap gap-3">
                {item.tags.map((tag) => (
                  <span class={`inline-block rounded-full px-5 py-2 text-[var(--fs-xs)] font-bold uppercase tracking-widest ${tagBg} ${tagText}`}>
                    {tag}
                  </span>
                ))}
              </div>
            )}

            {/* Testimonial */}
            {item.testimonial && (item.testimonial.quote || item.testimonial.author) && (
              <div class={`border-t border-[var(--text)]/10 pt-10 relative`}>
                <svg
                  class={`absolute -top-4 -left-2 h-12 w-12 ${tagText} opacity-20`}
                  xmlns="http://www.w3.org/2000/svg" 
                  fill="currentColor" 
                  viewBox="0 0 32 32"
                >
                  <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H7c0-1.7 1.3-3 3-3V8zm14 0c-3.3 0-6 2.7-6 6v10h10V14h-7c0-1.7 1.3-3 3-3V8z" />
                </svg>
                <p class={`italic leading-relaxed ${descColor} font-medium`} style="font-size: var(--fs-base);">
                  &ldquo;{item.testimonial.quote}&rdquo;
                </p>
                <p class={`mt-6 font-bold ${textColor} uppercase tracking-[0.2em]`} style="font-size: var(--fs-xs);">
                  &mdash; {item.testimonial.author}
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    );
  })}
</section>
