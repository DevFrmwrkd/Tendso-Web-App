---
/**
 * GalleryL2 - Automobile Shop / Before & After Slider
 * Pairs of before/after photos with vertical-divider treatment.
 * Each pair tells a "we fixed this" story.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Before & after',
  subheadline = 'The same vehicle. The difference our bay makes.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

// Group photos into pairs (before / after)
const allPhotos = items.length > 0 ? items.map(i => i.image).filter(Boolean) : (images.length > 0 ? images : photos);
const pairs: Array<{ before: string; after: string; title: string; tag: string }> = [];
const defaultTitles = [
  { title: 'Body repair', tag: 'COLLISION-04' },
  { title: 'Detailing & restoration', tag: 'DETAIL-09' },
  { title: 'Engine bay refresh', tag: 'ENGINE-12' },
  { title: 'Full overhaul', tag: 'BUILD-21' },
];
for (let i = 0; i < Math.min(4, Math.floor(allPhotos.length / 2)); i++) {
  pairs.push({
    before: allPhotos[i * 2]!,
    after: allPhotos[i * 2 + 1]!,
    title: items[i]?.title || defaultTitles[i].title,
    tag: items[i]?.tags?.[0] || defaultTitles[i].tag,
  });
}
// Fill at least 2 pairs even with no photos
while (pairs.length < 2) {
  pairs.push({
    before: '',
    after: '',
    title: defaultTitles[pairs.length].title,
    tag: defaultTitles[pairs.length].tag,
  });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="auto-fade-up text-[10px] font-mono font-black uppercase tracking-[0.5em] text-[var(--primary)] mb-4">— BEFORE · AFTER —</p>
      {showHeadline && (
        <h2 class="auto-fade-up font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="auto-fade-up text-[var(--text-muted)] max-w-xl mx-auto leading-[1.7]" style="font-size: 1.05rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="space-y-10">
        {pairs.map((p, i) => (
          <div class="auto-fade-up" style={`animation-delay: ${0.25 + i * 0.12}s`}>
            <div class="flex items-center justify-between mb-3">
              <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--primary)]">JOB · {p.tag}</p>
              <p class="text-lg font-black uppercase text-[var(--text)] tracking-tight">{p.title}</p>
            </div>

            <div class="grid grid-cols-2 gap-1 bg-[var(--surface)] p-1 border-2 border-[var(--accent)]/40">
              {/* Before */}
              <div class="relative aspect-[4/3] overflow-hidden bg-[var(--bg)]">
                {p.before ? (
                  <img src={p.before} alt={`${p.title} before`} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.1) saturate(0.6) brightness(0.85);" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-6xl">⊘</div>
                )}
                <div class="absolute top-3 left-3 bg-[var(--bg)]/85 backdrop-blur-sm border border-[var(--accent)]/50 px-3 py-1.5">
                  <span class="text-[9px] font-mono font-black uppercase tracking-[0.4em] text-[var(--text-muted)]">BEFORE</span>
                </div>
              </div>

              {/* After */}
              <div class="relative aspect-[4/3] overflow-hidden bg-[var(--bg)]">
                {p.after ? (
                  <img src={p.after} alt={`${p.title} after`} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.15) saturate(1.05);" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-6xl">✓</div>
                )}
                <div class="absolute top-3 right-3 bg-[var(--primary)] text-[var(--bg)] px-3 py-1.5">
                  <span class="text-[9px] font-mono font-black uppercase tracking-[0.4em]">AFTER</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
