---
/**
 * GalleryL3 - Automobile Shop / Project Index
 * Indexed list of projects — table-like layout with date, project, vehicle, work-done.
 * Image thumbnail at the start of each row.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Project index',
  subheadline = 'A record of recent work, by job number.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaultProjects = [
  { vehicle: 'Toyota Hilux · 2018', work: 'Suspension rebuild', month: 'JAN' },
  { vehicle: 'Honda Civic · 2015', work: 'Transmission service', month: 'JAN' },
  { vehicle: 'Ford Ranger · 2020', work: 'Engine top-end', month: 'FEB' },
  { vehicle: 'Mitsubishi Mirage · 2019', work: 'AC rebuild', month: 'FEB' },
  { vehicle: 'Nissan Navara · 2017', work: 'Brake & rotor', month: 'MAR' },
  { vehicle: 'Suzuki Vitara · 2021', work: 'Diagnostic & ECU', month: 'MAR' },
];

const rows = allPhotos.slice(0, 6).map((it: any, i: number) => ({
  image: it.image,
  jobNo: `J-${String(2400 + i).padStart(4, '0')}`,
  vehicle: it.title || defaultProjects[i % 6].vehicle,
  work: it.description || defaultProjects[i % 6].work,
  month: defaultProjects[i % 6].month,
}));

while (rows.length < 4) {
  const i = rows.length;
  rows.push({
    image: undefined,
    jobNo: `J-${String(2400 + i).padStart(4, '0')}`,
    vehicle: defaultProjects[i].vehicle,
    work: defaultProjects[i].work,
    month: defaultProjects[i].month,
  });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="mb-14">
      <p class="auto-fade-up text-[10px] font-mono font-black uppercase tracking-[0.5em] text-[var(--primary)] mb-4">— INDEX · {new Date().getFullYear()} —</p>
      {showHeadline && (
        <h2 class="auto-fade-up font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-4" style="font-size: clamp(2.5rem, 6vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="auto-fade-up text-[var(--text-muted)] max-w-xl leading-[1.7]" style="font-size: 1.05rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="bg-[var(--surface)] border-2 border-[var(--accent)]/40">
        {/* Header row */}
        <div class="hidden md:grid grid-cols-[80px_80px_80px_1fr_1fr] gap-4 px-5 py-3 border-b-2 border-[var(--accent)]/40 bg-[var(--bg)]/40 text-[9px] font-mono font-black uppercase tracking-[0.35em] text-[var(--accent)]">
          <span>Job</span>
          <span>Mo.</span>
          <span>Photo</span>
          <span>Vehicle</span>
          <span>Work performed</span>
        </div>

        {/* Rows */}
        {rows.map((r, i) => (
          <div class="auto-fade-up grid grid-cols-[1fr_1fr] md:grid-cols-[80px_80px_80px_1fr_1fr] gap-4 px-5 py-4 border-b border-[var(--accent)]/20 hover:bg-[var(--bg)]/30 transition-colors items-center" style={`animation-delay: ${0.25 + i * 0.07}s`}>
            <p class="text-[10px] font-mono font-black uppercase tracking-[0.3em] text-[var(--primary)]">{r.jobNo}</p>
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)]">{r.month}</p>
            <div class="relative aspect-square overflow-hidden bg-[var(--bg)] border border-[var(--accent)]/30">
              {r.image ? (
                <img src={r.image} alt={r.vehicle} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.1) saturate(0.85);" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-2xl">⚙</div>
              )}
            </div>
            <p class="text-sm font-bold text-[var(--text)] uppercase tracking-tight">{r.vehicle}</p>
            <p class="text-sm text-[var(--text-muted)] italic">{r.work}</p>
          </div>
        ))}

        {/* Footer */}
        <div class="px-5 py-3 bg-[var(--bg)]/30 border-t-2 border-[var(--accent)]/40 flex items-center justify-between text-[9px] font-mono uppercase tracking-[0.35em] text-[var(--text-muted)]">
          <span>{rows.length} OF MANY</span>
          <span>// END OF INDEX</span>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
