---
/**
 * GalleryK5 - Barber Shop / Daily Specials
 * Weekly menu of featured cuts — one per day of the week.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Daily Specials',
  subheadline = 'A different cut for every day of the week.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const defaultSpecials = ['Sharp Cut', 'Hot Towel', 'Beard Trim', 'Razor Shave', 'Full Service', 'The Classic', 'Quick Cut'];

const all = items.length > 0
  ? items
  : (images.length > 0
      ? images.map((img, i) => ({ image: img, title: defaultSpecials[i] || `Special ${i + 1}`, description: '', tags: [] }))
      : photos.slice(0, 7).map((p, i) => ({ image: p, title: defaultSpecials[i] || `Special ${i + 1}`, description: '', tags: [] })));

// Today's index
const todayIdx = (new Date().getDay() + 6) % 7; // 0=Monday
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <div class="barber-fade-up inline-flex items-center gap-4 mb-6">
        <span class="h-px w-10 bg-[var(--accent)]"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--primary)]">— Weekly board —</span>
        <span class="h-px w-10 bg-[var(--accent)]"></span>
      </div>
      {showHeadline && (
        <h2 class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-5" style="font-size: clamp(2.75rem, 6vw, 5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="barber-fade-up text-[var(--primary)] italic" style="font-size: 1.15rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {days.map((day, i) => {
          const item = all[i % all.length];
          const isToday = i === todayIdx;
          return (
            <article
              class={`daily-card barber-fade-up relative ${isToday ? 'ring-4 ring-[var(--accent)] ring-offset-2 ring-offset-[var(--bg)]' : ''}`}
              style={`animation-delay: ${i * 0.08 + 0.3}s;`}
            >
              {isToday && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[var(--primary)] text-[var(--bg)] px-3 py-1 z-10 shadow-md">
                  <span class="text-[10px] font-bold uppercase tracking-[0.4em]">— Today —</span>
                </div>
              )}

              <div class={`relative aspect-[3/4] overflow-hidden ${isToday ? 'bg-[var(--text)]' : 'bg-[var(--surface)] border-2 border-[var(--text)]/15'} shadow-[0_15px_30px_-10px_rgba(26,12,16,0.25)] transition-all duration-500 hover:shadow-[0_25px_50px_-15px_rgba(26,12,16,0.4)] hover:-translate-y-1`}>

                {item?.image && (
                  <img
                    src={item.image}
                    alt={item.title}
                    class="absolute inset-0 w-full h-full object-cover"
                    style="filter: sepia(0.4) contrast(1.05) brightness(0.92);"
                    loading="lazy"
                  />
                )}

                {/* Day banner */}
                <div class={`absolute top-0 inset-x-0 ${isToday ? 'bg-[var(--accent)]' : 'bg-[var(--primary)]'} py-2 text-center z-10`}>
                  <span class={`text-xs font-bold uppercase tracking-[0.45em] ${isToday ? 'text-[var(--text)]' : 'text-[var(--bg)]'}`}>{day}</span>
                </div>

                {/* Bottom caption */}
                <div class="absolute bottom-0 inset-x-0 p-5 bg-gradient-to-t from-[var(--text)]/90 to-transparent">
                  <p class="text-[var(--accent)] text-[10px] uppercase tracking-[0.35em] italic mb-1">— Special —</p>
                  <p class="text-[var(--bg)] text-lg font-bold italic" style="font-size: 1.2rem;">{item?.title || defaultSpecials[i]}</p>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    <p class="text-center text-[var(--primary)]/70 italic mt-16">— Walk in any day. We're ready for you. —</p>
  </div>
</section>

<style>
  .barber-fade-up { opacity: 0; transform: translateY(20px); animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }
  .daily-card { opacity: 0; transform: translateY(25px); animation: barberFadeUp 0.95s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @media (prefers-reduced-motion: reduce) { .barber-fade-up, .daily-card { animation: none; opacity: 1; transform: none; } }
</style>
