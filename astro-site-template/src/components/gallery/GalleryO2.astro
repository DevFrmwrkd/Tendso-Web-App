---
/**
 * GalleryO2 - Clinic / Team Portraits
 * Clean grid of medical team portraits with roles. Hover reveals brief credential.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'The team',
  subheadline = 'Faces you will see every visit. Names you will know.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaultRoles = [
  { name: 'Dr. A. Reyes', role: 'Family Medicine', cred: 'MD' },
  { name: 'Dr. M. Santos', role: 'Internal Medicine', cred: 'MD' },
  { name: 'Dr. C. Cruz', role: 'Pediatrics', cred: 'MD' },
  { name: 'Nurse J. Lim', role: 'Nurse Practitioner', cred: 'NP' },
  { name: 'A. Bautista', role: 'Practice Manager', cred: 'RN' },
  { name: 'R. Tan', role: 'Lab Technician', cred: 'MT' },
  { name: 'S. Chua', role: 'Front Desk', cred: '' },
  { name: 'P. Diaz', role: 'Medical Assistant', cred: 'CMA' },
];

const team = allPhotos.slice(0, 8).map((it: any, i: number) => ({
  image: it.image,
  name: it.title || defaultRoles[i].name,
  role: it.description || defaultRoles[i].role,
  cred: defaultRoles[i].cred,
}));

while (team.length < 6) {
  const i = team.length;
  team.push({ image: undefined, name: defaultRoles[i].name, role: defaultRoles[i].role, cred: defaultRoles[i].cred });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-14 max-w-3xl mx-auto">
      <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— Our staff —</p>
      {showHeadline && (
        <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-5">
        {team.map((p, i) => (
          <div class="clinic-fade-up group" style={`animation-delay: ${0.3 + i * 0.06}s`}>
            <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)] rounded-2xl mb-3">
              {p.image ? (
                <img src={p.image} alt={p.name} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-7xl">⚕</div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              {p.cred && (
                <div class="absolute top-3 right-3 bg-[var(--accent)] text-[var(--bg)] text-[10px] font-bold uppercase tracking-wider rounded-full px-2 py-1">
                  {p.cred}
                </div>
              )}
            </div>
            <h3 class="text-base font-bold text-[var(--text)] leading-tight">{p.name}</h3>
            <p class="text-xs text-[var(--text-muted)] mt-0.5">{p.role}</p>
          </div>
        ))}
      </div>
    )}

    <p class="text-center text-xs text-[var(--text-muted)] mt-12">All team members are credentialed and continuously trained. Click any provider for a full bio.</p>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
