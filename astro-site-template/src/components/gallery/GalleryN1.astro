---
/**
 * GalleryN - Restaurant / The Table
 * Asymmetric food gallery, plate-like circular frames mixed with rectangles.
 * Hover: lifts, terracotta border glow, caption with dish + ingredients.
 * Vibe: a curated photo wall of the kitchen's best.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'The Table',
  subheadline = 'Where every plate has a story',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const galleryItems = items.length > 0
  ? items
  : (images.length > 0
      ? images.map((img, i) => ({ image: img, title: `Dish ${i + 1}`, description: '', tags: [] }))
      : photos.slice(0, 6).map((p, i) => ({ image: p, title: `Dish ${i + 1}`, description: '', tags: [] })));
---

<section
  id="gallery"
  class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Warm blobs */}
  <div class="absolute top-0 -left-32 w-[500px] h-[500px] rounded-full bg-[#fbe9c8] opacity-50 blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 -right-32 w-[500px] h-[500px] rounded-full bg-[#dde0c4] opacity-40 blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <div class="rest-fade-up inline-flex items-center gap-3 mb-6">
        <span class="h-px w-12 bg-[var(--primary)]/40"></span>
        <span class="text-[var(--accent)]">❋</span>
        <span class="text-[11px] uppercase tracking-[0.45em] text-[var(--primary)] italic">— Bon appétit —</span>
        <span class="text-[var(--accent)]">❋</span>
        <span class="h-px w-12 bg-[var(--primary)]/40"></span>
      </div>

      {showHeadline && (
        <h2
          class="rest-fade-up font-normal leading-[0.95] tracking-tight text-[var(--text)] mb-4"
          style="font-size: clamp(3rem, 6vw, 5.5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      {showSubheadline && (
        <p
          class="rest-fade-up text-[var(--text-muted)] italic font-light"
          style="font-size: 1.2rem; animation-delay: 0.2s;"
        >
          {subheadline}
        </p>
      )}
    </div>

    {/* Mixed-shape grid */}
    {showItems && galleryItems.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 md:gap-6">
        {galleryItems.slice(0, 8).map((item: any, index: number) => {
          // Alternate circle / rectangle / tall rect for variety
          const variant = index % 3;
          const isCircle = variant === 0;
          const isTall = variant === 2;
          const shapeClass = isCircle
            ? 'rounded-full aspect-square'
            : isTall
              ? 'rounded-[2rem] aspect-[3/4]'
              : 'rounded-[2rem] aspect-square';
          // Stagger
          const offset = index % 3 === 1 ? 'lg:translate-y-8' : '';

          return (
            <div
              class={`dish-card group relative ${offset}`}
              style={`animation-delay: ${index * 0.1 + 0.3}s;`}
            >
              {/* Terracotta accent ring on hover */}
              <div class={`absolute -inset-2 ${shapeClass} border-2 border-[var(--primary)]/0 group-hover:border-[var(--primary)]/40 transition-all duration-500 pointer-events-none`}></div>

              <div class={`relative ${shapeClass} overflow-hidden bg-[var(--text)] shadow-[0_20px_40px_-15px_rgba(42,31,28,0.35)] transition-all duration-700 group-hover:shadow-[0_35px_70px_-20px_rgba(196,90,58,0.4)] group-hover:-translate-y-2`}>
                {item.image ? (
                  <img
                    src={item.image}
                    alt={item.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                    style="filter: saturate(1.1) contrast(1.05);"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-6xl">✦</div>
                )}

                <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/80 via-transparent to-transparent"></div>

                {/* Bottom caption */}
                <div class={`absolute inset-x-0 bottom-0 ${isCircle ? 'p-4 text-center' : 'p-4 md:p-5'} text-[var(--bg)]`}>
                  <p
                    class="font-medium italic leading-tight mb-1"
                    style="font-size: clamp(0.95rem, 1.6vw, 1.15rem);"
                  >
                    {item.title}
                  </p>
                  {item.tags && item.tags[0] && (
                    <p class="text-[9px] uppercase tracking-[0.3em] text-[var(--accent)] italic">
                      {item.tags[0]}
                    </p>
                  )}
                </div>

                {/* Top right ornament on hover */}
                <div class="absolute top-3 right-3 text-[var(--accent)] text-lg opacity-0 group-hover:opacity-100 transition-all duration-500 group-hover:rotate-45">
                  ✦
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {galleryItems.length === 0 && (
      <div class="text-center py-20">
        <span class="text-6xl text-[var(--primary)]/30">✦</span>
        <p class="mt-4 text-[var(--text-muted)]/60 italic">The gallery is being plated.</p>
      </div>
    )}

    {/* Bottom flourish + CTA */}
    <div class="text-center mt-16">
      <div class="inline-flex items-center gap-4 mb-8">
        <span class="h-px w-16 bg-[var(--primary)]/30"></span>
        <span class="text-[var(--accent)] text-xl">❋</span>
        <span class="h-px w-16 bg-[var(--primary)]/30"></span>
      </div>
      <p class="text-[var(--text-muted)] italic mb-6" style="font-size: 1.05rem;">
        Want a table? We'd love to host you.
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-3 text-[var(--primary)] hover:text-[var(--primary)] text-sm font-medium uppercase tracking-[0.4em] italic border-b border-[var(--primary)]/30 hover:border-[var(--primary)] pb-1 transition-colors"
      >
        Reserve a table →
      </a>
    </div>
  </div>
</section>

<style>
  .rest-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: restFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes restFadeUp { to { opacity: 1; transform: translateY(0); } }

  .dish-card {
    opacity: 0;
    transform: translateY(30px);
    animation: restFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .rest-fade-up, .dish-card { animation-duration: 0.01ms; opacity: 1; transform: none; }
  }
</style>
