---
/**
 * GalleryM4 - Salon/Spa / Bridal Lookbook
 * Bridal-focused lookbook — magazine cover hero + portrait gallery below.
 * "Issue" stamp, look numbers, designer-tag captions.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'The bridal lookbook',
  subheadline = 'Brides we\'ve had the joy of preparing.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const year = new Date().getFullYear();

const defaultStyles = [
  'Soft romantic · pearl tones',
  'Modern minimal · clean lines',
  'Garden glow · botanical',
  'Vintage glamour · classic',
  'Boho ethereal · loose waves',
];

const looks = allPhotos.slice(0, 5).map((it: any, i: number) => ({
  image: it.image,
  title: it.title || `Look ${String(i + 1).padStart(2, '0')}`,
  style: it.description || defaultStyles[i],
}));

while (looks.length < 3) {
  const i = looks.length;
  looks.push({ image: undefined, title: `Look ${String(i + 1).padStart(2, '0')}`, style: defaultStyles[i] });
}

const hero = looks[0];
const rest = looks.slice(1);
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-1/3 -left-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="flex flex-wrap items-end justify-between gap-6 mb-12 pb-6 border-b border-[var(--primary)]/30">
      <div>
        <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-3">— Lookbook · Issue {year} —</p>
        {showHeadline && (
          <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)]" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
        )}
      </div>
      {showSubheadline && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.7] max-w-sm" style="font-size: 1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_1fr] gap-6">
        {/* Cover look */}
        <div class="salon-fade-up relative group" style="animation-delay: 0.3s">
          <div class="relative aspect-[4/5] lg:aspect-auto lg:h-full overflow-hidden bg-[var(--surface)] rounded-tr-[200px] rounded-bl-[200px]">
            {hero.image ? (
              <img src={hero.image} alt={hero.title} data-field="gallery.tile.0" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">m</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/70 via-transparent to-transparent"></div>

            {/* Cover stamp */}
            <div class="absolute top-6 left-6 bg-[var(--bg)]/90 backdrop-blur-sm rounded-full px-4 py-2 border border-[var(--primary)]/40">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic flex items-center gap-2">
                <span>✦</span> Cover look
              </p>
            </div>

            {/* Caption */}
            <div class="absolute bottom-8 left-8 right-8">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-3">— {hero.title} —</p>
              <h3 class="text-3xl md:text-4xl italic text-[var(--text)] mb-3" style="font-family: var(--heading-font);">A bride's morning</h3>
              <p class="text-sm italic text-[var(--text-muted)]">{hero.style}</p>
            </div>
          </div>
        </div>

        {/* Side looks */}
        <div class="space-y-5">
          {rest.map((l, i) => (
            <div class="salon-fade-up grid grid-cols-[1fr_1.5fr] gap-4 items-center group" style={`animation-delay: ${0.4 + i * 0.08}s`}>
              <div class={`relative aspect-square overflow-hidden bg-[var(--surface)] ${i % 2 === 0 ? 'rounded-tl-[80px]' : 'rounded-tr-[80px]'} ${i % 2 === 0 ? 'rounded-br-[80px]' : 'rounded-bl-[80px]'}`}>
                {l.image ? (
                  <img src={l.image} alt={l.title} data-field={`gallery.tile.${i + 1}`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-5xl italic" style="font-family: var(--heading-font);">{String(i + 2).padStart(2, '0')}</div>
                )}
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-2">— {l.title} —</p>
                <p class="text-xl italic text-[var(--primary)] mb-1" style="font-family: var(--heading-font);">{l.style}</p>
                <div class="flex items-center gap-2 mt-2">
                  <span class="h-px w-8 bg-[var(--primary)]/40"></span>
                  <span class="text-[var(--primary)] text-xs">❀</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
