---
/**
 * GalleryM2 - Salon/Spa / Before & After
 * Soft luxury before/after showcase. Curved frame pairs with delicate divider,
 * petal accents, gentle hover scale. Treatment caption between pair.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Before & after',
  subheadline = 'The quiet difference a treatment makes.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items.map(i => i.image).filter(Boolean) : (images.length > 0 ? images : photos);
const defaultTitles = [
  'Facial radiance treatment',
  'Hair transformation',
  'Bridal trial',
  'Spa retreat',
];

const pairs: Array<{ before: string; after: string; title: string }> = [];
for (let i = 0; i < Math.min(4, Math.floor(allPhotos.length / 2)); i++) {
  pairs.push({
    before: allPhotos[i * 2]!,
    after: allPhotos[i * 2 + 1]!,
    title: items[i]?.title || defaultTitles[i],
  });
}
while (pairs.length < 2) {
  pairs.push({ before: '', after: '', title: defaultTitles[pairs.length] });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-1/4 -left-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Transformations —</p>
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.25rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="space-y-16">
        {pairs.map((p, i) => (
          <div class="salon-fade-up" style={`animation-delay: ${0.25 + i * 0.15}s`}>
            <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 md:gap-6 items-center">
              {/* Before */}
              <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)] rounded-tl-[100px] rounded-br-[100px] group">
                {p.before ? (
                  <img src={p.before} alt={`${p.title} before`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="filter: saturate(0.85) brightness(0.95);" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-6xl italic" style="font-family: var(--heading-font);">b</div>
                )}
                <div class="absolute top-4 left-4 bg-[var(--bg)]/90 backdrop-blur-sm rounded-full px-3 py-1.5 border border-[var(--primary)]/30">
                  <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic">Before</p>
                </div>
              </div>

              {/* Divider arrow */}
              <div class="hidden md:flex flex-col items-center justify-center gap-2">
                <span class="h-px w-12 bg-[var(--primary)]/40"></span>
                <span class="text-2xl text-[var(--primary)]">✦</span>
                <span class="h-px w-12 bg-[var(--primary)]/40"></span>
              </div>

              {/* After */}
              <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)] rounded-tr-[100px] rounded-bl-[100px] group">
                {p.after ? (
                  <img src={p.after} alt={`${p.title} after`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="filter: saturate(1.05) brightness(1.05);" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-6xl italic" style="font-family: var(--heading-font);">a</div>
                )}
                <div class="absolute top-4 right-4 bg-[var(--primary)] rounded-full px-3 py-1.5">
                  <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--bg)] italic">After</p>
                </div>
              </div>
            </div>

            {/* Caption */}
            <div class="text-center mt-6">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-1">— Treatment 0{i + 1} —</p>
              <p class="text-2xl italic text-[var(--primary)]" style="font-family: var(--heading-font);">{p.title}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
