---
/**
 * GalleryM2 — Salon · Maison Élite (Artistry on Display)
 *
 * Centered eyebrow + serif headline + a 3x2 portfolio grid with subtle hover
 * zoom. Restrained, no captions — let the images speak.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "Artistry on Display",
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const tiles = (items.length > 0 ? items.map((it) => it.image).filter(Boolean) as string[] : [])
  .concat(images || [])
  .concat(photos || [])
  .filter((src, i, arr) => src && arr.indexOf(src) === i)
  .slice(0, 6);

const showHeadline = visibility?.galleryHeadline !== false;
---

<section id="gallery" class="mae-gallery" data-component="GALLERY">
  <div class="mae-gallery-container">
    <p class="mae-gallery-eyebrow">— Our Portfolio —</p>
    {showHeadline && (
      <h2 class="mae-gallery-headline" data-field="gallery.headline" set:html={headline}></h2>
    )}

    <div class="mae-gallery-grid">
      {tiles.map((src, i) => (
        <figure class="mae-tile" data-field={`gallery.tile.${i}`}>
          <img src={src} alt={items[i]?.title || `Portfolio ${i + 1}`} />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .mae-gallery {
    --mg-bg: var(--bg);
    --mg-ink: var(--text);
    --mg-accent: var(--primary);
    --mg-rule: color-mix(in srgb, var(--text) 10%, transparent);
    --mg-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --mg-sans: var(--body-font, "Inter", system-ui, sans-serif);

    background: var(--mg-bg);
    color: var(--mg-ink);
    font-family: var(--mg-sans);
    padding: clamp(72px, 10vw, 112px) 0;
    text-align: center;
  }
  .mae-gallery-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .mae-gallery-eyebrow {
    font-family: var(--mg-sans);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--mg-accent);
    margin: 0 0 22px;
  }
  .mae-gallery-headline {
    font-family: var(--mg-serif);
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.1;
    color: var(--mg-ink);
    margin: 0 0 clamp(40px, 5vw, 60px);
    font-weight: 400;
  }
  .mae-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  @media (max-width: 900px) { .mae-gallery-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .mae-gallery-grid { grid-template-columns: 1fr; } }
  .mae-tile {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--mg-rule);
  }
  .mae-tile img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.5s ease;
    filter: saturate(0.92);
  }
  .mae-tile:hover img { transform: scale(1.05); filter: saturate(1); }
</style>
