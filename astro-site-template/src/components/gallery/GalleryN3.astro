---
/**
 * GalleryN3 - Restaurant / Behind the Pass
 * Behind-the-scenes kitchen photography. Documentary-style grid showing
 * chef at work, prep, plating, service moments. Black-and-white photojournalism feel.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Behind the pass',
  subheadline = 'Quiet hours, busy hands. What happens before the plates land.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaultCaptions = [
  { time: '14:00', body: 'Prep · vegetables for service' },
  { time: '16:30', body: 'Chef tasting sauces' },
  { time: '18:00', body: 'First orders called' },
  { time: '20:00', body: 'Peak service, plate after plate' },
  { time: '22:30', body: 'Quieter — coffee orders begin' },
];

const moments = allPhotos.slice(0, 5).map((it: any, i: number) => ({
  image: it.image,
  time: defaultCaptions[i].time,
  caption: it.title || defaultCaptions[i].body,
}));

while (moments.length < 4) {
  const i = moments.length;
  moments.push({ image: undefined, time: defaultCaptions[i].time, caption: defaultCaptions[i].body });
}
---

<section id="gallery" class="relative w-full bg-[var(--text)] text-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end mb-12 pb-8 border-b border-[var(--bg)]/15">
      <div>
        <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic mb-4">— Documentary · {new Date().getFullYear()} —</p>
        {showHeadline && (
          <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--bg)]" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
        )}
      </div>
      {showSubheadline && (
        <p class="resto-fade-up text-[var(--bg)]/70 italic leading-[1.8]" style="font-size: 1.05rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-1 md:grid-cols-12 gap-3 lg:gap-4">
        {/* Big hero */}
        <div class="resto-fade-up md:col-span-7 md:row-span-2 relative group" style="animation-delay: 0.3s">
          <div class="relative aspect-[4/5] md:aspect-auto md:h-full overflow-hidden bg-[var(--bg)]/10">
            {moments[0]?.image ? (
              <img src={moments[0].image} alt={moments[0].caption} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="filter: grayscale(0.3) contrast(1.1);" loading="lazy" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">📸</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/70 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-2">— {moments[0].time} —</p>
              <p class="text-2xl md:text-3xl italic text-[var(--bg)] leading-[1.15]" style="font-family: var(--heading-font);">{moments[0].caption}</p>
            </div>
          </div>
        </div>

        {/* Two stacked */}
        {moments.slice(1, 3).map((m, i) => (
          <div class="resto-fade-up md:col-span-5 relative group" style={`animation-delay: ${0.4 + i * 0.1}s`}>
            <div class="relative aspect-[4/3] overflow-hidden bg-[var(--bg)]/10">
              {m.image ? (
                <img src={m.image} alt={m.caption} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="filter: grayscale(0.3) contrast(1.1);" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-5xl">{['🔪', '🍳'][i]}</div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="absolute bottom-3 left-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
                <p class="text-[9px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-1">— {m.time} —</p>
                <p class="text-base italic text-[var(--bg)]" style="font-family: var(--heading-font);">{m.caption}</p>
              </div>
            </div>
          </div>
        ))}

        {/* Bottom row */}
        {moments.slice(3, 5).map((m, i) => (
          <div class="resto-fade-up md:col-span-6 relative group" style={`animation-delay: ${0.6 + i * 0.1}s`}>
            <div class="relative aspect-[16/9] overflow-hidden bg-[var(--bg)]/10">
              {m.image ? (
                <img src={m.image} alt={m.caption} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="filter: grayscale(0.3) contrast(1.1);" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-5xl">{['🍽', '☕'][i]}</div>
              )}
              <div class="absolute bottom-3 left-3 right-3">
                <p class="text-[9px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-1 bg-[var(--text)]/60 backdrop-blur-sm rounded-full px-3 py-1 inline-block">— {m.time} · {m.caption} —</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic mt-12">— Shot by us, on shift —</p>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
