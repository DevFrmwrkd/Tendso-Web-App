---
/**
 * GalleryO3 - Clinic / Equipment Showcase
 * Modern medical equipment showcase — emphasis on tech and capability.
 * Photo grid with model names and what each device does.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our equipment',
  subheadline = 'Modern tools, calibrated and maintained — so the diagnostic stays accurate.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const defaultEquipment = [
  { name: 'Digital X-ray system', body: 'High-resolution imaging with low radiation dose. Results in minutes.', tag: 'IMG-01' },
  { name: 'Ultrasound scanner', body: 'Color Doppler for vascular, abdominal, and obstetric studies.', tag: 'IMG-02' },
  { name: 'EKG machine', body: '12-lead resting and stress capability with automatic reporting.', tag: 'CRD-01' },
  { name: 'Lab analyzer', body: 'In-house complete blood panel, glucose, and lipid analysis.', tag: 'LAB-01' },
];

const equipment = allPhotos.slice(0, 4).map((it: any, i: number) => ({
  image: it.image,
  name: it.title || defaultEquipment[i].name,
  body: it.description || defaultEquipment[i].body,
  tag: defaultEquipment[i].tag,
}));

while (equipment.length < 3) {
  const i = equipment.length;
  equipment.push({ image: undefined, name: defaultEquipment[i].name, body: defaultEquipment[i].body, tag: defaultEquipment[i].tag });
}
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end mb-12 pb-8 border-b border-[var(--text)]/10">
      <div>
        <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— On-site capability —</p>
        {showHeadline && (
          <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)]" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
        )}
      </div>
      {showSubheadline && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.8]" style="font-size: 1.05rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {equipment.map((e, i) => (
          <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl overflow-hidden border border-[var(--text)]/10 hover:border-[var(--primary)]/30 hover:shadow-xl transition-all duration-500" style={`animation-delay: ${0.3 + i * 0.1}s`}>
            <div class="relative aspect-[16/10] bg-[var(--bg)] overflow-hidden">
              {e.image ? (
                <img src={e.image} alt={e.name} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-7xl">⚕</div>
              )}
              {/* Equipment code tag */}
              <div class="absolute top-4 left-4 bg-[var(--bg)] backdrop-blur-sm rounded-full px-3 py-1.5 shadow-sm border border-[var(--text)]/10">
                <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[var(--primary)]">{e.tag}</p>
              </div>
              {/* Status indicator */}
              <div class="absolute top-4 right-4 flex items-center gap-1.5 bg-[var(--accent)]/95 text-[var(--bg)] rounded-full px-3 py-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--bg)] animate-pulse"></span>
                <span class="text-[10px] font-bold uppercase tracking-wider">Calibrated</span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-[var(--text)] mb-2" style="font-family: var(--heading-font);">{e.name}</h3>
              <p class="text-sm text-[var(--text-muted)] leading-[1.65]">{e.body}</p>
            </div>
          </div>
        ))}
      </div>
    )}

    <div class="clinic-fade-up text-center mt-12 pt-10 border-t border-[var(--text)]/10" style="animation-delay: 0.7s">
      <p class="text-sm text-[var(--text-muted)]">All equipment is annually serviced and certified. Results read by licensed providers, not outsourced.</p>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
