---
/**
 * GalleryN4 - Restaurant / Daily Specials
 * Day-of-the-week specials board. Each day showcased with its featured dish.
 * Like a chalkboard schedule listing what's special each day.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "This week's specials",
  subheadline = 'A different dish each day. Always fresh, always limited.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const days = [
  { day: 'Monday', dish: 'Slow-braised oxtail' },
  { day: 'Tuesday', dish: 'Fresh catch ceviche' },
  { day: 'Wednesday', dish: 'House-made pasta' },
  { day: 'Thursday', dish: 'Wood-fired pizza' },
  { day: 'Friday', dish: 'Premium steak' },
  { day: 'Saturday', dish: "Chef's tasting" },
  { day: 'Sunday', dish: 'Family roast' },
];

const allPhotos = items.length > 0 ? items : (images.length > 0 ? images.map(img => ({ image: img, title: '', description: '', tags: [] })) : photos.map(p => ({ image: p, title: '', description: '', tags: [] })));

const specials = days.map((d, i) => ({
  day: d.day,
  dish: allPhotos[i]?.title || d.dish,
  image: allPhotos[i]?.image,
}));

const todayIdx = (new Date().getDay() + 6) % 7;
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-14">
      <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Weekly board · seven days, seven specials —</p>
      {showHeadline && (
        <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {specials.map((s, i) => {
          const isToday = i === todayIdx;
          return (
            <article
              class={`resto-fade-up relative ${isToday ? 'ring-4 ring-[var(--primary)] ring-offset-2 ring-offset-[var(--bg)]' : ''}`}
              style={`animation-delay: ${0.3 + i * 0.08}s`}
            >
              {isToday && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[var(--primary)] text-[var(--bg)] px-4 py-1 z-10 shadow-md rounded-full">
                  <span class="text-[9px] uppercase tracking-[0.4em] italic">— Tonight —</span>
                </div>
              )}

              <div class={`relative aspect-[3/4] overflow-hidden ${isToday ? 'bg-[var(--text)]' : 'bg-[var(--surface)]'} transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_25px_50px_-15px_rgba(42,31,28,0.3)]`}>
                {s.image ? (
                  <img src={s.image} alt={s.dish} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.05) saturate(1.05);" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)]/60 text-7xl">🍽</div>
                )}

                {/* Day banner top */}
                <div class={`absolute top-0 inset-x-0 py-3 text-center z-10 ${isToday ? 'bg-[var(--primary)]' : 'bg-[var(--text)]'}`}>
                  <span class={`text-[10px] uppercase tracking-[0.45em] italic ${isToday ? 'text-[var(--bg)]' : 'text-[var(--primary)]'}`}>{s.day}</span>
                </div>

                {/* Dish caption bottom */}
                <div class="absolute bottom-0 inset-x-0 p-5 bg-gradient-to-t from-[var(--text)]/90 to-transparent">
                  <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] italic mb-1">— Special —</p>
                  <p class="text-xl italic text-[var(--bg)] leading-tight" style="font-family: var(--heading-font);">{s.dish}</p>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mt-14">— Walk in any day. The board awaits. —</p>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
