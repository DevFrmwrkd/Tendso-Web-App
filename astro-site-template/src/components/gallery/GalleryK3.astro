---
/**
 * GalleryK3 - Barber Shop / Hall of Fame
 * Wall of ornate-framed portraits with names. Like a barbershop's wall of regulars.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  images?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Hall of Fame',
  subheadline = 'A wall of regulars. Names we never forget.',
  items = [],
  images = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

const galleryItems = items.length > 0
  ? items
  : (images.length > 0
      ? images.map((img, i) => ({ image: img, title: `Member ${i + 1}`, description: 'Regular since', tags: [] }))
      : photos.slice(0, 8).map((p, i) => ({ image: p, title: `Member ${i + 1}`, description: 'Regular since', tags: [] })));

// Mock years for "regular since"
const years = ['2008', '2012', '2015', '2018', '2009', '2011', '2014', '2019'];
---

<section id="gallery" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent 0 3px, var(--text) 3px 4px);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-16">
      <div class="barber-fade-up inline-flex items-center gap-4 mb-6">
        <span class="text-[var(--accent)] text-2xl">✦</span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--primary)]">— Patrons of the chair —</span>
        <span class="text-[var(--accent)] text-2xl">✦</span>
      </div>
      {showHeadline && (
        <h2 class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-5" style="font-size: clamp(2.75rem, 6vw, 5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showSubheadline && (
        <p class="barber-fade-up text-[var(--primary)] italic" style="font-size: 1.15rem; animation-delay: 0.2s;">{subheadline}</p>
      )}
    </div>

    {showItems && galleryItems.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8 lg:gap-10">
        {galleryItems.slice(0, 8).map((item: any, i: number) => (
          <div class="hall-frame barber-fade-up group" style={`animation-delay: ${i * 0.08 + 0.3}s;`}>
            {/* Ornate brass frame */}
            <div class="relative">
              <div class="absolute -inset-2 border-2 border-[var(--accent)]/60 pointer-events-none"></div>
              <div class="absolute -inset-1 border border-[var(--primary)]/40 pointer-events-none"></div>

              {/* Portrait */}
              <div class="relative aspect-[3/4] overflow-hidden bg-[var(--text)] shadow-[0_20px_40px_-12px_rgba(26,12,16,0.4)]">
                {item.image ? (
                  <img
                    src={item.image}
                    alt={item.title}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    style="filter: sepia(0.5) contrast(1.05) brightness(0.88) grayscale(0.15);"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-6xl">✂</div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/40 via-transparent to-transparent"></div>

                {/* Star count overlay */}
                <div class="absolute top-3 right-3 bg-[var(--text)]/85 backdrop-blur-sm border border-[var(--accent)]/60 px-2 py-1 flex gap-0.5">
                  {Array.from({ length: 5 }).map(() => <span class="text-[var(--accent)] text-[10px]">★</span>)}
                </div>
              </div>

              {/* Name plate */}
              <div class="mt-4 text-center">
                <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic mb-1">— Regular since {years[i % years.length]} —</p>
                <h3 class="font-bold text-[var(--text)] italic" style="font-size: 1.2rem;">{item.title}</h3>
                {item.description && item.description !== 'Regular since' && (
                  <p class="text-xs text-[var(--text-muted)]/70 italic mt-1 line-clamp-1">"{item.description}"</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    {galleryItems.length === 0 && (
      <div class="text-center py-16">
        <span class="text-6xl text-[var(--accent)]/30">✦</span>
        <p class="mt-4 text-[var(--text-muted)]/60 italic">Names being added to the wall.</p>
      </div>
    )}

    {/* Bottom dedication */}
    <div class="barber-fade-up mt-16 text-center pt-10 border-t-2 border-double border-[var(--primary)]/30" style="animation-delay: 1s">
      <p class="text-xs uppercase tracking-[0.5em] text-[var(--primary)] italic">— Dedicated to the patrons who made this place —</p>
    </div>
  </div>
</section>

<style>
  .barber-fade-up { opacity: 0; transform: translateY(20px); animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }
  .hall-frame { opacity: 0; transform: translateY(25px); animation: barberFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @media (prefers-reduced-motion: reduce) { .barber-fade-up, .hall-frame { animation: none; opacity: 1; transform: none; } }
</style>
