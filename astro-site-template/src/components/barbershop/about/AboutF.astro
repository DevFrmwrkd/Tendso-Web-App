---
interface Props { content: any; }
const { content } = Astro.props;
const about = content.about || {};
const tag = about.tag || '';
const headline = about.headline || '';
const paragraphs = Array.isArray(about.paragraphs) && about.paragraphs.length ? about.paragraphs : [];
const pullQuote = about.lead || about.signature || '';
const sign = about.signatureName || about.signature || '';
const aboutImage = about.image || (content.photos && content.photos[0]) || '';
const stampY = about.stampYear || '';
const stampT = about.stampTag || '';
---
<section class="pad-y" id="about">
  <div class="wrap about-grid reveal">
    <div class="about-media">
      <div class="img" data-image-field="about.image" style={aboutImage ? `background-image:url('${aboutImage}');` : ''}></div>
      {(stampY || stampT) && (
        <div class="stamp">
          {stampY && <div class="y" data-field="about.stampYear">{stampY}</div>}
          {stampT && <div class="t" data-field="about.stampTag">{stampT}</div>}
        </div>
      )}
    </div>
    <div class="about-body">
      <span class="kicker" data-field="about.tag">{tag}</span>
      <h2 class="h-sect" data-field="about.headline" set:html={headline}></h2>
      {pullQuote && <div class="pull" data-field="about.lead" set:html={pullQuote}></div>}
      {paragraphs.map((p: string, i: number) => (
        <p data-field={`about.paragraphs.${i}`} set:html={p}></p>
      ))}
      {sign && <div class="sign" data-field="about.signatureName">— {sign}</div>}
    </div>
  </div>
</section>
<style>
  .about-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(36px, 5vw, 80px); align-items: center; }
  .about-media { position: relative; }
  .about-media .img { width: 100%; height: min(70vh, 620px); background-size: cover; background-position: center; background-color: var(--ink-2); }
  .about-media .stamp {
    position: absolute; right: -22px; bottom: -22px; width: 128px; height: 128px; border-radius: 50%;
    background: var(--ink); color: var(--paper); display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; border: 1px solid var(--brass);
  }
  .about-media .stamp .y { font-family: var(--display); font-size: 34px; line-height: 1; color: var(--brass-bright); }
  .about-media .stamp .t { font-family: var(--cond); text-transform: uppercase; letter-spacing: .18em; font-size: 10px; margin-top: 4px; }
  .about-body p { color: var(--muted); margin: 0 0 18px; }
  .about-body p :global(strong) { color: var(--ink); font-weight: 600; }
  .pull { font-family: var(--serif); font-style: italic; font-size: clamp(22px, 2.4vw, 31px); line-height: 1.3; color: var(--ink); border-left: 3px solid var(--brass); padding-left: 24px; margin: 26px 0; }
  .sign { font-family: var(--serif); font-style: italic; font-size: 26px; color: var(--brass); margin-top: 24px; }
  @media (max-width: 840px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-media { order: -1; }
    .about-media .img { height: 48vh; }
  }
</style>
