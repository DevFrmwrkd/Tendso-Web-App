---
/**
 * Forge Stacked hero — paper background with giant ghost word,
 * 2-col grid (copy + asymmetric photo stack with rotating seal).
 * Same content.hero shape as HeroF — content stays portable.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const hero = content.hero || {};
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';
const heroImage2 = hero.image2 || (Array.isArray(hero.photos) && hero.photos[1]) || (Array.isArray(content.photos) && content.photos[1]) || heroImage;
const locality = hero.kicker || hero.locality || '';
const headlineLines: string[] = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0
  ? hero.headlineLines
  : (hero.headline ? [hero.headline] : []);
const titleMain = headlineLines.slice(0, 2).join('<br>');
const titleEm = headlineLines[2] || hero.thin || hero.sub_kicker || '';
const sub = hero.sub || '';
const cta1Text = hero.cta1?.text || '';
const cta1Href = hero.cta1?.href || '#visit';
const cta2Text = hero.cta2?.text || '';
const cta2Href = hero.cta2?.href || (layout.contact?.phone ? `tel:${String(layout.contact.phone).replace(/[^0-9+]/g, '')}` : '#');
const bgWord = (hero.ghostWord || (layout.businessName ? String(layout.businessName).split(/\s+/)[0] : 'FORGE')).toString().toUpperCase();
const ratingBig = hero.rating?.big || '';
const ratingLabel = hero.rating?.label || '';
const sealText = hero.sealText || `${layout.businessName || 'Forge'} · ${hero.sealSuffix || 'Est. · '}`;
type Mini = { value: string; label: string };
const mini: Mini[] = Array.isArray(hero.mini) && hero.mini.length ? hero.mini : [];
---
<section class="heroS" id="top">
  <div class="heroS-bgword" aria-hidden="true" data-field="hero.ghostWord">{bgWord}</div>
  <div class="wrap heroS-grid">
    <div class="heroS-copy">
      {locality && <div class="heroS-locality" data-field="hero.kicker">{locality}</div>}
      {(titleMain || titleEm) && (
        <h1 class="heroS-title">
          <span set:html={titleMain}></span>
          {titleEm && <span class="em" data-field="hero.thin">{titleEm}</span>}
        </h1>
      )}
      {sub && <p class="heroS-sub" data-field="hero.sub">{sub}</p>}
      <div class="heroS-actions">
        {cta1Text && <a class="btn btn--brass" href={cta1Href} data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>}
        {cta2Text && <a class="btn btn--ghost" href={cta2Href} data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>}
      </div>
      {mini.length > 0 && (
        <div class="heroS-mini">
          {mini.map((m: Mini, i: number) => (
            <div class="m">
              <div class="n" data-field={`hero.mini.${i}.value`} set:html={m.value}></div>
              <div class="l" data-field={`hero.mini.${i}.label`}>{m.label}</div>
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="heroS-stack">
      <div class="card ph-big">
        <div class="bg-img" data-image-field="hero.image" style={heroImage ? `background-image:url('${heroImage}');` : ''}></div>
      </div>
      <div class="card ph-small">
        <div class="bg-img" data-image-field="hero.image2" style={heroImage2 ? `background-image:url('${heroImage2}');` : ''}></div>
      </div>
      {(ratingBig || ratingLabel) && (
        <div class="card c-rating">
          {ratingBig && <div class="big" data-field="hero.rating.big">{ratingBig}</div>}
          <div>
            <span class="st">★★★★★</span>
            {ratingLabel && <div class="lbl" data-field="hero.rating.label" set:html={ratingLabel}></div>}
          </div>
        </div>
      )}
      <div class="card seal">
        <svg class="ring" viewBox="0 0 120 120">
          <defs><path id="sealpath-j" d="M60,60 m-42,0 a42,42 0 1,1 84,0 a42,42 0 1,1 -84,0" /></defs>
          <text><textPath href="#sealpath-j" startOffset="0">{sealText}</textPath></text>
        </svg>
        <div class="seal-core">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="6" cy="6" r="3" /><circle cx="6" cy="18" r="3" />
            <path d="M8.1 8.1L20 20M8.1 15.9L20 4M14 12l6 0" />
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  .heroS { position: relative; min-height: 100svh; background: var(--paper); color: var(--ink); overflow: hidden; display: flex; align-items: center; }
  .heroS-bgword {
    position: absolute; right: -2%; top: 6%;
    font-family: var(--display); font-size: 19vw; line-height: 1;
    color: transparent; -webkit-text-stroke: 1px rgba(var(--ink-rgb), .05);
    z-index: 0; pointer-events: none;
  }
  .heroS-grid {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.02fr .98fr;
    gap: clamp(30px, 5vw, 72px); align-items: center;
    width: 100%; padding-top: 128px; padding-bottom: 64px;
  }
  .heroS-copy > * { opacity: 0; animation: sFade .9s ease both; }
  .heroS-locality {
    font-family: var(--cond); text-transform: uppercase; letter-spacing: .34em;
    font-size: 12px; color: var(--brass);
    display: flex; align-items: center; gap: 12px; animation-delay: .1s;
  }
  .heroS-locality::before { content: ""; width: 34px; height: 1px; background: var(--brass); }
  .heroS-title {
    font-family: var(--display); font-weight: 700; text-transform: none;
    font-size: clamp(54px, 7.8vw, 120px); line-height: .96; letter-spacing: -.012em;
    margin: 18px 0 0; animation-delay: .2s;
  }
  .heroS-title .em {
    display: block; font-family: var(--serif); font-style: italic; font-weight: 500;
    text-transform: none; color: var(--brass);
    font-size: .4em; line-height: 1; margin-top: .16em; letter-spacing: 0;
  }
  .heroS-sub { max-width: 42ch; color: var(--muted); font-size: clamp(16px, 1.4vw, 19px); margin: 26px 0 34px; animation-delay: .35s; }
  .heroS-actions { display: flex; gap: 14px; flex-wrap: wrap; animation-delay: .5s; }
  .heroS-mini { display: flex; gap: 34px; margin-top: 38px; animation-delay: .65s; }
  .heroS-mini .m { min-width: 0; }
  .heroS-mini .n { font-family: var(--display); font-weight: 700; font-size: 30px; line-height: 1; color: var(--ink); }
  .heroS-mini .n :global(b) { color: var(--brass); font-weight: 700; }
  .heroS-mini .l { font-family: var(--cond); text-transform: uppercase; letter-spacing: .16em; font-size: 11px; color: var(--muted); margin-top: 6px; }
  .heroS-stack { position: relative; height: min(80vh, 650px); }
  .heroS-stack .card {
    position: absolute; border: 1px solid var(--line); background: var(--paper-2);
    box-shadow: 0 26px 64px rgba(var(--ink-rgb), .18); overflow: hidden;
    opacity: 0; animation: sPop 1s cubic-bezier(.2,.8,.2,1) both;
  }
  .heroS-stack .card .bg-img { width: 100%; height: 100%; background-size: cover; background-position: center; }
  .heroS-stack .ph-big { width: 66%; height: 82%; top: 0; right: 0; animation-delay: .4s; }
  .heroS-stack .ph-small { width: 46%; height: 48%; left: 0; bottom: 4%; animation-delay: .58s; }
  .heroS-stack .c-rating {
    right: 7%; bottom: 3%;
    background: var(--ink); color: var(--paper);
    padding: 18px 22px; display: flex; align-items: center; gap: 14px;
    animation-delay: .82s; width: auto; height: auto;
  }
  .heroS-stack .c-rating .big { font-family: var(--display); font-weight: 700; font-size: 34px; line-height: 1; color: var(--brass-bright); }
  .heroS-stack .c-rating .st { color: var(--brass); font-size: 12px; letter-spacing: 2px; display: block; margin-bottom: 3px; }
  .heroS-stack .c-rating .lbl { font-family: var(--cond); text-transform: uppercase; letter-spacing: .16em; font-size: 10.5px; color: var(--muted-light); line-height: 1.4; }
  .heroS-stack .seal {
    left: 1%; top: 1%; width: 106px; height: 106px;
    border-radius: 50%; background: var(--ink);
    box-shadow: 0 18px 40px rgba(var(--ink-rgb), .26);
    animation-delay: .98s;
  }
  .heroS-stack .seal .ring { width: 100%; height: 100%; animation: sSpin 22s linear infinite; }
  .heroS-stack .seal text { font-family: var(--cond); font-size: 10.5px; letter-spacing: 2.4px; text-transform: uppercase; fill: var(--paper); }
  .heroS-stack .seal-core { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--brass-bright); }
  .heroS-stack .seal-core svg { width: 26px; height: 26px; }
  @keyframes sFade { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }
  @keyframes sPop { from { opacity: 0; transform: translateY(42px) scale(.92); } to { opacity: 1; transform: none; } }
  @keyframes sSpin { to { transform: rotate(360deg); } }
  @media (max-width: 860px) {
    .heroS-grid { grid-template-columns: 1fr; }
    .heroS-stack { height: 52vh; margin-top: 8px; }
    .heroS-stack .ph-small, .heroS-stack .seal { display: none; }
    .heroS-stack .ph-big { width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .heroS-copy > *, .heroS-stack .card { animation: none !important; opacity: 1 !important; transform: none !important; }
    .heroS-stack .seal .ring { animation: none !important; }
  }
</style>
