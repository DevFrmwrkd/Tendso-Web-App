---
interface Props { content: any; }
const { content } = Astro.props;
const creds = content.credentials || {};
const tag = creds.tag || '';
const headline = creds.headline || '';
const sub = creds.sub || creds.body || '';
const items: Array<{ title: string; body?: string }> = Array.isArray(creds.items) ? creds.items : [];
const iconPaths = [
  '<path d="M12 2l8 4v6c0 5-3.4 8.5-8 10-4.6-1.5-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/>',
  '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18M7 15h4"/>',
  '<path d="M12 2v20M5 5h14M5 19h14"/><circle cx="12" cy="12" r="4"/>',
  '<circle cx="12" cy="8" r="5"/><path d="M8.5 13L7 22l5-3 5 3-1.5-9"/>',
];
---
{items.length > 0 && (
  <section class="pad-y ink-sect">
    <div class="wrap">
      <div class="sect-head reveal" style="margin-bottom:0;">
        <div>
          {tag && <span class="kicker on-dark" data-field="credentials.tag">{tag}</span>}
          {headline && <h2 class="h-sect" data-field="credentials.headline" set:html={headline}></h2>}
        </div>
        {sub && <p class="lead on-dark" data-field="credentials.sub">{sub}</p>}
      </div>
      <div class="creds reveal">
        {items.map((it, i) => (
          <div class="cred">
            <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={iconPaths[i % iconPaths.length]}></svg>
            <h3 data-field={`credentials.items.${i}.title`}>{it.title}</h3>
            {it.body && <p data-field={`credentials.items.${i}.body`}>{it.body}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}
<style>
  .creds { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(20px, 3vw, 40px); margin-top: 54px; }
  .cred { text-align: center; }
  .cred .ic { width: 48px; height: 48px; margin: 0 auto 18px; color: var(--brass-bright); }
  .cred h3 { font-family: var(--cond); text-transform: uppercase; letter-spacing: .08em; font-size: 16px; font-weight: 600; margin: 0 0 8px; color: var(--paper); }
  .cred p { color: var(--muted-light); font-size: 13.5px; margin: 0; }
  @media (max-width: 760px) { .creds { grid-template-columns: repeat(2, 1fr); gap: 32px; } }
</style>
