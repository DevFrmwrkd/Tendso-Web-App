---
interface Props { content: any; }
const { content } = Astro.props;
const how = content.how || {};
const tag = how.tag || '';
const headline = how.headline || '';
const sub = how.sub || '';
const steps = Array.isArray(how.steps) ? how.steps : [];
---
<section class="pad-y" id="how">
  <div class="wrap">
    <div class="sect-head reveal">
      <div>
        {tag && <span class="kicker" data-field="how.tag">{tag}</span>}
        {headline && <h2 class="h-sect" data-field="how.headline" set:html={headline}></h2>}
      </div>
      {sub && <p class="lead" data-field="how.sub">{sub}</p>}
    </div>
    {steps.length > 0 && (
      <div class="timeline reveal">
        {steps.map((s: any, i: number) => (
          <div class="tnode">
            <span class="stepno">Step {String(i + 1).padStart(2, '0')}</span>
            <h3 data-field={`how.steps.${i}.title`}>{s.title}</h3>
            <p data-field={`how.steps.${i}.body`}>{s.body || s.description || ''}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
<style>
  .timeline { position: relative; display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 24px; }
  .timeline::before { content: ""; position: absolute; top: 24px; left: 4px; right: 4px; height: 2px; background: var(--line); }
  .tnode { position: relative; padding-top: 62px; }
  .tnode::before {
    content: ""; position: absolute; top: 15px; left: 4px; width: 18px; height: 18px; border-radius: 50%;
    background: var(--brass); box-shadow: 0 0 0 5px var(--paper), 0 0 0 7px var(--brass);
  }
  .tnode .stepno { font-family: var(--cond); letter-spacing: .2em; font-size: 12px; color: var(--brass); font-weight: 600; }
  .tnode h3 { font-family: var(--cond); text-transform: uppercase; letter-spacing: .03em; font-weight: 600; font-size: 21px; margin: 7px 0 8px; }
  .tnode p { color: var(--muted); font-size: 15px; margin: 0; }
  @media (max-width: 760px) {
    .timeline { grid-template-columns: 1fr; gap: 0; }
    .timeline::before { left: 11px; top: 6px; bottom: 6px; width: 2px; height: auto; right: auto; }
    .tnode { padding: 0 0 30px 44px; }
    .tnode::before { top: 2px; left: 3px; }
  }
</style>
