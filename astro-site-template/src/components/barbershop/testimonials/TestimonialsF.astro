---
interface Props { content: any; }
const { content } = Astro.props;
const t = content.testimonials || {};
const tag = t.tag || '';
const headline = t.headline || '';
const sub = t.sub || '';
const items: Array<{ quote: string; who: string }> = Array.isArray(t.items) ? t.items : [];
const featured = items[0];
const side = items.slice(1);
---
{items.length > 0 && (
  <section class="pad-y testi-sec">
    <div class="wrap">
      <div class="sect-head reveal">
        <div>
          {tag && <span class="kicker" data-field="testimonials.tag">{tag}</span>}
          {headline && <h2 class="h-sect" data-field="testimonials.headline" set:html={headline}></h2>}
        </div>
        {sub && <p class="lead" data-field="testimonials.sub">{sub}</p>}
      </div>
      <div class="quotes reveal">
        {featured && (
          <figure class="feat">
            <div class="stars">★★★★★</div>
            <blockquote data-field="testimonials.items.0.quote" set:html={featured.quote}></blockquote>
            <figcaption class="by"><span data-field="testimonials.items.0.who">{featured.who || ''}</span></figcaption>
          </figure>
        )}
        {side.length > 0 && (
          <div class="side">
            {side.map((q, i) => (
              <figure class="sq">
                <div class="stars">★★★★★</div>
                <blockquote data-field={`testimonials.items.${i + 1}.quote`} set:html={q.quote}></blockquote>
                <figcaption class="by"><span data-field={`testimonials.items.${i + 1}.who`}>{q.who || ''}</span></figcaption>
              </figure>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
)}
<style>
  .testi-sec { background: var(--paper-2); }
  .quotes { display: grid; grid-template-columns: 1.4fr 1fr; gap: 24px; align-items: stretch; }
  .feat { background: var(--ink); color: var(--paper); padding: clamp(34px, 4vw, 48px); display: flex; flex-direction: column; justify-content: center; margin: 0; }
  .feat .stars { color: var(--brass); letter-spacing: 3px; margin-bottom: 18px; }
  .feat blockquote { font-family: var(--serif); font-style: italic; font-size: clamp(24px, 2.7vw, 36px); line-height: 1.32; margin: 0 0 24px; }
  .feat .by { font-family: var(--cond); text-transform: uppercase; letter-spacing: .16em; font-size: 12px; color: var(--muted-light); }
  .side { display: flex; flex-direction: column; gap: 24px; }
  .sq { border: 1px solid var(--line); padding: 28px 26px; flex: 1; display: flex; flex-direction: column; margin: 0; }
  .sq .stars { color: var(--brass); letter-spacing: 2px; font-size: 13px; margin-bottom: 12px; }
  .sq blockquote { font-family: var(--serif); font-style: italic; font-size: 18px; line-height: 1.42; margin: 0 0 14px; }
  .sq .by { font-family: var(--cond); text-transform: uppercase; letter-spacing: .16em; font-size: 11px; color: var(--muted); margin-top: auto; }
  @media (max-width: 860px) { .quotes { grid-template-columns: 1fr; } }
</style>
