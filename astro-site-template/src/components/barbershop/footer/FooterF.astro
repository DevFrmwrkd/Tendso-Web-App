---
interface Props { layout: any; content: any; }
const { layout, content } = Astro.props;
const f = content.footer || {};
const brand = f.brand || layout.businessName || 'Your Business';
const blurb = f.blurb || f.brand_blurb || '';
const visitLines: string[] = Array.isArray(f.visit?.lines) && f.visit.lines.length
  ? f.visit.lines
  : ([layout.contact?.address, layout.contact?.phone].filter(Boolean) as string[]);
const explore: Array<{ text: string; href: string }> = Array.isArray(f.explore?.links) && f.explore.links.length
  ? f.explore.links
  : [];
const hoursRows: Array<{ day: string; time: string }> = Array.isArray(f.hours) ? f.hours : [];
const social: Array<{ platform: string; url: string }> = Array.isArray(f.social) && f.social.length
  ? f.social
  : (Array.isArray(layout.socialLinks) ? layout.socialLinks : []);
const notes: string[] = Array.isArray(f.notes) && f.notes.length
  ? f.notes
  : [];
const phone = layout.contact?.phone || '';
const phoneDigits = phone.replace(/[^0-9+]/g, '');
---
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <div class="brand" data-field="footer.brand">{brand}<span class="dot">.</span></div>
        {blurb && <p data-field="footer.blurb">{blurb}</p>}
        {social.length > 0 && (
          <div class="foot-social">
            {social.map((s: any, i: number) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                data-field={`footer.social.${i}.platform`}
                data-href-field={`footer.social.${i}.url`}
                data-platform-field={`footer.social.${i}.platform`}
              >{s.platform}</a>
            ))}
          </div>
        )}
      </div>
      <div class="foot-col">
        <h4>Visit</h4>
        {visitLines.map((line: string, i: number) => (
          line === phone && phone
            ? <a href={`tel:${phoneDigits}`} data-field={`footer.visit.lines.${i}`} data-href-field={`footer.visit.lines.${i}.href`}>{line}</a>
            : <span class="li" data-field={`footer.visit.lines.${i}`}>{line}</span>
        ))}
      </div>
      {explore.length > 0 && (
        <div class="foot-col">
          <h4>Explore</h4>
          {explore.map((l: any, i: number) => (
            <a href={l.href} data-field={`footer.explore.links.${i}.text`} data-href-field={`footer.explore.links.${i}.href`}>{l.text}</a>
          ))}
        </div>
      )}
      {hoursRows.length > 0 && (
        <div class="foot-col foot-hours">
          <h4>Hours · live on Google</h4>
          {hoursRows.map((row: any, i: number) => (
            <div>
              <span data-field={`footer.hours.${i}.day`}>{row.day}</span>
              <span data-field={`footer.hours.${i}.time`}>{row.time}</span>
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="foot-bottom">
      {notes.map((n: string, i: number) => (
        <span data-field={`footer.notes.${i}`}>{n}</span>
      ))}
    </div>
  </div>
</footer>
<style>
  footer { background: var(--ink); color: var(--paper); }
  .foot-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 40px; padding-block: clamp(56px, 7vw, 90px); }
  .foot-brand .brand { font-family: var(--display); font-size: 30px; letter-spacing: .04em; text-transform: uppercase; }
  .foot-brand .brand .dot { color: var(--brass); }
  .foot-brand p { color: var(--muted-light); font-size: 14.5px; max-width: 34ch; margin: 18px 0 0; }
  .foot-social { margin-top: 18px; display: flex; gap: 12px; flex-wrap: wrap; }
  .foot-social a { font-family: var(--cond); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted-light); border: 1px solid var(--line-light); padding: 7px 12px; border-radius: 999px; transition: color .2s, border-color .2s; }
  .foot-social a:hover { color: var(--brass-bright); border-color: var(--brass-bright); }
  .foot-col h4 { font-family: var(--cond); text-transform: uppercase; letter-spacing: .18em; font-size: 12px; color: var(--brass); margin: 0 0 18px; font-weight: 600; }
  .foot-col a, .foot-col .li { display: block; color: var(--muted-light); font-size: 14.5px; padding: 5px 0; }
  .foot-col a:hover { color: var(--paper); }
  .foot-hours div { display: flex; justify-content: space-between; max-width: 280px; padding: 2px 0; font-size: 14.5px; color: var(--muted-light); }
  .foot-bottom { border-top: 1px solid var(--line-light); padding: 24px 0; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-size: 12.5px; color: var(--muted-light); }
  @media (max-width: 840px) { .foot-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .foot-grid { grid-template-columns: 1fr; } }
</style>
