---
/**
 * ContactM1 — Salon · Lumière footer ("Become the most-yourself you.")
 *
 * Big serif closing line + two CTAs on a deep pink ground, then a tight
 * footer row with brand + nav + social links. Doubles as the contact section.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description,
  socialLinks = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.contactHeadline !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();
---

<section id="contact" class="lum-contact" data-component="CONTACT">
  <div class="lum-contact-hero">
    <p class="lum-contact-eyebrow">— Ready when you are —</p>
    {showHeadline && (
      <h2 class="lum-contact-headline" data-field="contact.headline">
        Become the most-yourself <em>you</em>.
      </h2>
    )}
    {description && (
      <p class="lum-contact-sub" data-field="contact.description" set:html={description}></p>
    )}
    <div class="lum-contact-ctas">
      <a class="lum-cta-primary" href={phone ? `tel:${phone.replace(/[^0-9+]/g, '')}` : '#'}>Book Now</a>
      {phone && (
        <a class="lum-cta-ghost" href={`tel:${phone.replace(/[^0-9+]/g, '')}`}>
          Call <span data-field="contact.phone" set:html={phone}></span>
        </a>
      )}
    </div>
  </div>

  <footer class="lum-contact-footer">
    <div class="lum-contact-footer-grid">
      <div>
        <h3 class="lum-contact-brand" data-field="business.name" set:html={businessName}></h3>
        <p class="lum-contact-tagline">Where elegance begins.</p>
        {showSocial && (
          <div class="lum-contact-socials">
            {socialLinks.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="lum-social">{s.platform}</a>
            ))}
          </div>
        )}
      </div>
      <div class="lum-contact-col">
        <h4 class="lum-contact-col-head">Visit</h4>
        {address && <p data-field="contact.address" set:html={address}></p>}
      </div>
      <div class="lum-contact-col">
        <h4 class="lum-contact-col-head">Reach Us</h4>
        {showInfo && phone && <p><a href={`tel:${phone.replace(/[^0-9+]/g, '')}`} data-field="contact.phone" set:html={phone}></a></p>}
        {showInfo && email && <p><a href={`mailto:${email}`} data-field="contact.email" set:html={email}></a></p>}
      </div>
    </div>
    <div class="lum-contact-baseline">
      <span>© {year} <span set:html={businessName}></span>. All rights reserved.</span>
      <span>Made with care.</span>
    </div>
  </footer>
</section>

<style>
  .lum-contact {
    --lc-bg: var(--primary);
    --lc-ink: #fff;
    --lc-ink-2: color-mix(in srgb, #fff 85%, transparent);
    --lc-ink-3: color-mix(in srgb, #fff 60%, transparent);
    --lc-rule: color-mix(in srgb, #fff 18%, transparent);
    --lc-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --lc-sans: var(--body-font, "Inter", system-ui, sans-serif);
    background: var(--lc-bg);
    color: var(--lc-ink);
    font-family: var(--lc-sans);
  }
  .lum-contact-hero {
    text-align: center;
    padding: clamp(72px, 10vw, 120px) clamp(20px, 4vw, 56px) clamp(48px, 6vw, 72px);
    max-width: 880px;
    margin: 0 auto;
  }
  .lum-contact-eyebrow {
    font-family: var(--lc-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--lc-ink-2);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin: 0 0 22px;
  }
  .lum-contact-headline {
    font-family: var(--lc-serif);
    font-size: clamp(40px, 7vw, 84px);
    line-height: 1;
    color: var(--lc-ink);
    margin: 0;
    font-weight: 500;
  }
  .lum-contact-headline em { font-style: italic; }
  .lum-contact-sub {
    margin: 22px auto 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--lc-ink-2);
    max-width: 56ch;
  }
  .lum-contact-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .lum-cta-primary {
    background: #fff;
    color: var(--primary);
    padding: 14px 30px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .lum-cta-ghost {
    background: transparent;
    color: #fff;
    padding: 14px 26px;
    border-radius: 999px;
    border: 1px solid var(--lc-rule);
    font-size: 14px;
    text-decoration: none;
  }
  .lum-contact-footer {
    border-top: 1px solid var(--lc-rule);
    padding: clamp(36px, 5vw, 48px) clamp(20px, 4vw, 56px);
    max-width: 1180px;
    margin: 0 auto;
  }
  .lum-contact-footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 32px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--lc-rule);
  }
  @media (max-width: 768px) { .lum-contact-footer-grid { grid-template-columns: 1fr; } }
  .lum-contact-brand {
    font-family: var(--lc-serif);
    font-size: 28px;
    margin: 0 0 6px;
    font-weight: 500;
  }
  .lum-contact-tagline {
    margin: 0;
    color: var(--lc-ink-3);
    font-style: italic;
    font-family: var(--lc-serif);
    font-size: 15px;
  }
  .lum-contact-socials {
    display: flex;
    gap: 14px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .lum-social {
    color: var(--lc-ink-2);
    text-decoration: none;
    font-size: 12px;
    border-bottom: 1px solid var(--lc-rule);
    padding-bottom: 1px;
  }
  .lum-contact-col p {
    margin: 0 0 6px;
    font-size: 13.5px;
    color: var(--lc-ink-2);
    line-height: 1.6;
  }
  .lum-contact-col a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dotted var(--lc-rule);
  }
  .lum-contact-col-head {
    font-family: var(--lc-sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--lc-ink-3);
    margin: 0 0 12px;
    font-weight: 600;
  }
  .lum-contact-baseline {
    margin-top: 22px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-size: 11px;
    color: var(--lc-ink-3);
    font-family: var(--lc-sans);
    flex-wrap: wrap;
  }
</style>
