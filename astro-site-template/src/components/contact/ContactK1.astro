---
/**
 * ContactK - Barber Shop / Vintage Storefront
 * Dark charcoal background with brass accents.
 * Three column layout: HOURS / ADDRESS / PHONE — like a vintage barbershop sign.
 * Signature: animated open/closed sign + brass cornerwork.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description,
  socialLinks = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false && !!description;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

// Default hours — could come from content.footer_hours / footer_days but use sane defaults
const hoursDisplay = [
  { day: 'Mon — Fri', time: '9:00 — 8:00' },
  { day: 'Saturday', time: '9:00 — 9:00' },
  { day: 'Sunday', time: '10:00 — 6:00' },
];
---

<section
  id="contact"
  class="relative w-full bg-[var(--text)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Brass border frame */}
  <div class="absolute inset-6 md:inset-10 border border-[var(--accent)]/30 pointer-events-none"></div>
  <div class="absolute inset-8 md:inset-12 border border-[var(--accent)]/10 pointer-events-none"></div>

  {/* Wood-grain horizontal texture */}
  <div
    class="absolute inset-0 opacity-[0.06] pointer-events-none"
    style="background-image: repeating-linear-gradient(0deg, transparent 0 4px, var(--accent) 4px 5px);"
  ></div>

  <div class="relative z-10 mx-auto max-w-6xl px-8 md:px-16">

    {/* Open/Closed sign at top — animated */}
    <div class="barber-fade-up flex justify-center mb-12">
      <div class="inline-flex items-center gap-3 px-6 py-2 bg-[var(--primary)] border-y-2 border-[var(--accent)] shadow-[0_10px_30px_-5px_rgba(201,169,97,0.3)]">
        <span class="w-2 h-2 rounded-full bg-[var(--accent)] barber-pulse"></span>
        <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--bg)]">Now Open</span>
        <span class="w-2 h-2 rounded-full bg-[var(--accent)] barber-pulse" style="animation-delay: 0.5s"></span>
      </div>
    </div>

    {/* Headline */}
    {showHeadline && (
      <div class="text-center mb-16">
        <div class="barber-fade-up inline-flex items-center gap-4 mb-4" style="animation-delay: 0.1s">
          <span class="h-px w-10 bg-[var(--accent)]"></span>
          <span class="text-[10px] font-bold uppercase tracking-[0.45em] text-[var(--accent)]">— Visit Us —</span>
          <span class="h-px w-10 bg-[var(--accent)]"></span>
        </div>
        <h2
          class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--bg)]"
          style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.2s;"
        >
          {businessName}
        </h2>
        {showDescription && (
          <p
            class="barber-fade-up max-w-xl mx-auto mt-6 text-[var(--accent)] italic"
            style="animation-delay: 0.3s;"
          >
            {description}
          </p>
        )}
      </div>
    )}

    {/* Three column info — Hours / Address / Phone */}
    {showInfo && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 mb-16">

        {/* HOURS */}
        <div class="barber-fade-up text-center md:border-r md:border-[var(--accent)]/20 md:pr-8" style="animation-delay: 0.4s">
          <div class="inline-block w-12 h-12 mb-4 border border-[var(--accent)] rounded-full flex items-center justify-center">
            <span class="text-[var(--accent)] text-xl">⏱</span>
          </div>
          <h3 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--accent)] mb-4">— Hours —</h3>
          <ul class="space-y-2">
            {hoursDisplay.map((h) => (
              <li class="flex justify-between text-sm text-[var(--bg)]">
                <span class="italic">{h.day}</span>
                <span class="font-bold">{h.time}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* ADDRESS */}
        {address && (
          <div class="barber-fade-up text-center md:border-r md:border-[var(--accent)]/20 md:px-8" style="animation-delay: 0.5s">
            <div class="inline-block w-12 h-12 mb-4 border border-[var(--accent)] rounded-full flex items-center justify-center">
              <span class="text-[var(--accent)] text-xl">📍</span>
            </div>
            <h3 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--accent)] mb-4">— The Shop —</h3>
            <p class="text-[var(--bg)] text-sm leading-relaxed">{address}</p>
            <p class="mt-3 text-[10px] italic text-[var(--accent)]/70 uppercase tracking-widest">Walk-ins welcome</p>
          </div>
        )}

        {/* PHONE */}
        <div class="barber-fade-up text-center md:pl-8" style="animation-delay: 0.6s">
          <div class="inline-block w-12 h-12 mb-4 border border-[var(--accent)] rounded-full flex items-center justify-center">
            <span class="text-[var(--accent)] text-xl">☎</span>
          </div>
          <h3 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--accent)] mb-4">— Call to Book —</h3>
          <a
            href={`tel:${phone}`}
            class="block text-lg md:text-xl font-bold text-[var(--bg)] hover:text-[var(--accent)] transition-colors tracking-wide"
          >
            {phone}
          </a>
          {email && (
            <a
              href={`mailto:${email}`}
              class="block mt-2 text-xs italic text-[var(--accent)] hover:text-[var(--bg)] transition-colors break-words"
            >
              {email}
            </a>
          )}
        </div>
      </div>
    )}

    {/* CTA button */}
    <div class="text-center mb-16">
      <a
        href={`tel:${phone}`}
        class="barber-fade-up inline-flex items-center gap-3 bg-[var(--accent)] hover:bg-[var(--accent)] text-[var(--text)] px-10 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-all hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(201,169,97,0.6)]"
        style="animation-delay: 0.7s;"
      >
        ✂ Reserve your chair
      </a>
    </div>

    {/* Social row */}
    {showSocial && (
      <div class="barber-fade-up flex justify-center gap-4 mb-12" style="animation-delay: 0.8s">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 border border-[var(--accent)]/40 flex items-center justify-center text-[var(--accent)] hover:bg-[var(--accent)] hover:text-[var(--text)] transition-all"
            aria-label={link.platform}
          >
            <span class="text-xs font-bold uppercase">{link.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    {/* Signature flourish */}
    <div class="barber-fade-up flex items-center justify-center gap-4 pt-8 border-t border-[var(--accent)]/15" style="animation-delay: 0.9s">
      <span class="h-px w-12 bg-[var(--accent)]/30"></span>
      <span class="text-[var(--accent)] text-xl">✂</span>
      <span class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--accent)]/70">
        Est. {year} — {businessName}
      </span>
      <span class="text-[var(--accent)] text-xl">✂</span>
      <span class="h-px w-12 bg-[var(--accent)]/30"></span>
    </div>
  </div>
</section>

<style>
  .barber-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: barberFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .barber-pulse {
    animation: barberPulse 2s ease-in-out infinite;
  }
  @keyframes barberPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.4); box-shadow: 0 0 12px rgba(201, 169, 97, 0.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .barber-fade-up { animation-duration: 0.01ms; opacity: 1; transform: none; }
    .barber-pulse { animation: none; opacity: 1; }
  }
</style>
