---
/**
 * ContactM4 - Salon/Spa / Walk-In Welcome
 * Walk-in friendly with prominent hours, "no appointment needed" feel.
 * Day-by-day hours pills + welcome message + map cue.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const days = [
  { day: 'Mon', hours: '10 – 7' },
  { day: 'Tue', hours: '10 – 7' },
  { day: 'Wed', hours: '10 – 7' },
  { day: 'Thu', hours: '10 – 8' },
  { day: 'Fri', hours: '10 – 9' },
  { day: 'Sat', hours: '9 – 9' },
  { day: 'Sun', hours: '11 – 6' },
];

const todayIdx = (new Date().getDay() + 6) % 7;
const year = new Date().getFullYear();
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -right-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>
  <div class="absolute bottom-0 -left-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    {/* Welcome banner */}
    <div class="text-center mb-12">
      <div class="salon-fade-up inline-flex items-center gap-3 bg-[var(--surface)] rounded-full px-6 py-2 mb-6">
        <span class="w-2 h-2 rounded-full bg-[var(--primary)] animate-pulse"></span>
        <span class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic">— Walk-ins welcome —</span>
      </div>
      <h2 class="salon-fade-up font-light italic leading-[1.02] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6vw, 4.5rem); animation-delay: 0.1s;">Come find us</h2>
      <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] max-w-xl mx-auto" style="font-size: 1.1rem; animation-delay: 0.2s;">No appointment? No worry. Stop in any time we're open — we'll find space for you.</p>
    </div>

    {/* Hours pills */}
    <div class="salon-fade-up bg-[var(--surface)] rounded-3xl p-8 mb-8" style="animation-delay: 0.3s">
      <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-6">— Our open hours —</p>
      <div class="grid grid-cols-3 sm:grid-cols-7 gap-2">
        {days.map((d, i) => (
          <div class={`text-center py-4 rounded-2xl transition-colors ${i === todayIdx ? 'bg-[var(--primary)] text-[var(--bg)]' : 'bg-[var(--bg)]/60'}`}>
            <p class={`text-[10px] uppercase tracking-[0.4em] italic mb-1 ${i === todayIdx ? 'text-[var(--bg)]/80' : 'text-[var(--accent)]'}`}>{d.day}</p>
            <p class={`text-base italic ${i === todayIdx ? 'text-[var(--bg)]' : 'text-[var(--primary)]'}`} style="font-family: var(--heading-font);">{d.hours}</p>
            {i === todayIdx && <p class="text-[8px] uppercase tracking-[0.4em] mt-1 opacity-80">— Today —</p>}
          </div>
        ))}
      </div>
    </div>

    {/* Three-column info */}
    {showInfo && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
        <a href={`tel:${phone}`} class="salon-fade-up bg-[var(--surface)] rounded-2xl p-6 text-center hover:-translate-y-1 transition-all" style="animation-delay: 0.45s">
          <div class="w-12 h-12 rounded-full bg-[var(--primary)]/15 flex items-center justify-center mx-auto mb-3">
            <span class="text-xl text-[var(--primary)]">☎</span>
          </div>
          <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-1">— Call —</p>
          <p class="text-base italic text-[var(--primary)]" style="font-family: var(--heading-font);">{phone}</p>
        </a>
        {email && (
          <a href={`mailto:${email}`} class="salon-fade-up bg-[var(--surface)] rounded-2xl p-6 text-center hover:-translate-y-1 transition-all" style="animation-delay: 0.55s">
            <div class="w-12 h-12 rounded-full bg-[var(--primary)]/15 flex items-center justify-center mx-auto mb-3">
              <span class="text-xl text-[var(--primary)]">✉</span>
            </div>
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-1">— Email —</p>
            <p class="text-sm italic text-[var(--primary)] break-all">{email}</p>
          </a>
        )}
        {address && (
          <div class="salon-fade-up bg-[var(--surface)] rounded-2xl p-6 text-center" style="animation-delay: 0.65s">
            <div class="w-12 h-12 rounded-full bg-[var(--primary)]/15 flex items-center justify-center mx-auto mb-3">
              <span class="text-xl text-[var(--primary)]">❀</span>
            </div>
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-1">— Visit —</p>
            <p class="text-sm italic text-[var(--text)] leading-relaxed">{address}</p>
          </div>
        )}
      </div>
    )}

    {showSocial && (
      <div class="salon-fade-up flex justify-center gap-2 mb-8" style="animation-delay: 0.75s">
        {socialLinks.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-[var(--primary)]/40 hover:border-[var(--primary)] flex items-center justify-center text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--bg)] transition-colors" aria-label={l.platform}>
            <span class="text-xs italic">{l.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic">— © {year} · {businessName} —</p>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
