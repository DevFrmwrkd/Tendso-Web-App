---
/**
 * ContactK2 - Barber Shop / Walk-In Queue
 * Casual walk-in info. Simple hours-focused layout, no-appointment-needed vibe.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description,
  socialLinks = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false && !!description;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;
const year = new Date().getFullYear();
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent 0 3px, var(--text) 3px 4px);"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 lg:px-12 text-center">

    <div class="barber-fade-up mb-8">
      <span class="inline-block bg-[var(--accent)] text-[var(--text)] px-6 py-2 shadow-md">
        <span class="text-[10px] font-bold uppercase tracking-[0.45em]">— Walk-Ins Welcome —</span>
      </span>
    </div>

    {showHeadline && (
      <h2 class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-6" style="font-size: clamp(2.75rem, 7vw, 5rem); animation-delay: 0.1s;">
        No appointment.<br/><span class="italic text-[var(--primary)]">Just step in.</span>
      </h2>
    )}

    {showDescription && (
      <p class="barber-fade-up max-w-xl mx-auto text-[var(--text-muted)] italic leading-relaxed mb-12" style="font-size: 1.15rem; animation-delay: 0.2s;">
        {description}
      </p>
    )}

    {/* Big hours block */}
    {showInfo && (
      <div class="barber-fade-up bg-[var(--text)] text-[var(--bg)] p-10 lg:p-14 mb-10 relative shadow-[0_40px_80px_-20px_rgba(26,12,16,0.5)]" style="animation-delay: 0.3s">
        <div class="absolute top-4 left-4 w-8 h-8 border-t-2 border-l-2 border-[var(--accent)]"></div>
        <div class="absolute top-4 right-4 w-8 h-8 border-t-2 border-r-2 border-[var(--accent)]"></div>
        <div class="absolute bottom-4 left-4 w-8 h-8 border-b-2 border-l-2 border-[var(--accent)]"></div>
        <div class="absolute bottom-4 right-4 w-8 h-8 border-b-2 border-r-2 border-[var(--accent)]"></div>

        <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-6">— Shop Hours —</p>

        <div class="space-y-2 mb-8">
          <div class="flex items-baseline justify-between gap-4 text-xl">
            <span class="italic">Monday — Friday</span>
            <span class="font-bold">9 — 8</span>
          </div>
          <div class="flex items-baseline justify-between gap-4 text-xl">
            <span class="italic">Saturday</span>
            <span class="font-bold">9 — 9</span>
          </div>
          <div class="flex items-baseline justify-between gap-4 text-xl">
            <span class="italic">Sunday</span>
            <span class="font-bold">10 — 6</span>
          </div>
        </div>

        <div class="pt-6 border-t border-[var(--accent)]/30">
          <p class="text-[var(--accent)] text-[10px] uppercase tracking-[0.5em] italic">Average wait: 15 minutes</p>
        </div>
      </div>
    )}

    {/* Phone block */}
    <div class="barber-fade-up mb-10" style="animation-delay: 0.4s">
      <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] italic mb-2">— or call ahead —</p>
      <a href={`tel:${phone}`} class="text-3xl sm:text-4xl font-bold text-[var(--text)] hover:text-[var(--primary)] transition-colors">{phone}</a>
    </div>

    {/* Address */}
    {address && (
      <div class="barber-fade-up mb-10" style="animation-delay: 0.5s">
        <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] italic mb-2">— Find us —</p>
        <p class="text-lg text-[var(--text)] italic">{address}</p>
      </div>
    )}

    {showSocial && (
      <div class="barber-fade-up flex justify-center gap-3 mb-8" style="animation-delay: 0.6s">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-[var(--primary)]/40 flex items-center justify-center text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--bg)] transition-all" aria-label={link.platform}>
            <span class="text-xs font-bold uppercase">{link.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    <div class="barber-fade-up pt-8 border-t border-[var(--primary)]/20" style="animation-delay: 0.7s">
      <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)]/60 italic">— © {year} · {businessName} —</p>
    </div>
  </div>
</section>

<style>
  .barber-fade-up { opacity: 0; transform: translateY(20px); animation: barberFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .barber-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
