---
/**
 * ContactK5 - Barber Shop / Window Notice
 * Like a printed sign you'd see in the shop window. Bold, no-nonsense, classic shop notice.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;
const year = new Date().getFullYear();
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent 0 3px, var(--text) 3px 4px);"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 lg:px-12">

    {/* The notice — like a printed sign in the window */}
    <div class="barber-notice bg-[var(--surface)] border-8 border-[var(--text)] p-8 sm:p-12 lg:p-16 shadow-[0_40px_80px_-20px_rgba(26,12,16,0.4)] relative">

      {/* Tape strips on corners */}
      <div class="absolute -top-4 left-8 w-16 h-6 bg-[var(--accent)]/40 rotate-[-8deg] shadow-sm"></div>
      <div class="absolute -top-4 right-8 w-16 h-6 bg-[var(--accent)]/40 rotate-[6deg] shadow-sm"></div>

      <div class="text-center">
        <p class="barber-fade-up text-[var(--primary)] text-2xl mb-2">✂</p>
        <p class="barber-fade-up text-[10px] font-bold uppercase tracking-[0.5em] text-[var(--primary)] mb-6" style="animation-delay: 0.1s">— Window Notice —</p>

        <h2 class="barber-fade-up font-bold uppercase tracking-tight text-[var(--text)] mb-3" style="font-size: clamp(2rem, 5vw, 3.5rem); animation-delay: 0.15s; line-height: 0.95;">
          The Shop
        </h2>
        <h3 class="barber-fade-up text-2xl italic text-[var(--primary)] mb-8" style="font-size: clamp(1.25rem, 2.5vw, 1.85rem); animation-delay: 0.2s;">{businessName}</h3>

        {/* Bold notice items */}
        <div class="space-y-6 my-10">
          <div class="barber-fade-up py-4 border-y-2 border-[var(--text)]" style="animation-delay: 0.25s">
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] mb-2 italic">— Open —</p>
            <p class="text-3xl font-bold text-[var(--text)] uppercase tracking-tight" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
              Daily · 9 to 8
            </p>
            <p class="text-sm text-[var(--text-muted)] italic mt-1">(Saturdays 'til 9, Sunday 10 to 6)</p>
          </div>

          <div class="barber-fade-up py-4 border-b-2 border-[var(--text)]" style="animation-delay: 0.3s">
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] mb-2 italic">— Call —</p>
            <a href={`tel:${phone}`} class="text-3xl font-bold text-[var(--text)] hover:text-[var(--primary)] transition-colors" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">{phone}</a>
          </div>

          {address && (
            <div class="barber-fade-up py-4 border-b-2 border-[var(--text)]" style="animation-delay: 0.35s">
              <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] mb-2 italic">— Find us —</p>
              <p class="text-base text-[var(--text)] italic font-bold leading-relaxed">{address}</p>
            </div>
          )}
        </div>

        {/* Big bold message */}
        <div class="barber-fade-up bg-[var(--primary)] text-[var(--bg)] py-4 px-6 my-8" style="animation-delay: 0.45s">
          <p class="text-lg sm:text-xl font-bold uppercase tracking-[0.2em] italic" style="font-size: clamp(1rem, 2vw, 1.35rem);">
            ✂ Walk-Ins Welcome ✂
          </p>
        </div>

        {/* Bottom CTA */}
        <a href={`tel:${phone}`} class="barber-fade-up inline-flex items-center gap-3 bg-[var(--text)] hover:bg-[var(--text)] text-[var(--accent)] px-10 py-4 text-xs font-bold uppercase tracking-[0.5em] transition-colors mt-4" style="animation-delay: 0.5s">
          Reserve a chair →
        </a>

        {/* Signature */}
        <div class="mt-10 pt-6 border-t border-dashed border-[var(--primary)]/30">
          <p class="text-[9px] uppercase tracking-[0.5em] text-[var(--primary)]/60 italic">— Posted by management · {year} —</p>
        </div>
      </div>

      {/* Tape strips on bottom corners */}
      <div class="absolute -bottom-4 left-8 w-16 h-6 bg-[var(--accent)]/40 rotate-[8deg] shadow-sm"></div>
      <div class="absolute -bottom-4 right-8 w-16 h-6 bg-[var(--accent)]/40 rotate-[-6deg] shadow-sm"></div>
    </div>

    {showSocial && (
      <div class="barber-fade-up flex justify-center gap-3 mt-12" style="animation-delay: 0.6s">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-[var(--primary)]/40 flex items-center justify-center text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--bg)] transition-all" aria-label={link.platform}>
            <span class="text-xs font-bold uppercase">{link.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .barber-fade-up { opacity: 0; transform: translateY(15px); animation: barberFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }
  .barber-notice { transform: rotate(-0.5deg); }
  @media (prefers-reduced-motion: reduce) { .barber-fade-up { animation: none; opacity: 1; transform: none; } .barber-notice { transform: none; } }
</style>
