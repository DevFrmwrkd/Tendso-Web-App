---
/**
 * ContactN4 - Restaurant / Catering Inquiry
 * Catering-focused booking. Event-form aesthetic with type-of-event selector,
 * guest count, and call-back focused conversion.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;
const year = new Date().getFullYear();

const eventTypes = [
  { icon: '💼', label: 'Corporate' },
  { icon: '💍', label: 'Wedding' },
  { icon: '🎂', label: 'Birthday' },
  { icon: '🎓', label: 'Graduation' },
  { icon: '🏠', label: 'Family' },
  { icon: '✦', label: 'Other' },
];
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -right-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-10 items-start">
      {/* LEFT — Pitch */}
      <div>
        <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— Off-site catering —</p>
        <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 3.75rem); animation-delay: 0.1s;">We'll bring the kitchen to you</h2>
        <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.8] mb-8" style="font-size: 1.05rem; animation-delay: 0.2s;">From a 12-person dinner to a 200-guest event. Our team handles the food, setup, and service. You handle the rest.</p>

        {/* What's included */}
        <div class="resto-fade-up mb-8" style="animation-delay: 0.3s">
          <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-4">— Included in every catering —</p>
          <ul class="space-y-2.5">
            {['Custom menu consult', 'On-site chef', 'Service staff', 'Tableware & linens', 'Setup & teardown'].map((it) => (
              <li class="flex items-start gap-3 text-sm text-[var(--text-muted)] italic">
                <span class="text-[var(--primary)] mt-1 shrink-0">✓</span>
                <span>{it}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {/* RIGHT — Inquiry card */}
      <div class="resto-fade-up bg-[var(--surface)] border-2 border-[var(--text)]/15 p-8" style="animation-delay: 0.35s; box-shadow: 0 40px 80px -20px rgba(42,31,28,0.25);">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-[var(--primary)] text-xl">✉</span>
          <p class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic">— Catering inquiry —</p>
        </div>

        {/* Event type */}
        <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-3">— Type of event —</p>
        <div class="grid grid-cols-3 gap-2 mb-7">
          {eventTypes.map((t, i) => (
            <button class={`py-3 px-2 border transition-all hover:-translate-y-0.5 text-center ${i === 1 ? 'bg-[var(--primary)] text-[var(--bg)] border-[var(--primary)]' : 'border-[var(--text)]/20 hover:border-[var(--primary)] text-[var(--text)]'}`} type="button">
              <span class="text-xl block mb-1">{t.icon}</span>
              <span class="text-[9px] uppercase tracking-[0.3em] italic">{t.label}</span>
            </button>
          ))}
        </div>

        {/* Guest count placeholder */}
        <div class="mb-6 pb-6 border-b border-dashed border-[var(--text)]/20">
          <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-2">— Expected guests —</p>
          <div class="grid grid-cols-3 gap-2">
            {['10 — 25', '25 — 50', '50 — 100', '100 — 200', '200+', 'Not sure'].map((r) => (
              <button class="py-2 border border-[var(--text)]/20 hover:border-[var(--primary)] text-[var(--text)] text-xs italic transition-colors" type="button">{r}</button>
            ))}
          </div>
        </div>

        {/* Contact channels */}
        {showInfo && (
          <div class="space-y-3">
            <a href={`tel:${phone}`} class="block bg-[var(--primary)] text-[var(--bg)] py-3.5 text-center text-[11px] font-bold uppercase tracking-[0.4em] hover:-translate-y-0.5 transition-all">
              ☎ Call · {phone}
            </a>
            {email && (
              <a href={`mailto:${email}?subject=Catering%20inquiry`} class="block border-2 border-[var(--text)]/30 hover:border-[var(--text)] text-[var(--text)] py-3.5 text-center text-[11px] font-bold uppercase tracking-[0.4em] transition-all">
                ✉ Send inquiry
              </a>
            )}
          </div>
        )}

        <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic text-center mt-5">— Response within 24 hours —</p>
      </div>
    </div>

    {showInfo && address && (
      <p class="resto-fade-up text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-12" style="animation-delay: 0.6s">— Visit our restaurant · {address} —</p>
    )}

    {showSocial && (
      <div class="resto-fade-up flex justify-center gap-2 mt-6" style="animation-delay: 0.7s">
        {socialLinks.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-[var(--primary)]/40 hover:border-[var(--primary)] flex items-center justify-center text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--bg)] transition-colors" aria-label={l.platform}>
            <span class="text-xs italic">{l.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-8">— © {year} · {businessName} —</p>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
