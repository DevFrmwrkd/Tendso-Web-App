---
/**
 * ContactL2 - Automobile Shop / Service Bay Map
 * Visual map of service bays with status indicators per bay.
 * Each bay has a label, ETA, and contact line. Like a workshop dispatch screen.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const bays = [
  { id: '01', label: 'OIL & FLUIDS', status: 'OPEN', wait: '~ 20 MIN', color: 'primary' },
  { id: '02', label: 'BRAKE & TIRE', status: 'BUSY', wait: '~ 75 MIN', color: 'accent' },
  { id: '03', label: 'DIAGNOSTIC', status: 'OPEN', wait: '~ 45 MIN', color: 'primary' },
  { id: '04', label: 'HEAVY REPAIR', status: 'OPEN', wait: '~ 2 HRS', color: 'primary' },
];
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div
    class="absolute inset-0 z-0 opacity-[0.05] pointer-events-none"
    style="background-image: linear-gradient(var(--accent) 1px, transparent 1px), linear-gradient(90deg, var(--accent) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-14">
      <p class="auto-fade-up text-[10px] font-mono font-black uppercase tracking-[0.5em] text-[var(--primary)] mb-4">— BAY STATUS · DISPATCH —</p>
      <h2 class="auto-fade-up font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-4" style="font-size: clamp(2.25rem, 5.5vw, 4rem); animation-delay: 0.1s;">Find your bay</h2>
      <p class="auto-fade-up text-[var(--text-muted)] max-w-xl mx-auto" style="font-size: 1.05rem; animation-delay: 0.2s;">Drive in. We'll route you to the right bay.</p>
    </div>

    {/* Bay grid map */}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-10">
      {bays.map((b, i) => (
        <div class="auto-fade-up relative bg-[var(--surface)] border-2 border-[var(--accent)]/40 p-6 hover:border-[var(--primary)] transition-colors" style={`animation-delay: ${0.25 + i * 0.08}s`}>
          <div class="flex items-center gap-2 mb-3">
            <span class={`w-2 h-2 rounded-full ${b.status === 'OPEN' ? 'bg-[var(--primary)] animate-pulse' : 'bg-[var(--accent)]'}`}></span>
            <span class="text-[9px] font-mono font-black uppercase tracking-[0.4em] text-[var(--accent)]">BAY · {b.id}</span>
          </div>
          <p class="text-sm font-black uppercase text-[var(--text)] mb-3 tracking-tight">{b.label}</p>
          <div class="pt-3 border-t border-[var(--accent)]/30">
            <p class="text-[9px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)] mb-1">{b.status}</p>
            <p class="text-base font-black font-mono text-[var(--primary)]">{b.wait}</p>
          </div>
        </div>
      ))}
    </div>

    {/* Bottom — contact strip */}
    {showInfo && (
      <div class="auto-fade-up bg-[var(--surface)] border-2 border-[var(--primary)] grid grid-cols-1 md:grid-cols-3 gap-px bg-[var(--accent)]/30" style="animation-delay: 0.6s">
        <div class="bg-[var(--surface)] p-6">
          <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--accent)] mb-2">CALL</p>
          <a href={`tel:${phone}`} class="text-xl font-black text-[var(--text)] hover:text-[var(--primary)] transition-colors font-mono break-all">{phone}</a>
        </div>
        {email && (
          <div class="bg-[var(--surface)] p-6">
            <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--accent)] mb-2">EMAIL</p>
            <a href={`mailto:${email}`} class="text-sm font-bold text-[var(--text)] hover:text-[var(--primary)] transition-colors break-all">{email}</a>
          </div>
        )}
        {address && (
          <div class="bg-[var(--surface)] p-6">
            <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--accent)] mb-2">DRIVE IN</p>
            <p class="text-sm font-bold text-[var(--text)] leading-snug">{address}</p>
          </div>
        )}
      </div>
    )}

    {showSocial && (
      <div class="auto-fade-up flex justify-center gap-2 mt-10" style="animation-delay: 0.7s">
        {socialLinks.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-[var(--accent)]/40 hover:border-[var(--primary)] flex items-center justify-center text-[var(--accent)] hover:text-[var(--primary)] transition-colors" aria-label={l.platform}>
            <span class="text-xs font-bold uppercase">{l.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    <p class="text-center text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--text-muted)] mt-10">— © {new Date().getFullYear()} · {businessName} —</p>
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
