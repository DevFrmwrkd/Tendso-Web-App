---
/**
 * ContactM2 - Salon/Spa / Reservation Note
 * A handwritten reservation card aesthetic. Letter-style with delicate borders,
 * "kindly RSVP" feel, signature lines. Calm, intimate.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;
const year = new Date().getFullYear();
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute inset-0 z-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 30% 30%, var(--primary) 0.5px, transparent 1px), radial-gradient(circle at 70% 70%, var(--accent) 0.5px, transparent 1px); background-size: 5px 5px, 7px 7px;"></div>

  <div class="absolute top-1/4 -left-32 w-[400px] h-[400px] rounded-full opacity-20 blur-[100px]" style="background: var(--primary);"></div>
  <div class="absolute bottom-1/4 -right-32 w-[400px] h-[400px] rounded-full opacity-20 blur-[100px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6 lg:px-12">

    {/* Reservation card */}
    <div class="salon-fade-up bg-[var(--surface)]/85 backdrop-blur-sm p-10 sm:p-14 relative" style="box-shadow: 0 40px 80px -20px rgba(61,46,42,0.2);">
      {/* Decorative inner border */}
      <div class="absolute inset-3 border border-[var(--primary)]/20 pointer-events-none"></div>

      {/* Top floral motif */}
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="h-px w-16 bg-[var(--primary)]/40"></span>
        <span class="text-[var(--primary)] text-2xl">❀</span>
        <span class="h-px w-16 bg-[var(--primary)]/40"></span>
      </div>

      <div class="text-center mb-8">
        <p class="text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-3">— Kindly reserve —</p>
        <h2 class="font-light italic leading-[1.1] text-[var(--text)] mb-3" style="font-family: var(--heading-font); font-size: clamp(2rem, 5vw, 3.5rem);">A note for your visit</h2>
        <p class="text-[var(--text-muted)] italic leading-[1.7] max-w-md mx-auto" style="font-size: 1rem;">We hold space for each guest with care. A short note in advance lets us prepare your room just so.</p>
      </div>

      {/* Reservation field lines */}
      {showInfo && (
        <div class="space-y-6 mb-10">
          <div class="text-center">
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-2">— Reach us at —</p>
            <a href={`tel:${phone}`} class="text-3xl italic text-[var(--primary)] hover:text-[var(--text)] transition-colors block mb-1" style="font-family: var(--heading-font);">{phone}</a>
            <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--text-muted)] italic">Available during opening hours</p>
          </div>

          {email && (
            <div class="pt-5 border-t border-dashed border-[var(--primary)]/30 text-center">
              <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-2">— Or write to —</p>
              <a href={`mailto:${email}?subject=Reservation`} class="text-base italic text-[var(--primary)] hover:text-[var(--text)] transition-colors break-all">{email}</a>
            </div>
          )}

          {address && (
            <div class="pt-5 border-t border-dashed border-[var(--primary)]/30 text-center">
              <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-2">— Find us at —</p>
              <p class="text-base italic text-[var(--text)] leading-relaxed">{address}</p>
            </div>
          )}
        </div>
      )}

      {/* CTA */}
      <a href={`tel:${phone}`} class="block bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] py-4 text-center text-[11px] uppercase tracking-[0.45em] italic rounded-full hover:-translate-y-0.5 transition-all">
        ❀ Reserve your visit
      </a>

      {/* Signature */}
      <div class="mt-10 pt-6 border-t border-dashed border-[var(--primary)]/30 text-center">
        <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-1">— With care —</p>
        <p class="text-3xl italic text-[var(--primary)]" style="font-family: var(--heading-font);">{businessName}</p>
      </div>

      {showSocial && (
        <div class="flex justify-center gap-2 mt-6">
          {socialLinks.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full border border-[var(--primary)]/40 hover:border-[var(--primary)] flex items-center justify-center text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--bg)] transition-colors" aria-label={l.platform}>
              <span class="text-xs italic">{l.platform.charAt(0)}</span>
            </a>
          ))}
        </div>
      )}
    </div>

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-10">— © {year} · {businessName} —</p>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
