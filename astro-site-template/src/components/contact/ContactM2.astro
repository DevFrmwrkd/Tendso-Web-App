---
/**
 * ContactM2 — Salon · Maison Élite ("We'd Love to Hear from You")
 *
 * Two-column dark luxe footer: warm headline + CTA WhatsApp-style button on
 * the left, NAP block + hours on the right. Followed by a footer row with
 * brand + nav + social + legal.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const year = new Date().getFullYear();
const waDigits = (phone || "").replace(/[^0-9]/g, "");
---

<section id="contact" class="mae-contact" data-component="CONTACT">
  <div class="mae-contact-hero">
    <div class="mae-contact-grid">
      <div class="mae-contact-text">
        <p class="mae-contact-eyebrow">— Get In Touch —</p>
        <h2 class="mae-contact-headline" data-field="contact.headline">
          We'd Love to<br/>
          Hear <em>from You</em>
        </h2>
        {description && (
          <p class="mae-contact-sub" data-field="contact.description" set:html={description}></p>
        )}
        {waDigits && (
          <a class="mae-contact-wa" href={`https://wa.me/${waDigits}`} target="_blank" rel="noopener">
            <span class="mae-wa-icon" aria-hidden="true">●</span>
            Message Us on WhatsApp
          </a>
        )}
      </div>
      <div class="mae-contact-info">
        {showInfo && phone && (
          <div class="mae-contact-row">
            <div class="mae-contact-label">Phone</div>
            <a href={`tel:${phone.replace(/[^0-9+]/g, '')}`} class="mae-contact-value"><span data-field="contact.phone" set:html={phone}></span></a>
          </div>
        )}
        {showInfo && email && (
          <div class="mae-contact-row">
            <div class="mae-contact-label">Email</div>
            <a href={`mailto:${email}`} class="mae-contact-value"><span data-field="contact.email" set:html={email}></span></a>
          </div>
        )}
        {showInfo && address && (
          <div class="mae-contact-row">
            <div class="mae-contact-label">Address</div>
            <p class="mae-contact-value" data-field="contact.address" set:html={address}></p>
          </div>
        )}
        <div class="mae-contact-row">
          <div class="mae-contact-label">Hours</div>
          <p class="mae-contact-value">Mon-Fri · 9AM-8PM<br/>Sat-Sun · 10AM-6PM</p>
        </div>
      </div>
    </div>
  </div>

  <footer class="mae-footer">
    <div class="mae-footer-row">
      <h3 class="mae-footer-brand" data-field="business.name" set:html={businessName}></h3>
      {socialLinks.length > 0 && (
        <div class="mae-footer-socials">
          {socialLinks.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" class="mae-footer-social">{s.platform}</a>
          ))}
        </div>
      )}
    </div>
    <div class="mae-footer-baseline">
      © {year} <span set:html={businessName}></span>. All rights reserved.
    </div>
  </footer>
</section>

<style>
  .mae-contact {
    --mc-bg: var(--text);
    --mc-ink: color-mix(in srgb, var(--text) 0%, var(--bg));
    --mc-ink-2: color-mix(in srgb, var(--mc-ink) 80%, transparent);
    --mc-ink-3: color-mix(in srgb, var(--mc-ink) 60%, transparent);
    --mc-accent: var(--primary);
    --mc-rule: color-mix(in srgb, var(--mc-ink) 18%, transparent);
    --mc-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --mc-sans: var(--body-font, "Inter", system-ui, sans-serif);
    background: var(--mc-bg);
    color: var(--mc-ink);
    font-family: var(--mc-sans);
  }
  .mae-contact-hero {
    padding: clamp(72px, 10vw, 120px) clamp(20px, 4vw, 56px);
    max-width: 1180px;
    margin: 0 auto;
  }
  .mae-contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }
  @media (max-width: 900px) { .mae-contact-grid { grid-template-columns: 1fr; } }
  .mae-contact-eyebrow {
    font-family: var(--mc-sans);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--mc-accent);
    margin: 0 0 22px;
  }
  .mae-contact-headline {
    font-family: var(--mc-serif);
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    margin: 0;
    color: var(--mc-ink);
    font-weight: 400;
  }
  .mae-contact-headline em { font-style: italic; color: var(--mc-accent); }
  .mae-contact-sub {
    margin: 22px 0 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--mc-ink-2);
    max-width: 48ch;
  }
  .mae-contact-wa {
    margin-top: 28px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: #25D366;
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .mae-wa-icon {
    width: 8px;
    height: 8px;
    background: #fff;
    border-radius: 50%;
    display: inline-block;
  }
  .mae-contact-info {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 28px;
    border: 1px solid var(--mc-rule);
  }
  .mae-contact-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    align-items: start;
  }
  .mae-contact-label {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--mc-ink-3);
    padding-top: 2px;
  }
  .mae-contact-value {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--mc-ink);
    text-decoration: none;
  }
  .mae-contact-value:hover { color: var(--mc-accent); }
  .mae-footer {
    border-top: 1px solid var(--mc-rule);
    padding: 28px clamp(20px, 4vw, 56px);
    max-width: 1180px;
    margin: 0 auto;
  }
  .mae-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }
  .mae-footer-brand {
    font-family: var(--mc-serif);
    font-size: 22px;
    margin: 0;
    color: var(--mc-ink);
    font-weight: 500;
  }
  .mae-footer-socials { display: flex; gap: 18px; flex-wrap: wrap; }
  .mae-footer-social {
    color: var(--mc-ink-2);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .mae-footer-baseline {
    margin-top: 18px;
    font-size: 11px;
    color: var(--mc-ink-3);
  }
</style>
