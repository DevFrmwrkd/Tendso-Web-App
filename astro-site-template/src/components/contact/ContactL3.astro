---
/**
 * ContactL3 - Automobile Shop / Quote Request
 * Quote-request-card style with structured field rows. No real form, but
 * gives quote-form feeling. Strong CTA to call/email for a quote.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const fields = [
  { label: 'YOUR NAME', placeholder: '— Owner / Driver —' },
  { label: 'VEHICLE', placeholder: '— Make · Model · Year —' },
  { label: 'PROBLEM / SERVICE', placeholder: '— Brief description —' },
  { label: 'REACHABLE AT', placeholder: '— Phone or email —' },
];
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-3xl px-6 lg:px-12">

    {/* Quote card */}
    <div class="auto-fade-up bg-[var(--surface)] border-2 border-[var(--accent)]/50 relative">
      {/* Header tab */}
      <div class="absolute -top-4 left-6 bg-[var(--primary)] text-[var(--bg)] px-4 py-2 font-mono font-black text-[10px] tracking-[0.4em] shadow-md">
        QUOTE · REQUEST
      </div>

      {/* Header */}
      <div class="border-b-2 border-[var(--accent)]/50 px-7 py-7 pt-9">
        <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--accent)] mb-3">— Tell us what's going on —</p>
        <h2 class="font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-3" style="font-size: clamp(2rem, 4.5vw, 3rem);">Get a fair estimate</h2>
        <p class="text-sm text-[var(--text-muted)] leading-[1.65]">Send us the basics. We respond within the same business day with an honest range.</p>
      </div>

      {/* Field rows */}
      <div class="p-7 space-y-5">
        {fields.map((f) => (
          <div>
            <p class="text-[9px] font-mono font-black uppercase tracking-[0.4em] text-[var(--primary)] mb-1.5">— {f.label} —</p>
            <div class="border-b-2 border-[var(--accent)]/40 pb-1.5 text-sm italic text-[var(--text-muted)]">
              {f.placeholder}
            </div>
          </div>
        ))}
      </div>

      {/* CTA + contact channels */}
      {showInfo && (
        <div class="bg-[var(--bg)]/30 border-t-2 border-[var(--accent)]/40 p-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
            <a href={`tel:${phone}`} class="block bg-[var(--primary)] text-[var(--bg)] text-center py-4 text-[11px] font-black font-mono uppercase tracking-[0.4em] hover:-translate-y-0.5 transition-all">
              ☎ CALL {phone}
            </a>
            {email && (
              <a href={`mailto:${email}?subject=Quote%20request`} class="block border-2 border-[var(--accent)]/50 hover:border-[var(--primary)] text-[var(--text)] text-center py-4 text-[11px] font-black font-mono uppercase tracking-[0.4em] transition-all">
                ✉ EMAIL US
              </a>
            )}
          </div>
          {address && (
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)] text-center">📍 {address}</p>
          )}
        </div>
      )}

      {/* Footer stamp */}
      <div class="border-t-2 border-[var(--accent)]/40 px-7 py-3 flex items-center justify-between text-[9px] font-mono uppercase tracking-[0.35em] text-[var(--text-muted)]">
        <span>Q-{new Date().getFullYear()}-{String(Math.floor(Math.random() * 9000 + 1000))}</span>
        <span class="hidden sm:inline">FREE · NO OBLIGATION</span>
        <span>// {businessName.toUpperCase().slice(0, 12)}</span>
      </div>
    </div>

    {showSocial && (
      <div class="auto-fade-up flex justify-center gap-2 mt-10" style="animation-delay: 0.5s">
        {socialLinks.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-[var(--accent)]/40 hover:border-[var(--primary)] flex items-center justify-center text-[var(--accent)] hover:text-[var(--primary)] transition-colors" aria-label={l.platform}>
            <span class="text-xs font-bold uppercase">{l.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
