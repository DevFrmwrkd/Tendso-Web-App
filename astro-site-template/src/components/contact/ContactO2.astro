---
/**
 * ContactO2 - Clinic / Patient Portal
 * Portal access focus. Login/sign-up CTAs for patient portal, app icons,
 * "manage everything online" framing.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;
const year = new Date().getFullYear();

const portalFeatures = [
  { icon: '📅', name: 'Appointments', body: 'Book, reschedule, cancel in seconds.' },
  { icon: '🧪', name: 'Lab results', body: 'View results as soon as they\'re ready.' },
  { icon: '💊', name: 'Prescriptions', body: 'Request refills, see medication history.' },
  { icon: '💬', name: 'Messages', body: 'Talk to your provider between visits.' },
];
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -right-32 w-[400px] h-[400px] rounded-full opacity-[0.08] blur-[100px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-12 max-w-3xl mx-auto">
      <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— Online care · 24 / 7 —</p>
      <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">Patient portal access</h2>
      <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">Manage appointments, view results, message your provider — anywhere, anytime.</p>
    </div>

    {/* Portal access card */}
    <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl p-8 lg:p-10 border border-[var(--text)]/10 mb-10" style="animation-delay: 0.3s">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <a href="#portal-login" class="group bg-[var(--primary)] text-[var(--bg)] rounded-2xl p-6 flex items-center gap-4 hover:-translate-y-0.5 transition-all hover:shadow-xl">
          <div class="w-12 h-12 rounded-full bg-[var(--bg)]/15 flex items-center justify-center text-xl shrink-0">👤</div>
          <div class="flex-1">
            <p class="text-[10px] font-bold uppercase tracking-wider opacity-80 mb-0.5">Returning patient</p>
            <p class="text-base font-bold">Sign in to portal</p>
          </div>
          <span class="text-xl group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a href="#portal-signup" class="group bg-[var(--bg)] border-2 border-[var(--primary)]/20 hover:border-[var(--primary)] rounded-2xl p-6 flex items-center gap-4 hover:-translate-y-0.5 transition-all">
          <div class="w-12 h-12 rounded-full bg-[var(--primary)]/10 flex items-center justify-center text-xl shrink-0">✦</div>
          <div class="flex-1">
            <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--accent)] mb-0.5">New patient</p>
            <p class="text-base font-bold text-[var(--text)]">Create your account</p>
          </div>
          <span class="text-xl text-[var(--primary)] group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      {/* Features grid */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        {portalFeatures.map((f) => (
          <div class="bg-[var(--bg)] rounded-2xl p-4 text-center border border-[var(--text)]/5">
            <div class="text-2xl mb-2">{f.icon}</div>
            <p class="text-sm font-bold text-[var(--text)] mb-1">{f.name}</p>
            <p class="text-[10px] text-[var(--text-muted)] leading-tight">{f.body}</p>
          </div>
        ))}
      </div>

      {/* App download */}
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-6 border-t border-[var(--text)]/10">
        <p class="text-xs text-[var(--text-muted)] font-medium">Or get it on:</p>
        <div class="flex gap-2">
          <button class="bg-[var(--text)] text-[var(--bg)] px-4 py-2 rounded-lg flex items-center gap-2 text-xs font-semibold hover:opacity-90 transition-opacity" type="button">
            <span>🍎</span> App Store
          </button>
          <button class="bg-[var(--text)] text-[var(--bg)] px-4 py-2 rounded-lg flex items-center gap-2 text-xs font-semibold hover:opacity-90 transition-opacity" type="button">
            <span>▶</span> Google Play
          </button>
        </div>
      </div>
    </div>

    {/* Direct line fallback */}
    {showInfo && (
      <div class="clinic-fade-up grid grid-cols-1 md:grid-cols-3 gap-3 mb-8" style="animation-delay: 0.5s">
        <a href={`tel:${phone}`} class="bg-[var(--bg)] border border-[var(--text)]/10 hover:border-[var(--primary)] rounded-2xl p-5 text-center transition-colors">
          <p class="text-[10px] uppercase tracking-wider text-[var(--accent)] font-bold mb-2">Call front desk</p>
          <p class="text-lg font-bold text-[var(--text)]">{phone}</p>
        </a>
        {email && (
          <a href={`mailto:${email}`} class="bg-[var(--bg)] border border-[var(--text)]/10 hover:border-[var(--primary)] rounded-2xl p-5 text-center transition-colors">
            <p class="text-[10px] uppercase tracking-wider text-[var(--accent)] font-bold mb-2">Email general</p>
            <p class="text-sm font-semibold text-[var(--text)] break-all">{email}</p>
          </a>
        )}
        {address && (
          <div class="bg-[var(--bg)] border border-[var(--text)]/10 rounded-2xl p-5 text-center">
            <p class="text-[10px] uppercase tracking-wider text-[var(--accent)] font-bold mb-2">Visit clinic</p>
            <p class="text-sm font-semibold text-[var(--text)]">{address}</p>
          </div>
        )}
      </div>
    )}

    {showSocial && (
      <div class="clinic-fade-up flex justify-center gap-2 mb-6" style="animation-delay: 0.6s">
        {socialLinks.map((l) => (
          <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-[var(--text)]/15 hover:border-[var(--primary)] flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--primary)] transition-colors" aria-label={l.platform}>
            <span class="text-xs font-semibold">{l.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    <p class="text-center text-xs text-[var(--text-muted)]">© {year} · {businessName} · HIPAA-compliant portal</p>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
