---
/**
 * ContactO - Clinic / Book an Appointment
 * Clean white with medical blue, appointment-focused layout.
 * Phone-prominent, hours grid with today highlighted, "Most insurance accepted" reassurance.
 * Vibe: clear, professional, reassuring.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description,
  socialLinks = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false && !!description;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

const hours = [
  { day: 'Monday', time: '8:00 – 18:00', closed: false },
  { day: 'Tuesday', time: '8:00 – 18:00', closed: false },
  { day: 'Wednesday', time: '8:00 – 18:00', closed: false },
  { day: 'Thursday', time: '8:00 – 20:00', closed: false },
  { day: 'Friday', time: '8:00 – 18:00', closed: false },
  { day: 'Saturday', time: '9:00 – 14:00', closed: false },
  { day: 'Sunday', time: 'Emergency only', closed: true },
];

// "Today" highlight — get current day index (0=Sun, 1=Mon, etc.) and map to our 0-indexed Mon-start array
const dayIndex = new Date().getDay();
const todayIndex = dayIndex === 0 ? 6 : dayIndex - 1;
---

<section
  id="contact"
  class="relative w-full bg-white py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Subtle blue gradient */}
  <div class="absolute top-0 left-1/4 w-1/2 h-1/3 bg-gradient-to-b from-[#e8f0fa]/40 to-transparent pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    {/* Top status */}
    <div class="clinic-fade-up mb-10 flex items-center justify-center gap-3">
      <span class="relative flex w-2 h-2">
        <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--accent)] opacity-60 animate-ping"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--accent)]"></span>
      </span>
      <span class="text-[11px] font-bold uppercase tracking-[0.3em] text-[var(--accent)]">Accepting new patients</span>
    </div>

    {/* Header */}
    {showHeadline && (
      <div class="text-center mb-14">
        <div class="clinic-fade-up inline-flex items-center gap-2 mb-6" style="animation-delay: 0.1s">
          <span class="w-8 h-px bg-[var(--primary)]"></span>
          <span class="text-[10px] font-bold uppercase tracking-[0.35em] text-[var(--primary)]">— Book a visit —</span>
          <span class="w-8 h-px bg-[var(--primary)]"></span>
        </div>
        <h2
          class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5"
          style="font-size: clamp(2.5rem, 5vw, 4rem); animation-delay: 0.2s;"
        >
          Schedule your appointment
        </h2>
        {showDescription && (
          <p
            class="clinic-fade-up max-w-xl mx-auto text-[var(--text-muted)] leading-relaxed"
            style="font-size: 1.1rem; animation-delay: 0.3s;"
          >
            {description}
          </p>
        )}
      </div>
    )}

    {/* Booking card — phone + email + address */}
    <div class="clinic-fade-up bg-[var(--primary)] text-white rounded-3xl p-8 md:p-12 mb-8 relative overflow-hidden" style="animation-delay: 0.4s">
      {/* Decorative pulse line */}
      <div class="absolute top-0 inset-x-0 h-1 overflow-hidden">
        <svg class="clinic-ekg-bar w-full h-full" viewBox="0 0 600 4" preserveAspectRatio="none">
          <path d="M0 2 L100 2 L120 0 L140 4 L160 2 L260 2 L280 0 L300 4 L320 2 L420 2 L440 0 L460 4 L480 2 L600 2"
                stroke="var(--accent)" stroke-width="2" fill="none"/>
        </svg>
      </div>

      <div class="text-center">
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-[#a8c8ed] mb-4">— Call to schedule —</p>
        <a
          href={`tel:${phone}`}
          class="block text-3xl md:text-5xl lg:text-6xl font-bold text-white hover:text-[#a8c8ed] transition-colors leading-tight"
        >
          {phone}
        </a>
        <p class="mt-3 text-sm text-[#a8c8ed]">Or send us a message — we'll respond within an hour</p>

        <div class="my-8 mx-auto w-24 h-px bg-[#a8c8ed]/40"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
          {email && (
            <a
              href={`mailto:${email}`}
              class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 rounded-xl px-5 py-3 text-sm transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              <span class="break-all">{email}</span>
            </a>
          )}
          <a
            href={`tel:${phone}`}
            class="inline-flex items-center justify-center gap-2 bg-white text-[var(--primary)] hover:bg-[#a8c8ed] px-5 py-3 rounded-xl text-sm font-bold transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Book appointment
          </a>
        </div>
      </div>
    </div>

    {/* Hours + Address grid */}
    {showInfo && (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 lg:gap-6 mb-12">

        {/* Hours card */}
        <div class="clinic-fade-up bg-white rounded-3xl p-7 lg:p-9 border border-[#e5e7eb]" style="animation-delay: 0.5s">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-[#e8f0fa] flex items-center justify-center text-[var(--primary)]">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-[var(--text)]">Clinic hours</h3>
              <p class="text-xs text-[var(--text-muted)]">All times local</p>
            </div>
          </div>

          <ul class="space-y-1">
            {hours.map((h, i) => (
              <li class={`flex items-center justify-between py-2 px-3 rounded-lg transition-colors ${i === todayIndex ? 'bg-[#e8f0fa] border border-[var(--primary)]/20' : ''}`}>
                <div class="flex items-center gap-3 flex-1">
                  <span class={`text-sm font-medium w-24 ${h.closed ? 'text-[var(--text-muted)]' : 'text-[var(--text)]'} ${i === todayIndex ? 'text-[var(--primary)] font-bold' : ''}`}>
                    {h.day}
                    {i === todayIndex && <span class="ml-2 text-[9px] font-bold uppercase tracking-[0.2em] text-[var(--primary)]">· Today</span>}
                  </span>
                </div>
                <span class={`text-sm font-semibold ${h.closed ? 'text-[var(--text-muted)]' : 'text-[var(--text)]'} ${i === todayIndex ? 'text-[var(--primary)]' : ''}`}>
                  {h.time}
                </span>
              </li>
            ))}
          </ul>
        </div>

        {/* Address card */}
        {address && (
          <div class="clinic-fade-up bg-white rounded-3xl p-7 lg:p-9 border border-[#e5e7eb] flex flex-col" style="animation-delay: 0.6s">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-[var(--accent)]/10 flex items-center justify-center text-[var(--accent)]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <h3 class="text-base font-bold text-[var(--text)]">Location</h3>
                <p class="text-xs text-[var(--text-muted)]">Free parking available</p>
              </div>
            </div>

            <p class="text-base text-[var(--text)] leading-relaxed flex-1">{address}</p>

            <div class="mt-6 pt-6 border-t border-[#e5e7eb] grid grid-cols-3 gap-2 text-center">
              <div class="flex flex-col items-center gap-1 text-xs text-[var(--text-muted)]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
                <span class="font-medium">Insurance</span>
              </div>
              <div class="flex flex-col items-center gap-1 text-xs text-[var(--text-muted)]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <path d="M12 8v8M8 12h8"/>
                </svg>
                <span class="font-medium">Wheelchair</span>
              </div>
              <div class="flex flex-col items-center gap-1 text-xs text-[var(--text-muted)]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 12h6M12 9v6"/>
                  <circle cx="12" cy="12" r="10"/>
                </svg>
                <span class="font-medium">On-site lab</span>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    {/* Emergency notice */}
    <div class="clinic-fade-up bg-[#fef3c7] border border-[#fcd34d] rounded-2xl p-5 lg:p-6 flex items-start gap-4 mb-12" style="animation-delay: 0.7s">
      <div class="w-10 h-10 rounded-xl bg-[#f59e0b] flex items-center justify-center text-white shrink-0">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 9v2m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold text-[var(--text)] mb-1">In case of emergency</p>
        <p class="text-sm text-[var(--text)]/85 leading-relaxed">
          For life-threatening emergencies, please call{' '}
          <a href="tel:911" class="font-bold text-[var(--primary)] hover:underline">911</a>
          {' '}or go to your nearest emergency room. After-hours patients should call our main line for the on-call provider.
        </p>
      </div>
    </div>

    {/* Social */}
    {showSocial && (
      <div class="clinic-fade-up flex justify-center gap-3 mb-12" style="animation-delay: 0.8s">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 rounded-xl border border-[#e5e7eb] flex items-center justify-center text-[var(--text-muted)] hover:bg-[var(--primary)] hover:text-white hover:border-[var(--primary)] transition-all"
            aria-label={link.platform}
          >
            <span class="text-xs font-bold uppercase">{link.platform.charAt(0)}</span>
          </a>
        ))}
      </div>
    )}

    {/* Footer signature */}
    <div class="clinic-fade-up text-center pt-8 border-t border-[#e5e7eb]" style="animation-delay: 0.9s">
      <p class="text-base font-bold text-[var(--text)] mb-1">{businessName}</p>
      <p class="text-xs text-[var(--text-muted)] uppercase tracking-wide">© {year} · Licensed medical practice</p>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }

  .clinic-ekg-bar path {
    stroke-dasharray: 100 1000;
    stroke-dashoffset: 1000;
    animation: clinicEkgBar 3s linear infinite;
  }
  @keyframes clinicEkgBar { to { stroke-dashoffset: 0; } }

  @media (prefers-reduced-motion: reduce) {
    .clinic-fade-up { animation-duration: 0.01ms; opacity: 1; transform: none; }
    .clinic-ekg-bar path { animation: none; stroke-dasharray: none; }
  }
</style>
