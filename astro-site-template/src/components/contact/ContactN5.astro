---
/**
 * ContactN5 - Restaurant / Private Events
 * Private dining / event space buyout focus. Luxe dark panel with venue photo,
 * "the whole space, just for you" pitch, exclusivity feel.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const venuePhoto = photos[0] || '';
const year = new Date().getFullYear();
---

<section id="contact" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Private dining card */}
    <div class="resto-fade-up bg-[var(--text)] rounded-sm overflow-hidden relative" style="box-shadow: 0 50px 100px -25px rgba(42,31,28,0.6);">
      {/* Inner border */}
      <div class="absolute inset-4 border border-[var(--primary)]/30 pointer-events-none"></div>

      <div class="grid grid-cols-1 lg:grid-cols-2">
        {/* LEFT — Venue */}
        <div class="relative aspect-[4/5] lg:aspect-auto bg-[var(--text)] overflow-hidden">
          {venuePhoto ? (
            <img src={venuePhoto} alt="Private dining" class="absolute inset-0 w-full h-full object-cover" style="filter: brightness(0.7) contrast(1.1);" />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">🕯</div>
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/80 via-transparent to-transparent"></div>

          <div class="absolute bottom-10 left-10 right-10">
            <p class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic mb-3">— Private dining —</p>
            <p class="text-3xl italic text-[var(--bg)]" style="font-family: var(--heading-font);">{businessName}</p>
            <p class="text-sm italic text-[var(--bg)]/70 mt-2">Capacity · up to 60 seated · 100 standing</p>
          </div>
        </div>

        {/* RIGHT — Details */}
        <div class="p-10 lg:p-14 flex flex-col justify-center">
          <p class="text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic mb-5">— By invitation · by reservation —</p>
          <h2 class="font-bold italic leading-[1.05] text-[var(--bg)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2rem, 4.5vw, 3.25rem);">The whole room, just for you</h2>
          <p class="text-[var(--bg)]/75 italic leading-[1.85] mb-10" style="font-size: 1.05rem;">Full restaurant buyouts for private dinners, milestone celebrations, intimate weddings, and corporate events. Custom menus. Dedicated staff. A space made entirely yours for the evening.</p>

          {/* Inclusion list */}
          <div class="mb-10">
            <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-4">— Included —</p>
            <ul class="space-y-2.5">
              {['Exclusive use of the dining room', 'Custom menu by the chef', 'Dedicated service team', 'Sommelier consultation', 'Audio & lighting control'].map((it) => (
                <li class="flex items-start gap-3 text-sm text-[var(--bg)]/85 italic">
                  <span class="text-[var(--primary)] mt-1 shrink-0">✦</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* Channels */}
          {showInfo && (
            <div class="space-y-4 mb-8 pb-8 border-b border-[var(--primary)]/30">
              <a href={`tel:${phone}`} class="block group">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)]/70 italic mb-1">— Events line —</p>
                    <p class="text-xl italic text-[var(--bg)] group-hover:text-[var(--primary)] transition-colors" style="font-family: var(--heading-font);">{phone}</p>
                  </div>
                  <span class="text-[var(--primary)] text-2xl group-hover:translate-x-1 transition-transform">→</span>
                </div>
              </a>

              {email && (
                <a href={`mailto:${email}?subject=Private%20event%20inquiry`} class="block group">
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)]/70 italic mb-1">— Private inquiries —</p>
                      <p class="text-sm italic text-[var(--bg)] group-hover:text-[var(--primary)] transition-colors break-all">{email}</p>
                    </div>
                    <span class="text-[var(--primary)] text-2xl group-hover:translate-x-1 transition-transform">→</span>
                  </div>
                </a>
              )}
            </div>
          )}

          <a href={`mailto:${email || ''}?subject=Private%20event%20inquiry`} class="block bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--text)] py-4 text-center text-[11px] font-bold uppercase tracking-[0.5em] hover:-translate-y-0.5 transition-all">
            ✦ Request private event
          </a>

          {showSocial && (
            <div class="flex gap-2 mt-6">
              {socialLinks.map((l) => (
                <a href={l.url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-[var(--primary)]/40 hover:border-[var(--primary)] flex items-center justify-center text-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--text)] transition-colors" aria-label={l.platform}>
                  <span class="text-xs italic">{l.platform.charAt(0)}</span>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>

    <p class="text-center text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mt-10">— © {year} · {businessName} · Discretion assured —</p>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
