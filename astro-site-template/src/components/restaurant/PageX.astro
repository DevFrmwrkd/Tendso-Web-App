---
/**
 * restaurant / PageX — Ember (Cinematic). Charcoal-black room lit by amber
 * ember light — Marcellus display + Mulish body. Reuses the restaurant U-letter
 * shared sections; only the hero (HeroX) is bespoke to this cinematic variant.
 * All palette/font tokens are scoped to html[data-page="X"] so they never bleed
 * into sister restaurant wrappers.
 */
import HeaderU from './header/HeaderU.astro';
import HeroX from './hero/HeroX.astro';
import TrustU from './trust/TrustU.astro';
import AboutU from './about/AboutU.astro';
import ServicesU from './services/ServicesU.astro';
import WhyU from './why/WhyU.astro';
import HowU from './how/HowU.astro';
import TestimonialsU from './testimonials/TestimonialsU.astro';
import GalleryU from './gallery/GalleryU.astro';
import FaqU from './faq/FaqU.astro';
import AreaU from './area/AreaU.astro';
import CredentialsU from './credentials/CredentialsU.astro';
import LocationU from './location/LocationU.astro';
import CtaBandU from './ctaBand/CtaBandU.astro';
import FooterU from './footer/FooterU.astro';
import RestaurantSpine from './RestaurantSpine.astro';
import { resolveTheme, buildFontHref, buildOverrideCss } from '../../lib/genericThemeOverrides';

interface Props { siteData: any; }
const { siteData } = Astro.props;
const layout = siteData.layout ?? {};
const content = siteData.content ?? {};
const visibility = siteData.visibility ?? {};
const title = layout.businessName
  ? `${layout.businessName}${layout.tagline ? ' — ' + layout.tagline : ''}`
  : 'Welcome';
const { scheme: __themeScheme, pairing: __themePairing } = resolveTheme(layout, (content as any).business_type, { lockVariant: true });
const __overrideCss = buildOverrideCss(__themeScheme, __themePairing);
const __fontHref = buildFontHref(__themePairing);
---
<!DOCTYPE html>
<html lang="en" data-page="X">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {content.description && <meta name="description" content={content.description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  {layout.favicon && <link rel="icon" href={layout.favicon} />}
  {(layout.ogImage || layout.favicon) && <meta property="og:image" content={layout.ogImage || layout.favicon} />}
  <style is:global>
    html[data-page="X"] {
      --paper: #ECE4D5; --paper-2: #A89C88;
      --ink: #0D0B09; --ink-2: #15110D; --ink-3: #1D1813;
      --paper-rgb: 236,228,213; --ink-rgb: 13,11,9;
      --accent: #E0913C; --accent-2: #F2B45C; --accent-rgb: 224,145,60;
      --line: rgba(236,228,213, .12);
      --muted: rgba(236,228,213, .62); --muted-light: rgba(236,228,213, .68);
      --serif: "Marcellus", Georgia, serif;
      --display: "Marcellus", Georgia, serif;
      --sans: "Mulish", system-ui, sans-serif;
      --pad: clamp(20px, 5vw, 72px); --maxw: 1240px;
      --on-accent: #1a1106; --on-ink: #ECE4D5; --on-paper: #0D0B09;
    }
  </style>
  <RestaurantSpine />
  {__fontHref && <link href={__fontHref} rel="stylesheet" />}
  <style is:global set:html={__overrideCss}></style>
</head>
<body>
  <HeaderU layout={layout} content={content} />
  <main id="top">
    {visibility.heroSection !== false && <HeroX content={content} layout={layout} />}
    {visibility.trustBlock !== false && <TrustU content={content} />}
    {visibility.aboutSection !== false && <AboutU content={content} />}
    {visibility.servicesSection !== false && <ServicesU content={content} />}
    {visibility.whyUsBlock !== false && <WhyU content={content} />}
    {visibility.howItWorksBlock !== false && <HowU content={content} />}
    {visibility.testimonialsBlock !== false && <TestimonialsU content={content} />}
    {visibility.gallerySection !== false && <GalleryU content={content} layout={layout} />}
    {visibility.faqBlock !== false && <FaqU content={content} />}
    {visibility.serviceAreaBlock !== false && <AreaU content={content} />}
    {visibility.credentialsBlock !== false && <CredentialsU content={content} />}
    {visibility.locationBlock !== false && <LocationU content={content} layout={layout} />}
  </main>
  {visibility.ctaBandBlock !== false && <CtaBandU content={content} layout={layout} />}
  <FooterU layout={layout} content={content} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !document.hidden) {
        var io = new IntersectionObserver(function (es) { es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }); }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      } else { document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in'); }); }
      var hdr = document.querySelector('header.nav');
      if (hdr) { var onScroll = function () { if (window.scrollY > 16) hdr.classList.add('scrolled'); else hdr.classList.remove('scrolled'); }; window.addEventListener('scroll', onScroll, { passive: true }); onScroll(); }
      window.__restaurantInitMap = function (lat, lng, label) {
        if (!window.L) return; var el = document.getElementById('map'); if (!el) return; el.innerHTML = '';
        var map = L.map('map', { scrollWheelZoom: false }).setView([lat, lng], 15);
        L.tileLayer('https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19, subdomains: 'abcd' }).addTo(map);
        var icon = L.divIcon({ className: '', html: '<div style="width:16px;height:16px;border-radius:50%;background:#E0913C;box-shadow:0 0 0 4px rgba(224,145,60,.3),0 0 16px rgba(224,145,60,.8);"></div>', iconSize: [16, 16], iconAnchor: [8, 8] });
        L.marker([lat, lng], { icon: icon }).addTo(map).bindPopup('<b>' + label + '</b>');
      };
    })();
  </script>
</body>
</html>
