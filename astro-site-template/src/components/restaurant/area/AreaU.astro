---
interface Props { content: any; }
const { content } = Astro.props;
const area = content.area || {};
const tag = area.tag || '';
const headline = area.headline || '';
const sub = area.sub || '';
const places: string[] = Array.isArray(area.places) ? area.places : (Array.isArray(area.items) ? area.items : []);
---
{places.length > 0 && (
  <section class="area-sect">
    <div class="wrap">
      <div class="area-copy reveal">
        {tag && <span class="kicker" data-field="area.tag">{tag}</span>}
        {headline && <h2 data-field="area.headline" set:html={headline}></h2>}
        {sub && <p class="area-sub" data-field="area.sub">{sub}</p>}
        <div class="chips">
          {places.map((place, i) => (
            <span class="chip" data-field={`area.places.${i}`}>{place}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
)}
<style>
  .area-sect { background: var(--paper-2); padding-block: clamp(78px, 10vw, 160px); }
  .area-copy { max-width: 760px; }
  .area-copy h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(30px, 4vw, 48px); margin: 12px 0 14px; }
  .area-copy h2 :global(em) { font-style: italic; color: var(--accent); }
  .area-sub { color: var(--stone, var(--muted)); margin: 0 0 4px; }
  .chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
  .chip { border: 1px solid var(--line); padding: 9px 16px; font-family: var(--sans); font-size: 13px; color: var(--stone, var(--muted)); }
</style>
