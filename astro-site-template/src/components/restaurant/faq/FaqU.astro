---
interface Props { content: any; }
const { content } = Astro.props;
const faq = content.faq || {};
const tag = faq.tag || '';
const headline = faq.headline || '';
type Item = { q: string; a: string };
const items: Item[] = Array.isArray(faq.items) ? faq.items : (Array.isArray(faq) ? faq : []);
---
{items.length > 0 && (
  <section class="faq-sect">
    <div class="wrap">
      <div class="faq-head reveal">
        {tag && <span class="kicker" data-field="faq.tag">{tag}</span>}
        {headline && <h2 data-field="faq.headline" set:html={headline}></h2>}
      </div>
      <div class="faq-wrap reveal">
        {items.map((item, i) => (
          <details class="faq">
            <summary>
              <span class="faq-q" data-field={`faq.items.${i}.q`}>{item.q}</span>
              <span class="pm" aria-hidden="true">+</span>
            </summary>
            <div class="ans" data-field={`faq.items.${i}.a`} set:html={item.a}></div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
<style>
  .faq-sect { padding-block: clamp(78px, 10vw, 160px); }
  .faq-head { text-align: center; margin-bottom: 56px; display: block; }
  .faq-head h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(34px, 5vw, 64px); margin-top: 14px; }
  .faq-head h2 :global(em) { font-style: italic; color: var(--accent); }
  .faq-wrap { max-width: 840px; margin: 0 auto; }
  details.faq { border-bottom: 1px solid var(--line); }
  details.faq summary {
    list-style: none; cursor: pointer; padding: 26px 0;
    display: flex; justify-content: space-between; gap: 20px;
    font-family: var(--serif); font-weight: 400; font-size: clamp(21px, 2.4vw, 28px);
  }
  details.faq summary::-webkit-details-marker { display: none; }
  details.faq summary .pm { color: var(--accent); font-size: 26px; line-height: 1; transition: transform .3s; }
  details.faq[open] summary .pm { transform: rotate(45deg); }
  details.faq .ans { padding: 0 0 28px; color: var(--stone, var(--muted)); max-width: 66ch; }
</style>
