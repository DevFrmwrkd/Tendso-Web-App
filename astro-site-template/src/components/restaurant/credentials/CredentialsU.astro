---
interface Props { content: any; }
const { content } = Astro.props;
const cred = content.credentials || {};
const tag = cred.tag || '';
const headline = cred.headline || '';
type Item = { title: string; desc?: string };
const items: Item[] = Array.isArray(cred.items) ? cred.items : [];
---
{items.length > 0 && (
  <section class="cred-sect">
    <div class="wrap">
      <div class="cred-copy reveal">
        {tag && <span class="kicker" data-field="credentials.tag">{tag}</span>}
        {headline && <h2 data-field="credentials.headline" set:html={headline}></h2>}
        <ul class="creds">
          {items.map((item, i) => (
            <li>
              <svg class="ck" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
              <div>
                <span class="ct" data-field={`credentials.items.${i}.title`}>{item.title}</span>
                {item.desc && <span class="cdsc" data-field={`credentials.items.${i}.desc`}> — {item.desc}</span>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
)}
<style>
  .cred-sect { background: var(--paper-2); padding-block: clamp(78px, 10vw, 160px); }
  .cred-copy { max-width: 760px; }
  .cred-copy h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(30px, 4vw, 48px); margin: 12px 0 14px; }
  .cred-copy h2 :global(em) { font-style: italic; color: var(--accent); }
  .creds { list-style: none; padding: 0; margin: 20px 0 0; }
  .creds li { display: flex; gap: 14px; align-items: center; padding: 16px 0; border-bottom: 1px solid var(--line); font-size: 16px; }
  .creds li .ck { color: var(--olive-2); flex: none; }
  .creds .ct { color: var(--ink); }
  .creds .cdsc { color: var(--stone, var(--muted)); }
</style>
