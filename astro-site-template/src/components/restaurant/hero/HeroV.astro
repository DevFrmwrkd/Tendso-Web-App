---
/**
 * restaurant / HeroV — Atelier (Minimal). Centered editorial hero: eyebrow,
 * oversized serif headline with an italic accent word, centered subcopy, a
 * pair of CTAs, a hairline 4-cell stat strip, then a full-width hero photo.
 *
 * Reads the shared restaurant content.hero shape (headlineLines[], kicker, sub,
 * cta1{text,href}, cta2{text,href}, image, rating, tag) so content stays
 * portable when admin swaps to another restaurant letter. The stat strip is
 * driven by an optional hero.stats[]{value,label}; when absent it falls back to
 * hero.rating + hero.tag so swapping never leaves the strip empty.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const hero = content.hero || {};
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';
const kicker = hero.kicker || hero.locality || '';
const headlineLines: string[] = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0
  ? hero.headlineLines
  : (hero.headline ? [hero.headline] : []);
const sub = hero.sub || '';
const cta1Text = hero.cta1?.text || '';
const cta1Href = hero.cta1?.href || '#visit';
const cta2Text = hero.cta2?.text || '';
const cta2Href = hero.cta2?.href || '#services';
const rating = hero.rating || '';
const tag = hero.tag || '';

// Optional hairline stat strip. Prefer explicit hero.stats[], otherwise
// synthesize a couple of cells from the portable fields so it never renders bare.
const statsRaw: any[] = Array.isArray(hero.stats) ? hero.stats : [];
const stats = statsRaw
  .map((s: any) => ({ value: s?.value ?? s?.num ?? '', label: s?.label ?? '' }))
  .filter((s: any) => s.value || s.label);
const fallbackStats = [
  rating ? { value: rating, label: 'Guest rating' } : null,
  tag ? { value: tag, label: 'Availability' } : null,
].filter(Boolean) as { value: string; label: string }[];
const stripCells = stats.length ? stats : fallbackStats;
---
<section class="hero-v wrap" id="top">
  <div class="hero-in reveal">
    {kicker && <p class="eyebrow" data-field="hero.kicker">{kicker}</p>}
    {headlineLines.length > 0 && (
      <h1>
        {headlineLines.map((line: string, i: number) => (
          <span class="ln"><span data-field={`hero.headlineLines.${i}`} set:html={line}></span></span>
        ))}
      </h1>
    )}
    {sub && <p class="hero-sub" data-field="hero.sub">{sub}</p>}
    <div class="hero-cta">
      {cta1Text && <a class="btn btn--fill" href={cta1Href} data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>}
      {cta2Text && <a class="link-u" href={cta2Href} data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>}
    </div>
    {stripCells.length > 0 && (
      <div class="hero-strip">
        {stripCells.map((c, i) => (
          <div>
            <b data-field={stats.length ? `hero.stats.${i}.value` : (i === 0 ? 'hero.rating' : 'hero.tag')}>{c.value}</b>
            {c.label && <span data-field={stats.length ? `hero.stats.${i}.label` : undefined}>{c.label}</span>}
          </div>
        ))}
      </div>
    )}
  </div>
  <div class="hero-img reveal">
    {heroImage
      ? <div class="bg-img" data-image-field="hero.image" style={`background-image:url('${heroImage}');`}></div>
      : <div class="bg-img placeholder" data-image-field="hero.image"><span>Hero photo — hearth / plated dish</span></div>}
  </div>
</section>
<style>
  .hero-v {
    padding-block: clamp(70px, 12vw, 150px) clamp(40px, 7vw, 90px);
    text-align: center;
  }
  .hero-in { display: block; }
  .eyebrow {
    font-family: var(--sans); font-weight: 500; font-size: 11px;
    letter-spacing: .42em; text-transform: uppercase;
    color: var(--accent); margin: 0 0 30px;
  }
  .hero-v h1 {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(52px, 11vw, 150px); line-height: 1.03;
    letter-spacing: -.01em; margin: 0;
  }
  .hero-v h1 .ln { display: block; }
  .hero-v h1 :global(em) { font-style: italic; color: var(--accent-deep, var(--accent)); }
  .hero-sub {
    max-width: 50ch; margin: 34px auto 40px;
    color: var(--muted); font-size: clamp(16px, 1.9vw, 19px); line-height: 1.7;
  }
  .hero-cta {
    display: flex; gap: 20px; justify-content: center;
    align-items: center; flex-wrap: wrap;
  }
  .hero-strip {
    display: flex; justify-content: center; flex-wrap: wrap;
    margin-top: 70px;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
  }
  .hero-strip > div {
    padding: 22px clamp(18px, 4vw, 48px);
    border-left: 1px solid var(--line);
    font-size: 12px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--muted);
  }
  .hero-strip > div:first-child { border-left: 0; }
  .hero-strip b {
    display: block; font-family: var(--serif); font-weight: 400;
    font-size: 32px; letter-spacing: 0; text-transform: none;
    color: var(--ink); margin-bottom: 4px;
  }
  .hero-img { margin-top: 64px; }
  .hero-img .bg-img {
    display: block; width: 100%;
    height: clamp(300px, 46vw, 560px);
    background-size: cover; background-position: center;
    background-color: var(--paper-2);
  }
  .hero-img .placeholder {
    display: flex; align-items: center; justify-content: center;
    background: repeating-linear-gradient(45deg, var(--paper-2) 0 14px, var(--paper) 14px 28px);
  }
  .hero-img .placeholder span {
    font-size: 11px; letter-spacing: .22em; text-transform: uppercase;
    color: var(--muted); text-align: center; padding: 18px;
  }
  @media (max-width: 860px) {
    .hero-strip > div { flex: 1 1 50%; border-top: 1px solid var(--line); }
    .hero-strip > div:nth-child(-n+2) { border-top: 0; }
    .hero-strip > div:nth-child(odd) { border-left: 0; }
    .hero-img { margin-top: 44px; }
  }
</style>
