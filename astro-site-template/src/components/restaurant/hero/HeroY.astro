---
/**
 * restaurant / HeroY — Garden (Playful). Asymmetric layered card stack:
 * a teal blob behind two rotated photo cards, with a floating rating tag.
 * Reads content.hero (shared shape across the restaurant family so content
 * stays portable when admin swaps variant). Hero image comes from
 * content.hero.image → Hyperagent enhanced image; gallery.items[1] fills
 * the second (small) card when present, else falls back to the hero image.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const hero = content.hero || {};
const gallery = content.gallery || {};
const galItems: any[] = Array.isArray(gallery.items) ? gallery.items : [];
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';
const secondImage = (galItems[1] && galItems[1].image) || (galItems[0] && galItems[0].image) || heroImage || '';
const kicker = hero.kicker || hero.locality || '';
const headlineLines: string[] = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0
  ? hero.headlineLines
  : (hero.headline ? [hero.headline] : []);
const sub = hero.sub || '';
const cta1Text = hero.cta1?.text || '';
const cta1Href = hero.cta1?.href || '#reserve';
const cta2Text = hero.cta2?.text || '';
const cta2Href = hero.cta2?.href || '#menu';
const rating = hero.rating || '';
const badge = hero.tag || '';
---
<section class="heroY" id="top">
  <div class="wrap heroY-grid">
    <div class="heroY-copy">
      {badge && <span class="heroY-badge" data-field="hero.tag">{badge}</span>}
      {headlineLines.length > 0 && (
        <h1 class="heroY-headline">
          {headlineLines.map((line: string, i: number) => (
            <span class={`word w${i}`} data-field={`hero.headlineLines.${i}`} set:html={line}></span>
          ))}
        </h1>
      )}
      {sub && <p class="heroY-sub" data-field="hero.sub">{sub}</p>}
      <div class="heroY-cta">
        {cta1Text && <a class="btn btn--accent" href={cta1Href} data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>}
        {cta2Text && <a class="btn btn--paper" href={cta2Href} data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>}
      </div>
      {kicker && <span class="heroY-kicker" data-field="hero.kicker">{kicker}</span>}
    </div>
    <div class="heroY-stack">
      <div class="heroY-blob" aria-hidden="true"></div>
      <div class="card c1">
        {heroImage
          ? <div class="bg-img" data-image-field="hero.image" style={`background-image:url('${heroImage}');`}></div>
          : <div class="bg-img placeholder" data-image-field="hero.image"></div>}
      </div>
      <div class="card c2">
        {secondImage
          ? <div class="bg-img" data-image-field="gallery.items.1.image" style={`background-image:url('${secondImage}');`}></div>
          : <div class="bg-img placeholder" data-image-field="gallery.items.1.image"></div>}
      </div>
      {rating && <span class="heroY-tag" data-field="hero.rating">⭐ {rating}</span>}
    </div>
  </div>
</section>
<style>
  .heroY { padding: clamp(36px, 6vw, 72px) 0 clamp(50px, 7vw, 90px); position: relative; overflow: hidden; }
  .heroY-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(24px, 4vw, 48px); align-items: center; }
  .heroY-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--sun, var(--accent)); color: var(--ink);
    border: 2.5px solid var(--ink); border-radius: 999px;
    padding: 8px 16px; font-weight: 700; font-size: 14px; font-family: var(--sans);
  }
  .heroY-headline {
    font-family: var(--display); font-weight: 400; line-height: 1;
    font-size: clamp(52px, 9vw, 128px); margin: 24px 0;
  }
  .heroY-headline .word { display: inline-block; }
  .heroY-headline .w1 { color: var(--accent); }
  .heroY-headline .w2 { color: var(--teal, var(--ink)); }
  .heroY-sub {
    font-family: var(--sans); font-size: clamp(17px, 1.4vw, 19px);
    max-width: 42ch; color: var(--muted, rgba(var(--ink-rgb), .8)); margin: 0 0 28px;
  }
  .heroY-cta { display: flex; gap: 14px; flex-wrap: wrap; }
  .heroY-kicker {
    display: block; margin-top: 26px; font-family: var(--sans);
    font-weight: 700; font-size: 13px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--accent);
  }
  .heroY-stack { position: relative; height: clamp(380px, 46vw, 520px); }
  .heroY-blob {
    position: absolute; top: 18%; left: 4%; width: 46%; height: 46%;
    background: var(--teal, var(--accent)); border-radius: 50%; z-index: 1;
  }
  .heroY-stack .card {
    position: absolute; overflow: hidden;
    border: 2.5px solid var(--ink); border-radius: var(--r, 26px);
    background: var(--paper-2, var(--paper));
  }
  .heroY-stack .c1 { top: 0; right: 0; width: 72%; height: 72%; z-index: 2; transform: rotate(3deg); }
  .heroY-stack .c2 { bottom: 0; left: 0; width: 60%; height: 54%; z-index: 3; transform: rotate(-4deg); }
  .heroY-stack .bg-img { position: absolute; inset: 0; width: 100%; height: 100%; background-size: cover; background-position: center; }
  .heroY-stack .placeholder { background: repeating-linear-gradient(45deg, var(--paper-2, var(--paper)) 0 12px, var(--paper) 12px 24px); }
  .heroY-tag {
    position: absolute; z-index: 4; bottom: 8%; right: 4%;
    background: var(--accent); color: var(--on-accent, #fff);
    border: 2.5px solid var(--ink); border-radius: 999px;
    padding: 8px 16px; font-family: var(--sans); font-weight: 700; font-size: 14px;
    transform: rotate(-6deg); box-shadow: 0 4px 0 var(--ink);
  }
  @media (max-width: 860px) {
    .heroY-grid { grid-template-columns: 1fr; }
    .heroY-stack { height: 340px; margin-top: 10px; }
    .heroY-headline { margin: 18px 0; }
  }
</style>
