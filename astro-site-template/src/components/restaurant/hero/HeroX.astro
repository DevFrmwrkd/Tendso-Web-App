---
/**
 * restaurant / HeroX — Ember (Cinematic). Full-bleed hero: background photo
 * with a dark scrim + amber glow, headline + copy pinned to the bottom-left,
 * and a locality tag pinned top-left. Reads content.hero (shared shape across
 * the restaurant family so content stays portable when admin swaps variant).
 * Hero image comes from content.hero.image → Hyperagent enhanced image.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const hero = content.hero || {};
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';
const locality = hero.kicker || hero.locality || '';
const headlineLines: string[] = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0
  ? hero.headlineLines
  : (hero.headline ? [hero.headline] : []);
const sub = hero.sub || '';
const cta1Text = hero.cta1?.text || '';
const cta1Href = hero.cta1?.href || '#reserve';
const cta2Text = hero.cta2?.text || '';
const cta2Href = hero.cta2?.href || '#menu';
---
<section class="heroX" id="top">
  <div class="heroX-bg">
    {heroImage
      ? <div class="bg-img" data-image-field="hero.image" style={`background-image:url('${heroImage}');`}></div>
      : <div class="bg-img placeholder" data-image-field="hero.image"></div>}
  </div>
  <div class="heroX-scrim"></div>
  <div class="heroX-glow"></div>
  {locality && <div class="heroX-loc" data-field="hero.kicker">{locality}</div>}
  <div class="wrap heroX-in">
    {headlineLines.length > 0 && (
      <h1 class="heroX-headline">
        {headlineLines.map((line: string, i: number) => (
          <span class="ln"><span data-field={`hero.headlineLines.${i}`} set:html={line}></span></span>
        ))}
      </h1>
    )}
    {sub && <p class="heroX-sub" data-field="hero.sub">{sub}</p>}
    <div class="heroX-cta">
      {cta1Text && <a class="btn btn--accent" href={cta1Href} data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>}
      {cta2Text && <a class="btn btn--ghost" href={cta2Href} data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>}
    </div>
  </div>
</section>
<style>
  .heroX {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .heroX-bg { position: absolute; inset: 0; }
  .heroX-bg .bg-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    background-size: cover; background-position: center;
    background-color: var(--ink);
  }
  .heroX-bg .placeholder {
    background-image: repeating-linear-gradient(45deg, rgba(var(--paper-rgb), .06) 0 14px, rgba(var(--paper-rgb), .02) 14px 28px);
    background-color: var(--ink);
  }
  .heroX-scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg,
      rgba(var(--ink-rgb), .55) 0%,
      rgba(var(--ink-rgb), .2) 40%,
      rgba(var(--ink-rgb), .88) 100%);
  }
  .heroX-glow {
    position: absolute; top: -10%; right: -5%; width: 60vw; height: 60vw;
    pointer-events: none;
    background: radial-gradient(circle, rgba(var(--accent-rgb), .18), transparent 60%);
  }
  .heroX-loc {
    position: absolute; top: clamp(88px, 12vw, 110px); left: var(--pad, clamp(20px, 5vw, 72px));
    z-index: 2; font-family: var(--sans);
    font-size: 12px; letter-spacing: .24em; text-transform: uppercase;
    color: var(--muted-light, rgba(var(--paper-rgb), .7));
  }
  .heroX-in {
    position: relative; z-index: 2;
    padding-top: 120px;
    padding-bottom: clamp(50px, 8vw, 110px);
  }
  .heroX-headline {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(54px, 10vw, 150px); line-height: .98;
    color: var(--paper); letter-spacing: .01em;
  }
  .heroX-headline .ln { display: block; overflow: hidden; }
  .heroX-headline .ln > span { display: block; }
  .heroX-headline :global(em) { font-style: italic; color: var(--accent); }
  .heroX-sub {
    max-width: 46ch; margin: 28px 0 32px;
    font-size: clamp(17px, 2vw, 20px); line-height: 1.6;
    color: var(--paper);
  }
  .heroX-cta { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }
  @media (max-width: 860px) {
    .heroX { min-height: 84vh; }
    .heroX-in { padding-top: 100px; }
    .heroX-sub { max-width: 100%; }
  }
</style>
