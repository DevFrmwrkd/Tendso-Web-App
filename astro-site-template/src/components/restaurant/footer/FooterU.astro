---
interface Props { layout: any; content: any; }
const { layout, content } = Astro.props;
const f = content.footer || {};
const brand = f.brand || layout.businessName || 'Your Restaurant';
const blurb = f.blurb || f.brand_blurb || f.tagline || '';
const visitLines: string[] = Array.isArray(f.visit?.lines) && f.visit.lines.length
  ? f.visit.lines
  : ([layout.contact?.address, layout.contact?.phone].filter(Boolean) as string[]);
const explore: Array<{ text: string; href: string }> = Array.isArray(f.explore?.links) && f.explore.links.length
  ? f.explore.links
  : [];
const hoursRows: Array<{ day: string; time: string }> = Array.isArray(f.hours) ? f.hours : [];
const social: Array<{ platform: string; url: string }> = Array.isArray(f.social) && f.social.length
  ? f.social
  : (Array.isArray(layout.socialLinks) ? layout.socialLinks : []);
const notes: string[] = Array.isArray(f.notes) && f.notes.length ? f.notes : [];
const phone = layout.contact?.phone || '';
const phoneDigits = phone.replace(/[^0-9+]/g, '');
---
<footer>
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brandcol">
        <div class="foot-brand" data-field="footer.brand">{brand}</div>
        {blurb && <p data-field="footer.blurb">{blurb}</p>}
        {social.length > 0 && (
          <div class="foot-social">
            {social.map((s, i) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer"
                 data-field={`footer.social.${i}.platform`}
                 data-href-field={`footer.social.${i}.url`}>{s.platform}</a>
            ))}
          </div>
        )}
      </div>
      <div class="foot-col">
        <h4>Visit</h4>
        {visitLines.map((line, i) => (
          line === phone && phone
            ? <a href={`tel:${phoneDigits}`} data-field={`footer.visit.lines.${i}`}>{line}</a>
            : <p data-field={`footer.visit.lines.${i}`}>{line}</p>
        ))}
      </div>
      {hoursRows.length > 0 && (
        <div class="foot-col">
          <h4>Hours</h4>
          {hoursRows.map((row, i) => (
            <p>
              <span data-field={`footer.hours.${i}.day`}>{row.day}</span> · <span data-field={`footer.hours.${i}.time`}>{row.time}</span>
            </p>
          ))}
        </div>
      )}
      {explore.length > 0 && (
        <div class="foot-col">
          <h4>Explore</h4>
          {explore.map((l, i) => (
            <a href={l.href}
               data-field={`footer.explore.links.${i}.text`}
               data-href-field={`footer.explore.links.${i}.href`}>{l.text}</a>
          ))}
        </div>
      )}
    </div>
    {notes.length > 0 && (
      <div class="foot-bottom">
        {notes.map((n, i) => (
          <span data-field={`footer.notes.${i}`}>{n}</span>
        ))}
      </div>
    )}
  </div>
</footer>
<style>
  footer { background: var(--ink); color: var(--paper); padding: clamp(64px, 8vw, 108px) 0 56px; }
  .foot-top {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 38px;
    padding-bottom: 52px; border-bottom: 1px solid rgba(var(--paper-rgb), .16);
  }
  .foot-brand { font-family: var(--serif); font-size: 38px; letter-spacing: .34em; text-transform: uppercase; padding-left: .34em; }
  .foot-brandcol p { color: rgba(var(--paper-rgb), .62); max-width: 32ch; margin: 16px 0 0; }
  .foot-social { margin-top: 18px; display: flex; gap: 10px; flex-wrap: wrap; }
  .foot-social a {
    font-family: var(--sans); font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: rgba(var(--paper-rgb), .7); border: 1px solid rgba(var(--paper-rgb), .2);
    padding: 6px 12px; transition: color .2s, border-color .2s;
  }
  .foot-social a:hover { color: var(--accent); border-color: var(--accent); }
  .foot-col h4 { font-family: var(--sans); font-weight: 600; font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); margin: 0 0 18px; }
  .foot-col a, .foot-col p { display: block; color: rgba(var(--paper-rgb), .7); font-size: 15px; margin-bottom: 10px; }
  .foot-col a:hover { color: var(--paper); }
  .foot-bottom {
    display: flex; justify-content: space-between; gap: 18px; flex-wrap: wrap;
    padding-top: 28px; font-family: var(--sans); font-size: 11px;
    letter-spacing: .14em; text-transform: uppercase; color: rgba(var(--paper-rgb), .42);
  }
  @media (max-width: 760px) {
    .foot-top { grid-template-columns: 1fr 1fr; }
    .foot-brandcol { grid-column: 1 / -1; }
  }
</style>
