---
/**
 * Restaurant spine — shared base CSS injected once per page.
 *
 * The 5 Restaurant variants (PageU–PageY: Harvest, Atelier, Press, Ember,
 * Garden) each set their own palette + font tokens scoped to
 * `html[data-page="<L>"]`, so this spine references those via var(--accent),
 * var(--paper), etc. and works for every variant without bleed.
 *
 * Editorial/rustic vocabulary from the source: warm bone paper, terracotta
 * accent, deep-olive ink sections, light serif display (Newsreader), italic
 * accents. Button text routes through --on-accent / --on-ink / --on-paper
 * contrast tokens (playbook §"Contrast guarantee") so extreme schemes never
 * produce invisible buttons.
 */
---
<style is:global>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.72;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  h1, h2, h3, h4 {
    font-family: var(--serif);
    font-weight: 300; margin: 0;
    line-height: 1.04; letter-spacing: -.01em;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  section { position: relative; }
  .wrap { max-width: var(--maxw, 1320px); margin: 0 auto; padding-inline: var(--pad, clamp(22px, 5vw, 84px)); }
  .pad-y { padding-block: clamp(78px, 10vw, 160px); }
  .ink-sect { background: var(--olive); color: var(--paper); }
  .ink-sect .h-sect { color: var(--paper); }
  .ink-sect .kicker { color: var(--muted-light, rgba(var(--paper-rgb), .72)); }

  .kicker {
    font-family: var(--sans); font-weight: 600;
    text-transform: uppercase; letter-spacing: .38em;
    font-size: 11px; color: var(--accent);
    display: inline-flex; align-items: center;
  }
  .kicker.olive { color: var(--olive-2); }
  .h-sect {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(34px, 4.6vw, 62px); line-height: 1.04;
    letter-spacing: -.01em; margin: 14px 0 0;
  }
  .h-sect em { font-style: italic; color: var(--accent); }
  .lead {
    font-family: var(--serif); font-style: italic;
    font-size: clamp(17px, 1.5vw, 20px);
    color: var(--muted, rgba(var(--ink-rgb), .66)); max-width: 40ch;
  }

  /* Buttons: solid ink fill, terracotta on hover (Harvest signature).
     Text colors route through contrast tokens so extreme schemes stay legible. */
  .btn {
    display: inline-flex; align-items: center; gap: .7em;
    font-family: var(--sans); font-weight: 600;
    text-transform: uppercase; letter-spacing: .22em; font-size: 12px;
    padding: 17px 34px; min-height: 52px; cursor: pointer;
    border: 1px solid var(--ink); background: var(--ink); color: var(--on-ink, var(--paper));
    transition: background .45s, color .45s, border-color .45s, transform .45s;
  }
  .btn:hover { background: var(--accent); border-color: var(--accent); color: #fff; transform: translateY(-2px); }
  .btn--accent { background: var(--accent); border-color: var(--accent); color: var(--on-accent, #fff); }
  .btn--accent:hover { background: var(--ink); border-color: var(--ink); color: var(--on-ink, var(--paper)); }
  .btn--ghost { background: transparent; color: var(--on-paper, var(--ink)); border-color: var(--ink); }
  .btn--ghost:hover { background: var(--ink); color: var(--on-ink, var(--paper)); border-color: var(--ink); }
  .btn--ghost.on-dark { background: transparent; color: var(--on-ink, var(--paper)); border-color: rgba(var(--paper-rgb), .5); }
  .btn--ghost.on-dark:hover { background: var(--paper); color: var(--on-paper, var(--ink)); border-color: var(--paper); }

  .ulink {
    font-family: var(--sans); font-weight: 600;
    text-transform: uppercase; letter-spacing: .2em; font-size: 12px;
    position: relative; padding-bottom: 5px;
  }
  .ulink::after {
    content: ""; position: absolute; left: 0; bottom: 0; height: 1px; width: 100%;
    background: currentColor; transform-origin: right; transition: transform .5s ease;
  }
  .ulink:hover::after { transform: scaleX(0); }

  .sect-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 30px; flex-wrap: wrap; margin-bottom: 60px; }
  .sect-head .lead { margin: 0; }

  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 1.2s cubic-bezier(.2,.7,.2,1), transform 1.2s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    * { animation: none !important; }
  }
</style>
