---
interface Props { content: any; }
const { content } = Astro.props;
const how = content.how || {};
const tag = how.tag || '';
const headline = how.headline || '';
type Step = { title: string; body?: string; desc?: string; description?: string };
const steps: Step[] = Array.isArray(how.steps) ? how.steps : (Array.isArray(how.items) ? how.items : []);
---
{steps.length > 0 && (
  <section class="how">
    <div class="wrap">
      <div class="how-head reveal">
        {tag && <span class="kicker" data-field="how.tag">{tag}</span>}
        {headline && <h2 data-field="how.headline" set:html={headline}></h2>}
      </div>
      {steps.map((step, i) => (
        <div class="how-row reveal">
          <span class="hn">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 data-field={`how.steps.${i}.title`}>{step.title}</h3>
            {(step.body ?? step.desc ?? step.description) && (
              <p data-field={`how.steps.${i}.body`}>{step.body ?? step.desc ?? step.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
)}
<style>
  .how { background: var(--olive); color: var(--paper); padding-block: clamp(78px, 10vw, 160px); }
  .how-head { margin-bottom: 60px; display: block; }
  .how-head .kicker { color: rgba(var(--paper-rgb), .7); }
  .how-head h2 { font-family: var(--serif); font-weight: 300; font-size: clamp(34px, 5vw, 62px); color: var(--paper); margin-top: 14px; }
  .how-head h2 :global(em) { font-style: italic; }
  .how-row {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(28px, 5vw, 70px); padding: 42px 0;
    border-top: 1px solid rgba(var(--paper-rgb), .18); align-items: baseline;
  }
  .how-row:last-child { border-bottom: 1px solid rgba(var(--paper-rgb), .18); }
  .how-row .hn {
    font-family: var(--serif); font-weight: 300;
    font-size: clamp(40px, 5vw, 72px); line-height: 1; color: rgba(var(--paper-rgb), .55);
  }
  .how-row h3 { font-family: var(--serif); font-weight: 300; font-size: clamp(24px, 2.8vw, 34px); margin-bottom: 10px; }
  .how-row p { color: rgba(var(--paper-rgb), .78); margin: 0; max-width: 56ch; }
</style>
