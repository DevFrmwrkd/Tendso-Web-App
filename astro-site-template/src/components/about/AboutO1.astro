---
/**
 * AboutO - Clinic / Our Practice
 * Clean white with medical blue, doctor portrait + credentials,
 * trust-focused stats, clean cards layout.
 * Vibe: professional credibility, no flourish.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Our Practice',
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;

const stats = [
  { num: '15+', label: 'Years of practice' },
  { num: '5,000+', label: 'Patients served' },
  { num: '12', label: 'Specialists on team' },
  { num: '98%', label: 'Patient satisfaction' },
];
---

<section
  id="about"
  class="relative w-full bg-[var(--surface)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Subtle blue gradient */}
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-b from-[#e8f0fa]/40 to-transparent pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-12 lg:gap-20 items-center mb-20">

      {/* LEFT — Photo */}
      {showImages && (
        <div class="clinic-image-fade relative">
          {/* Blue accent square */}
          <div class="absolute -top-4 -left-4 w-32 h-32 rounded-2xl bg-[var(--primary)]/8 pointer-events-none"></div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-2xl bg-[var(--accent)]/10 pointer-events-none"></div>

          <div class="relative aspect-[4/5] rounded-3xl overflow-hidden bg-[#e8f0fa] shadow-[0_30px_60px_-15px_rgba(31,41,55,0.2)]">
            {mainPhoto ? (
              <img
                src={mainPhoto}
                alt={businessName}
                class="absolute inset-0 w-full h-full object-cover"
                style="filter: contrast(1.02) saturate(0.95);"
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center">
                <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" opacity="0.3">
                  <path d="M9 11.5 a3.5 3.5 0 1 1 7 0 c0 1.5 -1 2.5 -3.5 5 c-2.5 -2.5 -3.5 -3.5 -3.5 -5z"/>
                  <path d="M12 2v3M12 16v6M2 11h3M19 11h3"/>
                </svg>
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/20 via-transparent to-transparent"></div>

            {/* Credentials plaque */}
            <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-md rounded-2xl px-5 py-4 shadow-lg border border-[#e5e7eb]">
              <div class="flex items-center gap-2 mb-1">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="6"/>
                  <path d="M15.5 12.5 21 22l-4-2.5-4 2.5 5.5-9.5"/>
                </svg>
                <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-[var(--primary)]">Board certified</p>
              </div>
              <p class="text-base font-bold text-[var(--text)] leading-tight">{businessName}</p>
            </div>
          </div>
        </div>
      )}

      {/* RIGHT — Story */}
      <div>
        {showTagline && (
          <div class="clinic-fade-up mb-4 inline-flex items-center gap-2">
            <span class="w-8 h-px bg-[var(--primary)]"></span>
            <span class="text-[10px] font-bold uppercase tracking-[0.35em] text-[var(--primary)]">{tagline}</span>
          </div>
        )}

        {showHeadline && (
          <h2
            class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-8"
            style="font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;"
          >
            {headline}
          </h2>
        )}

        {showDescription && (
          <p
            class="clinic-fade-up text-[var(--text-muted)] leading-[1.75] mb-10"
            style="font-size: clamp(1rem, 1.25vw, 1.15rem); animation-delay: 0.2s;"
          >
            {description}
          </p>
        )}

        {/* USPs as cards */}
        {usps.length > 0 && (
          <div class="clinic-fade-up grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8" style="animation-delay: 0.3s">
            {usps.slice(0, 4).map((usp) => (
              <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-[#e5e7eb]">
                <div class="w-8 h-8 rounded-lg bg-[var(--accent)]/10 flex items-center justify-center shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <p class="text-sm text-[var(--text)] leading-relaxed font-medium">{usp}</p>
              </div>
            ))}
          </div>
        )}

        {/* Tags as credentials chips */}
        {showTags && (
          <div class="clinic-fade-up flex flex-wrap gap-2" style="animation-delay: 0.4s">
            {tags.map((tag) => (
              <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[#e8f0fa] text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--primary)]">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>

    {/* Stats row — clean grid */}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {stats.map((stat, i) => (
        <div
          class="clinic-fade-up bg-white rounded-2xl p-6 lg:p-8 border border-[#e5e7eb] text-center"
          style={`animation-delay: ${0.5 + i * 0.1}s`}
        >
          <p
            class="font-bold text-[var(--primary)] leading-none mb-3"
            style="font-size: clamp(2rem, 3.5vw, 3rem);"
          >
            {stat.num}
          </p>
          <p class="text-xs font-medium text-[var(--text-muted)] uppercase tracking-wider">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clinic-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }

  .clinic-image-fade {
    opacity: 0;
    transform: translateY(25px);
    animation: clinicFadeUp 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .clinic-fade-up, .clinic-image-fade { animation-duration: 0.01ms; opacity: 1; transform: none; }
  }
</style>
