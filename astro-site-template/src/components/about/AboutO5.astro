---
/**
 * AboutO5 - Clinic / Patient Outcomes
 * Outcomes-focused: data-driven trust. Big metric cards showing recovery rates,
 * satisfaction, wait times. Quietly confident, evidence-based.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Outcomes that matter',
  tagline,
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const metrics = [
  { value: '98%', label: 'Patient satisfaction', sub: 'Year-end survey, 2024' },
  { value: '12 min', label: 'Average wait', sub: 'Across all appointments' },
  { value: '24h', label: 'Result turnaround', sub: 'Lab results delivered' },
  { value: '2K+', label: 'Patients served', sub: 'Active panel' },
];

const testimonials = [
  { quote: 'They actually listened. First time in years.', source: '— M.R., longtime patient' },
  { quote: 'My results came back faster than expected.', source: '— J.S., new patient' },
];
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-16 items-start mb-12">
      {/* LEFT */}
      <div class="lg:sticky lg:top-24">
        {showTagline && (
          <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— {tagline} —</p>
        )}
        {showHeadline && (
          <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 3.75rem); animation-delay: 0.1s;">{headline}</h2>
        )}
        {showDescription && (
          <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.85] mb-8" style="font-size: 1.05rem; animation-delay: 0.2s;">{description}</p>
        )}

        {showImages && (
          <div class="clinic-fade-up relative aspect-[4/3] overflow-hidden bg-[var(--surface)] rounded-2xl" style="animation-delay: 0.3s">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">📊</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-tr from-[var(--text)]/30 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--bg)] bg-[var(--text)]/50 backdrop-blur-sm rounded-full px-3 py-1.5 inline-block">— Data from {new Date().getFullYear()} review —</p>
            </div>
          </div>
        )}
      </div>

      {/* RIGHT — Metrics + testimonials */}
      <div>
        {/* Metric cards */}
        <div class="grid grid-cols-2 gap-4 mb-8">
          {metrics.map((m, i) => (
            <div class="clinic-fade-up bg-[var(--surface)] rounded-2xl p-6 border border-[var(--text)]/10 hover:border-[var(--primary)]/30 hover:-translate-y-1 transition-all" style={`animation-delay: ${0.35 + i * 0.08}s`}>
              <p class={`text-5xl font-bold ${i % 2 === 0 ? 'text-[var(--primary)]' : 'text-[var(--accent)]'} mb-2 leading-none`} style="font-family: var(--heading-font);">{m.value}</p>
              <p class="text-sm font-semibold text-[var(--text)] mb-1">{m.label}</p>
              <p class="text-[10px] uppercase tracking-wider text-[var(--text-muted)]">{m.sub}</p>
            </div>
          ))}
        </div>

        {/* Testimonials */}
        <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--accent)] mb-4" style="animation-delay: 0.7s">— In their words —</p>
        <div class="space-y-3">
          {testimonials.map((t, i) => (
            <div class="clinic-fade-up bg-[var(--bg)] border-l-4 border-[var(--accent)] p-5 rounded-r-2xl" style={`animation-delay: ${0.75 + i * 0.1}s`}>
              <p class="text-base italic text-[var(--text)] mb-2">"{t.quote}"</p>
              <p class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] font-semibold">{t.source}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
