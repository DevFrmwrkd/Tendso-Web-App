---
/**
 * AboutM4 - Salon/Spa / Wellness Pillars
 * Four-pillar philosophy layout. Each pillar a soft card with icon, name, body.
 * Symmetric grid, premium-spa-brand brochure feel.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Our four pillars',
  tagline,
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const defaultPillars = [
  { icon: '❀', name: 'Restore', body: 'Soothe what the week has worn down. Touch that gives back.' },
  { icon: '✦', name: 'Refine', body: 'Bring out the best version of you, in small honest steps.' },
  { icon: '❦', name: 'Reset', body: 'Pause the noise. Breathe. Let the room do its work.' },
  { icon: '✿', name: 'Renew', body: 'Leave lighter than you arrived. That\'s the promise.' },
];

const pillars = usps.length > 0
  ? usps.slice(0, 4).map((u, i) => ({
      icon: defaultPillars[i].icon,
      name: defaultPillars[i].name,
      body: u,
    }))
  : defaultPillars;
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-0 -left-32 w-[500px] h-[500px] rounded-full opacity-20 blur-[120px]" style="background: var(--primary);"></div>
  <div class="absolute bottom-0 -right-32 w-[500px] h-[500px] rounded-full opacity-20 blur-[120px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Hero header */}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
      <div>
        {showTagline && (
          <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— {tagline} —</p>
        )}
        {showHeadline && (
          <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
        )}
        {showDescription && (
          <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.85] max-w-md" style="font-size: 1.1rem; animation-delay: 0.2s;">{description}</p>
        )}
      </div>

      {showImages && (
        <div class="salon-fade-up relative" style="animation-delay: 0.3s">
          <div class="relative aspect-[4/3] overflow-hidden bg-[var(--surface)] rounded-[80px_30px_80px_30px]">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">m</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-tr from-[var(--accent)]/15 to-transparent"></div>
          </div>
        </div>
      )}
    </div>

    {/* Pillars grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {pillars.map((p, i) => (
        <div class="salon-fade-up bg-[var(--surface)] rounded-3xl p-7 text-center hover:-translate-y-1 transition-all duration-500 hover:shadow-[0_25px_50px_-15px_rgba(61,46,42,0.2)]" style={`animation-delay: ${0.35 + i * 0.1}s`}>
          <div class="w-14 h-14 rounded-full bg-[var(--primary)]/10 flex items-center justify-center mx-auto mb-5">
            <span class="text-3xl text-[var(--primary)]">{p.icon}</span>
          </div>
          <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-2">— Pillar 0{i + 1} —</p>
          <h3 class="text-2xl italic text-[var(--primary)] mb-4" style="font-family: var(--heading-font);">{p.name}</h3>
          <p class="text-sm text-[var(--text-muted)] italic leading-[1.7]">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
