---
/**
 * AboutO2 - Clinic / Provider Bios
 * Multi-provider clinic team grid. Each provider with portrait, specialty, credentials.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Meet our providers',
  tagline,
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const providers = [
  { name: 'Dr. A. Reyes', specialty: 'Family Medicine', creds: 'MD · 15 yrs', icon: '⚕' },
  { name: 'Dr. M. Santos', specialty: 'Internal Medicine', creds: 'MD · Board-cert.', icon: '⚕' },
  { name: 'Dr. C. Cruz', specialty: 'Pediatrics', creds: 'MD · Fellowship', icon: '⚕' },
  { name: 'Dr. L. Garcia', specialty: 'Cardiology', creds: 'MD · Specialist', icon: '⚕' },
];
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-16 max-w-3xl mx-auto">
      {showTagline && (
        <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">{tagline}</p>
      )}
      {showHeadline && (
        <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showDescription && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">{description}</p>
      )}
    </div>

    {showImages && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {providers.map((p, i) => (
          <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl overflow-hidden border border-[var(--text)]/10 hover:border-[var(--primary)]/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-500" style={`animation-delay: ${0.3 + i * 0.08}s`}>
            <div class="relative aspect-[4/5] bg-[var(--bg)] overflow-hidden">
              {photos[i] ? (
                <img src={photos[i]} alt={p.name} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-7xl">{p.icon}</div>
              )}
              {/* Cred badge */}
              <div class="absolute top-3 right-3 bg-[var(--accent)] text-[var(--bg)] rounded-full px-2.5 py-1 text-[9px] font-bold uppercase tracking-wider">{p.creds.split(' · ')[0]}</div>
            </div>
            <div class="p-5 text-center">
              <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-2">Provider {String(i + 1).padStart(2, '0')}</p>
              <h3 class="text-lg font-bold text-[var(--text)] mb-1 leading-tight">{p.name}</h3>
              <p class="text-xs text-[var(--text-muted)] mb-3">{p.specialty}</p>
              <div class="pt-3 border-t border-[var(--text)]/10">
                <p class="text-[10px] text-[var(--accent)] font-medium">{p.creds}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    <div class="clinic-fade-up text-center mt-12 pt-10 border-t border-[var(--text)]/10" style="animation-delay: 0.7s">
      <p class="text-sm text-[var(--text-muted)]">All providers are board-certified and accepting new patients at <span class="font-semibold text-[var(--primary)]">{businessName}</span>.</p>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
