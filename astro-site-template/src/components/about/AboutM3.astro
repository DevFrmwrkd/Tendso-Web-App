---
/**
 * AboutM3 - Salon/Spa / Our Practice
 * Editorial magazine spread style. Drop-cap opening, multi-column flow,
 * pulled-quote breaks, photo collage on side.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Our practice, our philosophy',
  tagline,
  tags = [],
  photos = [],
  visibility,
} = Astro.props;

const photo1 = photos[0] || '';
const photo2 = photos[1] || '';
const photo3 = photos[2] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;

const dropCap = description ? description.charAt(0).toUpperCase() : 'O';
const restOfText = description ? description.slice(1) : '';
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-1/4 -right-20 w-[500px] h-[500px] rounded-full opacity-20 blur-[120px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Editorial header */}
    <div class="text-center mb-16">
      {showTagline && (
        <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— {tagline} —</p>
      )}
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] max-w-3xl mx-auto" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 3.75rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      <div class="salon-fade-up flex items-center gap-3 justify-center mt-6" style="animation-delay: 0.2s">
        <span class="h-px w-12 bg-[var(--primary)]/40"></span>
        <span class="text-[var(--primary)] text-base">✦</span>
        <span class="h-px w-12 bg-[var(--primary)]/40"></span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-16 items-start">
      {/* LEFT — Editorial text */}
      <div>
        {showDescription && (
          <p class="salon-fade-up text-[var(--text)] leading-[1.85] mb-8" style="font-size: 1.1rem; animation-delay: 0.3s;">
            <span class="float-left text-7xl leading-[0.85] mr-3 mt-1 italic text-[var(--primary)]" style="font-family: var(--heading-font);">{dropCap}</span>
            {restOfText}
          </p>
        )}

        {/* Pulled quote */}
        <div class="salon-fade-up my-10 py-6 border-y border-[var(--primary)]/30 text-center" style="animation-delay: 0.4s">
          <p class="text-2xl italic text-[var(--primary)] leading-[1.4]" style="font-family: var(--heading-font); font-size: clamp(1.25rem, 2vw, 1.65rem);">
            "We treat every guest like they're the only one in the room."
          </p>
        </div>

        {showTags && tags.length > 0 && (
          <div class="salon-fade-up flex flex-wrap gap-2 pt-4" style="animation-delay: 0.5s">
            {tags.map((tag) => (
              <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic border border-[var(--accent)]/40 rounded-full px-3 py-1.5">{tag}</span>
            ))}
          </div>
        )}
      </div>

      {/* RIGHT — Photo collage */}
      {showImages && (
        <div class="space-y-4">
          <div class="salon-fade-up relative aspect-[4/5] overflow-hidden bg-[var(--surface)] rounded-tl-[120px] rounded-br-[120px]" style="animation-delay: 0.35s">
            {photo1 ? (
              <img src={photo1} alt={businessName} data-field="about.image" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-6xl italic" style="font-family: var(--heading-font);">m</div>
            )}
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="salon-fade-up relative aspect-square overflow-hidden bg-[var(--surface)] rounded-full" style="animation-delay: 0.45s">
              {photo2 ? (
                <img src={photo2} alt="" data-field="about.image.1" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-3xl">❀</div>
              )}
            </div>
            <div class="salon-fade-up relative aspect-square overflow-hidden bg-[var(--surface)] rounded-tr-[80px] rounded-bl-[80px]" style="animation-delay: 0.55s">
              {photo3 ? (
                <img src={photo3} alt="" data-field="about.image.2" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-3xl">❦</div>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
