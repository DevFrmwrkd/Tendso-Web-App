---
/**
 * AboutA - Gallery Split Layout
 * Light background with scroll-triggered fade-in animations.
 * Top: Split layout (badge + headline left, description right).
 * Bottom: 4-image horizontal gallery with hover scale and staggered reveals.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'About Us',
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.aboutBadge !== false;
const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;

// Take up to 4 photos for the gallery
const galleryPhotos = photos.slice(0, 4);
---

<section id="about" class="relative overflow-hidden bg-[var(--bg)] py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    {/* Top: Split layout */}
    <div class="reveal grid grid-cols-1 items-start gap-12 md:grid-cols-2 md:gap-20">

      {/* LEFT: Badge + Headline */}
      <div>
        {showBadge && (
          <div class="reveal mb-8">
            <span class="inline-block rounded-full px-6 py-2 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] bg-[var(--primary)] text-[var(--text-inverse)] shadow-lg shadow-[var(--primary)]/20">
              Overview
            </span>
          </div>
        )}

        {showHeadline && (
          <h2 class="reveal-delay-1 reveal font-bold leading-tight tracking-tight text-[var(--text)]"
              style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
              data-field="about_headline"
              set:html={headline}>
          </h2>
        )}
      </div>

      {/* RIGHT: Description */}
      {showDescription && (
        <div class="reveal-delay-2 reveal flex items-start md:pt-4 lg:pt-12">
          <p class="max-w-xl leading-[1.6] text-[var(--text-muted)] font-medium"
             style="font-size: var(--fs-lg);"
             data-field="about_description"
             set:html={description}>
          </p>
        </div>
      )}
    </div>

    {/* Bottom: 4-image gallery */}
    {showImages && galleryPhotos.length > 0 && (
      <div class="mt-16 md:mt-24 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
        {galleryPhotos.map((photo, index) => (
          <div 
            class="reveal overflow-hidden rounded-[2.5rem] bg-[var(--surface)] border border-[var(--text)]/5 shadow-xl transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl"
            style={`transition-delay: ${index * 0.15 + 0.5}s;`}
          >
            <img
              src={photo}
              alt={`${businessName} - ${index + 1}`}
              class="aspect-[3/4] w-full object-cover transition-transform duration-[1s] hover:scale-110"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    )}
  </div>
</section>
