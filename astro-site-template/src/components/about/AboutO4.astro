---
/**
 * AboutO4 - Clinic / Insurance Network
 * Insurance acceptance grid. Major insurers listed with logos placeholder.
 * "We accept" trust signal page, common-question coverage info.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Insurance & coverage',
  tagline,
  visibility,
} = Astro.props;

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const insurers = [
  'PhilHealth', 'Maxicare', 'Medicard', 'Intellicare',
  'Pacific Cross', 'Caritas', 'Insular Health', 'Cocolife',
  'Sun Life', 'HMO Pinoy', 'Generali', 'Other PPOs',
];

const faqs = [
  { q: 'Do I need a referral?', a: 'For most primary care visits, no referral needed.' },
  { q: 'What if my plan isn\'t listed?', a: 'Call us — we work with most plans, even if not shown.' },
  { q: 'How are claims handled?', a: 'We file directly to your insurer. No paperwork on your end.' },
];
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="text-center mb-12 max-w-3xl mx-auto">
      {showTagline && (
        <p class="clinic-fade-up text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-4">— {tagline} —</p>
      )}
      {showHeadline && (
        <h2 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-5" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showDescription && (
        <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75]" style="font-size: 1.1rem; animation-delay: 0.2s;">{description}</p>
      )}
    </div>

    {/* Stats strip */}
    <div class="clinic-fade-up grid grid-cols-3 gap-4 mb-12 max-w-3xl mx-auto" style="animation-delay: 0.3s">
      <div class="bg-[var(--surface)] rounded-2xl p-5 text-center border border-[var(--text)]/10">
        <p class="text-3xl font-bold text-[var(--primary)] mb-1">12+</p>
        <p class="text-[10px] uppercase tracking-wider text-[var(--text-muted)]">Plans accepted</p>
      </div>
      <div class="bg-[var(--surface)] rounded-2xl p-5 text-center border border-[var(--text)]/10">
        <p class="text-3xl font-bold text-[var(--accent)] mb-1">0</p>
        <p class="text-[10px] uppercase tracking-wider text-[var(--text-muted)]">Claim paperwork</p>
      </div>
      <div class="bg-[var(--surface)] rounded-2xl p-5 text-center border border-[var(--text)]/10">
        <p class="text-3xl font-bold text-[var(--primary)] mb-1">24h</p>
        <p class="text-[10px] uppercase tracking-wider text-[var(--text-muted)]">Verification</p>
      </div>
    </div>

    {/* Insurer grid */}
    <div class="mb-14">
      <p class="clinic-fade-up text-center text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--accent)] mb-6" style="animation-delay: 0.4s">— Plans we accept —</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {insurers.map((name, i) => (
          <div class="clinic-fade-up bg-[var(--surface)] border border-[var(--text)]/10 rounded-xl py-4 px-3 text-center hover:border-[var(--primary)]/30 transition-colors" style={`animation-delay: ${0.45 + i * 0.04}s`}>
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-[var(--accent)] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-sm font-semibold text-[var(--text)]">{name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* FAQ */}
    <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl p-8 border border-[var(--text)]/10" style="animation-delay: 0.9s">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-5 text-center">— Quick answers —</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {faqs.map((f) => (
          <div>
            <p class="text-sm font-bold text-[var(--text)] mb-2">{f.q}</p>
            <p class="text-xs text-[var(--text-muted)] leading-[1.65]">{f.a}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-xs text-[var(--text-muted)] mt-6 pt-5 border-t border-[var(--text)]/10">
        Plan not listed? Call <span class="font-semibold text-[var(--primary)]">{businessName}</span> — we can verify in under a day.
      </p>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
