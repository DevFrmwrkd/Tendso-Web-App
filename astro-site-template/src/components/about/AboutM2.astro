---
/**
 * AboutM2 — Salon · Maison Élite (4-pillar)
 *
 * "The Difference Is in the Details" — a centered eyebrow + serif headline
 * followed by 4 pillar cards (Award-Winning Team · Organic Luxury Products
 * · Bespoke Consultations · Private Suite Experience). Luxe, restrained.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  description,
  headline = "The Difference Is in the Details",
  usps = [
    "Our master stylists hold international certifications and have been recognized by the industry's most prestigious awards.",
    "We exclusively use sustainably-sourced, organic formulations from the world's finest beauty houses.",
    "Every visit begins with a tailored consultation to craft a personalized beauty plan tailored to you.",
    "Enjoy complete privacy in our exclusive suites — a rare sanctuary of calm and indulgence.",
  ],
  visibility,
} = Astro.props;

const PILLARS = [
  { icon: "✦", label: "Award-Winning Team",    body: usps[0] },
  { icon: "✿", label: "Organic Luxury Products", body: usps[1] },
  { icon: "❖", label: "Bespoke Consultations",  body: usps[2] },
  { icon: "❋", label: "Private Suite Experience", body: usps[3] },
];

const showHeadline = visibility?.aboutHeadline !== false;
const showDesc = visibility?.aboutDescription !== false;
---

<section id="about" class="mae-about" data-component="ABOUT">
  <div class="mae-about-container">
    <p class="mae-about-eyebrow">— Maison Élite —</p>
    {showHeadline && (
      <h2 class="mae-about-headline" data-field="about.headline" set:html={headline}></h2>
    )}
    {showDesc && description && (
      <p class="mae-about-sub" data-field="about.description" set:html={description}></p>
    )}

    <div class="mae-about-pillars">
      {PILLARS.map((p, i) => (
        <div class="mae-pillar">
          <div class="mae-pillar-icon">{p.icon}</div>
          <h3 class="mae-pillar-label" data-field={`about.usps.${i}.label`} set:html={p.label}></h3>
          <p class="mae-pillar-body" data-field={`about.usps.${i}`} set:html={p.body}></p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .mae-about {
    --ma-bg:     color-mix(in srgb, var(--text) 4%, var(--bg));
    --ma-card:   var(--bg);
    --ma-ink:    var(--text);
    --ma-ink-2:  color-mix(in srgb, var(--text) 70%, var(--bg));
    --ma-ink-3:  color-mix(in srgb, var(--text) 50%, var(--bg));
    --ma-accent: var(--primary);
    --ma-rule:   color-mix(in srgb, var(--text) 12%, transparent);
    --ma-serif:  var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --ma-sans:   var(--body-font, "Inter", system-ui, sans-serif);

    background: var(--ma-bg);
    color: var(--ma-ink);
    font-family: var(--ma-sans);
    padding: clamp(72px, 10vw, 120px) 0;
    text-align: center;
  }
  .mae-about-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .mae-about-eyebrow {
    font-family: var(--ma-sans);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--ma-accent);
    margin: 0 0 22px;
  }
  .mae-about-headline {
    font-family: var(--ma-serif);
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.1;
    color: var(--ma-ink);
    margin: 0 auto;
    font-weight: 400;
    max-width: 24ch;
  }
  .mae-about-sub {
    margin: 22px auto 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ma-ink-2);
    max-width: 56ch;
  }
  .mae-about-pillars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    margin-top: clamp(48px, 6vw, 72px);
  }
  @media (max-width: 1000px) { .mae-about-pillars { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .mae-about-pillars { grid-template-columns: 1fr; } }
  .mae-pillar {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    padding: 28px 18px;
  }
  .mae-pillar-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ma-ink);
    color: var(--ma-accent);
    font-size: 18px;
  }
  .mae-pillar-label {
    margin: 0;
    font-family: var(--ma-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--ma-ink);
  }
  .mae-pillar-body {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ma-ink-2);
    max-width: 28ch;
  }
</style>
