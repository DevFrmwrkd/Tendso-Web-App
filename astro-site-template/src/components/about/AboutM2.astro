---
/**
 * AboutM2 - Salon/Spa / Founder Note
 * Handwritten-letter aesthetic from the salon founder.
 * Script signature, paper texture, personal-letter feel with portrait inset.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'A note from the founder',
  tagline,
  tags = [],
  photos = [],
  visibility,
} = Astro.props;

const portraitPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  {/* Paper grain */}
  <div class="absolute inset-0 z-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle at 30% 30%, var(--primary) 0.5px, transparent 1px), radial-gradient(circle at 70% 70%, var(--accent) 0.5px, transparent 1px); background-size: 5px 5px, 7px 7px;"></div>

  <div class="absolute top-1/3 -left-32 w-[400px] h-[400px] rounded-full opacity-20 blur-[100px]" style="background: var(--primary);"></div>
  <div class="absolute bottom-1/3 -right-32 w-[400px] h-[400px] rounded-full opacity-20 blur-[100px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12">

    {/* Letter card */}
    <div class="salon-fade-up bg-[var(--surface)]/85 backdrop-blur-sm p-10 sm:p-16 relative" style="box-shadow: 0 40px 80px -25px rgba(61,46,42,0.25);">
      {/* Corner ornaments */}
      <div class="absolute top-4 left-4 w-10 h-10 border-t border-l border-[var(--primary)]/40"></div>
      <div class="absolute top-4 right-4 w-10 h-10 border-t border-r border-[var(--primary)]/40"></div>
      <div class="absolute bottom-4 left-4 w-10 h-10 border-b border-l border-[var(--primary)]/40"></div>
      <div class="absolute bottom-4 right-4 w-10 h-10 border-b border-r border-[var(--primary)]/40"></div>

      <div class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-10 items-start">
        {/* Portrait */}
        {showImages && (
          <div class="relative">
            <div class="relative w-44 h-44 rounded-full overflow-hidden bg-[var(--bg)] border-4 border-[var(--primary)]/30 mx-auto">
              {portraitPhoto ? (
                <img src={portraitPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: brightness(1.02);" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-7xl italic" style="font-family: var(--heading-font);">m</div>
              )}
            </div>
            <p class="text-center text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] italic mt-4">— Founder —</p>
          </div>
        )}

        {/* Letter content */}
        <div>
          {showTagline && (
            <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-3">— {tagline} —</p>
          )}
          <p class="text-2xl italic text-[var(--primary)] mb-6" style="font-family: var(--heading-font);">Dear visitor,</p>

          {showHeadline && (
            <h2 class="font-light italic leading-[1.1] text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(1.85rem, 4vw, 2.85rem);">{headline}</h2>
          )}

          {showDescription && (
            <p class="text-[var(--text-muted)] italic leading-[1.85] mb-8" style="font-size: 1.05rem;">{description}</p>
          )}

          {/* Signature flourish */}
          <div class="pt-6 border-t border-dashed border-[var(--primary)]/30">
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-1">— With care —</p>
            <p class="text-3xl italic text-[var(--primary)]" style="font-family: var(--heading-font);">{businessName}</p>
          </div>
        </div>
      </div>

      {showTags && (
        <div class="mt-10 pt-6 border-t border-dashed border-[var(--primary)]/30 flex flex-wrap justify-center gap-2">
          {tags.map((tag) => (
            <span class="text-[10px] uppercase tracking-[0.35em] text-[var(--accent)] italic border border-[var(--accent)]/40 rounded-full px-3 py-1.5">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
