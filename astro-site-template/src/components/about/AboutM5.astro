---
/**
 * AboutM5 - Salon/Spa / Studio Tour
 * Walk-through of the studio space. Numbered "stops" through different rooms.
 * Each stop with image + room description, like a guided tour brochure.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'A tour of the studio',
  tagline,
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const defaultStops = [
  { name: 'The Lounge', body: 'Where the day slows. Soft seats, gentle music, herbal tea on arrival.' },
  { name: 'Treatment Suites', body: 'Three quiet rooms, each with its own light and scent.' },
  { name: 'Wash Atelier', body: 'Reclined basins with hot towels. Massage built into every wash.' },
  { name: 'The Garden Patio', body: 'For finishing touches outdoors, when the weather invites.' },
];

const stops = defaultStops;
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="absolute top-1/3 -left-32 w-[500px] h-[500px] rounded-full opacity-15 blur-[120px]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center max-w-3xl mx-auto mb-16">
      {showTagline && (
        <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-5">— {tagline} —</p>
      )}
      {showHeadline && (
        <h2 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 3.75rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showDescription && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.85]" style="font-size: 1.1rem; animation-delay: 0.2s;">{description}</p>
      )}
    </div>

    {/* Tour stops */}
    {showImages && (
      <div class="space-y-16">
        {stops.map((s, i) => {
          const isEven = i % 2 === 0;
          return (
            <div class={`salon-fade-up grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center ${isEven ? '' : 'lg:grid-flow-dense'}`} style={`animation-delay: ${0.25 + i * 0.12}s`}>
              {/* Image */}
              <div class={isEven ? '' : 'lg:col-start-2'}>
                <div class={`relative aspect-[4/3] overflow-hidden bg-[var(--surface)] ${isEven ? 'rounded-tl-[140px] rounded-br-[140px]' : 'rounded-tr-[140px] rounded-bl-[140px]'}`}>
                  {photos[i] ? (
                    <img src={photos[i]} alt={s.name} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">{i + 1}</div>
                  )}
                </div>
              </div>

              {/* Stop info */}
              <div class={isEven ? '' : 'lg:col-start-1 lg:row-start-1'}>
                <div class="flex items-center gap-4 mb-5">
                  <span class="text-6xl italic text-[var(--primary)] leading-none" style="font-family: var(--heading-font);">0{i + 1}</span>
                  <div class="flex-1">
                    <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-1">— Stop 0{i + 1} —</p>
                    <h3 class="text-3xl italic text-[var(--primary)]" style="font-family: var(--heading-font);">{s.name}</h3>
                  </div>
                </div>
                <p class="text-[var(--text-muted)] italic leading-[1.8] max-w-md" style="font-size: 1.05rem;">{s.body}</p>
                <div class="flex items-center gap-3 mt-6">
                  <span class="h-px w-12 bg-[var(--primary)]/40"></span>
                  <span class="text-[var(--primary)]">❀</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
