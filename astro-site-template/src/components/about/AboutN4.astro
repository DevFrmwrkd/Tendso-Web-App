---
/**
 * AboutN4 - Restaurant / Sourcing Story
 * Farm-to-table sourcing story. Map of suppliers, each with location + product.
 * "Where it comes from" transparency feel.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Where it all comes from',
  tagline,
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const sources = [
  { product: 'Produce', supplier: 'Sagada Farms', distance: '12 km away', icon: '🥬' },
  { product: 'Seafood', supplier: 'Catanduanes Coast', distance: 'Morning catch', icon: '🐟' },
  { product: 'Pork & beef', supplier: 'Batangas heritage farm', distance: 'Pasture-raised', icon: '🥩' },
  { product: 'Bread & grains', supplier: 'Local micro-bakery', distance: 'Baked daily', icon: '🍞' },
  { product: 'Spices', supplier: 'Family spice merchant', distance: 'Third generation', icon: '🌶' },
  { product: 'Dairy', supplier: 'Laguna creamery', distance: 'Fresh weekly', icon: '🧈' },
];
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    {/* Top header */}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end mb-16 pb-8 border-b border-[var(--text)]/15">
      <div>
        {showTagline && (
          <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-4">— {tagline} —</p>
        )}
        {showHeadline && (
          <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-4" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
        )}
      </div>
      {showDescription && (
        <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.85]" style="font-size: 1.05rem; animation-delay: 0.2s;">{description}</p>
      )}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-16 items-start">
      {/* LEFT — Sourcing image */}
      {showImages && (
        <div class="resto-fade-up lg:sticky lg:top-24" style="animation-delay: 0.3s">
          <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)]">
            {mainPhoto ? (
              <img src={mainPhoto} alt="Sourcing" class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.05) saturate(1.05);" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-9xl">🌾</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/50 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-2">— Today's harvest —</p>
              <p class="text-2xl italic text-[var(--bg)]" style="font-family: var(--heading-font);">Direct from the source</p>
            </div>
          </div>
        </div>
      )}

      {/* RIGHT — Suppliers list */}
      <div class="space-y-4">
        {sources.map((s, i) => (
          <div class="resto-fade-up grid grid-cols-[60px_1fr_auto] gap-4 items-center py-4 border-b border-dashed border-[var(--text)]/20" style={`animation-delay: ${0.4 + i * 0.08}s`}>
            <div class="w-14 h-14 rounded-full bg-[var(--primary)]/15 flex items-center justify-center text-2xl">{s.icon}</div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic mb-1">— {s.product} —</p>
              <p class="text-lg italic text-[var(--primary)] leading-tight" style="font-family: var(--heading-font);">{s.supplier}</p>
            </div>
            <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--text-muted)] italic text-right">{s.distance}</span>
          </div>
        ))}

        <div class="resto-fade-up pt-6 text-center" style="animation-delay: 1s">
          <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic">— We know who grew it. So should you. —</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
