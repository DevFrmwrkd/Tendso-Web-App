---
/**
 * AboutO3 - Clinic / Mission Statement
 * Mission-driven layout. Big mission paragraph + three core principles.
 * Trustworthy institutional feel — what we stand for.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Our mission',
  tagline,
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const defaultPrinciples = [
  { title: 'Care, first', body: 'Every decision starts with what is best for the patient — not what is fastest or easiest.' },
  { title: 'Time, honored', body: 'Visits should not feel rushed. We schedule with room to actually listen.' },
  { title: 'Transparency', body: 'Plain language, real prices, and answers you can take home.' },
];

const principles = usps.length >= 3
  ? usps.slice(0, 3).map((u, i) => ({
      title: defaultPrinciples[i].title,
      body: u,
    }))
  : defaultPrinciples;
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    {/* Mission statement card */}
    <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl p-10 lg:p-16 border border-[var(--text)]/10 relative overflow-hidden mb-12">
      {/* Decorative quote mark */}
      <div class="absolute top-6 right-6 text-[8rem] leading-none text-[var(--primary)]/10 font-bold" style="font-family: var(--heading-font);">"</div>

      <div class="relative grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-10 lg:gap-14 items-start">
        {/* LEFT — Image */}
        {showImages && (
          <div class="relative aspect-square overflow-hidden rounded-2xl bg-[var(--bg)]">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">⚕</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--primary)]/15 to-transparent"></div>
          </div>
        )}

        {/* RIGHT — Mission */}
        <div>
          {showTagline && (
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--accent)] mb-4">— {tagline} —</p>
          )}
          {showHeadline && (
            <h2 class="font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2rem, 4.5vw, 3.25rem);">{headline}</h2>
          )}
          {showDescription && (
            <p class="text-[var(--text-muted)] leading-[1.85] mb-6" style="font-size: clamp(1rem, 1.2vw, 1.15rem);">{description}</p>
          )}
          <div class="pt-5 border-t border-[var(--text)]/10">
            <p class="text-sm text-[var(--accent)] font-semibold">— Signed by every provider at {businessName}</p>
          </div>
        </div>
      </div>
    </div>

    {/* Three principles */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {principles.map((p, i) => (
        <div class="clinic-fade-up bg-[var(--bg)] rounded-2xl p-7 border border-[var(--text)]/10 hover:border-[var(--primary)]/30 hover:-translate-y-1 transition-all" style={`animation-delay: ${0.4 + i * 0.1}s`}>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-2xl bg-[var(--primary)]/10 flex items-center justify-center">
              <span class="text-lg font-bold text-[var(--primary)]" style="font-family: var(--heading-font);">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--accent)]">Principle {String(i + 1).padStart(2, '0')}</p>
          </div>
          <h3 class="text-xl font-bold text-[var(--text)] mb-3" style="font-family: var(--heading-font);">{p.title}</h3>
          <p class="text-sm text-[var(--text-muted)] leading-[1.7]">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
