---
/**
 * AboutC - Tags Card Layout
 * White background with centered headline (italic accent on last words).
 * Content card below with image left, tagline + description + tags right.
 * Tags displayed as inline-flex pills with checkmark icons.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'About Us',
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;

const mainPhoto = photos[0] || '';

// Split headline to italicize last portion
// Find " in " or " for " to split, otherwise italicize last 2 words
function splitHeadline(text: string): { regular: string; italic: string } {
  const separators = [' in ', ' for ', ' with ', ' of '];
  for (const sep of separators) {
    const idx = text.toLowerCase().lastIndexOf(sep);
    if (idx !== -1) {
      return {
        regular: text.slice(0, idx),
        italic: text.slice(idx),
      };
    }
  }
  // Fallback: italicize last 2 words
  const words = text.split(' ');
  if (words.length > 2) {
    return {
      regular: words.slice(0, -2).join(' ') + ' ',
      italic: words.slice(-2).join(' '),
    };
  }
  return { regular: text, italic: '' };
}

const headlineParts = splitHeadline(headline);
---

<section id="about" class="reveal relative overflow-hidden bg-[var(--bg)] py-32 md:py-48 lg:py-64">
  {/* Modern background element */}
  <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[var(--primary)]/5 to-transparent pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">

    {/* Centered headline */}
    {showHeadline && (
      <div class="reveal mb-24 text-center md:mb-40">
        <h2 class="mx-auto max-w-5xl font-black leading-[1.1] tracking-tighter text-[var(--text)]"
            style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);"
            data-field="about_headline"
            set:html={headline}>
        </h2>
      </div>
    )}

    {/* Content card */}
    <div class="reveal reveal-delay-1 overflow-hidden rounded-[4rem] bg-[var(--surface)] shadow-[0_60px_120px_rgba(0,0,0,0.15)] border border-[var(--text)]/5">
      <div class="grid grid-cols-1 lg:grid-cols-2">

        {/* LEFT: Image */}
        {showImages && mainPhoto && (
          <div class="relative overflow-hidden group min-h-[500px]">
            <img
              src={mainPhoto}
              alt={businessName}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-[2s] group-hover:scale-110 grayscale-[0.2] group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--secondary)]/60 via-transparent to-transparent opacity-60"></div>
          </div>
        )}

        {/* RIGHT: Tagline + Description + Tags */}
        <div class="flex flex-col justify-center p-12 md:p-20 lg:p-24 relative overflow-hidden">
          {/* Subtle decoration */}
          <div class="absolute -right-20 -bottom-20 w-80 h-80 rounded-full bg-[var(--primary)]/5 blur-[100px] pointer-events-none"></div>

          {showTagline && (
            <div class="reveal-delay-2 reveal mb-10 w-fit rounded-full bg-[var(--primary)]/10 border border-[var(--primary)]/20 px-8 py-3">
              <p class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)]"
                 data-field="about_tagline"
                 set:html={tagline}>
              </p>
            </div>
          )}

          {showDescription && (
            <p class="reveal-delay-3 reveal mb-16 leading-[1.6] text-[var(--text-muted)] font-medium"
               style="font-size: var(--fs-lg);"
               data-field="about_description"
               set:html={description}>
            </p>
          )}

          {showTags && (
            <div class="reveal-delay-4 reveal flex flex-wrap gap-6">
              {tags.map((tag) => (
                <span class="group inline-flex items-center gap-4 rounded-[1.5rem] border border-[var(--text)]/10 bg-[var(--bg)] px-8 py-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--text)] transition-all duration-500 hover:border-[var(--primary)] hover:bg-[var(--primary)] hover:text-[var(--text-inverse)] hover:shadow-2xl hover:shadow-[var(--primary)]/30">
                  <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--primary)] text-[var(--text-inverse)] transition-all duration-500 group-hover:bg-[var(--text-inverse)] group-hover:text-[var(--primary)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
