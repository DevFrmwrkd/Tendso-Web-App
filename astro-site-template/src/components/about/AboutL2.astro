---
/**
 * AboutL2 - Automobile Shop / Mechanics Crew
 * Team-focused: featured lead mechanic + supporting crew cards with role badges.
 * Industrial card grid, ID-badge style headers.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Meet the crew',
  tagline,
  tags = [],
  photos = [],
  visibility,
} = Astro.props;

const leadPhoto = photos[0] || '';
const crewPhotos = photos.slice(1, 4);

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;

const roles = ['Lead Mechanic', 'Engine Tech', 'Body & Paint'];
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div
    class="absolute inset-0 z-0 opacity-[0.06] pointer-events-none"
    style="background-image: linear-gradient(var(--accent) 1px, transparent 1px), linear-gradient(90deg, var(--accent) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="text-center mb-14">
      {showTagline && (
        <p class="auto-fade-up text-[10px] font-bold font-mono uppercase tracking-[0.5em] text-[var(--primary)] mb-4">— {tagline} —</p>
      )}
      {showHeadline && (
        <h2 class="auto-fade-up font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-5" style="font-size: clamp(2.5rem, 6vw, 4.5rem); animation-delay: 0.1s;">{headline}</h2>
      )}
      {showDescription && (
        <p class="auto-fade-up text-[var(--text-muted)] max-w-2xl mx-auto leading-[1.7]" style="font-size: 1.1rem; animation-delay: 0.2s;">{description}</p>
      )}
    </div>

    {showImages && (
      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_1fr] gap-8 mb-12">
        {/* Lead mechanic */}
        <div class="auto-fade-up relative" style="animation-delay: 0.3s">
          <div class="relative aspect-[4/3] overflow-hidden bg-[var(--surface)] border-4 border-[var(--primary)]">
            {leadPhoto ? (
              <img src={leadPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.15) saturate(0.85);" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-9xl">👷</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/85 to-transparent"></div>
            {/* Badge tag */}
            <div class="absolute top-4 left-4 bg-[var(--primary)] text-[var(--bg)] px-3 py-2 font-mono font-black text-[10px] uppercase tracking-[0.3em]">LEAD · 01</div>
            <div class="absolute bottom-6 left-6 right-6">
              <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--primary)] mb-1">— Head of the bay —</p>
              <p class="text-2xl font-black text-[var(--text)] uppercase">{businessName}</p>
            </div>
          </div>
        </div>

        {/* Crew cards */}
        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-4">
          {[0, 1, 2].map((i) => (
            <div class="auto-fade-up bg-[var(--surface)] border border-[var(--accent)]/30 p-4 flex items-center gap-4" style={`animation-delay: ${0.4 + i * 0.1}s`}>
              <div class="relative w-14 h-14 shrink-0 overflow-hidden bg-[var(--bg)] border-2 border-[var(--primary)]">
                {crewPhotos[i] ? (
                  <img src={crewPhotos[i]} alt={roles[i]} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.1) saturate(0.85);" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-2xl">{['🔧', '⚙', '🎨'][i]}</div>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--primary)] mb-1">CREW · 0{i + 2}</p>
                <p class="text-sm font-black text-[var(--text)] uppercase truncate">{roles[i]}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {showTags && (
      <div class="auto-fade-up flex flex-wrap justify-center gap-2" style="animation-delay: 0.7s">
        {tags.map((tag) => (
          <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)] border border-[var(--accent)]/30 px-3 py-1.5">{tag}</span>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
