---
/**
 * AboutN3 - Restaurant / Chef Profile
 * Focused chef profile — portrait + bio + credentials.
 * Magazine "meet the chef" feature with quote and accolades.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Meet the chef',
  tagline,
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const portrait = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;

const defaultCredits = [
  { year: '2008', body: 'Apprenticed at Le Marché, Manila' },
  { year: '2013', body: 'Head chef · La Cucina, Cebu' },
  { year: '2019', body: 'Opened first restaurant' },
  { year: '2023', body: 'Featured in Manila Diner' },
];

const credits = usps.length > 0
  ? usps.slice(0, 4).map((u, i) => ({ year: defaultCredits[i].year, body: u }))
  : defaultCredits;
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1.3fr] gap-12 lg:gap-16 items-start">
      {/* LEFT — Portrait */}
      {showImages && (
        <div class="resto-fade-up relative lg:sticky lg:top-24">
          <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)]">
            {portrait ? (
              <img src={portrait} alt="Chef" class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.05) saturate(0.95);" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">👨‍🍳</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/40 via-transparent to-transparent"></div>

            {/* Caption */}
            <div class="absolute bottom-6 left-6 right-6">
              <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-2">— Behind the pass —</p>
              <p class="text-2xl italic text-[var(--bg)]" style="font-family: var(--heading-font);">Chef · {businessName}</p>
            </div>
          </div>
        </div>
      )}

      {/* RIGHT — Bio */}
      <div>
        {showTagline && (
          <p class="resto-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--accent)] italic mb-4">— {tagline} —</p>
        )}
        {showHeadline && (
          <h2 class="resto-fade-up font-bold italic leading-[1.05] text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5vw, 4rem); animation-delay: 0.1s;">{headline}</h2>
        )}

        {/* Pulled quote */}
        <div class="resto-fade-up border-l-4 border-[var(--primary)] pl-5 py-2 mb-8" style="animation-delay: 0.2s">
          <p class="text-xl italic text-[var(--primary)] leading-[1.5]" style="font-family: var(--heading-font); font-size: clamp(1.15rem, 1.8vw, 1.5rem);">
            "I cook the way my mother did — and the way I wished restaurants would."
          </p>
        </div>

        {showDescription && (
          <p class="resto-fade-up text-[var(--text-muted)] italic leading-[1.85] mb-10" style="font-size: 1.05rem; animation-delay: 0.3s;">{description}</p>
        )}

        {/* Career timeline */}
        <div class="resto-fade-up" style="animation-delay: 0.4s">
          <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic mb-5">— Path to the pass —</p>
          <div class="space-y-4">
            {credits.map((c, i) => (
              <div class="grid grid-cols-[80px_1fr] gap-4 items-baseline pb-3 border-b border-dashed border-[var(--text)]/20">
                <span class="text-xl font-bold text-[var(--primary)] italic" style="font-family: var(--heading-font);">{c.year}</span>
                <span class="text-sm text-[var(--text-muted)] italic">{c.body}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
