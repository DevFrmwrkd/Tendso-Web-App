---
/**
 * AboutK3 - Barber Shop / Master Letter
 * A handwritten-style letter from the master barber. Centered narrow column on cream paper.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'A Letter from the Master',
  usps = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
---

<section
  id="about"
  class="relative w-full bg-[var(--text)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  <div class="mx-auto max-w-3xl px-6 lg:px-12">

    {/* Letter envelope opening accent */}
    <div class="barber-fade-up text-center mb-10">
      <span class="text-[var(--accent)] text-3xl">✉</span>
      <p class="text-[10px] font-bold uppercase tracking-[0.5em] text-[var(--accent)] mt-3 italic">— A personal note —</p>
    </div>

    {/* Letter paper */}
    <div class="barber-letter relative bg-[var(--bg)] p-10 sm:p-14 md:p-20 shadow-[0_50px_100px_-25px_rgba(0,0,0,0.6)]">
      {/* Aged paper edges */}
      <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle at 20% 30%, rgba(122,26,44,0.04), transparent 40%), radial-gradient(circle at 80% 70%, rgba(201,169,97,0.05), transparent 40%);"></div>

      {/* Corner postmark/stamp */}
      <div class="absolute top-6 right-6 w-16 h-16 border-2 border-[var(--primary)]/30 rounded-full flex items-center justify-center text-[var(--primary)]/40 text-xs font-bold uppercase tracking-widest rotate-12">
        ★
      </div>

      {/* Heading */}
      {showHeadline && (
        <h2
          class="barber-fade-up font-bold tracking-tight text-[var(--text)] mb-3"
          style="font-size: clamp(2rem, 4.5vw, 3.5rem); animation-delay: 0.1s;"
        >
          {headline}
        </h2>
      )}

      <div class="barber-fade-up flex items-center gap-3 mb-10" style="animation-delay: 0.15s">
        <span class="text-[var(--primary)] text-sm">✂</span>
        <span class="h-px w-20 bg-[var(--primary)]/30"></span>
        <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--primary)]/70 italic">In my own hand</span>
      </div>

      {/* Letter salutation */}
      <p class="barber-fade-up text-base italic text-[var(--text-muted)] mb-6" style="animation-delay: 0.2s; font-size: 1.15rem;">
        Dear Friend,
      </p>

      {/* Body */}
      {showDescription && (
        <p class="barber-fade-up text-[var(--text-muted)] leading-[2] italic mb-8" style="animation-delay: 0.3s; font-size: clamp(1rem, 1.25vw, 1.15rem);">
          {description}
        </p>
      )}

      {/* USPs as numbered convictions */}
      {usps.length > 0 && (
        <div class="barber-fade-up mb-8" style="animation-delay: 0.4s">
          <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--primary)] italic mb-4">— What I believe —</p>
          <ol class="space-y-3">
            {usps.slice(0, 4).map((usp, i) => (
              <li class="flex items-baseline gap-3 text-[var(--text-muted)] italic" style="font-size: 1.05rem;">
                <span class="text-[var(--primary)] font-bold text-sm">{i + 1}.</span>
                <span class="leading-relaxed">{usp}</span>
              </li>
            ))}
          </ol>
        </div>
      )}

      {/* Sign-off */}
      <div class="barber-fade-up pt-8 border-t border-[var(--primary)]/15" style="animation-delay: 0.5s">
        <p class="text-[var(--text-muted)] italic mb-2" style="font-size: 1.05rem;">With my hands & heart,</p>
        <p class="text-3xl italic font-bold text-[var(--primary)]" style="font-size: 2rem;">— The Master Barber</p>
        <p class="text-xs uppercase tracking-[0.35em] text-[var(--primary)]/60 mt-2 italic">{businessName}</p>
      </div>

      {/* Wax seal */}
      <div class="absolute -bottom-6 -right-2 w-16 h-16 rounded-full bg-[var(--primary)] border-4 border-[var(--primary)] flex items-center justify-center shadow-xl rotate-12">
        <span class="text-[var(--accent)] text-2xl font-bold">✂</span>
      </div>
    </div>
  </div>
</section>

<style>
  .barber-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: barberFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }

  .barber-letter {
    opacity: 0;
    transform: translateY(40px) rotate(-1deg);
    animation: barberLetterReveal 1.3s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }
  @keyframes barberLetterReveal {
    to { opacity: 1; transform: translateY(0) rotate(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .barber-fade-up, .barber-letter { animation: none; opacity: 1; transform: none; }
  }
</style>
