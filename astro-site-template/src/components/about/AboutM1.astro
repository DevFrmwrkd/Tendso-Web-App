---
/**
 * AboutM1 — Salon · Lumière (house-of-beauty 2-col)
 *
 * Two-column: an arched founder portrait with a "2014" stamp on the left,
 * editorial headline + body + pulled quote on the right. Soft pink ground.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  signatureName?: string;
  signatureRole?: string;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = "A house of beauty, built on patience & precision.",
  tagline,
  tags = [],
  photos = [],
  signatureName,
  signatureRole,
  visibility,
} = Astro.props;

const photo = photos[0] || "";
const showHeadline = visibility?.aboutHeadline !== false;
const showDesc = visibility?.aboutDescription !== false;
const showImage = visibility?.aboutImages !== false && !!photo;
---

<section id="about" class="lum-about" data-component="ABOUT">
  <div class="lum-about-container">
    <p class="lum-about-eyebrow">— Our Story —</p>
    <div class="lum-about-grid">
      <div class="lum-about-image">
        {showImage && (
          <figure class="lum-about-figure">
            <img src={photo} alt={businessName} data-field="about.image" />
          </figure>
        )}
        <div class="lum-about-meta">
          <span class="lum-about-meta-label">Established</span>
          <span class="lum-about-meta-value">2014</span>
        </div>
      </div>
      <div class="lum-about-text">
        {showHeadline && (
          <h2 class="lum-about-headline" data-field="about.headline" set:html={headline}></h2>
        )}
        {showDesc && (
          <p class="lum-about-body" data-field="about.description" set:html={description}></p>
        )}
        {tagline && (
          <blockquote class="lum-about-quote">
            <span data-field="about.tagline" set:html={`“${tagline}”`}></span>
            {signatureName && (
              <cite class="lum-about-cite">
                — <span data-field="about.signature_name" set:html={signatureName}></span>
                {signatureRole && <>, <span data-field="about.signature_role" set:html={signatureRole}></span></>}
              </cite>
            )}
          </blockquote>
        )}
        {tags && tags.length > 0 && (
          <div class="lum-about-tags">
            {tags.map((t, i) => (
              <span class="lum-about-tag" data-field={`about.tags.${i}`} set:html={t}></span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .lum-about {
    --la-paper: color-mix(in srgb, var(--primary) 6%, var(--bg));
    --la-paper-2: color-mix(in srgb, var(--primary) 14%, var(--bg));
    --la-ink: var(--text);
    --la-ink-2: color-mix(in srgb, var(--text) 78%, var(--bg));
    --la-ink-3: color-mix(in srgb, var(--text) 55%, var(--bg));
    --la-accent: var(--primary);
    --la-serif: var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --la-sans: var(--body-font, "Inter", system-ui, sans-serif);

    background: color-mix(in srgb, var(--primary) 3%, var(--bg));
    color: var(--la-ink);
    font-family: var(--la-sans);
    padding: clamp(56px, 8vw, 96px) 0;
  }
  .lum-about-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .lum-about-eyebrow {
    text-align: center;
    font-family: var(--la-serif);
    font-style: italic;
    font-size: 14px;
    color: var(--la-accent);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin: 0 0 28px;
  }
  .lum-about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .lum-about-grid { grid-template-columns: 1fr; }
  }
  .lum-about-figure {
    position: relative;
    margin: 0;
    border-radius: clamp(160px, 22vw, 240px) clamp(160px, 22vw, 240px) 24px 24px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--la-paper-2);
  }
  .lum-about-figure img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .lum-about-image {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .lum-about-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    padding: 8px 14px;
    align-self: flex-start;
    background: color-mix(in srgb, var(--la-accent) 10%, var(--bg));
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--la-accent) 25%, transparent);
  }
  .lum-about-meta-label {
    font-family: var(--la-sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--la-accent);
    font-weight: 600;
  }
  .lum-about-meta-value {
    font-family: var(--la-serif);
    font-size: 16px;
    color: var(--la-ink);
    font-style: italic;
  }
  .lum-about-headline {
    font-family: var(--la-serif);
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    color: var(--la-ink);
    margin: 0;
    font-weight: 500;
  }
  .lum-about-body {
    margin: 22px 0 0;
    font-size: 16px;
    line-height: 1.65;
    color: var(--la-ink-2);
    max-width: 58ch;
  }
  .lum-about-quote {
    margin: 28px 0 0;
    padding: 0 0 0 18px;
    border-left: 2px solid var(--la-accent);
    font-family: var(--la-serif);
    font-style: italic;
    font-size: 20px;
    line-height: 1.4;
    color: var(--la-ink);
  }
  .lum-about-cite {
    display: block;
    margin-top: 10px;
    font-family: var(--la-sans);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--la-ink-3);
  }
  .lum-about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }
  .lum-about-tag {
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--la-ink) 18%, transparent);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--la-ink-2);
  }
</style>
