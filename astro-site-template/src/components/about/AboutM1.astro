---
/**
 * AboutM - Salon/Spa / Personal Touch Story
 * Asymmetric two-column with curved circular image frame on right.
 * Soft cream background, sage flourishes, script-italic accents.
 * Vibe: a personal letter from the founder.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Welcome to our sanctuary',
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;
---

<section
  id="about"
  class="relative w-full bg-[var(--surface)] py-24 md:py-32 overflow-hidden"
  style="font-family: var(--body-font);"
>
  {/* Soft watercolor blobs */}
  <div class="absolute -top-20 right-1/3 w-[400px] h-[400px] rounded-full bg-[var(--bg)] opacity-60 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 -left-20 w-[500px] h-[500px] rounded-full bg-[#dde5d3] opacity-40 blur-[120px] pointer-events-none"></div>

  {/* Top ornamental divider */}
  <div class="absolute top-10 left-1/2 -translate-x-1/2 flex items-center gap-5 z-10">
    <span class="h-px w-16 bg-[var(--primary)]/40"></span>
    <span class="text-[var(--accent)] text-xl salon-flourish-pulse">❀</span>
    <span class="h-px w-16 bg-[var(--primary)]/40"></span>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 mt-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-12 lg:gap-24 items-center">

      {/* LEFT — Text */}
      <div class="order-2 lg:order-1">
        {showTagline && (
          <div class="salon-fade-up mb-6 inline-flex items-center gap-2">
            <span class="text-[var(--accent)] text-sm">❀</span>
            <span class="text-[11px] font-medium uppercase tracking-[0.45em] text-[var(--primary)] italic">{tagline}</span>
          </div>
        )}

        {showHeadline && (
          <h2
            class="salon-fade-up font-normal leading-[1.05] tracking-tight text-[var(--text)] mb-3"
            style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); animation-delay: 0.1s;"
          >
            {headline}
          </h2>
        )}

        <div class="salon-fade-up mb-8 flex items-center gap-3" style="animation-delay: 0.2s">
          <span class="h-px w-12 bg-[var(--primary)]"></span>
          <span class="text-xs italic text-[var(--primary)]/80">— A note from the founder</span>
        </div>

        {showDescription && (
          <p
            class="salon-fade-up text-[var(--text-muted)] leading-[1.85] mb-10 italic font-light"
            style="font-size: clamp(1.05rem, 1.35vw, 1.2rem); animation-delay: 0.3s;"
          >
            {description}
          </p>
        )}

        {/* USPs as elegant list */}
        {usps.length > 0 && (
          <div class="salon-fade-up mb-10" style="animation-delay: 0.4s">
            <ul class="space-y-4">
              {usps.slice(0, 4).map((usp) => (
                <li class="flex items-start gap-4 text-[var(--text)]">
                  <span class="text-[var(--primary)] text-base mt-0.5">❀</span>
                  <span class="text-base leading-relaxed italic font-light" style="font-size: 1.1rem;">{usp}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Tags as soft chips */}
        {showTags && (
          <div class="salon-fade-up flex flex-wrap gap-2" style="animation-delay: 0.5s">
            {tags.map((tag) => (
              <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-[var(--primary)]/30 bg-[var(--bg)] text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--primary)] italic">
                {tag}
              </span>
            ))}
          </div>
        )}

        {/* Signature flourish */}
        <div class="salon-fade-up mt-12 flex items-end gap-4" style="animation-delay: 0.6s">
          <div class="flex flex-col">
            <span class="text-2xl italic text-[var(--primary)]" style="font-size: 1.75rem;">— {businessName}</span>
            <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--text-muted)]/60 mt-1">with love</span>
          </div>
          <span class="text-[var(--accent)] text-2xl mb-1">❀</span>
        </div>
      </div>

      {/* RIGHT — Circular framed image with floating accents */}
      {showImages && (
        <div class="order-1 lg:order-2 relative flex justify-center">
          <div class="salon-image-reveal relative">

            {/* Sage decorative ring */}
            <div class="absolute -inset-8 rounded-full border-2 border-dashed border-[var(--accent)]/30 salon-rotate-slow pointer-events-none"></div>

            {/* Main circular image */}
            <div class="relative w-72 h-72 sm:w-80 sm:h-80 lg:w-[420px] lg:h-[420px] rounded-full overflow-hidden bg-[var(--text)] shadow-[0_30px_60px_-15px_rgba(184,123,108,0.4)]">
              {mainPhoto ? (
                <img
                  src={mainPhoto}
                  alt={businessName}
                  class="absolute inset-0 w-full h-full object-cover"
                  style="filter: saturate(0.9) brightness(1.05);"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">❀</div>
              )}
              <div class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-[var(--primary)]/20"></div>
            </div>

            {/* Floating accent badges */}
            <div class="absolute top-2 -right-4 lg:-right-8 bg-[var(--bg)] rounded-full px-5 py-3 shadow-[0_15px_30px_-8px_rgba(184,123,108,0.3)] border border-[var(--accent)]/30 salon-float-1">
              <p class="text-[10px] uppercase tracking-[0.35em] text-[var(--accent)] italic">est. since</p>
              <p class="text-lg font-medium text-[var(--text)] text-center">2018</p>
            </div>

            <div class="absolute bottom-4 -left-4 lg:-left-10 bg-[var(--accent)] rounded-full p-5 shadow-[0_15px_30px_-8px_rgba(156,175,136,0.4)] salon-float-2">
              <span class="text-2xl text-[var(--bg)]">❀</span>
            </div>

            {/* Floating sage leaf */}
            <div class="absolute top-1/3 -left-12 text-[var(--accent)]/40 text-4xl salon-leaf-drift hidden lg:block">❀</div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .salon-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }

  .salon-image-reveal {
    opacity: 0;
    transform: scale(0.94);
    animation: salonImageReveal 1.3s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }
  @keyframes salonImageReveal { to { opacity: 1; transform: scale(1); } }

  .salon-rotate-slow {
    animation: salonRotate 60s linear infinite;
  }
  @keyframes salonRotate { to { transform: rotate(360deg); } }

  .salon-flourish-pulse {
    display: inline-block;
    animation: salonFlourish 4s ease-in-out infinite;
  }
  @keyframes salonFlourish {
    0%, 100% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(60deg) scale(1.15); }
  }

  .salon-float-1 {
    animation: salonFloat1 5s ease-in-out infinite;
  }
  @keyframes salonFloat1 {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .salon-float-2 {
    animation: salonFloat2 6s ease-in-out infinite;
  }
  @keyframes salonFloat2 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(8deg); }
  }

  .salon-leaf-drift {
    animation: salonLeafDrift 8s ease-in-out infinite;
  }
  @keyframes salonLeafDrift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(15px, -10px) rotate(20deg); }
    66% { transform: translate(-5px, 15px) rotate(-15deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .salon-fade-up, .salon-image-reveal { animation-duration: 0.01ms; opacity: 1; transform: none; }
    .salon-rotate-slow, .salon-flourish-pulse, .salon-float-1, .salon-float-2, .salon-leaf-drift { animation: none; }
  }
</style>
