---
/**
 * AboutL3 - Automobile Shop / Certifications
 * Lays out certification badges like an ASE/manufacturer-cert wall.
 * Three-column trust-grid with each cert as a stamped tile.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Certified to do the work',
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showTags = visibility?.aboutTags !== false && tags.length > 0;

const defaultCerts = [
  { code: 'ASE', label: 'Master Tech' },
  { code: 'OEM', label: 'Factory Trained' },
  { code: 'EPA', label: 'AC Refrigerant' },
  { code: 'I-CAR', label: 'Collision Repair' },
  { code: 'EV', label: 'Hybrid · Electric' },
  { code: 'DOT', label: 'Brake & Safety' },
];
const certs = usps.length > 0
  ? usps.slice(0, 6).map((u, i) => ({ code: defaultCerts[i % 6].code, label: u }))
  : defaultCerts;
---

<section id="about" class="relative w-full bg-[var(--bg)] py-24 md:py-32 overflow-hidden" style="font-family: var(--body-font);">
  <div class="relative z-10 mx-auto max-w-6xl px-6 lg:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-16 items-start mb-14">
      {/* LEFT — Headline + photo */}
      <div>
        {showTagline && (
          <p class="auto-fade-up text-[10px] font-bold font-mono uppercase tracking-[0.5em] text-[var(--primary)] mb-4">— {tagline} —</p>
        )}
        {showHeadline && (
          <h2 class="auto-fade-up font-black uppercase leading-[0.95] tracking-tight text-[var(--text)] mb-6" style="font-size: clamp(2.25rem, 5vw, 3.75rem); animation-delay: 0.1s;">{headline}</h2>
        )}
        {showDescription && (
          <p class="auto-fade-up text-[var(--text-muted)] leading-[1.75] mb-8" style="font-size: 1.05rem; animation-delay: 0.2s;">{description}</p>
        )}
        {showImages && mainPhoto && (
          <div class="auto-fade-up relative aspect-[4/3] overflow-hidden bg-[var(--surface)]" style="animation-delay: 0.3s">
            <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.15) saturate(0.85);" />
            <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-[var(--primary)]"></div>
            <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-[var(--primary)]"></div>
            <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-[var(--primary)]"></div>
            <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-[var(--primary)]"></div>
          </div>
        )}
      </div>

      {/* RIGHT — Certification wall */}
      <div>
        <div class="auto-fade-up flex items-center gap-3 mb-6" style="animation-delay: 0.25s">
          <span class="h-px w-12 bg-[var(--primary)]"></span>
          <p class="text-[10px] font-mono font-bold uppercase tracking-[0.4em] text-[var(--primary)]">// Credentials wall</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {certs.map((c, i) => (
            <div class="auto-fade-up relative bg-[var(--surface)] border-2 border-[var(--accent)]/30 p-4 hover:border-[var(--primary)] transition-colors group" style={`animation-delay: ${0.35 + i * 0.07}s`}>
              {/* Stamp ring */}
              <div class="absolute top-2 right-2 w-8 h-8 rounded-full border-2 border-[var(--primary)]/40 flex items-center justify-center">
                <span class="text-[8px] font-mono text-[var(--primary)]">✓</span>
              </div>
              <p class="text-2xl font-black text-[var(--primary)] mb-1 tracking-tight">{c.code}</p>
              <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-[var(--text-muted)] leading-tight">{c.label}</p>
            </div>
          ))}
        </div>
        {showTags && tags.length > 0 && (
          <div class="auto-fade-up mt-6 flex flex-wrap gap-2" style="animation-delay: 0.85s">
            {tags.map((tag) => (
              <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)] border border-[var(--accent)]/40 px-3 py-1.5">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
