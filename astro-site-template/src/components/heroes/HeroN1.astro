---
/**
 * HeroN - Restaurant / Warm Table
 * Cream background with terracotta accents, rising steam SVG animation,
 * dotted-leader menu treatment under headline, "Today's special" sidebar.
 * Vibe: warmth-of-the-kitchen, appetizing, hospitality.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'A table for you',
  testimonial,
  ctaLabel = 'Reserve a table',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'View the menu',
  ctaSecondaryLink = '#services',
  photos = [],
  services = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;

// Today's special - pulled from services
const todaysSpecial = services[0]?.name || 'Today\'s chef\'s choice';
---

<section
  id="hero"
  class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]"
  style="font-family: var(--body-font);"
>
  {/* Warm gradient blobs */}
  <div class="absolute -top-32 -right-20 w-[500px] h-[500px] rounded-full bg-[#f0d9a6] opacity-40 blur-[100px] pointer-events-none"></div>
  <div class="absolute -bottom-40 -left-20 w-[600px] h-[600px] rounded-full bg-[#e8c8a8] opacity-30 blur-[110px] pointer-events-none"></div>

  {/* Rising steam — over image area on lg+ */}
  <div class="absolute right-0 top-1/4 w-1/2 h-1/2 pointer-events-none hidden lg:block z-0">
    {Array.from({ length: 5 }).map((_, i) => (
      <span
        class="steam absolute"
        style={`left: ${30 + i * 10}%; animation-delay: ${i * 0.8}s;`}
      >
        <svg width="40" height="80" viewBox="0 0 40 80" fill="none">
          <path
            d="M20 80 Q15 65 22 50 Q28 35 18 20 Q14 10 22 0"
            stroke="var(--bg)"
            stroke-width="3"
            stroke-linecap="round"
            opacity="0.7"
            fill="none"
          />
        </svg>
      </span>
    ))}
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 pt-28 pb-20 lg:pt-32">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-20 items-center">

      {/* LEFT — Text */}
      <div>
        {showTagline && (
          <div class="rest-fade-up mb-8 inline-flex items-center gap-3">
            <span class="text-[var(--primary)]">✦</span>
            <span class="text-[11px] font-medium uppercase tracking-[0.45em] text-[var(--accent)] italic">
              {badgeText}
            </span>
            <span class="text-[var(--primary)]">✦</span>
          </div>
        )}

        {showHeadline && (
          <h1
            class="rest-fade-up font-normal leading-[0.95] tracking-tight text-[var(--text)] mb-8"
            style="font-size: clamp(3rem, 7.5vw, 6.5rem); animation-delay: 0.15s;"
          >
            {headline}
          </h1>
        )}

        {/* Menu-style dotted divider */}
        <div class="rest-fade-up flex items-center gap-3 mb-8 max-w-md" style="animation-delay: 0.25s">
          <span class="text-[var(--primary)] text-xs">❋</span>
          <span class="flex-1 border-b border-dotted border-[var(--primary)]/40 translate-y-[-3px]"></span>
          <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--text-muted)] italic">— Established</span>
          <span class="flex-1 border-b border-dotted border-[var(--primary)]/40 translate-y-[-3px]"></span>
          <span class="text-[var(--primary)] text-xs">❋</span>
        </div>

        {showDescription && (
          <p
            class="rest-fade-up max-w-[500px] text-[var(--text-muted)] leading-[1.8] mb-12 italic"
            style="font-size: clamp(1.05rem, 1.35vw, 1.25rem); animation-delay: 0.35s;"
          >
            {description}
          </p>
        )}

        {showButton && (
          <div
            class="rest-fade-up flex flex-col sm:flex-row gap-3 items-stretch sm:items-center"
            style="animation-delay: 0.45s;"
          >
            <a
              href={ctaLink}
              class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-10 py-4 text-xs font-medium uppercase tracking-[0.35em] transition-all hover:-translate-y-1 hover:shadow-[0_20px_40px_-12px_rgba(196,90,58,0.5)]"
              style="border-radius: 999px;"
            >
              <span class="text-base">✦</span> {ctaLabel}
            </a>
            <a
              href={ctaSecondaryLink}
              class="inline-flex items-center justify-center gap-2 text-[var(--text)] hover:text-[var(--primary)] px-6 py-4 text-xs font-medium uppercase tracking-[0.35em] transition-colors italic border-b border-[var(--text)]/30 hover:border-[var(--primary)]"
            >
              {ctaSecondaryLabel} →
            </a>
          </div>
        )}

        {showTestimonial && (
          <div
            class="rest-fade-up mt-14 max-w-[460px]"
            style="animation-delay: 0.55s;"
          >
            <div class="flex items-center gap-2 mb-3">
              {Array.from({ length: 5 }).map(() => (
                <span class="text-[var(--accent)] text-sm">★</span>
              ))}
            </div>
            <p class="text-base italic text-[var(--text-muted)] leading-relaxed mb-3 font-light" style="font-size: 1.1rem;">
              "{testimonial}"
            </p>
            <p class="text-[10px] uppercase tracking-[0.4em] text-[var(--primary)] italic">— A returning guest</p>
          </div>
        )}
      </div>

      {/* RIGHT — Food image with serving-plate frame */}
      {showImage && (
        <div class="relative">
          <div class="rest-image-reveal relative">
            {/* Plate outer ring (warm earth tone) */}
            <div class="absolute -inset-8 rounded-full bg-[#e8c8a8]/30 pointer-events-none hidden lg:block"></div>

            {/* Image in circular plate frame */}
            <div class="relative w-full aspect-square rounded-full overflow-hidden bg-[var(--text)] shadow-[0_40px_80px_-20px_rgba(42,31,28,0.5)]">
              {mainPhoto ? (
                <img
                  src={mainPhoto}
                  alt={businessName}
                  class="absolute inset-0 w-full h-full object-cover rest-plate-rotate"
                  style="filter: contrast(1.05) saturate(1.05) brightness(0.95);"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">✦</div>
              )}
              {/* Warm vignette */}
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/40 via-transparent to-transparent"></div>
              {/* Plate inner ring */}
              <div class="absolute inset-2 rounded-full border border-[var(--bg)]/30 pointer-events-none"></div>
            </div>

            {/* Floating "Today's Special" callout */}
            <div
              class="rest-special-card absolute top-4 -left-4 lg:-left-12 bg-[var(--bg)] rounded-2xl px-6 py-4 shadow-[0_20px_40px_-12px_rgba(42,31,28,0.25)] border-2 border-[var(--primary)]/30 max-w-[200px]"
            >
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[var(--primary)] text-xs">✦</span>
                <span class="text-[9px] font-medium uppercase tracking-[0.3em] text-[var(--primary)] italic">Today's Special</span>
              </div>
              <p class="text-base text-[var(--text)] italic leading-tight" style="font-size: 1.05rem;">
                {todaysSpecial}
              </p>
            </div>

            {/* Floating star rating */}
            <div
              class="rest-rating-card absolute bottom-6 -right-2 lg:-right-8 bg-[var(--text)] text-[var(--bg)] rounded-2xl px-5 py-3 shadow-[0_20px_40px_-12px_rgba(42,31,28,0.4)]"
            >
              <div class="flex items-center gap-1 mb-1">
                {Array.from({ length: 5 }).map(() => (
                  <span class="text-[var(--accent)] text-xs">★</span>
                ))}
              </div>
              <p class="text-[9px] uppercase tracking-[0.25em] text-[var(--bg)]/80">Highly recommended</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Rising steam */
  .steam {
    bottom: 0;
    opacity: 0;
    animation: steamRise 6s ease-out infinite;
  }
  @keyframes steamRise {
    0% { transform: translateY(0) scaleX(1); opacity: 0; }
    20% { opacity: 0.6; }
    80% { opacity: 0.4; }
    100% { transform: translateY(-200px) scaleX(1.4); opacity: 0; }
  }

  .rest-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: restFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes restFadeUp { to { opacity: 1; transform: translateY(0); } }

  .rest-image-reveal {
    opacity: 0;
    transform: scale(0.92);
    animation: restImageReveal 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  @keyframes restImageReveal { to { opacity: 1; transform: scale(1); } }

  /* Slow rotating plate image */
  .rest-plate-rotate {
    animation: restPlateSpin 120s linear infinite;
  }
  @keyframes restPlateSpin { to { transform: rotate(360deg); } }

  .rest-special-card {
    opacity: 0;
    transform: translateY(-15px) rotate(-2deg);
    animation: restFadeRotIn 1s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards;
  }
  .rest-rating-card {
    opacity: 0;
    transform: translateY(15px) rotate(3deg);
    animation: restFadeRotIn 1s cubic-bezier(0.22, 1, 0.36, 1) 1s forwards;
  }
  @keyframes restFadeRotIn {
    to { opacity: 1; transform: translateY(0) rotate(0deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .steam, .rest-plate-rotate { animation: none; }
    .rest-fade-up, .rest-image-reveal, .rest-special-card, .rest-rating-card {
      animation-duration: 0.01ms;
      opacity: 1;
      transform: none;
    }
  }
</style>
