---
/**
 * HeroK3 - Barber Shop / Vintage Poster
 * Cream background, ALL typography, no image. Ornate Victorian engraving feel
 * with decorative borders, est-since stamps, and old-newspaper hierarchy.
 * Distinct from K1/K2: no image at all, purely typographic, centered.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Established',
  ctaLabel = 'Book a cut',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'View services',
  ctaSecondaryLink = '#services',
  visibility,
} = Astro.props;

const showHeadline = visibility?.heroHeadline !== false;
const showDescription = visibility?.heroDescription !== false;
const showButton = visibility?.heroButton !== false;

const year = new Date().getFullYear() - 18;
---

<section
  id="hero"
  class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)] flex items-center"
  style="font-family: var(--body-font);"
>
  {/* Subtle paper grain */}
  <div
    class="absolute inset-0 opacity-[0.08] pointer-events-none"
    style="background-image: repeating-linear-gradient(0deg, transparent 0 2px, var(--text) 2px 3px), repeating-linear-gradient(90deg, transparent 0 3px, var(--text) 3px 4px);"
  ></div>

  {/* Outer ornate frame */}
  <div class="absolute inset-6 sm:inset-12 lg:inset-20 border-4 border-[var(--primary)] pointer-events-none"></div>
  <div class="absolute inset-8 sm:inset-14 lg:inset-[5.5rem] border border-[var(--primary)]/40 pointer-events-none"></div>

  {/* Corner ornaments */}
  <div class="absolute top-8 left-8 sm:top-14 sm:left-14 lg:top-[5.5rem] lg:left-[5.5rem] w-10 h-10 border-t-2 border-l-2 border-[var(--accent)] pointer-events-none"></div>
  <div class="absolute top-8 right-8 sm:top-14 sm:right-14 lg:top-[5.5rem] lg:right-[5.5rem] w-10 h-10 border-t-2 border-r-2 border-[var(--accent)] pointer-events-none"></div>
  <div class="absolute bottom-8 left-8 sm:bottom-14 sm:left-14 lg:bottom-[5.5rem] lg:left-[5.5rem] w-10 h-10 border-b-2 border-l-2 border-[var(--accent)] pointer-events-none"></div>
  <div class="absolute bottom-8 right-8 sm:bottom-14 sm:right-14 lg:bottom-[5.5rem] lg:right-[5.5rem] w-10 h-10 border-b-2 border-r-2 border-[var(--accent)] pointer-events-none"></div>

  <div class="relative z-10 w-full max-w-3xl mx-auto px-12 sm:px-20 lg:px-32 py-16 text-center">

    {/* Top — Est. stamp */}
    <div class="barber-fade-up mb-8 inline-flex items-center gap-4">
      <span class="h-px w-12 sm:w-16 bg-[var(--primary)]"></span>
      <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.5em] text-[var(--primary)]">
        ✦ {badgeText} {year} ✦
      </span>
      <span class="h-px w-12 sm:w-16 bg-[var(--primary)]"></span>
    </div>

    {/* Business name in ornate display */}
    <div class="barber-fade-up mb-3" style="animation-delay: 0.1s">
      <p
        class="font-bold uppercase tracking-[0.15em] text-[var(--primary)] leading-none"
        style="font-size: clamp(1.5rem, 3.5vw, 2.5rem);"
      >
        {businessName}
      </p>
    </div>

    {/* Decorative divider */}
    <div class="barber-fade-up flex items-center justify-center gap-3 mb-6" style="animation-delay: 0.15s">
      <span class="h-px w-16 sm:w-24 bg-[var(--accent)]"></span>
      <span class="text-[var(--primary)] text-xl">✂</span>
      <span class="h-px w-16 sm:w-24 bg-[var(--accent)]"></span>
    </div>

    {/* Main headline — huge serif */}
    {showHeadline && (
      <h1
        class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-2"
        style="font-size: clamp(2.5rem, 8vw, 6rem); animation-delay: 0.2s;"
      >
        {headline}
      </h1>
    )}

    {/* "Master Barbers" sub-credit */}
    <div class="barber-fade-up mt-3 mb-8" style="animation-delay: 0.25s">
      <p class="text-xs sm:text-sm italic text-[var(--primary)] tracking-[0.3em] uppercase">
        — Master Barbers & Razor Artisans —
      </p>
    </div>

    {/* Ornate horizontal flourish */}
    <div class="barber-fade-up flex items-center justify-center gap-2 mb-8" style="animation-delay: 0.3s">
      <span class="text-[var(--accent)] text-2xl">❋</span>
      <span class="h-px w-32 sm:w-48 bg-[var(--accent)]/50"></span>
      <span class="text-[var(--primary)] text-3xl">✦</span>
      <span class="h-px w-32 sm:w-48 bg-[var(--accent)]/50"></span>
      <span class="text-[var(--accent)] text-2xl">❋</span>
    </div>

    {/* Description — newspaper column style */}
    {showDescription && (
      <p
        class="barber-fade-up max-w-xl mx-auto text-[var(--text-muted)] leading-[1.85] mb-10 italic"
        style="font-size: clamp(0.95rem, 1.2vw, 1.1rem); animation-delay: 0.35s;"
      >
        {description}
      </p>
    )}

    {/* CTAs — vintage style */}
    {showButton && (
      <div
        class="barber-fade-up flex flex-col sm:flex-row gap-3 items-center justify-center"
        style="animation-delay: 0.4s"
      >
        <a
          href={ctaLink}
          class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-10 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-all hover:-translate-y-1"
        >
          <span>✂</span> {ctaLabel}
        </a>
        <a
          href={ctaSecondaryLink}
          class="inline-flex items-center justify-center gap-2 text-[var(--primary)] hover:text-[var(--text)] px-6 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-colors italic underline decoration-[var(--accent)] decoration-2 underline-offset-4"
        >
          {ctaSecondaryLabel}
        </a>
      </div>
    )}

    {/* Bottom marquee — services words */}
    <div class="barber-fade-up mt-12 pt-8 border-t border-[var(--primary)]/15" style="animation-delay: 0.5s">
      <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--primary)]/80 italic">
        Hot Towel · Straight Razor · Beard Trim · Hot Lather · Hand Cut
      </p>
    </div>
  </div>
</section>

<style>
  .barber-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: barberFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberFadeUp { to { opacity: 1; transform: translateY(0); } }

  @media (prefers-reduced-motion: reduce) {
    .barber-fade-up { animation: none; opacity: 1; transform: none; }
  }
</style>
