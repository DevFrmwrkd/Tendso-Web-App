---
/**
 * HeroM1 — Salon · Lumière (pink editorial)
 *
 * Two-column hero: serif headline + lede + dual CTAs on the left,
 * portrait-shaped image with floating "Booking fast" badge on the right.
 * Stat row at the bottom (years open / star rating / treatments).
 *
 * Theme: routes through --bg / --text / --primary / --heading-font /
 * --body-font so the Theme tab + inline content edits propagate. Local
 * --lum-* vars derive from globals — no hardcoded hex.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = "Where elegance begins",
  testimonial,
  ctaLabel = "Reserve Your Visit",
  ctaLink = "#contact",
  ctaSecondaryLabel = "View Services",
  ctaSecondaryLink = "#services",
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || "";

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false && !!mainPhoto;

// Split headline so the last 2-3 words can be italicized (Lumière signature).
// Strips trailing punctuation from the lead AND the emphasis so we never
// end up with a stray period dangling on its own line.
function splitHeadline(h: string): { lead: string; emphasis: string } {
  const cleaned = (h || "").trim().replace(/[.,;:!?]+\s*$/, "");
  const words = cleaned.split(/\s+/);
  if (words.length < 3) return { lead: cleaned, emphasis: "" };
  const cut = Math.max(words.length - 2, Math.floor(words.length * 0.6));
  return {
    lead: words.slice(0, cut).join(" "),
    emphasis: words.slice(cut).join(" "),
  };
}
const split = splitHeadline(headline);
---

<section
  id="hero"
  class="lum-hero"
  data-component="HERO"
>
  <div class="lum-container">
    <div class="lum-eyebrow-row">
      <span class="lum-brand-mark" data-field="business.name" set:html={businessName}></span>
    </div>

    <div class="lum-grid">
      <div class="lum-col-text">
        {showTagline && (
          <p class="lum-eyebrow" data-field="hero.badge_text" set:html={badgeText}></p>
        )}

        {showHeadline && (
          <h1 class="lum-display">
            <span data-field="hero.headline.lead">{split.lead}</span>
            {split.emphasis && (
              <>
                {" "}
                <em data-field="hero.headline.emphasis">{split.emphasis}</em>
              </>
            )}
            <span class="lum-display-dot">.</span>
          </h1>
        )}

        {showDescription && (
          <p class="lum-lede" data-field="hero.description" set:html={description}></p>
        )}

        {showButton && (
          <div class="lum-cta-row">
            <a class="lum-btn lum-btn-primary" href={ctaLink} data-field="hero.cta_label">
              {ctaLabel}
            </a>
            <a class="lum-btn lum-btn-ghost" href={ctaSecondaryLink} data-field="hero.cta_secondary_label">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        <div class="lum-stats">
          <div class="lum-stat">
            <span class="lum-stat-num">10k</span>
            <span class="lum-stat-label">Happy Clients</span>
          </div>
          <div class="lum-stat">
            <span class="lum-stat-num">5★</span>
            <span class="lum-stat-label">Average Rating</span>
          </div>
          <div class="lum-stat">
            <span class="lum-stat-num">12+</span>
            <span class="lum-stat-label">Years Crafting</span>
          </div>
        </div>
      </div>

      <div class="lum-col-image">
        {showImage && (
          <figure class="lum-figure">
            <div class="lum-figure-frame">
              <img src={mainPhoto} alt={businessName || "Salon portrait"} data-field="hero.image" />
            </div>
            <div class="lum-booking-pill">
              <span class="lum-pulse" aria-hidden="true"></span>
              <span>Booking fast</span>
            </div>
          </figure>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .lum-hero {
    --lum-paper:   color-mix(in srgb, var(--primary) 8%, var(--bg));
    --lum-paper-2: color-mix(in srgb, var(--primary) 14%, var(--bg));
    --lum-ink:     var(--text);
    --lum-ink-2:   color-mix(in srgb, var(--text) 80%, var(--bg));
    --lum-ink-3:   color-mix(in srgb, var(--text) 55%, var(--bg));
    --lum-accent:  var(--primary);
    --lum-rule:    color-mix(in srgb, var(--text) 10%, transparent);
    --lum-serif:   var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --lum-sans:    var(--body-font, "Inter", system-ui, sans-serif);

    background: var(--lum-paper);
    color: var(--lum-ink);
    font-family: var(--lum-sans);
    padding: 28px 0 clamp(56px, 8vw, 96px);
    border-bottom: 1px solid var(--lum-rule);
  }
  .lum-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }

  .lum-eyebrow-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(24px, 4vw, 48px);
  }
  .lum-brand-mark {
    font-family: var(--lum-serif);
    font-style: italic;
    font-size: 22px;
    color: var(--lum-ink);
    letter-spacing: -0.005em;
  }

  .lum-grid {
    display: grid;
    grid-template-columns: 1fr 0.95fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .lum-grid { grid-template-columns: 1fr; }
  }

  .lum-eyebrow {
    font-family: var(--lum-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--lum-accent);
    margin: 0 0 14px;
    letter-spacing: -0.005em;
  }
  .lum-display {
    font-family: var(--lum-serif);
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--lum-ink);
    font-weight: 500;
  }
  .lum-display em {
    font-style: italic;
    font-weight: 500;
  }
  .lum-display-dot {
    color: var(--lum-accent);
    margin-left: 2px;
  }
  .lum-lede {
    margin: 22px 0 0;
    font-size: 17px;
    line-height: 1.55;
    color: var(--lum-ink-2);
    max-width: 52ch;
  }

  .lum-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .lum-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 26px;
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--lum-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: 0.18s ease;
  }
  .lum-btn-primary {
    background: var(--lum-accent);
    color: #fff;
    border: 1px solid var(--lum-accent);
  }
  .lum-btn-primary:hover {
    filter: brightness(1.06);
    transform: translateY(-1px);
  }
  .lum-btn-ghost {
    background: transparent;
    color: var(--lum-ink);
    border: 1px solid color-mix(in srgb, var(--lum-ink) 25%, transparent);
  }
  .lum-btn-ghost:hover {
    background: var(--lum-paper-2);
  }

  .lum-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: clamp(36px, 5vw, 56px);
    padding-top: 28px;
    border-top: 1px solid var(--lum-rule);
    max-width: 480px;
  }
  .lum-stat { display: flex; flex-direction: column; gap: 4px; }
  .lum-stat-num {
    font-family: var(--lum-serif);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 500;
    color: var(--lum-accent);
    line-height: 1;
  }
  .lum-stat-label {
    font-size: 11px;
    color: var(--lum-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  /* ── Portrait image with floating booking pill ───────── */
  .lum-figure { margin: 0; position: relative; }
  .lum-figure-frame {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--lum-paper-2);
    border-radius: clamp(180px, 30vw, 280px) clamp(180px, 30vw, 280px) 24px 24px;
    overflow: hidden;
    box-shadow: 0 30px 60px color-mix(in srgb, var(--lum-accent) 18%, transparent);
  }
  .lum-figure-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lum-booking-pill {
    position: absolute;
    bottom: 18px;
    right: 18px;
    background: #fff;
    color: var(--lum-ink);
    padding: 10px 16px;
    border-radius: 999px;
    box-shadow: 0 12px 24px color-mix(in srgb, var(--lum-ink) 12%, transparent);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
  }
  .lum-pulse {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 0 0 #22c55e80;
    animation: lum-pulse 1.6s infinite;
  }
  @keyframes lum-pulse {
    0%   { box-shadow: 0 0 0 0   color-mix(in srgb, #22c55e 50%, transparent); }
    70%  { box-shadow: 0 0 0 8px color-mix(in srgb, #22c55e 0%, transparent); }
    100% { box-shadow: 0 0 0 0   color-mix(in srgb, #22c55e 0%, transparent); }
  }
</style>
