---
/**
 * HeroL2 - Automobile Shop / Garage Floor
 * Concrete-floor split layout with safety stripes and shop-bay numbering.
 * Big bay-door framing on the image, hazard tape accents.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Open bay · drive in',
  testimonial,
  ctaLabel = 'Book a bay',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'See services',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section
  id="hero"
  class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]"
  style="font-family: var(--body-font);"
>
  {/* Concrete floor texture */}
  <div
    class="absolute inset-0 z-0 opacity-[0.06] pointer-events-none"
    style="background-image: radial-gradient(circle at 25% 25%, var(--text) 1px, transparent 1px), radial-gradient(circle at 75% 75%, var(--text) 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  {/* Hazard tape — top */}
  <div class="absolute top-0 inset-x-0 h-3 z-10 overflow-hidden">
    <div class="h-full w-full" style="background-image: repeating-linear-gradient(45deg, var(--primary) 0 16px, var(--bg) 16px 32px);"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 pt-20 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-stretch">

      {/* LEFT — Image inside bay-door frame */}
      {showImage && (
        <div class="auto-fade-up relative order-2 lg:order-1">
          <div class="relative aspect-[4/5] bg-[var(--surface)] overflow-hidden border-4 border-[var(--primary)]">
            {/* Bay-door horizontal slats */}
            <div class="absolute inset-0 pointer-events-none z-10 opacity-30" style="background-image: repeating-linear-gradient(0deg, transparent 0 60px, var(--bg) 60px 64px);"></div>

            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.1) saturate(0.9);" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-9xl">🔧</div>
            )}

            {/* Bay number */}
            <div class="absolute top-4 left-4 z-20 bg-[var(--primary)] text-[var(--bg)] px-4 py-2 font-mono font-black text-xs tracking-[0.4em]">
              BAY 03
            </div>

            {/* Floor reflection gradient */}
            <div class="absolute bottom-0 inset-x-0 h-1/3 bg-gradient-to-t from-[var(--bg)]/80 to-transparent z-10"></div>
          </div>

          {/* Concrete floor block under image */}
          <div class="mt-3 h-2 bg-[var(--surface)] relative overflow-hidden">
            <div class="absolute inset-0" style="background-image: repeating-linear-gradient(90deg, var(--accent) 0 2px, transparent 2px 40px);"></div>
          </div>
        </div>
      )}

      {/* RIGHT — Text */}
      <div class="order-1 lg:order-2 flex flex-col justify-center">
        {showTagline && (
          <div class="auto-fade-up inline-flex items-center gap-2 mb-6 self-start">
            <span class="w-2 h-2 rounded-full bg-[var(--primary)] animate-pulse"></span>
            <span class="text-[10px] font-bold font-mono uppercase tracking-[0.4em] text-[var(--primary)]">{badgeText}</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="auto-fade-up font-black leading-[0.92] tracking-tight text-[var(--text)] mb-8 uppercase" style="font-size: clamp(2.5rem, 7vw, 5.5rem); animation-delay: 0.1s;">
            {headline}
          </h1>
        )}

        <div class="auto-fade-up h-1 w-20 bg-[var(--primary)] mb-8" style="animation-delay: 0.2s"></div>

        {showDescription && (
          <p class="auto-fade-up max-w-[520px] text-[var(--text-muted)] leading-[1.7] mb-10" style="font-size: clamp(1rem, 1.25vw, 1.15rem); animation-delay: 0.3s;">
            {description}
          </p>
        )}

        {showButton && (
          <div class="auto-fade-up flex flex-col sm:flex-row gap-3 mb-8" style="animation-delay: 0.4s">
            <a href={ctaLink} class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] text-[var(--bg)] px-8 py-4 text-xs font-black uppercase tracking-[0.3em] transition-all hover:-translate-y-0.5">
              {ctaLabel}
              <span class="text-base group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-3 border-2 border-[var(--accent)]/60 hover:border-[var(--accent)] text-[var(--text)] px-8 py-4 text-xs font-black uppercase tracking-[0.3em] transition-all">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {/* Bay stats strip */}
        <div class="auto-fade-up grid grid-cols-3 gap-4 mt-4 pt-8 border-t border-[var(--accent)]/30" style="animation-delay: 0.5s">
          <div>
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)] mb-1">Bays</p>
            <p class="text-3xl font-black text-[var(--text)]">04</p>
          </div>
          <div>
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)] mb-1">Hrs/wk</p>
            <p class="text-3xl font-black text-[var(--text)]">66</p>
          </div>
          <div>
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)] mb-1">Yrs</p>
            <p class="text-3xl font-black text-[var(--primary)]">18+</p>
          </div>
        </div>

        {showTestimonial && (
          <p class="auto-fade-up text-xs italic text-[var(--text-muted)] mt-6" style="animation-delay: 0.6s">"{testimonial}"</p>
        )}
      </div>
    </div>
  </div>

  {/* Hazard tape — bottom */}
  <div class="absolute bottom-0 inset-x-0 h-3 z-10 overflow-hidden">
    <div class="h-full w-full" style="background-image: repeating-linear-gradient(-45deg, var(--primary) 0 16px, var(--bg) 16px 32px);"></div>
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(24px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
