---
/**
 * HeroL4 - Automobile Shop / Tool Wall
 * Pegboard wall with tools laid out around the headline + image.
 * Lots of small framed tools as decoration, like a mechanic's organized garage.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Right tool for the job',
  testimonial,
  ctaLabel = 'Drop by the shop',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'What we fix',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;

// Tool icons laid out on the pegboard
const tools = ['🔧', '🔩', '⚙', '🔨', '🪛', '⛓'];
---

<section
  id="hero"
  class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]"
  style="font-family: var(--body-font);"
>
  {/* Pegboard dots */}
  <div
    class="absolute inset-0 z-0 opacity-[0.08] pointer-events-none"
    style="background-image: radial-gradient(circle at center, var(--text) 1px, transparent 1.5px); background-size: 28px 28px;"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 py-20">

    {/* Top label strip */}
    {showTagline && (
      <div class="auto-fade-up flex items-center gap-3 mb-10 justify-center">
        <span class="h-px w-12 bg-[var(--primary)]"></span>
        <span class="text-[10px] font-bold font-mono uppercase tracking-[0.5em] text-[var(--primary)]">{badgeText}</span>
        <span class="h-px w-12 bg-[var(--primary)]"></span>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">

      {/* LEFT — Tool wall column */}
      <div class="hidden lg:flex flex-col gap-4">
        {tools.slice(0, 3).map((t, i) => (
          <div class="auto-fade-up bg-[var(--surface)] border border-[var(--accent)]/30 p-5 flex flex-col items-center" style={`animation-delay: ${i * 0.08}s`}>
            <span class="text-4xl mb-2 text-[var(--primary)]">{t}</span>
            <span class="text-[9px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)]">No. {String(i + 1).padStart(2, '0')}</span>
          </div>
        ))}
      </div>

      {/* CENTER — Main content */}
      <div class="text-center">
        {showHeadline && (
          <h1 class="auto-fade-up font-black uppercase leading-[0.92] tracking-tight text-[var(--text)] mb-6" style="font-size: clamp(2.5rem, 6.5vw, 5rem); animation-delay: 0.15s;">
            {headline}
          </h1>
        )}

        {showImage && mainPhoto && (
          <div class="auto-fade-up relative my-8 max-w-md mx-auto" style="animation-delay: 0.25s">
            <div class="relative aspect-square overflow-hidden border-4 border-[var(--primary)] bg-[var(--surface)]">
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: contrast(1.1) saturate(0.9);" />
              {/* Hanging hook detail */}
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-1 h-3 bg-[var(--accent)]"></div>
              <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full border-2 border-[var(--accent)] bg-[var(--bg)]"></div>
            </div>
            <p class="mt-3 text-[10px] font-mono uppercase tracking-[0.4em] text-[var(--accent)]">— Toolbox · {businessName.toUpperCase()} —</p>
          </div>
        )}

        {showDescription && (
          <p class="auto-fade-up max-w-lg mx-auto text-[var(--text-muted)] leading-[1.7] mb-8" style="font-size: clamp(0.95rem, 1.2vw, 1.1rem); animation-delay: 0.35s;">
            {description}
          </p>
        )}

        {showButton && (
          <div class="auto-fade-up flex flex-col sm:flex-row gap-3 justify-center" style="animation-delay: 0.45s">
            <a href={ctaLink} class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] text-[var(--bg)] px-8 py-4 text-xs font-black uppercase tracking-[0.35em] transition-all hover:-translate-y-0.5">
              {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-3 border-2 border-[var(--accent)]/50 hover:border-[var(--accent)] text-[var(--text)] px-8 py-4 text-xs font-black uppercase tracking-[0.35em] transition-all">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {showTestimonial && (
          <p class="auto-fade-up text-xs italic text-[var(--text-muted)] mt-8 max-w-md mx-auto" style="animation-delay: 0.55s">"{testimonial}"</p>
        )}
      </div>

      {/* RIGHT — Tool wall column */}
      <div class="hidden lg:flex flex-col gap-4">
        {tools.slice(3, 6).map((t, i) => (
          <div class="auto-fade-up bg-[var(--surface)] border border-[var(--accent)]/30 p-5 flex flex-col items-center" style={`animation-delay: ${(i + 3) * 0.08}s`}>
            <span class="text-4xl mb-2 text-[var(--primary)]">{t}</span>
            <span class="text-[9px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)]">No. {String(i + 4).padStart(2, '0')}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .auto-fade-up { opacity: 0; transform: translateY(20px); animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .auto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
