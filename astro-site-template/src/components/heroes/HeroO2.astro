---
/**
 * HeroO2 - Clinic / Patient Welcome
 * Friendly patient-facing welcome with reassurance signals.
 * Trust badges, "now accepting new patients" banner, easy-booking emphasis.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Now accepting new patients',
  testimonial,
  ctaLabel = 'Book appointment',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Our services',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)] flex items-center" style="font-family: var(--body-font);">
  {/* Soft circular accents */}
  <div class="absolute top-0 -right-32 w-[400px] h-[400px] rounded-full opacity-[0.08]" style="background: var(--primary);"></div>
  <div class="absolute -bottom-40 -left-32 w-[500px] h-[500px] rounded-full opacity-[0.06]" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 py-20 w-full">

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">

      {/* LEFT — Text */}
      <div>
        {showTagline && (
          <div class="clinic-fade-up inline-flex items-center gap-2 mb-8 bg-[var(--accent)]/15 text-[var(--accent)] px-4 py-2 rounded-full">
            <span class="w-2 h-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
            <span class="text-[11px] font-semibold tracking-wide">{badgeText}</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6vw, 4.75rem); animation-delay: 0.1s;">
            {headline}
          </h1>
        )}

        {showDescription && (
          <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75] mb-8 max-w-lg" style="font-size: clamp(1rem, 1.2vw, 1.15rem); animation-delay: 0.2s;">
            {description}
          </p>
        )}

        {showButton && (
          <div class="clinic-fade-up flex flex-col sm:flex-row gap-3 mb-10" style="animation-delay: 0.3s">
            <a href={ctaLink} class="group inline-flex items-center justify-center gap-2 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-7 py-3.5 text-sm font-semibold rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-lg">
              {ctaLabel}
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-2 border-2 border-[var(--text)]/15 hover:border-[var(--primary)] text-[var(--text)] hover:text-[var(--primary)] px-7 py-3.5 text-sm font-semibold rounded-lg transition-all">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {/* Trust signal row */}
        <div class="clinic-fade-up grid grid-cols-3 gap-3 pt-6 border-t border-[var(--text)]/10" style="animation-delay: 0.4s">
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-full bg-[var(--accent)]/15 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-[var(--text)]">Insured</p>
              <p class="text-[10px] text-[var(--text-muted)]">All major plans</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-full bg-[var(--primary)]/15 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[var(--primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-[var(--text)]">Same-day</p>
              <p class="text-[10px] text-[var(--text-muted)]">Most visits</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-full bg-[var(--accent)]/15 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L3 7v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V7l-9-5z"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-[var(--text)]">Board-certified</p>
              <p class="text-[10px] text-[var(--text-muted)]">All providers</p>
            </div>
          </div>
        </div>

        {showTestimonial && (
          <p class="clinic-fade-up italic text-sm text-[var(--text-muted)] mt-8 max-w-md border-l-4 border-[var(--primary)] pl-4" style="animation-delay: 0.5s">"{testimonial}"</p>
        )}
      </div>

      {/* RIGHT — Image with patient-portal style card */}
      {showImage && (
        <div class="clinic-fade-up relative" style="animation-delay: 0.25s">
          <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)] rounded-3xl shadow-2xl">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">⚕</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/40 via-transparent to-transparent"></div>

            {/* Floating appointment card */}
            <div class="absolute bottom-6 left-6 right-6 bg-[var(--bg)] rounded-2xl p-5 shadow-xl border border-[var(--text)]/10">
              <div class="flex items-center justify-between mb-3">
                <p class="text-[10px] font-semibold uppercase tracking-wider text-[var(--accent)]">Next available</p>
                <span class="w-2 h-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
              </div>
              <p class="text-lg font-bold text-[var(--text)] mb-1">Today · 2:30 PM</p>
              <p class="text-xs text-[var(--text-muted)]">Dr. on call · {businessName}</p>
              <a href={ctaLink} class="block mt-3 text-center bg-[var(--primary)] text-[var(--bg)] text-xs font-semibold py-2.5 rounded-lg hover:-translate-y-0.5 transition-all">
                Reserve this slot →
              </a>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
