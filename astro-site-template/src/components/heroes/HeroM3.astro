---
/**
 * HeroM3 - Salon/Spa / Garden Bath
 * Botanical garden inspired. Vine flourishes, leaf decorations,
 * water/zen feel. Tall asymmetric image with botanical overlay.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Botanical · bespoke',
  testimonial,
  ctaLabel = 'Reserve a session',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Treatments',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]" style="font-family: var(--body-font);">
  {/* Botanical SVG decorations */}
  <svg class="absolute top-6 left-6 w-32 h-32 text-[var(--accent)] opacity-40 salon-sway" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 Q40 30 50 50 Q60 30 50 5 M50 50 Q35 65 30 90 M50 50 Q65 65 70 90 M50 50 Q25 55 10 70 M50 50 Q75 55 90 70" stroke="currentColor" stroke-width="1" fill="none"/>
    <circle cx="50" cy="20" r="3"/>
    <circle cx="35" cy="40" r="2"/>
    <circle cx="65" cy="40" r="2"/>
    <circle cx="25" cy="62" r="2"/>
    <circle cx="75" cy="62" r="2"/>
  </svg>
  <svg class="absolute bottom-10 right-10 w-40 h-40 text-[var(--accent)] opacity-30 salon-sway" style="animation-delay: 1.5s; transform: rotate(180deg);" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 5 Q40 30 50 50 Q60 30 50 5 M50 50 Q35 65 30 90 M50 50 Q65 65 70 90 M50 50 Q25 55 10 70 M50 50 Q75 55 90 70" stroke="currentColor" stroke-width="1" fill="none"/>
    <circle cx="50" cy="20" r="3"/>
  </svg>

  {/* Soft watercolor washes */}
  <div class="absolute top-1/4 -left-32 w-[400px] h-[400px] rounded-full opacity-25 blur-[100px]" style="background: var(--accent);"></div>
  <div class="absolute bottom-1/4 -right-20 w-[450px] h-[450px] rounded-full opacity-20 blur-[120px]" style="background: var(--primary);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 py-20 min-h-screen flex flex-col justify-center">

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-20 items-center">

      {/* LEFT — Text */}
      <div>
        {showTagline && (
          <div class="salon-fade-up flex items-center gap-3 mb-8">
            <span class="text-[var(--accent)] text-2xl">❦</span>
            <span class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic">— {badgeText} —</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="salon-fade-up font-light italic leading-[1.02] text-[var(--text)] mb-8" style="font-family: var(--heading-font); font-size: clamp(2.75rem, 7vw, 5.5rem); animation-delay: 0.1s;">
            {headline}
          </h1>
        )}

        {/* Garden divider */}
        <div class="salon-fade-up flex items-center gap-3 mb-8" style="animation-delay: 0.2s">
          <span class="h-px w-16 bg-[var(--accent)]"></span>
          <svg class="w-4 h-4 text-[var(--accent)]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8 8 8 16 12 22C16 16 16 8 12 2Z"/></svg>
          <span class="h-px w-16 bg-[var(--accent)]"></span>
        </div>

        {showDescription && (
          <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.85] mb-10 max-w-lg" style="font-size: clamp(1rem, 1.3vw, 1.2rem); animation-delay: 0.3s;">
            {description}
          </p>
        )}

        {showButton && (
          <div class="salon-fade-up flex flex-col sm:flex-row gap-3" style="animation-delay: 0.4s">
            <a href={ctaLink} class="group inline-flex items-center justify-center gap-3 bg-[var(--accent)] hover:bg-[var(--accent)] text-[var(--bg)] px-8 py-4 text-[11px] uppercase tracking-[0.4em] transition-all hover:-translate-y-0.5 rounded-full">
              {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-3 border border-[var(--accent)]/50 hover:border-[var(--accent)] text-[var(--accent)] px-8 py-4 text-[11px] uppercase tracking-[0.4em] transition-all rounded-full">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {showTestimonial && (
          <p class="salon-fade-up italic text-sm text-[var(--text-muted)] mt-10 max-w-md border-l-2 border-[var(--accent)]/40 pl-4" style="animation-delay: 0.5s">"{testimonial}"</p>
        )}
      </div>

      {/* RIGHT — Asymmetric image */}
      {showImage && (
        <div class="salon-fade-up relative" style="animation-delay: 0.25s">
          <div class="relative aspect-[3/4] overflow-hidden bg-[var(--surface)] rounded-[200px_200px_50px_50px]">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} data-field="hero.image" class="absolute inset-0 w-full h-full object-cover" style="filter: brightness(1.03) saturate(0.95);" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-9xl italic" style="font-family: var(--heading-font);">m</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--accent)]/20 to-transparent"></div>
          </div>

          {/* Floating leaf badge */}
          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 bg-[var(--bg)] rounded-full px-5 py-2.5 shadow-xl border border-[var(--accent)]/30">
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--accent)] italic flex items-center gap-2">
              <span class="text-base">❦</span> Sanctuary
            </p>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  .salon-sway { animation: salonSway 6s ease-in-out infinite; transform-origin: center; }
  @keyframes salonSway { 0%, 100% { transform: rotate(-3deg); } 50% { transform: rotate(3deg); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up, .salon-sway { animation: none; opacity: 1; transform: none; } }
</style>
