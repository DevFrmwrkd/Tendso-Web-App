---
/**
 * HeroO3 - Clinic / Specialty Focus
 * Specialty practice (cardiology, dermatology, etc.) focused hero.
 * Specialty icon prominent, credentials emphasized, "leading specialists" framing.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Specialty practice',
  testimonial,
  ctaLabel = 'Schedule consult',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Conditions we treat',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]" style="font-family: var(--body-font);">

  {/* Top credential bar */}
  <div class="clinic-fade-down relative z-20 bg-[var(--text)] text-[var(--bg)]">
    <div class="mx-auto max-w-7xl px-6 py-2.5 flex items-center justify-between text-[10px] font-medium uppercase tracking-wider">
      <span class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] animate-pulse"></span>
        Board-certified · {businessName.toUpperCase()}
      </span>
      <span class="hidden sm:inline opacity-70">Member · College of Physicians</span>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 pt-16 pb-20">

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">

      {/* LEFT — Text */}
      <div>
        {showTagline && (
          <div class="clinic-fade-up inline-flex items-center gap-3 mb-8">
            <div class="w-14 h-14 rounded-2xl bg-[var(--primary)]/10 border-2 border-[var(--primary)]/20 flex items-center justify-center">
              <svg class="w-7 h-7 text-[var(--primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-0.5">{badgeText}</p>
              <p class="text-xs text-[var(--text-muted)]">Decades of specialty experience</p>
            </div>
          </div>
        )}

        {showHeadline && (
          <h1 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6vw, 4.75rem); animation-delay: 0.1s;">
            {headline}
          </h1>
        )}

        <div class="clinic-fade-up h-1 w-16 bg-[var(--primary)] rounded-full mb-6" style="animation-delay: 0.2s"></div>

        {showDescription && (
          <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75] mb-10 max-w-lg" style="font-size: clamp(1rem, 1.2vw, 1.15rem); animation-delay: 0.3s;">
            {description}
          </p>
        )}

        {showButton && (
          <div class="clinic-fade-up flex flex-col sm:flex-row gap-3 mb-8" style="animation-delay: 0.4s">
            <a href={ctaLink} class="group inline-flex items-center justify-center gap-2 bg-[var(--primary)] text-[var(--bg)] px-7 py-3.5 text-sm font-semibold rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-lg">
              {ctaLabel}
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-2 border-2 border-[var(--text)]/15 hover:border-[var(--primary)] text-[var(--text)] hover:text-[var(--primary)] px-7 py-3.5 text-sm font-semibold rounded-lg transition-all">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {/* Credential ribbons */}
        <div class="clinic-fade-up flex flex-wrap gap-2 mt-4" style="animation-delay: 0.5s">
          {['MD · Specialist', 'Fellowship trained', '15+ years', 'Research published'].map((c) => (
            <span class="inline-flex items-center gap-1.5 bg-[var(--surface)] border border-[var(--text)]/10 px-3 py-1.5 rounded-full text-xs text-[var(--text-muted)]">
              <span class="w-1 h-1 rounded-full bg-[var(--accent)]"></span>
              {c}
            </span>
          ))}
        </div>

        {showTestimonial && (
          <p class="clinic-fade-up italic text-sm text-[var(--text-muted)] mt-8 max-w-md" style="animation-delay: 0.6s">"{testimonial}"</p>
        )}
      </div>

      {/* RIGHT — Specialist portrait */}
      {showImage && (
        <div class="clinic-fade-up relative" style="animation-delay: 0.25s">
          <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)] rounded-3xl">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">⚕</div>
            )}

            {/* Credential overlay */}
            <div class="absolute top-6 left-6 right-6 flex items-center justify-between">
              <div class="bg-[var(--bg)] backdrop-blur-sm rounded-full px-4 py-2 shadow-md border border-[var(--text)]/10">
                <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--primary)]">Specialist · MD</p>
              </div>
              <div class="bg-[var(--accent)]/95 text-[var(--bg)] rounded-full px-3 py-1.5 shadow-md">
                <p class="text-[10px] font-bold">★ Top-rated</p>
              </div>
            </div>

            {/* Bottom CV stat */}
            <div class="absolute bottom-6 left-6 right-6 bg-[var(--bg)]/95 backdrop-blur-sm rounded-2xl p-5 shadow-xl border border-[var(--text)]/10">
              <div class="grid grid-cols-3 gap-3">
                <div>
                  <p class="text-2xl font-bold text-[var(--primary)] leading-none">5K+</p>
                  <p class="text-[10px] text-[var(--text-muted)] mt-1 uppercase tracking-wider">Patients</p>
                </div>
                <div class="border-l border-[var(--text)]/10 pl-3">
                  <p class="text-2xl font-bold text-[var(--primary)] leading-none">15</p>
                  <p class="text-[10px] text-[var(--text-muted)] mt-1 uppercase tracking-wider">Years</p>
                </div>
                <div class="border-l border-[var(--text)]/10 pl-3">
                  <p class="text-2xl font-bold text-[var(--accent)] leading-none">98%</p>
                  <p class="text-[10px] text-[var(--text-muted)] mt-1 uppercase tracking-wider">Rated</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .clinic-fade-down { opacity: 0; transform: translateY(-10px); animation: clinicFadeDown 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes clinicFadeDown { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up, .clinic-fade-down { animation: none; opacity: 1; transform: none; } }
</style>
