---
/**
 * HeroL - Automobile Shop / Industrial Diagnostic
 * Full-bleed dark workshop background with technical corner markers + blueprint grid.
 * Bold engineering typography, rotating gear motif, safety-yellow primary CTA.
 * Vibe: garage-floor, no-nonsense, technical-spec.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Certified Mechanics',
  testimonial,
  ctaLabel = 'Get a free quote',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Our services',
  ctaSecondaryLink = '#services',
  photos = [],
  services = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;

// Top status bar / marquee items
const marqueeServices = services.length > 0
  ? services.slice(0, 6).map(s => s.name)
  : ['Engine Diagnostics', 'Brake Service', 'Oil Change', 'Tire Alignment', 'Transmission', 'AC Repair'];
---

<section
  id="hero"
  class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]"
  style="font-family: var(--body-font);"
>
  {/* Blueprint grid overlay */}
  <div
    class="absolute inset-0 z-0 opacity-[0.07] pointer-events-none"
    style="background-image: linear-gradient(rgba(74,107,138,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(74,107,138,0.6) 1px, transparent 1px); background-size: 50px 50px;"
  ></div>

  {/* Top status bar */}
  <div class="auto-fade-down relative z-20 border-b border-[var(--accent)]/30 bg-[var(--surface)]/80 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-6 py-3 flex items-center justify-between text-[10px] font-mono uppercase tracking-[0.25em]">
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-2 text-[var(--primary)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--primary)] animate-pulse"></span>
          BAY OPEN
        </span>
        <span class="hidden sm:inline text-[var(--text-muted)]">| Mon–Sat 08:00 – 18:00</span>
      </div>
      <div class="text-[var(--text)]">{businessName.toUpperCase()}</div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 pt-16 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">

      {/* LEFT — Text */}
      <div>
        {showTagline && (
          <div class="auto-fade-up mb-8 inline-flex items-center gap-3">
            <span class="auto-gear w-6 h-6 text-[var(--primary)]">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65a.5.5 0 00.12-.64l-2-3.46a.5.5 0 00-.61-.22l-2.49 1a7.03 7.03 0 00-1.69-.98l-.38-2.65A.5.5 0 0014 2h-4a.5.5 0 00-.49.42l-.38 2.65c-.61.25-1.17.58-1.69.98l-2.49-1a.5.5 0 00-.61.22l-2 3.46a.5.5 0 00.12.64l2.11 1.65c-.04.32-.07.64-.07.98s.03.66.07.98l-2.11 1.65a.5.5 0 00-.12.64l2 3.46a.5.5 0 00.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.05.24.25.42.49.42h4c.24 0 .44-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1a.5.5 0 00.61-.22l2-3.46a.5.5 0 00-.12-.64l-2.11-1.65zM12 15.5A3.5 3.5 0 0112 8.5a3.5 3.5 0 010 7z"/>
              </svg>
            </span>
            <span class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--primary)]">
              {badgeText}
            </span>
          </div>
        )}

        {showHeadline && (
          <h1
            class="auto-fade-up font-black leading-[0.95] tracking-tight text-[var(--text)] mb-8 uppercase"
            style="font-size: clamp(2.75rem, 7vw, 5.5rem); animation-delay: 0.1s;"
          >
            {headline}
          </h1>
        )}

        {/* Technical separator */}
        <div class="auto-fade-up flex items-center gap-2 mb-6" style="animation-delay: 0.2s">
          <span class="h-2 w-8 bg-[var(--primary)]"></span>
          <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--accent)]">// Spec sheet</span>
          <span class="h-px flex-1 bg-[var(--accent)]/30"></span>
        </div>

        {showDescription && (
          <p
            class="auto-fade-up max-w-[520px] text-[var(--text-muted)] leading-[1.7] mb-10"
            style="font-size: clamp(1rem, 1.25vw, 1.15rem); animation-delay: 0.3s;"
          >
            {description}
          </p>
        )}

        {showButton && (
          <div
            class="auto-fade-up flex flex-col sm:flex-row gap-3"
            style="animation-delay: 0.4s;"
          >
            <a
              href={ctaLink}
              class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-8 py-4 text-xs font-black uppercase tracking-[0.25em] transition-all hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(245,200,66,0.6)]"
            >
              {ctaLabel}
              <span class="text-base group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a
              href={ctaSecondaryLink}
              class="inline-flex items-center justify-center gap-3 border-2 border-[var(--accent)]/50 hover:border-[var(--accent)] text-[var(--text)] hover:bg-[var(--accent)]/10 px-8 py-4 text-xs font-black uppercase tracking-[0.25em] transition-all"
            >
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {showTestimonial && (
          <div
            class="auto-fade-up mt-12 max-w-md p-5 bg-[var(--surface)] border-l-4 border-[var(--primary)]"
            style="animation-delay: 0.5s;"
          >
            <p class="text-sm text-[var(--text)] leading-relaxed mb-2 italic">"{testimonial}"</p>
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-[var(--primary)]">— Verified customer</p>
          </div>
        )}
      </div>

      {/* RIGHT — Image with diagnostic overlay */}
      {showImage && (
        <div class="relative">
          {mainPhoto ? (
            <div class="relative aspect-[4/5] overflow-hidden bg-[var(--surface)]">
              {/* Corner markers — technical style */}
              <div class="absolute top-0 left-0 w-10 h-10 border-t-2 border-l-2 border-[var(--primary)] z-20"></div>
              <div class="absolute top-0 right-0 w-10 h-10 border-t-2 border-r-2 border-[var(--primary)] z-20"></div>
              <div class="absolute bottom-0 left-0 w-10 h-10 border-b-2 border-l-2 border-[var(--primary)] z-20"></div>
              <div class="absolute bottom-0 right-0 w-10 h-10 border-b-2 border-r-2 border-[var(--primary)] z-20"></div>

              <img
                src={mainPhoto}
                alt={businessName}
                class="auto-image-reveal absolute inset-0 w-full h-full object-cover"
                style="filter: contrast(1.15) saturate(0.85);"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/90 via-[var(--bg)]/20 to-transparent"></div>

              {/* Diagnostic readout panel */}
              <div class="absolute bottom-6 left-6 right-6 bg-[var(--surface)]/90 backdrop-blur-md border border-[var(--accent)]/40 px-5 py-3 z-20">
                <div class="flex items-center justify-between text-[10px] font-mono uppercase tracking-[0.2em]">
                  <span class="text-[var(--text-muted)]">// DIAGNOSTIC</span>
                  <span class="text-[var(--primary)]">ALL SYSTEMS GO</span>
                </div>
                <div class="mt-2 h-1 bg-[var(--bg)] overflow-hidden">
                  <div class="auto-progress h-full bg-[var(--primary)]"></div>
                </div>
              </div>

              {/* Floating stat */}
              <div class="absolute top-6 right-6 bg-[var(--primary)] text-[var(--bg)] px-4 py-3 z-20">
                <p class="text-[9px] font-bold uppercase tracking-[0.3em] opacity-70">Avg turn</p>
                <p class="font-black text-2xl leading-none">24h</p>
              </div>
            </div>
          ) : (
            <div class="aspect-[4/5] bg-[var(--surface)] flex items-center justify-center">
              <span class="text-[var(--accent)] text-9xl">⚙</span>
            </div>
          )}
        </div>
      )}
    </div>
  </div>

  {/* Marquee — services scrolling */}
  <div class="relative z-10 border-y border-[var(--accent)]/30 bg-[var(--surface)] py-4 overflow-hidden">
    <div class="auto-marquee flex items-center gap-8 whitespace-nowrap">
      {[...marqueeServices, ...marqueeServices, ...marqueeServices].map((s) => (
        <span class="flex items-center gap-8 text-[11px] font-mono uppercase tracking-[0.3em] text-[var(--text-muted)]">
          <span class="text-[var(--primary)]">◢</span>
          {s}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .auto-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: autoFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .auto-fade-down {
    opacity: 0;
    transform: translateY(-20px);
    animation: autoFadeDown 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes autoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes autoFadeDown { to { opacity: 1; transform: translateY(0); } }

  .auto-image-reveal {
    opacity: 0;
    transform: scale(1.05);
    animation: autoImageReveal 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }
  @keyframes autoImageReveal { to { opacity: 1; transform: scale(1); } }

  .auto-gear svg {
    animation: autoGearSpin 8s linear infinite;
  }
  @keyframes autoGearSpin { to { transform: rotate(360deg); } }

  .auto-progress {
    width: 0;
    animation: autoProgress 2s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards;
  }
  @keyframes autoProgress { to { width: 87%; } }

  .auto-marquee {
    animation: autoMarquee 30s linear infinite;
    width: max-content;
  }
  @keyframes autoMarquee { to { transform: translateX(-33.333%); } }

  @media (prefers-reduced-motion: reduce) {
    .auto-fade-up, .auto-fade-down, .auto-image-reveal { animation-duration: 0.01ms; opacity: 1; transform: none; }
    .auto-gear svg, .auto-marquee { animation: none; }
    .auto-progress { width: 87%; animation: none; }
  }
</style>
