---
/**
 * HeroM4 - Salon/Spa / Velvet Curtain
 * Dramatic theatrical entrance. Velvet curtain side panels framing
 * central reveal image. Luxe rich tone, intimate, "behind the curtain" feel.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Private appointments',
  testimonial,
  ctaLabel = 'Step inside',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Menu',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)] flex items-center" style="font-family: var(--body-font);">
  {/* Velvet curtain left */}
  <div class="absolute top-0 left-0 bottom-0 w-[14vw] z-10 pointer-events-none salon-curtain-left">
    <div class="h-full w-full" style="background: linear-gradient(90deg, var(--primary) 0%, var(--primary) 70%, transparent 100%); opacity: 0.6;"></div>
    <div class="absolute inset-0" style="background-image: repeating-linear-gradient(90deg, transparent 0 14px, rgba(0,0,0,0.15) 14px 16px); opacity: 0.5;"></div>
  </div>

  {/* Velvet curtain right */}
  <div class="absolute top-0 right-0 bottom-0 w-[14vw] z-10 pointer-events-none salon-curtain-right">
    <div class="h-full w-full" style="background: linear-gradient(-90deg, var(--primary) 0%, var(--primary) 70%, transparent 100%); opacity: 0.6;"></div>
    <div class="absolute inset-0" style="background-image: repeating-linear-gradient(90deg, transparent 0 14px, rgba(0,0,0,0.15) 14px 16px); opacity: 0.5;"></div>
  </div>

  {/* Soft center spotlight */}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vh] rounded-full opacity-20 blur-[120px] pointer-events-none" style="background: var(--accent);"></div>

  <div class="relative z-20 mx-auto max-w-5xl w-full px-12 sm:px-20 py-24 text-center">

    {showImage && mainPhoto && (
      <div class="salon-fade-up relative mx-auto mb-10 max-w-md">
        <div class="relative aspect-[3/4] overflow-hidden border-4 border-[var(--primary)]/40 rounded-t-full bg-[var(--surface)]">
          <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: brightness(1.05) contrast(1.05);" />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/50 via-transparent to-transparent"></div>
        </div>
        {/* Top tassel */}
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-[var(--primary)] shadow-lg"></div>
      </div>
    )}

    {showTagline && (
      <p class="salon-fade-up text-[10px] uppercase tracking-[0.55em] text-[var(--primary)] italic mb-6" style="animation-delay: 0.15s">— {badgeText} —</p>
    )}

    {showHeadline && (
      <h1 class="salon-fade-up font-light italic leading-[1.02] text-[var(--text)] mb-8" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6.5vw, 5rem); animation-delay: 0.2s;">
        {headline}
      </h1>
    )}

    <div class="salon-fade-up flex items-center gap-3 justify-center mb-8" style="animation-delay: 0.3s">
      <span class="h-px w-12 bg-[var(--primary)]/40"></span>
      <span class="text-[var(--primary)] text-base">✦</span>
      <span class="h-px w-12 bg-[var(--primary)]/40"></span>
    </div>

    {showDescription && (
      <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.85] mb-10 max-w-lg mx-auto" style="font-size: clamp(1rem, 1.3vw, 1.15rem); animation-delay: 0.4s;">
        {description}
      </p>
    )}

    {showButton && (
      <div class="salon-fade-up flex flex-col sm:flex-row gap-3 justify-center" style="animation-delay: 0.5s">
        <a href={ctaLink} class="group inline-flex items-center justify-center gap-2 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-10 py-4 text-[11px] uppercase tracking-[0.45em] transition-all hover:-translate-y-0.5 rounded-full">
          {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">✦</span>
        </a>
        <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-2 border border-[var(--primary)]/50 hover:border-[var(--primary)] text-[var(--primary)] px-10 py-4 text-[11px] uppercase tracking-[0.45em] transition-all rounded-full">
          {ctaSecondaryLabel}
        </a>
      </div>
    )}

    {showTestimonial && (
      <p class="salon-fade-up mt-12 italic text-sm text-[var(--text-muted)] max-w-md mx-auto" style="animation-delay: 0.6s">"{testimonial}"</p>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  .salon-curtain-left { transform: translateX(-20%); animation: curtainOpenLeft 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .salon-curtain-right { transform: translateX(20%); animation: curtainOpenRight 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes curtainOpenLeft { to { transform: translateX(0); } }
  @keyframes curtainOpenRight { to { transform: translateX(0); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up, .salon-curtain-left, .salon-curtain-right { animation: none; opacity: 1; transform: none; } }
</style>
