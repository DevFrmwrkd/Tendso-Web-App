---
/**
 * HeroN4 - Restaurant / Dinner Service
 * Evening dinner service feel. Dark warm tones, candlelight glow,
 * full-bleed dining image with overlay copy, "service tonight" status.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Dinner service · nightly',
  testimonial,
  ctaLabel = 'Book tonight',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Tonight\'s menu',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--text)] flex flex-col" style="font-family: var(--body-font);">

  {/* Full-bleed image with warm overlay */}
  {showImage && (
    <div class="absolute inset-0 z-0">
      {mainPhoto ? (
        <img src={mainPhoto} alt={businessName} class="resto-image-reveal w-full h-full object-cover" style="filter: brightness(0.5) contrast(1.1) saturate(1.1);" />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">🕯</div>
      )}
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 40%, rgba(0,0,0,0.85) 100%);"></div>
      {/* Candle glow */}
      <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] rounded-full opacity-20 blur-[100px]" style="background: var(--primary);"></div>
    </div>
  )}

  <div class="relative z-10 mx-auto max-w-6xl w-full px-6 lg:px-12 py-24 flex-1 flex items-center">

    <div class="max-w-2xl">
      {showTagline && (
        <div class="resto-fade-up inline-flex items-center gap-3 mb-8 bg-[var(--bg)]/10 backdrop-blur-sm border border-[var(--primary)]/40 rounded-full px-5 py-2">
          <span class="w-2 h-2 rounded-full bg-[var(--primary)] animate-pulse"></span>
          <span class="text-[10px] uppercase tracking-[0.45em] text-[var(--bg)] italic">{badgeText}</span>
        </div>
      )}

      {showHeadline && (
        <h1 class="resto-fade-up font-bold leading-[0.95] tracking-tight text-[var(--bg)] mb-8" style="font-family: var(--heading-font); font-size: clamp(2.75rem, 7vw, 6rem); animation-delay: 0.15s;">
          {headline}
        </h1>
      )}

      <div class="resto-fade-up flex items-center gap-3 mb-8" style="animation-delay: 0.25s">
        <span class="h-px w-16 bg-[var(--primary)]"></span>
        <span class="text-[var(--primary)] text-base">✦</span>
        <span class="text-[10px] uppercase tracking-[0.45em] text-[var(--bg)]/70 italic">— Reservations · {businessName} —</span>
      </div>

      {showDescription && (
        <p class="resto-fade-up text-[var(--bg)]/85 leading-[1.8] mb-10 max-w-xl italic" style="font-size: clamp(1.05rem, 1.4vw, 1.2rem); animation-delay: 0.35s;">
          {description}
        </p>
      )}

      {showButton && (
        <div class="resto-fade-up flex flex-col sm:flex-row gap-3" style="animation-delay: 0.45s">
          <a href={ctaLink} class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-10 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-all hover:-translate-y-0.5">
            {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
          <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-3 border-2 border-[var(--bg)]/40 hover:border-[var(--bg)] text-[var(--bg)] px-10 py-4 text-xs font-bold uppercase tracking-[0.35em] transition-all">
            {ctaSecondaryLabel}
          </a>
        </div>
      )}

      {showTestimonial && (
        <p class="resto-fade-up italic text-sm text-[var(--bg)]/80 mt-12 max-w-md" style="animation-delay: 0.55s">"{testimonial}"</p>
      )}
    </div>
  </div>

  {/* Bottom service-time strip */}
  <div class="relative z-10 bg-[var(--text)]/80 backdrop-blur-sm border-t border-[var(--primary)]/40 py-4">
    <div class="mx-auto max-w-6xl px-6 lg:px-12 flex items-center justify-between text-[10px] uppercase tracking-[0.4em] text-[var(--bg)]/70 italic">
      <span>— Open 5:30 – 10:30 PM —</span>
      <span class="hidden sm:inline text-[var(--primary)]">✦ Last seating · 9:30 PM</span>
    </div>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  .resto-image-reveal { opacity: 0; transform: scale(1.05); animation: restoImageReveal 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoImageReveal { to { opacity: 1; transform: scale(1); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up, .resto-image-reveal { animation: none; opacity: 1; transform: none; } }
</style>
