---
/**
 * HeroO5 - Clinic / Family Care
 * Multi-generational family practice. Warm, welcoming, "from kids to grandparents".
 * Friendly aesthetic, family-oriented imagery, age-spectrum service framing.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Family medicine · all ages',
  testimonial,
  ctaLabel = 'Schedule your visit',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'For your family',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;

const ageGroups = [
  { age: 'Newborn', range: '0 — 12 mo', icon: '👶' },
  { age: 'Children', range: '1 — 12 yrs', icon: '🧒' },
  { age: 'Teens', range: '13 — 18', icon: '👦' },
  { age: 'Adults', range: '19 — 65', icon: '👨' },
  { age: 'Seniors', range: '65+', icon: '👴' },
];
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)]" style="font-family: var(--body-font);">

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 py-20 min-h-screen flex flex-col justify-center">

    {/* Top photo + headline split */}
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-16 items-center mb-16">

      {/* LEFT — Family photo */}
      {showImage && (
        <div class="clinic-fade-up relative">
          <div class="relative aspect-[5/6] overflow-hidden bg-[var(--surface)] rounded-[40px]">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl">👨‍👩‍👧</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/20 to-transparent"></div>

            {/* Floating welcome card */}
            <div class="absolute top-5 left-5 bg-[var(--bg)] rounded-2xl px-4 py-3 shadow-lg border border-[var(--text)]/10">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
                <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--accent)]">Open today</p>
              </div>
            </div>

            {/* Floating family count */}
            <div class="absolute bottom-5 right-5 bg-[var(--primary)] text-[var(--bg)] rounded-2xl px-5 py-3 shadow-xl">
              <p class="text-[9px] font-semibold uppercase tracking-wider opacity-80 mb-0.5">Families served</p>
              <p class="text-2xl font-bold leading-none">2,400+</p>
            </div>
          </div>
        </div>
      )}

      {/* RIGHT — Text */}
      <div>
        {showTagline && (
          <div class="clinic-fade-up inline-flex items-center gap-2 mb-7 bg-[var(--primary)]/12 text-[var(--primary)] px-4 py-2 rounded-full">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span class="text-[11px] font-semibold tracking-wide">{badgeText}</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="clinic-fade-up font-bold leading-[1.05] tracking-tight text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6vw, 4.75rem); animation-delay: 0.1s;">
            {headline}
          </h1>
        )}

        {showDescription && (
          <p class="clinic-fade-up text-[var(--text-muted)] leading-[1.75] mb-8 max-w-lg" style="font-size: clamp(1rem, 1.2vw, 1.15rem); animation-delay: 0.2s;">
            {description}
          </p>
        )}

        {showButton && (
          <div class="clinic-fade-up flex flex-col sm:flex-row gap-3" style="animation-delay: 0.3s">
            <a href={ctaLink} class="group inline-flex items-center justify-center gap-2 bg-[var(--primary)] text-[var(--bg)] px-7 py-3.5 text-sm font-semibold rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-lg">
              {ctaLabel}
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-2 border-2 border-[var(--text)]/15 hover:border-[var(--primary)] text-[var(--text)] hover:text-[var(--primary)] px-7 py-3.5 text-sm font-semibold rounded-lg transition-all">
              {ctaSecondaryLabel}
            </a>
          </div>
        )}

        {showTestimonial && (
          <p class="clinic-fade-up italic text-sm text-[var(--text-muted)] mt-8 max-w-md border-l-4 border-[var(--accent)] pl-4" style="animation-delay: 0.4s">"{testimonial}"</p>
        )}
      </div>
    </div>

    {/* Age-group strip */}
    <div class="clinic-fade-up bg-[var(--surface)] rounded-3xl p-6 lg:p-8 border border-[var(--text)]/10" style="animation-delay: 0.5s">
      <div class="text-center mb-5">
        <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)] mb-1">— Care across every life stage —</p>
        <p class="text-sm text-[var(--text-muted)]">From your newborn's first visit to your grandparent's annual checkup.</p>
      </div>
      <div class="grid grid-cols-5 gap-2 sm:gap-4">
        {ageGroups.map((g) => (
          <div class="text-center bg-[var(--bg)] rounded-2xl py-4 border border-[var(--text)]/5 hover:border-[var(--primary)]/30 transition-colors">
            <div class="text-3xl mb-1">{g.icon}</div>
            <p class="text-xs font-bold text-[var(--text)] leading-tight">{g.age}</p>
            <p class="text-[10px] text-[var(--text-muted)] mt-0.5">{g.range}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .clinic-fade-up { opacity: 0; transform: translateY(20px); animation: clinicFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes clinicFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .clinic-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
