---
/**
 * HeroN3 - Restaurant / Reservation Desk
 * Reservation-card aesthetic — booking-focused hero. Like a hostess station
 * placecard with seating diagram cue and "we're holding your table" feel.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Reservations recommended',
  testimonial,
  ctaLabel = 'Reserve your table',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Browse menu',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';
const year = new Date().getFullYear();

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)] flex items-center" style="font-family: var(--body-font);">

  {/* Subtle linen weave */}
  <div class="absolute inset-0 z-0 opacity-[0.05] pointer-events-none" style="background-image: linear-gradient(45deg, var(--accent) 1px, transparent 1px), linear-gradient(-45deg, var(--accent) 1px, transparent 1px); background-size: 30px 30px;"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 lg:px-12 py-20 w-full">

    {/* Reservation card */}
    <div class="resto-fade-up bg-[var(--surface)] border-2 border-[var(--text)]/20 relative" style="box-shadow: 0 50px 100px -25px rgba(42,31,28,0.3);">
      {/* Top tab label */}
      <div class="absolute -top-4 left-10 bg-[var(--primary)] text-[var(--bg)] px-5 py-2 font-bold text-[10px] uppercase tracking-[0.4em] italic shadow-md">
        Hostess station
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr]">
        {/* LEFT — Reservation details */}
        <div class="p-8 lg:p-12 border-b lg:border-b-0 lg:border-r-2 border-dashed border-[var(--text)]/20">
          {showTagline && (
            <p class="text-[10px] uppercase tracking-[0.5em] text-[var(--accent)] italic mb-3">— {badgeText} —</p>
          )}
          {showHeadline && (
            <h1 class="font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-8" style="font-family: var(--heading-font); font-size: clamp(2.25rem, 5.5vw, 4.25rem);">{headline}</h1>
          )}

          {/* Reservation form rows */}
          <div class="space-y-4 mb-8">
            <div class="flex items-baseline gap-4 pb-2 border-b-2 border-dotted border-[var(--text)]/30">
              <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic w-20 shrink-0">— Service —</span>
              <span class="text-base text-[var(--text)] italic">Dinner</span>
            </div>
            <div class="flex items-baseline gap-4 pb-2 border-b-2 border-dotted border-[var(--text)]/30">
              <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic w-20 shrink-0">— Hours —</span>
              <span class="text-base text-[var(--text)] italic">5:30 – 10:30 PM</span>
            </div>
            <div class="flex items-baseline gap-4 pb-2 border-b-2 border-dotted border-[var(--text)]/30">
              <span class="text-[10px] uppercase tracking-[0.4em] text-[var(--accent)] italic w-20 shrink-0">— Seats —</span>
              <span class="text-base text-[var(--text)] italic">Limited tables · 32 covers</span>
            </div>
          </div>

          {showDescription && (
            <p class="text-[var(--text-muted)] italic leading-[1.8] mb-8 max-w-md" style="font-size: 1rem;">{description}</p>
          )}

          {showButton && (
            <div class="flex flex-col sm:flex-row gap-3">
              <a href={ctaLink} class="group inline-flex items-center justify-center gap-2 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-7 py-3.5 text-xs font-bold uppercase tracking-[0.3em] transition-all hover:-translate-y-0.5">
                {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">→</span>
              </a>
              <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-2 border-2 border-[var(--text)]/40 hover:border-[var(--text)] text-[var(--text)] px-7 py-3.5 text-xs font-bold uppercase tracking-[0.3em] transition-all">
                {ctaSecondaryLabel}
              </a>
            </div>
          )}
        </div>

        {/* RIGHT — Image + stamp */}
        {showImage && (
          <div class="p-6 lg:p-8 flex flex-col">
            <div class="relative aspect-[3/4] overflow-hidden bg-[var(--bg)] mb-4">
              {mainPhoto ? (
                <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--accent)] text-9xl">🍷</div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/30 to-transparent"></div>
              {/* Corner reservation tag */}
              <div class="absolute top-4 right-4 bg-[var(--primary)] text-[var(--bg)] px-3 py-1.5 text-[9px] font-bold uppercase tracking-[0.35em]">RESERVED</div>
            </div>

            {/* Reservation stamp */}
            <div class="text-center pt-3 border-t-2 border-dashed border-[var(--text)]/20">
              <p class="text-[9px] uppercase tracking-[0.4em] text-[var(--accent)] italic mb-1">— Ticket no. —</p>
              <p class="text-2xl font-bold text-[var(--primary)] tracking-tight" style="font-family: var(--heading-font);">№ {Math.floor(Math.random() * 900 + 100)} · {year}</p>
            </div>
          </div>
        )}
      </div>

      {/* Bottom footer */}
      <div class="border-t-2 border-dashed border-[var(--text)]/20 px-8 py-3 flex items-center justify-between text-[9px] uppercase tracking-[0.4em] text-[var(--text-muted)] italic">
        <span>{businessName}</span>
        {showTestimonial && <span class="hidden md:inline">"{testimonial}"</span>}
        <span>est. {year}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .resto-fade-up { opacity: 0; transform: translateY(20px); animation: restoFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes restoFadeUp { to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .resto-fade-up { animation: none; opacity: 1; transform: none; } }
</style>
