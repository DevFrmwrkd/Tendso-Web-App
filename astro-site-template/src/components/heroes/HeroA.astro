---
/**
 * HeroA - Split Dark Modern
 * Dark background (#0a0a0a) with split grid layout: content left (45%) + image right (55%).
 * Ported from hero-styles.ts generateHeroStyle1.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText,
  testimonial,
  ctaLabel = 'Work with us',
  ctaLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

// Visibility defaults (all visible unless explicitly false)
const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden bg-[var(--bg)] py-20 md:py-32">
  {/* Modern background element */}
  <div class="absolute -top-[10%] -right-[10%] w-[60%] h-[60%] rounded-full bg-[var(--primary)]/5 blur-[120px] pointer-events-none"></div>
  <div class="absolute -bottom-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-[var(--secondary)]/5 blur-[100px] pointer-events-none"></div>

  <div class="mx-auto grid max-w-[1500px] grid-cols-1 items-center gap-16 px-6 md:grid-cols-2 md:px-16 lg:gap-24 lg:px-24">

    {/* Content Side */}
    <div class="hero-content order-2 flex flex-col justify-center md:order-1">

      {showTagline && (
        <div class="reveal mb-10 w-fit items-center gap-4 rounded-full border border-[var(--text)]/10 bg-[var(--surface)] px-6 py-3 shadow-xl shadow-black/5">
          <span class="flex items-center gap-3">
            <span class="h-3 w-3 rounded-full bg-[var(--primary)] shadow-[0_0_15px_var(--primary)] animate-pulse-dot"></span>
            <span class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.25em] text-[var(--text-muted)]" data-field="hero_badge_text" set:html={badgeText}></span>
          </span>
        </div>
      )}

      {showHeadline && (
        <h1 class="reveal-delay-1 reveal mb-8 font-bold leading-[1.05] tracking-tight text-[var(--text)]"
            style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);"
            data-field="tagline"
            set:html={headline}>
        </h1>
      )}

      {showDescription && (
        <p class="reveal-delay-2 reveal mb-14 max-w-[500px] leading-[1.6] text-[var(--text-muted)] font-medium"
           style="font-size: var(--fs-lg);"
           data-field="about"
           set:html={description}>
        </p>
      )}

      {showButton && (
        <div class="reveal-delay-3 reveal">
          <a href={ctaLink}
             class="group inline-flex w-fit items-center justify-center gap-4 rounded-full bg-[var(--primary)] px-10 py-6 text-[var(--fs-sm)] font-bold uppercase tracking-widest text-[var(--text-inverse)] transition-all duration-500 hover:scale-105 hover:shadow-[0_20px_50px_rgba(var(--primary-rgb),0.4)] hover:-translate-y-1">
            <span data-field="hero_cta.label" set:html={ctaLabel}></span>
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--text-inverse)] text-[var(--primary)] transition-all duration-500 group-hover:rotate-[360deg]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 7h10v10"></path>
                <path d="M7 17L17 7"></path>
              </svg>
            </span>
          </a>
        </div>
      )}
    </div>

    {/* Image Side */}
    {showImage && (
      <div class="hero-image relative order-1 md:order-2">
        <div class="relative overflow-hidden rounded-[3rem] lg:rounded-[5rem] shadow-2xl border border-[var(--text)]/5 group">
          {mainPhoto ? (
            <img 
              src={mainPhoto} 
              alt={businessName} 
              class="aspect-[4/5] w-full object-cover transition-transform duration-[2s] group-hover:scale-110" 
            />
          ) : (
            <div class="aspect-[4/5] w-full bg-[var(--surface)]"></div>
          )}

          {/* Floating Testimonial Card */}
          {showTestimonial && (
            <div class="reveal-delay-4 reveal absolute bottom-8 left-8 right-8 rounded-[2rem] bg-[var(--surface)]/80 p-8 shadow-2xl backdrop-blur-2xl border border-[var(--text)]/10 md:bottom-12 md:left-12 lg:max-w-[350px] lg:right-auto">
              <div class="mb-4 flex gap-1.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="h-4 w-4 fill-[var(--primary)]" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                  </svg>
                ))}
              </div>
              <p class="text-[var(--fs-xs)] font-bold italic leading-[1.6] text-[var(--text)] tracking-tight">&ldquo;<span data-field="hero_testimonial" set:html={testimonial}></span>&rdquo;</p>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .hero-image {
    opacity: 0;
    transform: perspective(1000px) rotateY(-10deg) translateX(50px);
    animation: imageReveal 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }

  @keyframes imageReveal {
    to {
      opacity: 1;
      transform: perspective(1000px) rotateY(0deg) translateX(0);
    }
  }
</style>
