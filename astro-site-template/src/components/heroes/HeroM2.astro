---
/**
 * HeroM2 - Salon/Spa / Bridal Promise
 * Bridal/event-focused: invitation card aesthetic with seal/script, lace divider,
 * "save the date" feel. Cream paper texture, blush + sage palette.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Bridal & special events',
  testimonial,
  ctaLabel = 'Reserve a fitting',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'View packages',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)] flex items-center" style="font-family: var(--body-font);">
  {/* Paper texture grain */}
  <div class="absolute inset-0 z-0 opacity-[0.07] pointer-events-none" style="background-image: radial-gradient(circle at 30% 30%, var(--primary) 0.5px, transparent 1px), radial-gradient(circle at 70% 70%, var(--accent) 0.5px, transparent 1px); background-size: 5px 5px, 7px 7px;"></div>

  {/* Soft corner washes */}
  <div class="absolute -top-32 -right-20 w-[420px] h-[420px] rounded-full opacity-30 blur-[80px] pointer-events-none" style="background: var(--primary);"></div>
  <div class="absolute -bottom-32 -left-20 w-[420px] h-[420px] rounded-full opacity-25 blur-[100px] pointer-events-none" style="background: var(--accent);"></div>

  <div class="relative z-10 mx-auto max-w-6xl w-full px-6 lg:px-12 py-20">

    {/* Invitation card */}
    <div class="bg-[var(--surface)]/80 backdrop-blur-sm border-2 border-[var(--primary)]/30 p-10 sm:p-14 lg:p-20 relative">
      {/* Inner ornament border */}
      <div class="absolute inset-3 border border-[var(--primary)]/20 pointer-events-none"></div>

      {/* Top wax seal */}
      <div class="absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[var(--primary)] flex items-center justify-center shadow-lg salon-seal">
        <span class="text-[var(--bg)] text-xl italic" style="font-family: var(--heading-font);">m</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-10 lg:gap-14 items-center">
        {/* LEFT — Image in oval frame */}
        {showImage && (
          <div class="salon-fade-up relative">
            <div class="relative aspect-[4/5] overflow-hidden bg-[var(--bg)]" style="border-radius: 50% / 30%;">
              {mainPhoto ? (
                <img src={mainPhoto} alt={businessName} class="absolute inset-0 w-full h-full object-cover" style="filter: sepia(0.1) brightness(1.02);" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">m</div>
              )}
            </div>
            {/* Floating ring */}
            <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-full border-2 border-dashed border-[var(--accent)] salon-spin"></div>
          </div>
        )}

        {/* RIGHT — Text */}
        <div class="text-center lg:text-left">
          {showTagline && (
            <div class="salon-fade-up flex items-center gap-3 justify-center lg:justify-start mb-6">
              <span class="h-px w-10 bg-[var(--primary)]/50"></span>
              <span class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic">— {badgeText} —</span>
              <span class="h-px w-10 bg-[var(--primary)]/50"></span>
            </div>
          )}

          {showHeadline && (
            <h1 class="salon-fade-up font-light italic leading-[1.05] text-[var(--text)] mb-6" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 6vw, 4.75rem); animation-delay: 0.1s;">
              {headline}
            </h1>
          )}

          {/* Lace divider */}
          <div class="salon-fade-up flex items-center gap-3 mb-8 justify-center lg:justify-start" style="animation-delay: 0.2s">
            <span class="text-[var(--primary)] text-xl">❀</span>
            <span class="h-px flex-1 bg-gradient-to-r from-[var(--primary)]/40 via-[var(--accent)]/30 to-transparent"></span>
          </div>

          {showDescription && (
            <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] mb-10 max-w-md mx-auto lg:mx-0" style="font-size: clamp(1rem, 1.25vw, 1.15rem); animation-delay: 0.3s;">
              {description}
            </p>
          )}

          {showButton && (
            <div class="salon-fade-up flex flex-col sm:flex-row gap-3 justify-center lg:justify-start" style="animation-delay: 0.4s">
              <a href={ctaLink} class="group inline-flex items-center justify-center gap-2 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-8 py-3.5 text-[11px] uppercase tracking-[0.4em] transition-all hover:-translate-y-0.5 rounded-full">
                {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">→</span>
              </a>
              <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-2 border border-[var(--primary)]/50 hover:border-[var(--primary)] text-[var(--primary)] px-8 py-3.5 text-[11px] uppercase tracking-[0.4em] transition-all rounded-full">
                {ctaSecondaryLabel}
              </a>
            </div>
          )}

          {showTestimonial && (
            <p class="salon-fade-up mt-10 italic text-sm text-[var(--text-muted)] max-w-md mx-auto lg:mx-0" style="animation-delay: 0.5s">"{testimonial}"</p>
          )}
        </div>
      </div>

      {/* Bottom signature */}
      <div class="salon-fade-up mt-12 pt-6 border-t border-dashed border-[var(--primary)]/30 text-center" style="animation-delay: 0.6s">
        <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] italic">— With love · {businessName} —</p>
      </div>
    </div>
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  .salon-seal { animation: salonPulse 4s ease-in-out infinite; }
  @keyframes salonPulse { 50% { transform: translateX(-50%) scale(1.05); } }
  .salon-spin { animation: salonSpin 30s linear infinite; }
  @keyframes salonSpin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up, .salon-seal, .salon-spin { animation: none; opacity: 1; transform: none; } }
</style>
