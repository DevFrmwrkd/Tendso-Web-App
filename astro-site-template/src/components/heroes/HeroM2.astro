---
/**
 * HeroM2 — Salon · Maison Élite (gold luxe centered)
 *
 * Full-bleed cinematic hero with the hero image as a dim backdrop, a centered
 * serif headline + ornate "Salon & Spa" rule, body copy, and a single primary
 * CTA pill. Aspirational, premium, magazine-cover feel.
 *
 * All colors + fonts route through global theme vars so the picker + inline
 * edits take effect. Local --mae-* derive from globals.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = "Luxury Beauty Destination",
  ctaLabel = "Book a Consultation",
  ctaLink = "#contact",
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || "";

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false && !!mainPhoto;
---

<section
  id="hero"
  class="mae-hero"
  data-component="HERO"
>
  {showImage && (
    <div class="mae-bg" aria-hidden="true">
      <img src={mainPhoto} alt="" data-field="hero.image" />
      <div class="mae-bg-overlay"></div>
    </div>
  )}

  <div class="mae-container">
    {showTagline && (
      <p class="mae-eyebrow" data-field="hero.badge_text" set:html={badgeText}></p>
    )}

    {showHeadline && (
      <h1 class="mae-display" data-field="hero.headline" set:html={headline}></h1>
    )}

    <div class="mae-rule">
      <span class="mae-rule-line"></span>
      <span class="mae-rule-label" data-field="business.name" set:html={businessName}></span>
      <span class="mae-rule-line"></span>
    </div>
    <p class="mae-rule-sub">Salon & Spa</p>

    {showDescription && (
      <p class="mae-lede" data-field="hero.description" set:html={description}></p>
    )}

    {showButton && (
      <a class="mae-btn" href={ctaLink} data-field="hero.cta_label">
        {ctaLabel}
      </a>
    )}
  </div>
</section>

<style>
  .mae-hero {
    --mae-ink:     var(--text);
    --mae-ink-inv: color-mix(in srgb, var(--text) 4%, var(--bg));
    --mae-accent:  var(--primary);
    --mae-rule:    color-mix(in srgb, var(--mae-ink-inv) 35%, transparent);
    --mae-serif:   var(--heading-font, "Cormorant Garamond", Georgia, serif);
    --mae-sans:    var(--body-font, "Inter", system-ui, sans-serif);

    position: relative;
    min-height: clamp(560px, 80vh, 760px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--mae-ink);
    color: var(--mae-ink-inv);
    font-family: var(--mae-sans);
    text-align: center;
  }

  .mae-bg { position: absolute; inset: 0; z-index: 0; }
  .mae-bg img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    filter: brightness(0.55) saturate(1.1);
  }
  .mae-bg-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--mae-ink) 65%, transparent),
      color-mix(in srgb, var(--mae-ink) 80%, transparent)
    );
  }

  .mae-container {
    position: relative; z-index: 1;
    max-width: 880px;
    padding: clamp(80px, 12vw, 140px) clamp(20px, 5vw, 60px);
    display: flex; flex-direction: column; align-items: center;
  }

  .mae-eyebrow {
    font-family: var(--mae-sans);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--mae-accent);
    margin: 0 0 28px;
    font-weight: 500;
  }

  .mae-display {
    font-family: var(--mae-serif);
    font-size: clamp(48px, 8vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.01em;
    color: var(--mae-ink-inv);
    margin: 0 0 32px;
    font-weight: 400;
  }

  .mae-rule {
    display: flex; align-items: center; gap: 14px;
    width: clamp(220px, 30vw, 340px);
    margin: 0 auto;
  }
  .mae-rule-line { flex: 1; height: 1px; background: var(--mae-rule); }
  .mae-rule-label {
    font-family: var(--mae-sans);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--mae-accent);
  }
  .mae-rule-sub {
    margin: 8px 0 0;
    font-family: var(--mae-sans);
    font-size: 10px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--mae-ink-inv) 65%, transparent);
  }

  .mae-lede {
    margin: 32px auto 0;
    font-size: 16px;
    line-height: 1.65;
    color: color-mix(in srgb, var(--mae-ink-inv) 82%, transparent);
    max-width: 56ch;
  }

  .mae-btn {
    margin-top: 36px;
    display: inline-flex; align-items: center;
    padding: 16px 36px;
    background: var(--mae-accent);
    color: var(--mae-ink);
    border-radius: 0;
    text-decoration: none;
    font-family: var(--mae-sans);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    transition: 0.18s;
  }
  .mae-btn:hover {
    background: var(--mae-ink-inv);
    color: var(--mae-ink);
  }
</style>
