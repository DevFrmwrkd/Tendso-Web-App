---
/**
 * HeroK - Barber Shop / Heritage Master
 * Asymmetric split: left text panel on cream parchment, right image with sepia overlay.
 * Signature: animated vertical barber-pole stripe ribbon down the left edge.
 * Vibe: vintage masculine, est-since heritage branding.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Master Barbers',
  testimonial,
  ctaLabel = 'Book a cut',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'View services',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section
  id="hero"
  class="relative w-full min-h-screen overflow-hidden flex bg-[var(--bg)]"
  style="font-family: var(--body-font);"
>
  {/* Barber pole — vertical animated stripe ribbon on left edge */}
  <div class="absolute left-0 top-0 bottom-0 w-3 sm:w-4 z-30 overflow-hidden">
    <div class="barber-pole h-[200%]"></div>
  </div>

  {/* Parchment paper grain overlay */}
  <div class="absolute inset-0 z-0 opacity-[0.04] pointer-events-none"
       style="background-image: repeating-linear-gradient(0deg, transparent 0 2px, var(--text) 2px 3px), repeating-linear-gradient(90deg, transparent 0 3px, var(--text) 3px 4px);">
  </div>

  <div class="relative z-10 w-full grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] items-stretch">

    {/* LEFT — Text panel */}
    <div class="flex flex-col justify-center px-8 sm:px-14 lg:px-20 xl:px-28 py-24 lg:py-32">

      {/* Top ornamental rule + business name */}
      <div class="barber-fade-up mb-10 flex items-center gap-4">
        <span class="h-px w-12 bg-[var(--accent)]"></span>
        <span class="text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.4em] text-[var(--primary)]">
          {businessName}
        </span>
      </div>

      {showTagline && (
        <div class="barber-fade-up mb-6" style="animation-delay: 0.15s">
          <span class="inline-block px-4 py-1.5 border border-[var(--primary)]/30 bg-[var(--bg)] text-[var(--primary)] text-[10px] font-bold uppercase tracking-[0.35em]">
            ✦ {badgeText} ✦
          </span>
        </div>
      )}

      {showHeadline && (
        <h1
          class="barber-fade-up font-bold leading-[0.95] tracking-tight text-[var(--text)] mb-8"
          style="font-size: clamp(3rem, 7vw, 5.5rem); animation-delay: 0.3s;"
        >
          {headline}
        </h1>
      )}

      {showDescription && (
        <p
          class="barber-fade-up max-w-[480px] text-[var(--text-muted)] leading-[1.7] mb-10 italic"
          style="font-size: clamp(1rem, 1.3vw, 1.2rem); animation-delay: 0.45s;"
        >
          {description}
        </p>
      )}

      {showButton && (
        <div
          class="barber-fade-up flex flex-col sm:flex-row gap-4"
          style="animation-delay: 0.6s;"
        >
          <a
            href={ctaLink}
            class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-8 py-4 text-xs font-bold uppercase tracking-[0.3em] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(122,26,44,0.6)]"
          >
            <span>✂</span> {ctaLabel}
          </a>
          <a
            href={ctaSecondaryLink}
            class="inline-flex items-center justify-center gap-3 border border-[var(--text)]/30 hover:border-[var(--primary)] text-[var(--text)] hover:text-[var(--primary)] px-8 py-4 text-xs font-bold uppercase tracking-[0.3em] transition-colors"
          >
            {ctaSecondaryLabel} →
          </a>
        </div>
      )}

      {showTestimonial && (
        <div
          class="barber-fade-up mt-16 max-w-[460px] pl-6 border-l-2 border-[var(--accent)]"
          style="animation-delay: 0.75s;"
        >
          <p class="text-sm italic text-[var(--text-muted)] leading-relaxed mb-2">"{testimonial}"</p>
          <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary)]">— A loyal customer</p>
        </div>
      )}
    </div>

    {/* RIGHT — Image panel with sepia treatment */}
    {showImage && (
      <div class="relative hidden lg:block overflow-hidden bg-[var(--text)]">
        {mainPhoto ? (
          <>
            <img
              src={mainPhoto}
              alt={businessName}
              class="barber-image-reveal absolute inset-0 w-full h-full object-cover"
              style="filter: sepia(0.35) contrast(1.1) brightness(0.85);"
            />
            <div class="absolute inset-0 bg-gradient-to-l from-transparent via-transparent to-[var(--bg)]/60"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--text)]/40 via-transparent to-transparent"></div>

            {/* Corner ornament */}
            <div class="absolute top-8 right-8 w-20 h-20 border-t-2 border-r-2 border-[var(--accent)]/70 pointer-events-none"></div>
            <div class="absolute bottom-8 left-8 w-20 h-20 border-b-2 border-l-2 border-[var(--accent)]/70 pointer-events-none"></div>

            {/* Floating brass plaque */}
            <div class="absolute bottom-12 right-12 bg-[var(--text)] border border-[var(--accent)] px-6 py-4 text-[var(--accent)] shadow-2xl">
              <p class="text-[9px] font-bold uppercase tracking-[0.4em] mb-1 opacity-70">Walk-ins welcome</p>
              <p class="text-xs font-bold uppercase tracking-[0.25em]">Hot towel · Straight razor</p>
            </div>
          </>
        ) : (
          <div class="absolute inset-0 bg-[var(--text-muted)] flex items-center justify-center">
            <span class="text-[var(--accent)] text-9xl">✂</span>
          </div>
        )}
      </div>
    )}
  </div>
</section>

<style>
  /* Barber pole — diagonal stripes scrolling vertically */
  .barber-pole {
    background-image: repeating-linear-gradient(
      135deg,
      var(--primary) 0px,
      var(--primary) 12px,
      var(--bg) 12px,
      var(--bg) 24px,
      #ffffff 24px,
      #ffffff 36px,
      var(--bg) 36px,
      var(--bg) 48px
    );
    animation: barberPoleScroll 4s linear infinite;
  }

  @keyframes barberPoleScroll {
    from { transform: translateY(-50%); }
    to { transform: translateY(0); }
  }

  /* Fade up on load */
  .barber-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: barberFadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes barberFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Image scale-in */
  .barber-image-reveal {
    opacity: 0;
    transform: scale(1.08);
    animation: barberImageReveal 1.5s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  @keyframes barberImageReveal {
    to { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .barber-pole { animation: none; }
    .barber-fade-up, .barber-image-reveal { animation-duration: 0.01ms; opacity: 1; transform: none; }
  }
</style>
