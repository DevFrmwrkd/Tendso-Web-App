---
/**
 * HeroM5 - Salon/Spa / Morning Light
 * Bright, airy, sunrise-feel. Big horizon split between light upper + soft lower.
 * Sunbeams motif, minimal warm aesthetic, "fresh start" vibe.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Open early · golden hour',
  testimonial,
  ctaLabel = 'Reserve your morning',
  ctaLink = '#contact',
  ctaSecondaryLabel = 'Treatments',
  ctaSecondaryLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative w-full min-h-screen overflow-hidden bg-[var(--bg)] flex flex-col" style="font-family: var(--body-font);">
  {/* Upper sunrise gradient */}
  <div class="absolute top-0 inset-x-0 h-2/5 z-0" style="background: linear-gradient(180deg, var(--primary) 0%, transparent 100%); opacity: 0.15;"></div>

  {/* Sunbeam rays */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[120vw] h-[80vh] z-0 pointer-events-none opacity-30">
    {Array.from({ length: 7 }).map((_, i) => {
      const rot = (i - 3) * 9;
      return (
        <div class="absolute top-0 left-1/2 w-1 h-full origin-top salon-beam" style={`transform: translateX(-50%) rotate(${rot}deg); background: linear-gradient(180deg, var(--primary) 0%, transparent 60%); animation-delay: ${i * 0.1}s`}></div>
      );
    })}
  </div>

  <div class="relative z-10 mx-auto max-w-7xl w-full px-6 lg:px-12 py-20 flex-1 flex flex-col justify-center">

    <div class="text-center mb-12">
      {showTagline && (
        <div class="salon-fade-up inline-flex items-center gap-3 mb-6">
          <span class="text-[var(--primary)] text-xl">☀</span>
          <span class="text-[10px] uppercase tracking-[0.5em] text-[var(--primary)] italic">— {badgeText} —</span>
          <span class="text-[var(--primary)] text-xl">☀</span>
        </div>
      )}

      {showHeadline && (
        <h1 class="salon-fade-up font-light italic leading-[1.02] text-[var(--text)] mb-6 max-w-4xl mx-auto" style="font-family: var(--heading-font); font-size: clamp(2.5rem, 7vw, 5.5rem); animation-delay: 0.1s;">
          {headline}
        </h1>
      )}

      {showDescription && (
        <p class="salon-fade-up text-[var(--text-muted)] italic leading-[1.8] mb-10 max-w-xl mx-auto" style="font-size: clamp(1rem, 1.3vw, 1.2rem); animation-delay: 0.2s;">
          {description}
        </p>
      )}

      {showButton && (
        <div class="salon-fade-up flex flex-col sm:flex-row gap-3 justify-center mb-10" style="animation-delay: 0.3s">
          <a href={ctaLink} class="group inline-flex items-center justify-center gap-3 bg-[var(--primary)] hover:bg-[var(--primary)] text-[var(--bg)] px-8 py-4 text-[11px] uppercase tracking-[0.4em] transition-all hover:-translate-y-0.5 rounded-full">
            {ctaLabel} <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
          <a href={ctaSecondaryLink} class="inline-flex items-center justify-center gap-3 border border-[var(--accent)]/60 hover:border-[var(--accent)] text-[var(--accent)] px-8 py-4 text-[11px] uppercase tracking-[0.4em] transition-all rounded-full">
            {ctaSecondaryLabel}
          </a>
        </div>
      )}
    </div>

    {/* Horizon-line image */}
    {showImage && (
      <div class="salon-fade-up relative mt-auto max-w-5xl mx-auto w-full" style="animation-delay: 0.4s">
        <div class="relative aspect-[16/8] overflow-hidden bg-[var(--surface)] rounded-t-[300px_120px]">
          {mainPhoto ? (
            <img src={mainPhoto} alt={businessName} data-field="hero.image" class="absolute inset-0 w-full h-full object-cover" style="filter: brightness(1.05) saturate(0.9);" />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-[var(--primary)] text-9xl italic" style="font-family: var(--heading-font);">m</div>
          )}
          <div class="absolute inset-0 bg-gradient-to-b from-[var(--primary)]/20 via-transparent to-[var(--bg)]/30"></div>

          {/* Floating early-bird badge */}
          <div class="absolute top-6 right-6 bg-[var(--bg)]/90 backdrop-blur-sm border border-[var(--primary)]/30 rounded-full px-5 py-2 shadow-md">
            <p class="text-[10px] uppercase tracking-[0.45em] text-[var(--primary)] italic flex items-center gap-2">
              <span>☀</span> Open 7AM
            </p>
          </div>
        </div>
      </div>
    )}

    {showTestimonial && (
      <p class="salon-fade-up italic text-sm text-[var(--text-muted)] text-center mt-8 max-w-md mx-auto" style="animation-delay: 0.5s">"{testimonial}"</p>
    )}
  </div>
</section>

<style>
  .salon-fade-up { opacity: 0; transform: translateY(20px); animation: salonFadeUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  @keyframes salonFadeUp { to { opacity: 1; transform: translateY(0); } }
  .salon-beam { opacity: 0; animation: beamFade 2s ease-out forwards; }
  @keyframes beamFade { to { opacity: 0.4; } }
  @media (prefers-reduced-motion: reduce) { .salon-fade-up, .salon-beam { animation: none; opacity: 1; transform: none; } }
</style>
