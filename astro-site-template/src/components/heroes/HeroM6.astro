---
/**
 * HeroM6 — Salon/Spa · Editorial (NEO Labs)
 *
 * Inspired by the NEO Labs landing page (components/landing/HeroSection.tsx).
 * Voice: editorial · cinematic · paper-magazine. Not SaaS.
 *
 *  - Warm paper background (#F8F5EE)
 *  - Display serif (Instrument Serif) headline with one italic emphasis word
 *  - Mono eyebrow pill with live-dot ("Issue No. 01 · {Month Year}")
 *  - Tag chips for the value props
 *  - Two-tone "Door" CTAs (ink + ghost)
 *  - Right-rail editorial portrait inside a rounded oval frame
 *  - Counter strip below the fold (Years · Cuts · Stylists · Reviews)
 *
 * The editorial palette is locally scoped via CSS variables so it doesn't
 * fight the global --bg / --primary chosen by the color scheme picker —
 * this variant deliberately overrides them to maintain the NEO Labs look.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = "Issue No. 01",
  testimonial,
  ctaLabel = "Book your treatment",
  ctaLink = "#contact",
  ctaSecondaryLabel = "View services",
  ctaSecondaryLink = "#services",
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || "";

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false && !!mainPhoto;

// Magazine-y headline split: first ~2/3 plain, last word italic-accent.
function splitHeadline(h: string): { lead: string; emphasis: string } {
  const words = (h || "").trim().split(/\s+/);
  if (words.length < 3) return { lead: h, emphasis: "" };
  const cut = Math.max(words.length - 1, Math.floor(words.length * 0.66));
  return {
    lead: words.slice(0, cut).join(" "),
    emphasis: words.slice(cut).join(" "),
  };
}
const split = splitHeadline(headline);

// Tag chips — short, opinionated, sourced from the brief.
const TAGS = [
  "Real stylists",
  "Editorial photography",
  "By-appointment",
  "Walk-ins welcome",
  "Open since 2018",
];

// Live "Issue date" computed at build time (Astro is SSG by default, so this
// shifts whenever the site is regenerated — close enough to "live").
const now = new Date();
const issueDate = now.toLocaleString("en-US", { month: "long", year: "numeric" });
---

<section
  id="hero"
  class="m6-section"
  data-component="HERO"
>
  <div class="m6-container">
    <div class="m6-grid">
      <div class="m6-col-text">
        {showTagline && (
          <div class="m6-eyebrow">
            <span class="m6-livedot" aria-hidden="true"></span>
            <span data-field="hero.badge_text" set:html={badgeText}></span>
            <span class="m6-eyebrow-sep" aria-hidden="true">·</span>
            <span class="m6-eyebrow-date">{issueDate}</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="m6-display">
            <span data-field="hero.headline.lead">{split.lead}</span>
            {split.emphasis && (
              <>
                {" "}
                <em data-field="hero.headline.emphasis">{split.emphasis}</em>
              </>
            )}
          </h1>
        )}

        <div class="m6-business-name">
          <span data-field="business.name" set:html={businessName}></span>
        </div>

        {showDescription && (
          <p class="m6-lede" data-field="hero.description" set:html={description}></p>
        )}

        <div class="m6-tags">
          {TAGS.map((t) => (
            <span class="m6-tag">{t}</span>
          ))}
        </div>

        {showButton && (
          <div class="m6-doors">
            <a class="m6-door m6-door-solid" href={ctaLink}>
              <span class="m6-door-meta">PRIMARY</span>
              <span class="m6-door-title" data-field="hero.cta_label">{ctaLabel}</span>
              <span class="m6-door-arrow" aria-hidden="true">→</span>
            </a>
            <a class="m6-door m6-door-ghost" href={ctaSecondaryLink}>
              <span class="m6-door-meta">SECONDARY</span>
              <span class="m6-door-title" data-field="hero.cta_secondary_label">{ctaSecondaryLabel}</span>
              <span class="m6-door-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        )}

        {showTestimonial && (
          <div class="m6-testimonial">
            <div class="m6-testimonial-mark" aria-hidden="true">"</div>
            <p data-field="hero.testimonial" set:html={testimonial}></p>
          </div>
        )}
      </div>

      <div class="m6-col-image">
        {showImage && (
          <figure class="m6-figure">
            <div class="m6-figure-meta">
              <span class="m6-figure-label">FEATURED · {issueDate.split(" ")[0].toUpperCase()}</span>
              <span class="m6-figure-no">№ 01</span>
            </div>
            <div class="m6-figure-frame">
              <img
                src={mainPhoto}
                alt={businessName ? `${businessName} interior` : "Salon interior"}
                data-field="hero.image"
              />
            </div>
            <figcaption class="m6-figcaption">
              <span class="m6-figcaption-line"></span>
              <span>Photography · in-house</span>
            </figcaption>
          </figure>
        )}
      </div>
    </div>

    <div class="m6-counters">
      <div class="m6-counter">
        <span class="m6-counter-num">07</span>
        <span class="m6-counter-label">Years open</span>
      </div>
      <div class="m6-counter">
        <span class="m6-counter-num">12k+</span>
        <span class="m6-counter-label">Treatments</span>
      </div>
      <div class="m6-counter">
        <span class="m6-counter-num">04</span>
        <span class="m6-counter-label">Stylists</span>
      </div>
      <div class="m6-counter">
        <span class="m6-counter-num">4.9</span>
        <span class="m6-counter-label">Google rating</span>
      </div>
    </div>
  </div>
</section>

<style>
  .m6-section {
    /* Routes ALL colors + fonts through the global theme vars exposed by
       BaseLayout.astro (--bg / --surface / --text / --text-muted / --primary /
       --accent / --heading-font / --body-font). That way the color scheme
       + font pairing picker in the Theme tab actually affects this hero.
       Local m6-* vars are derived from globals — never hardcoded hex.   */
    --m6-paper:    var(--bg);
    --m6-paper-2:  var(--surface, var(--bg));
    --m6-paper-3:  var(--surface, var(--bg));
    --m6-ink:      var(--text);
    --m6-ink-2:    var(--text);
    --m6-ink-3:    var(--text-muted, var(--text));
    --m6-rule:     color-mix(in srgb, var(--text) 12%, transparent);
    --m6-rule-2:   color-mix(in srgb, var(--text) 22%, transparent);
    --m6-accent:   var(--primary);
    --m6-accent-2: var(--accent, var(--primary));
    --m6-live:     var(--primary);
    --m6-serif: var(--heading-font, "Instrument Serif", Georgia, serif);
    --m6-sans:  var(--body-font, "Onest", system-ui, sans-serif);
    --m6-mono:  "JetBrains Mono", ui-monospace, monospace;

    background: var(--m6-paper);
    color: var(--m6-ink);
    font-family: var(--m6-sans);
    padding: clamp(40px, 7vw, 96px) 0 clamp(64px, 9vw, 120px);
    border-bottom: 1px solid var(--m6-rule);
  }

  .m6-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }

  .m6-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(28px, 4vw, 56px);
    align-items: end;
  }
  @media (max-width: 900px) {
    .m6-grid { grid-template-columns: 1fr; align-items: stretch; }
  }

  /* ── EYEBROW ─────────────────────────────────────────────── */
  .m6-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px;
    border: 1px solid var(--m6-rule);
    border-radius: 999px;
    background: var(--m6-paper-3);
    font-family: var(--m6-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--m6-ink-3);
    margin-bottom: 28px;
  }
  .m6-livedot {
    width: 7px;
    height: 7px;
    background: var(--m6-live);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 0 0 rgba(63, 168, 106, 0.6);
    animation: m6-pulse 2s infinite;
  }
  @keyframes m6-pulse {
    0% { box-shadow: 0 0 0 0 rgba(63, 168, 106, 0.5); }
    70% { box-shadow: 0 0 0 8px rgba(63, 168, 106, 0); }
    100% { box-shadow: 0 0 0 0 rgba(63, 168, 106, 0); }
  }
  .m6-eyebrow-sep { opacity: 0.45; }

  /* ── DISPLAY HEADLINE ────────────────────────────────────── */
  .m6-display {
    font-family: var(--m6-serif);
    font-size: clamp(44px, 6.5vw, 84px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--m6-ink);
    margin: 0;
    font-weight: 400;
  }
  .m6-display em {
    font-style: italic;
    color: var(--m6-accent);
  }

  .m6-business-name {
    font-family: var(--m6-mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--m6-ink-3);
    margin-top: 18px;
  }

  .m6-lede {
    font-size: 18px;
    line-height: 1.55;
    color: var(--m6-ink-2);
    margin: 22px 0 0;
    max-width: 56ch;
  }

  /* ── TAG CHIPS ───────────────────────────────────────────── */
  .m6-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 24px;
  }
  .m6-tag {
    padding: 6px 12px;
    font-size: 11px;
    font-family: var(--m6-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--m6-ink-2);
    background: var(--m6-paper-3);
    border: 1px solid var(--m6-rule);
    border-radius: 999px;
  }

  /* ── DOOR BUTTONS ────────────────────────────────────────── */
  .m6-doors {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 32px;
    max-width: 540px;
  }
  @media (max-width: 540px) {
    .m6-doors { grid-template-columns: 1fr; }
  }
  .m6-door {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    align-items: end;
    column-gap: 12px;
    padding: 18px 20px;
    border-radius: 14px;
    border: 1px solid var(--m6-ink);
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
    min-height: 96px;
  }
  .m6-door:hover { transform: translateY(-2px); }
  .m6-door-solid {
    background: var(--m6-ink);
    color: var(--m6-paper-3);
  }
  .m6-door-ghost {
    background: transparent;
    color: var(--m6-ink);
  }
  .m6-door-ghost:hover {
    background: var(--m6-ink);
    color: var(--m6-paper-3);
  }
  .m6-door-meta {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
    font-family: var(--m6-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  .m6-door-title {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
    font-family: var(--m6-serif);
    font-size: 22px;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .m6-door-arrow {
    grid-column: 2 / 3;
    grid-row: 1 / 3;
    align-self: center;
    font-size: 22px;
    line-height: 1;
  }

  /* ── TESTIMONIAL ─────────────────────────────────────────── */
  .m6-testimonial {
    margin-top: 36px;
    padding: 24px 28px 26px;
    background: var(--m6-paper-3);
    border: 1px solid var(--m6-rule);
    border-radius: 16px;
    position: relative;
    max-width: 540px;
  }
  .m6-testimonial-mark {
    position: absolute;
    top: -14px;
    left: 16px;
    background: var(--m6-paper);
    color: var(--m6-accent);
    font-family: var(--m6-serif);
    font-size: 48px;
    line-height: 0.6;
    padding: 0 8px;
  }
  .m6-testimonial p {
    font-family: var(--m6-serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: var(--m6-ink);
    margin: 0;
  }

  /* ── IMAGE FIGURE ────────────────────────────────────────── */
  .m6-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .m6-figure-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--m6-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--m6-ink-3);
  }
  .m6-figure-no {
    color: var(--m6-accent);
  }
  .m6-figure-frame {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--m6-paper-2);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--m6-rule);
    box-shadow: 0 24px 60px rgba(27, 28, 36, 0.12);
  }
  .m6-figure-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .m6-figcaption {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--m6-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--m6-ink-3);
  }
  .m6-figcaption-line {
    flex: 1;
    height: 1px;
    background: var(--m6-rule);
  }

  /* ── COUNTER STRIP ──────────────────────────────────────── */
  .m6-counters {
    margin-top: clamp(40px, 6vw, 72px);
    padding-top: clamp(24px, 4vw, 40px);
    border-top: 1px solid var(--m6-rule-2);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }
  @media (max-width: 700px) {
    .m6-counters { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }
  .m6-counter {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .m6-counter-num {
    font-family: var(--m6-serif);
    font-size: clamp(36px, 4vw, 48px);
    line-height: 1;
    color: var(--m6-ink);
    font-variant-numeric: tabular-nums;
  }
  .m6-counter-label {
    font-family: var(--m6-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--m6-ink-3);
  }
</style>
