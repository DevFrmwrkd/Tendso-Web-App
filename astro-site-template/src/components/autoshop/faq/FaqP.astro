---
/**
 * Autoshop / FaqP — Foundry 2-column <details> accordion with a rotating
 * accent "+" marker. Reads content.faq.tag/headline/items[]{q,a}.
 */
interface Props { content: any; }
const { content } = Astro.props;
const faq = content.faq || {};
const tag = faq.tag || '';
const headline = faq.headline || '';
type Item = { q: string; a: string };
const items: Item[] = Array.isArray(faq.items) ? faq.items : (Array.isArray(faq) ? faq : []);
const mid = Math.ceil(items.length / 2);
const columns = [items.slice(0, mid), items.slice(mid)];
---
{items.length > 0 && (
  <section class="block" id="faq">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          {tag && <span class="kicker" data-field="faq.tag"><span class="dot"></span> {tag}</span>}
          {headline && <h2 class="h-sect" data-field="faq.headline" set:html={headline}></h2>}
        </div>
      </div>
      <div class="faq-grid">
        {columns.map((col, c) => (
          <div>
            {col.map((item, j) => {
              const i = c === 0 ? j : mid + j;
              return (
                <details class="q reveal">
                  <summary>
                    <span data-field={`faq.items.${i}.q`}>{item.q}</span>
                    <span class="ic" aria-hidden="true">+</span>
                  </summary>
                  <p data-field={`faq.items.${i}.a`} set:html={item.a}></p>
                </details>
              );
            })}
          </div>
        ))}
      </div>
    </div>
  </section>
)}
<style>
  .block { padding-block: clamp(64px, 9vw, 120px); }
  .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 48px; }
  details.q { border-bottom: 1px solid rgba(var(--ink-rgb), .2); }
  details.q summary { list-style: none; cursor: pointer; padding: 22px 0; display: flex; justify-content: space-between; gap: 16px; font-family: var(--display); font-weight: 700; font-size: 18px; text-transform: none; letter-spacing: -.01em; }
  details.q summary::-webkit-details-marker { display: none; }
  details.q .ic { font-family: var(--mono); color: var(--accent); transition: transform .2s ease; }
  details.q[open] .ic { transform: rotate(45deg); }
  details.q p { margin: 0 0 22px; color: var(--muted); font-size: 15px; max-width: 54ch; }
  @media (max-width: 860px) { .faq-grid { grid-template-columns: 1fr; } }
</style>
