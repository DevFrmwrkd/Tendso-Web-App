---
/**
 * Autoshop / HeaderP — Foundry sticky nav. Hard-bordered industrial bar with
 * an accent logo mark, underline-on-hover links, a mono phone number, and an
 * accent Book CTA. Reads layout.navLinks + content.footer.brand so it stays
 * portable across P–T. Mobile burger toggles the links.
 */
interface Props { layout: any; content: any; }
const { layout, content } = Astro.props;
const brand = (content as any).footer?.brand || layout.businessName || 'Your Shop';
const navLinks: Array<{ href: string; label: string }> = (layout.navLinks && layout.navLinks.length)
  ? layout.navLinks
  : [];
const phone = layout.contact?.phone || '';
const phoneDigits = phone.replace(/[^0-9+]/g, '');
const ctaText = (content as any).navCtaText || 'Book Service';
const ctaHref = (content as any).navCtaHref || '#book';
---
<header class="site">
  <div class="wrap nav">
    <a class="logo" href="#top" data-field="footer.brand"><span class="mark">▲</span> {brand}</a>
    {navLinks.length > 0 && (
      <nav class="nav-links">
        {navLinks.map((link, i) => (
          <a href={link.href} data-field={`navbar_links.${i}.label`} data-href-field={`navbar_links.${i}.href`}>{link.label}</a>
        ))}
      </nav>
    )}
    <div class="nav-cta">
      {phone && <a class="nav-phone" href={`tel:${phoneDigits}`} data-field="location.phone">{phone}</a>}
      <a class="btn btn--accent" href={ctaHref} data-field="navCtaText" data-href-field="navCtaHref">{ctaText}</a>
      <button class="burger" aria-label="Menu" onclick="var l=document.querySelector('.nav-links'); if(l) l.classList.toggle('open');"><span></span></button>
    </div>
  </div>
</header>
<style>
  header.site { position: sticky; top: 0; z-index: 50; background: var(--paper); border-bottom: 2px solid var(--ink); }
  .nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; height: 72px; }
  .logo { display: flex; align-items: center; gap: 12px; font-family: var(--display); font-weight: 900; font-size: 20px; text-transform: uppercase; letter-spacing: -.02em; }
  .logo .mark { width: 34px; height: 34px; background: var(--accent); border: 2px solid var(--ink); display: grid; place-items: center; font-size: 18px; color: var(--on-accent, var(--ink)); }
  .nav-links { display: flex; gap: 28px; align-items: center; }
  .nav-links :global(a) { font-weight: 600; font-size: 15px; position: relative; padding: 4px 0; }
  .nav-links :global(a::after) { content: ""; position: absolute; left: 0; bottom: 0; width: 0; height: 2px; background: var(--accent); transition: width .2s ease; }
  .nav-links :global(a:hover::after) { width: 100%; }
  .nav-cta { display: flex; align-items: center; gap: 16px; }
  .nav-phone { font-family: var(--mono); font-weight: 600; font-size: 15px; white-space: nowrap; }
  .burger { display: none; background: none; border: 2px solid var(--ink); width: 44px; height: 44px; cursor: pointer; align-items: center; justify-content: center; }
  .burger span { display: block; width: 20px; height: 2px; background: var(--ink); position: relative; }
  .burger span::before, .burger span::after { content: ""; position: absolute; left: 0; width: 20px; height: 2px; background: var(--ink); }
  .burger span::before { top: -6px; } .burger span::after { top: 6px; }
  @media (max-width: 860px) {
    .nav-links { display: none; position: absolute; top: 72px; left: 0; right: 0; background: var(--paper); border-bottom: 2px solid var(--ink); flex-direction: column; gap: 0; padding: 12px var(--pad); }
    .nav-links.open { display: flex; }
    .nav-links :global(a) { padding: 12px 0; }
    .burger { display: flex; }
    .nav-phone { display: none; }
  }
</style>
