---
/**
 * Autoshop spine — shared base CSS injected once per page.
 *
 * The 5 Autoshop variants (PageP–PageT: Foundry, Meridian, Volt, Redline,
 * Maple Street) each set their own palette + font tokens scoped to
 * `html[data-page="<L>"]`, so this spine references those via var(--accent),
 * var(--paper), etc. and works for every variant without bleed.
 *
 * Industrial/neo-brutalist vocabulary from the source: hard borders, offset
 * hover shadows, uppercase Archivo display. Button text routes through
 * --on-accent / --on-ink / --on-paper contrast tokens (playbook §"Contrast
 * guarantee") so extreme schemes never produce invisible buttons.
 */
---
<style is:global>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 17px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  h1, h2, h3, h4 {
    font-family: var(--display);
    font-weight: 900; line-height: 0.95; margin: 0;
    letter-spacing: -0.02em; text-transform: uppercase;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  section { position: relative; }
  .wrap { max-width: var(--maxw, 1280px); margin: 0 auto; padding-inline: var(--pad, clamp(20px, 5vw, 80px)); }
  .pad-y { padding-block: clamp(64px, 8vw, 128px); }
  .ink-sect { background: var(--ink); color: var(--paper); }
  .ink-sect .h-sect { color: var(--paper); }
  .ink-sect .mono, .ink-sect .kicker { color: var(--muted-light, rgba(var(--paper-rgb), .66)); }

  .mono {
    font-family: var(--mono); text-transform: uppercase;
    letter-spacing: .18em; font-size: 12px; font-weight: 500;
    color: var(--muted, rgba(var(--ink-rgb), .6));
  }
  .kicker {
    font-family: var(--mono); text-transform: uppercase;
    letter-spacing: .2em; font-weight: 600; font-size: 11px;
    color: var(--accent);
    display: inline-flex; align-items: center; gap: 10px;
  }
  .kicker .dot { width: 9px; height: 9px; background: var(--accent); border-radius: 50%; display: inline-block; }
  .h-sect {
    font-family: var(--display); font-weight: 900;
    font-size: clamp(38px, 5.5vw, 76px); line-height: 0.98;
    letter-spacing: -.02em; text-transform: uppercase; margin: 14px 0 0;
  }
  .lead { font-size: clamp(16px, 1.3vw, 19px); color: var(--muted, rgba(var(--ink-rgb), .66)); max-width: 56ch; }
  .on-dark .lead, .lead.on-dark { color: var(--muted-light, rgba(var(--paper-rgb), .66)); }

  /* Buttons: hard border + offset accent shadow on hover (Autoshop signature).
     Text colors route through contrast tokens so black/yellow schemes stay legible. */
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--display); font-weight: 800;
    text-transform: uppercase; letter-spacing: .02em; font-size: 15px;
    padding: 15px 26px; min-height: 44px; cursor: pointer;
    border: 2px solid var(--ink); background: var(--ink); color: var(--on-ink, var(--paper));
    transition: transform .15s ease, box-shadow .15s ease, background .15s ease, color .15s ease;
  }
  .btn:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0 var(--accent); }
  .btn--accent { background: var(--accent); border-color: var(--accent); color: var(--on-accent, var(--ink)); }
  .btn--accent:hover { box-shadow: 6px 6px 0 var(--ink); }
  .btn--ghost { background: transparent; color: var(--on-paper, var(--ink)); border-color: var(--on-paper, var(--ink)); }
  .btn--ghost:hover { box-shadow: 6px 6px 0 var(--ink); }
  .btn--ghost.on-dark { color: var(--on-ink, var(--paper)); border-color: var(--on-ink, var(--paper)); }

  .sect-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 30px; flex-wrap: wrap; margin-bottom: 44px; }
  .sect-head .lead { margin: 12px 0 0; }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    * { animation: none !important; }
  }
</style>
