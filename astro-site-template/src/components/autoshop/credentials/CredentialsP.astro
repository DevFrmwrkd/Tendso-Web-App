---
/**
 * Autoshop / CredentialsP — Foundry credential cards: 4 hard-bordered boxes,
 * each with an accent mark, a name, and a note. Reads
 * content.credentials.tag/headline/items[]{name,note}. Accepts title/desc
 * aliases so the shape stays portable with the sibling families.
 */
interface Props { content: any; }
const { content } = Astro.props;
const cred = content.credentials || {};
const tag = cred.tag || '';
const headline = cred.headline || '';
type Item = { name?: string; title?: string; note?: string; desc?: string; mark?: string };
const items: Item[] = Array.isArray(cred.items) ? cred.items : [];
const marks = ['✓', '⛨', '★', '◆'];
---
{items.length > 0 && (
  <section class="block" id="creds">
    <div class="wrap">
      <div class="sec-head reveal">
        <div>
          {tag && <span class="kicker" data-field="credentials.tag"><span class="dot"></span> {tag}</span>}
          {headline && <h2 class="h-sect" data-field="credentials.headline" set:html={headline}></h2>}
        </div>
      </div>
      <div class="creds">
        {items.map((item, i) => (
          <div class="cred reveal">
            <div class="ci" aria-hidden="true">{item.mark || marks[i % marks.length]}</div>
            <h4 data-field={`credentials.items.${i}.name`}>{item.name ?? item.title}</h4>
            {(item.note ?? item.desc) && <p data-field={`credentials.items.${i}.note`}>{item.note ?? item.desc}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}
<style>
  .block { padding-block: clamp(64px, 9vw, 120px); }
  .creds { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .cred { border: 2px solid var(--ink); padding: 26px; text-align: center; }
  .cred .ci { font-family: var(--display); font-size: 30px; color: var(--accent); }
  .cred h4 { font-size: 15px; margin-top: 10px; }
  .cred p { font-size: 13px; color: var(--muted); margin-top: 6px; }
  @media (max-width: 860px) { .creds { grid-template-columns: 1fr 1fr; } }
</style>
