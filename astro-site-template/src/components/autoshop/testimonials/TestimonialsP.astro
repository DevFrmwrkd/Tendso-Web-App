---
/**
 * Autoshop / TestimonialsP — Foundry stacked quote rows: a "SOURCE" label
 * column beside an accent star row + big quote. Reads
 * content.testimonials.items[]{quote,name,context}; also accepts who/author/role
 * aliases so the shape stays portable with the sibling families.
 */
interface Props { content: any; }
const { content } = Astro.props;
const test = content.testimonials || {};
type Item = { quote: string; name?: string; who?: string; author?: string; context?: string; role?: string; source?: string };
const items: Item[] = Array.isArray(test.items) ? test.items : (Array.isArray(test) ? test : []);
const tag = test.tag || '';
const headline = test.headline || '';
---
{items.length > 0 && (
  <section class="block" id="reviews">
    <div class="wrap">
      {(tag || headline) && (
        <div class="sec-head reveal">
          <div>
            {tag && <span class="kicker" data-field="testimonials.tag"><span class="dot"></span> {tag}</span>}
            {headline && <h2 class="h-sect" data-field="testimonials.headline" set:html={headline}></h2>}
          </div>
        </div>
      )}
      <div class="quotes">
        {items.map((item, i) => {
          const who = item.name ?? item.who ?? item.author;
          const context = item.context ?? item.role;
          const src = item.source || 'REVIEW';
          return (
            <div class="quote reveal">
              <div class="src" data-field={`testimonials.items.${i}.source`}>{src}</div>
              <div>
                <span class="stars" aria-hidden="true">★★★★★</span>
                <blockquote data-field={`testimonials.items.${i}.quote`}>“{item.quote}”</blockquote>
                {(who || context) && (
                  <div class="who">
                    {who && <span data-field={`testimonials.items.${i}.name`}>— {who}</span>}
                    {context && <span data-field={`testimonials.items.${i}.context`}> · {context}</span>}
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}
<style>
  .block { padding-block: clamp(64px, 9vw, 120px); }
  .quotes { display: grid; gap: 0; border-top: 2px solid var(--ink); }
  .quote { padding: 34px 0; border-bottom: 1px solid rgba(var(--ink-rgb), .16); display: grid; grid-template-columns: auto 1fr; gap: 30px; align-items: start; }
  .quote .src { font-family: var(--mono); font-size: 12px; color: var(--muted); white-space: nowrap; letter-spacing: .18em; }
  .quote blockquote { margin: 8px 0 0; font-family: var(--display); font-weight: 700; font-size: clamp(19px, 2vw, 26px); text-transform: none; letter-spacing: -.01em; line-height: 1.25; }
  .quote .who { margin-top: 12px; font-size: 14px; color: var(--muted); }
  .quote .stars { color: var(--accent); letter-spacing: 2px; font-size: 15px; }
  @media (max-width: 860px) { .quote { grid-template-columns: 1fr; gap: 10px; } }
</style>
