---
/**
 * Vogue hero — editorial DM Serif Display variant. Oversized centered
 * headline + ratio image below. Higher-contrast pink palette.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const hero = content.hero || {};
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';
const locality = hero.kicker || hero.locality || '';
const headlineLines: string[] = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0
  ? hero.headlineLines : (hero.headline ? [hero.headline] : []);
const sub = hero.sub || '';
const cta1Text = hero.cta1?.text || '';
const cta1Href = hero.cta1?.href || '#visit';
const cta2Text = hero.cta2?.text || '';
const cta2Href = hero.cta2?.href || (layout.contact?.phone ? `tel:${String(layout.contact.phone).replace(/[^0-9+]/g, '')}` : '#');
---
<section class="heroN" id="top">
  <div class="wrap heroN-inner">
    {locality && <div class="heroN-eyebrow"><span class="kicker" data-field="hero.kicker">{locality}</span></div>}
    {headlineLines.length > 0 && (
      <h1 class="heroN-headline">
        {headlineLines.map((line: string, i: number) => (
          <span class="hl-line" data-field={`hero.headlineLines.${i}`} set:html={line}></span>
        ))}
      </h1>
    )}
    {sub && <p class="heroN-sub" data-field="hero.sub">{sub}</p>}
    <div class="heroN-cta">
      {cta1Text && <a class="btn btn--accent" href={cta1Href} data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>}
      {cta2Text && <a class="btn btn--ghost" href={cta2Href} data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>}
    </div>
  </div>
  {heroImage && (
    <div class="wrap heroN-imgwrap">
      <div class="heroN-img">
        <div class="bg-img" data-image-field="hero.image" style={`background-image:url('${heroImage}');`}></div>
      </div>
    </div>
  )}
</section>
<style>
  .heroN { padding-top: clamp(140px, 16vw, 200px); padding-bottom: clamp(50px, 6vw, 80px); text-align: center; }
  .heroN-inner { max-width: 1100px; }
  .heroN-eyebrow { display: flex; justify-content: center; margin-bottom: 26px; }
  .heroN-headline {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(54px, 9vw, 132px); line-height: .98; letter-spacing: -.02em;
    margin: 0 auto 32px; max-width: 16ch;
  }
  .heroN-headline .hl-line { display: block; }
  .heroN-sub {
    font-size: clamp(17px, 1.5vw, 20px); color: var(--muted, rgba(var(--ink-rgb), .72));
    max-width: 50ch; margin: 0 auto 38px; line-height: 1.6;
  }
  .heroN-cta { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .heroN-imgwrap { margin-top: clamp(60px, 8vw, 100px); }
  .heroN-img { aspect-ratio: 16 / 9; overflow: hidden; }
  .heroN-img .bg-img { width: 100%; height: 100%; background-size: cover; background-position: center; }
</style>
