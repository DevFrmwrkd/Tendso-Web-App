---
/**
 * SalonSpa location — NAP card + Leaflet map.
 *
 * Map rendering strategy (per the user's "render leaflet even when
 * address isn't reasonable" requirement, 2026-06):
 *
 *   1. If build-time geocoding produced `lat`/`lng` → render Leaflet
 *      directly via `window.__salonspaInitMap(lat, lng, label)`.
 *
 *   2. Else if we have ANY address string → fire a client-side
 *      Nominatim (OSM) lookup. On success, render Leaflet at the
 *      resolved coords. The Page wrapper's `__salonspaInitMap` global
 *      accepts a `{ address }` form for this path.
 *
 *   3. Else (no coords AND no address) → render a clean "find us on
 *      Google Maps" tile that links to a maps search if address is
 *      missing, OR a graceful empty card.
 *
 * Nominatim is OSM's free geocoder. Rate-limited to ~1 req/sec — fine
 * for a per-page-load client-side lookup. Same User-Agent / Accept-Language
 * conventions we use server-side in lib/geocode.ts.
 */
interface Props { content: any; layout: any; }
const { content, layout } = Astro.props;
const loc = content.location || {};
const tag = loc.tag || '';
const headline = loc.headline || '';
const sub = loc.sub || '';
const address = loc.address || layout.contact?.address || '';
const addressLines = address ? address.split('\n') : [];
const phone = loc.phone || layout.contact?.phone || '';
const phoneDigits = phone.replace(/[^0-9+]/g, '');
const hours: Array<{ day: string; time: string }> = Array.isArray(loc.hours)
  ? loc.hours
  : (Array.isArray((content as any).footer?.hours) ? (content as any).footer.hours : []);
const dirText = loc.directions?.text || 'Get directions';
const dirHref = loc.directions?.href || (address
  ? `https://maps.google.com/?q=${encodeURIComponent(address.replace(/\n/g, ' '))}`
  : '#');
const lat = loc.lat != null
  ? Number(loc.lat)
  : (layout.contact?.lat != null ? Number(layout.contact.lat) : null);
const lng = loc.lng != null
  ? Number(loc.lng)
  : (layout.contact?.lng != null ? Number(layout.contact.lng) : null);
const label = layout.businessName || 'Our location';
const mapAria = `Map showing ${label}`;
const hasCoords = lat != null && lng != null && !isNaN(lat as number) && !isNaN(lng as number);
const hasAddress = !!address;
---
<section class="pad-y loc-sect" id="visit">
  <div class="wrap">
    <div class="sect-head reveal">
      <div>
        {tag && <span class="kicker" data-field="location.tag">{tag}</span>}
        {headline && <h2 class="h-sect" data-field="location.headline" set:html={headline}></h2>}
      </div>
      {sub && <p class="lead" data-field="location.sub">{sub}</p>}
    </div>
    <div class="loc-grid reveal">
      <div class="loc-info">
        {address && (
          <div class="row">
            <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <div class="k">Address</div>
              <div class="v" data-field="location.address">
                {addressLines.map((line: string, i: number) => (<>{i > 0 && <br />}{line}</>))}
              </div>
            </div>
          </div>
        )}
        {phone && (
          <div class="row">
            <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg>
            <div>
              <div class="k">Phone</div>
              <div class="v"><a href={`tel:${phoneDigits}`} data-field="location.phone">{phone}</a></div>
            </div>
          </div>
        )}
        {hours.length > 0 && (
          <div class="row">
            <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <div>
              <div class="k">Hours</div>
              <div class="v loc-hours">
                {hours.map((row: any, i: number) => (
                  <div>
                    <span data-field={`location.hours.${i}.day`}>{row.day}</span>
                    <span data-field={`location.hours.${i}.time`}>{row.time}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
        <div class="loc-actions">
          <a class="btn btn--accent" href={dirHref} target="_blank" rel="noopener noreferrer" data-field="location.directions.text" data-href-field="location.directions.href">{dirText}</a>
        </div>
      </div>
      <div id="map" role="img" aria-label={mapAria}>
        {!hasCoords && !hasAddress && (
          <div class="map-fallback">No address on file yet.</div>
        )}
        {!hasCoords && hasAddress && (
          <div class="map-fallback" id="map-fallback">Loading map…</div>
        )}
      </div>
    </div>
  </div>
</section>
{/* Render path A: build-time coords ready — call the init directly */}
{hasCoords && (
  <script is:inline define:vars={{ lat, lng, label }}>
    (function init() {
      if (window.__salonspaInitMap) window.__salonspaInitMap(lat, lng, label);
      else setTimeout(init, 80);
    })();
  </script>
)}
{/* Render path B: no build-time coords but address present — try client-side
    Nominatim. Failure is silent + falls back to the "find on Google Maps"
    link visible in the address block + CTA. */}
{!hasCoords && hasAddress && (
  <script is:inline define:vars={{ address, label }}>
    (function geocodeThenInit() {
      var attempt = 0;
      function tryInit(lat, lng) {
        if (window.__salonspaInitMap) {
          window.__salonspaInitMap(lat, lng, label);
        } else if (attempt++ < 25) {
          setTimeout(function () { tryInit(lat, lng); }, 80);
        }
      }
      try {
        var query = encodeURIComponent(String(address).replace(/\n/g, ', '));
        var url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + query;
        fetch(url, {
          headers: { 'Accept-Language': 'en' },
        })
          .then(function (r) { return r.ok ? r.json() : []; })
          .then(function (results) {
            if (!Array.isArray(results) || results.length === 0) {
              var el = document.getElementById('map-fallback');
              if (el) el.textContent = 'Map preview unavailable — use the directions button.';
              return;
            }
            var lat = parseFloat(results[0].lat);
            var lng = parseFloat(results[0].lon);
            if (isNaN(lat) || isNaN(lng)) return;
            tryInit(lat, lng);
          })
          .catch(function () {
            var el = document.getElementById('map-fallback');
            if (el) el.textContent = 'Map preview unavailable — use the directions button.';
          });
      } catch (e) { /* never block render */ }
    })();
  </script>
)}
<style>
  .loc-grid { display: grid; grid-template-columns: 1fr 1.15fr; gap: 0; border: 1px solid var(--line); }
  .loc-info { padding: clamp(34px, 4vw, 56px); }
  .loc-info .row { display: flex; gap: 16px; padding: 22px 0; border-bottom: 1px solid var(--line); }
  .loc-info .row:last-of-type { border-bottom: none; }
  .loc-info .ic { width: 22px; height: 22px; color: var(--accent); flex: 0 0 auto; margin-top: 3px; }
  .loc-info .row .k {
    font-family: var(--sans); text-transform: uppercase; letter-spacing: .18em;
    font-size: 11px; color: var(--muted, rgba(var(--ink-rgb), .6)); margin-bottom: 4px;
  }
  .loc-info .row .v { font-size: 16px; line-height: 1.5; }
  .loc-info .row .v a:hover { color: var(--accent); }
  .loc-hours { font-size: 14.5px; color: var(--muted, rgba(var(--ink-rgb), .68)); }
  .loc-hours div { display: flex; justify-content: space-between; max-width: 280px; padding: 2px 0; }
  .loc-actions { margin-top: 30px; display: flex; gap: 12px; flex-wrap: wrap; }
  #map { width: 100%; height: 100%; min-height: 440px; background: var(--paper-2, var(--paper)); }
  .map-fallback {
    display: flex; align-items: center; justify-content: center; height: 100%;
    color: var(--muted, rgba(var(--ink-rgb), .6));
    font-family: var(--sans); letter-spacing: .1em;
    text-transform: uppercase; font-size: 12.5px; padding: 24px; text-align: center;
  }
  @media (max-width: 840px) {
    .loc-grid { grid-template-columns: 1fr; }
    #map { min-height: 320px; order: -1; }
  }
</style>
