---
interface Props { content: any; }
const { content } = Astro.props;
const faq = content.faq || {};
const tag = faq.tag || '';
const headline = faq.headline || '';
type Item = { q: string; a: string };
const items: Item[] = Array.isArray(faq.items) ? faq.items : (Array.isArray(faq) ? faq : []);
---
{items.length > 0 && (
  <section class="pad-y faq-sect">
    <div class="wrap faq-wrap">
      <div class="faq-head reveal">
        {tag && <span class="kicker" data-field="faq.tag">{tag}</span>}
        {headline && <h2 class="h-sect" data-field="faq.headline" set:html={headline}></h2>}
      </div>
      <div class="faq-list">
        {items.map((item, i) => (
          <details class="faq-item reveal">
            <summary>
              <span class="faq-q" data-field={`faq.items.${i}.q`}>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a" data-field={`faq.items.${i}.a`} set:html={item.a}></div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
<style>
  .faq-wrap { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(40px, 5vw, 80px); align-items: start; }
  .faq-head { position: sticky; top: 120px; }
  .faq-list { display: flex; flex-direction: column; }
  .faq-item { border-bottom: 1px solid var(--line); padding: 22px 0; }
  .faq-item:first-child { border-top: 1px solid var(--line); }
  .faq-item summary {
    list-style: none; cursor: pointer; display: flex; align-items: center;
    justify-content: space-between; gap: 16px;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-q { font-family: var(--serif); font-size: clamp(18px, 1.6vw, 22px); color: var(--ink); }
  .faq-icon {
    font-family: var(--serif); font-size: 24px; color: var(--accent);
    transition: transform .3s ease; width: 24px; text-align: center;
  }
  .faq-item[open] .faq-icon { transform: rotate(45deg); }
  .faq-a {
    margin-top: 16px; color: var(--muted, rgba(var(--ink-rgb), .72));
    font-size: 15.5px; line-height: 1.7;
  }
  @media (max-width: 880px) {
    .faq-wrap { grid-template-columns: 1fr; }
    .faq-head { position: static; }
  }
</style>
