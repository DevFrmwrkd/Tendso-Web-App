---
/**
 * SalonSpa spine — shared base CSS injected once per page.
 *
 * The 5 SalonSpa variants (PageK–PageO: Atelier, Botanica, Clinic, Vogue,
 * Bloom) each set their own palette + font tokens scoped to
 * `html[data-page="<L>"]`, so this spine references those tokens via
 * `var(--accent)`, `var(--paper)`, etc. and works for every variant
 * without bleed.
 *
 * Per the playbook §"Contrast guarantee", button text colors route
 * through `--on-accent` / `--on-ink` / `--on-paper` contrast tokens so
 * extreme schemes (black, yellow) don't produce invisible buttons.
 *
 * Variant-specific overrides (Atelier's espresso CTA, Botanica's
 * sage section bg, etc.) live in the per-letter wrapper, also scoped
 * to `html[data-page="<L>"]` to stop them leaking into sister wrappers.
 */
---
<style is:global>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  section { position: relative; }
  .wrap { max-width: var(--maxw, 1280px); margin: 0 auto; padding-inline: var(--pad, clamp(20px, 5vw, 96px)); }
  .pad-y { padding-block: clamp(72px, 9vw, 140px); }
  .ink-sect { background: var(--ink); color: var(--paper); }
  .ink-sect .h-sect { color: var(--paper); }
  .ink-sect .kicker { color: var(--muted-light, rgba(var(--paper-rgb), 0.66)); }
  .eyebrow {
    font-family: var(--serif); font-style: italic;
    font-size: clamp(18px, 2vw, 24px); color: var(--accent);
    line-height: 1; margin: 0 0 18px;
  }
  .kicker {
    font-family: var(--sans); text-transform: uppercase;
    letter-spacing: .26em; font-weight: 500; font-size: 11px;
    color: var(--muted, rgba(var(--ink-rgb), 0.6));
    display: inline-flex; align-items: center; gap: 12px;
  }
  .kicker::before { content: ""; width: 28px; height: 1px; background: var(--accent); display: inline-block; }
  .kicker.on-dark { color: var(--muted-light, rgba(var(--paper-rgb), 0.66)); }
  .h-sect {
    font-family: var(--serif); font-weight: 500;
    font-size: clamp(38px, 5.5vw, 78px); line-height: 1.05;
    letter-spacing: -.005em; margin: 14px 0 0;
  }
  .lead { font-size: clamp(16px, 1.3vw, 19px); color: var(--muted, rgba(var(--ink-rgb), 0.66)); max-width: 56ch; }
  .on-dark .lead, .lead.on-dark { color: var(--muted-light, rgba(var(--paper-rgb), 0.66)); }

  /* Buttons consume contrast-paired tokens (see playbook §"Contrast guarantee").
     `--on-accent` / `--on-ink` / `--on-paper` are luminance-aware in every
     variant + the override CSS, so extreme schemes can never produce
     white-on-white. Fallback chains keep older variants buildable. */
  .btn {
    font-family: var(--sans); text-transform: uppercase;
    letter-spacing: .12em; font-weight: 600; font-size: 12.5px;
    padding: 14px 28px; display: inline-flex; align-items: center; gap: 10px;
    border: 1px solid var(--ink); background: var(--ink); color: var(--on-ink, var(--paper));
    cursor: pointer; transition: transform .25s ease, background .25s ease, color .25s ease, border-color .25s ease;
    white-space: nowrap; border-radius: 999px;
  }
  .btn:hover { background: var(--accent); border-color: var(--accent); color: var(--on-accent, var(--paper)); transform: translateY(-1px); }
  .btn--accent { background: var(--accent); border-color: var(--accent); color: var(--on-accent, var(--paper)); }
  .btn--accent:hover { background: var(--ink); border-color: var(--ink); color: var(--on-ink, var(--paper)); }
  .btn--ghost { background: transparent; color: var(--on-paper, var(--ink)); border-color: var(--on-paper, var(--ink)); }
  .btn--ghost:hover { background: var(--ink); color: var(--on-ink, var(--paper)); border-color: var(--ink); }
  .btn--ghost.on-dark { color: var(--on-ink, var(--paper)); border-color: var(--on-ink, var(--paper)); }
  .btn--ghost.on-dark:hover { background: var(--on-ink, var(--paper)); color: var(--ink); border-color: var(--on-ink, var(--paper)); }

  .sect-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 30px; flex-wrap: wrap; margin-bottom: 48px; }
  .sect-head .lead { margin: 12px 0 0; }
  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .8s ease, transform .8s ease; }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    * { animation: none !important; }
  }
</style>
