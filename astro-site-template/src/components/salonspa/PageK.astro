---
/**
 * salonspa / PageK — Atelier default.
 * Warm pearl + brass — Cormorant Garamond + Jost.
 * Palette tokens scoped to html[data-page="K"].
 */
import HeaderK from './header/HeaderK.astro';
import HeroK from './hero/HeroK.astro';
import TrustK from './trust/TrustK.astro';
import AboutK from './about/AboutK.astro';
import ServicesK from './services/ServicesK.astro';
import WhyK from './why/WhyK.astro';
import HowK from './how/HowK.astro';
import TestimonialsK from './testimonials/TestimonialsK.astro';
import GalleryK from './gallery/GalleryK.astro';
import FaqK from './faq/FaqK.astro';
import AreaK from './area/AreaK.astro';
import CredentialsK from './credentials/CredentialsK.astro';
import LocationK from './location/LocationK.astro';
import CtaBandK from './ctaBand/CtaBandK.astro';
import FooterK from './footer/FooterK.astro';
import SalonspaSpine from './SalonspaSpine.astro';
import { resolveTheme, buildFontHref, buildOverrideCss } from '../../lib/genericThemeOverrides';

interface Props { siteData: any; }
const { siteData } = Astro.props;
const layout = siteData.layout ?? {};
const content = siteData.content ?? {};
const visibility = siteData.visibility ?? {};
const title = layout.businessName
  ? `${layout.businessName}${layout.tagline ? ' — ' + layout.tagline : ''}`
  : 'Welcome';
const { scheme: __themeScheme, pairing: __themePairing } = resolveTheme(layout, (content as any).business_type, { lockVariant: true });
const __overrideCss = buildOverrideCss(__themeScheme, __themePairing);
const __fontHref = buildFontHref(__themePairing);
---

<!DOCTYPE html>
<html lang="en" data-page="K">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {content.description && <meta name="description" content={content.description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  {layout.favicon && <link rel="icon" href={layout.favicon} />}
  {(layout.ogImage || layout.favicon) && <meta property="og:image" content={layout.ogImage || layout.favicon} />}
  <style is:global>
    html[data-page="K"] {
      --paper: #f8f3ea; --paper-2: #efe7d6;
      --ink: #33291f; --ink-2: #4a3f33;
      --paper-rgb: 248,243,234; --ink-rgb: 51,41,31;
      --accent: #b08a57; --accent-rgb: 176,138,87;
      --line: rgba(51,41,31, .18);
      --muted: rgba(51,41,31, .62); --muted-light: rgba(248,243,234, .68);
      --serif: "Cormorant Garamond", Georgia, serif;
      --sans: "Jost", system-ui, sans-serif;
      --pad: clamp(20px, 5vw, 96px); --maxw: 1280px;
      --on-accent: #f8f3ea; --on-ink: #f8f3ea; --on-paper: #33291f;
    }
  </style>
  <SalonspaSpine />
  {__fontHref && <link href={__fontHref} rel="stylesheet" />}
  <style is:global set:html={__overrideCss}></style>
</head>
<body>
  <HeaderK layout={layout} content={content} />
  <main id="top">
    {visibility.heroSection !== false && <HeroK content={content} layout={layout} />}
    {visibility.trustBlock !== false && <TrustK content={content} />}
    {visibility.aboutSection !== false && <AboutK content={content} />}
    {visibility.servicesSection !== false && <ServicesK content={content} />}
    {visibility.whyUsBlock !== false && <WhyK content={content} />}
    {visibility.howItWorksBlock !== false && <HowK content={content} />}
    {visibility.testimonialsBlock !== false && <TestimonialsK content={content} />}
    {visibility.gallerySection !== false && <GalleryK content={content} layout={layout} />}
    {visibility.faqBlock !== false && <FaqK content={content} />}
    {visibility.serviceAreaBlock !== false && <AreaK content={content} />}
    {visibility.credentialsBlock !== false && <CredentialsK content={content} />}
    {visibility.locationBlock !== false && <LocationK content={content} layout={layout} />}
  </main>
  {visibility.ctaBandBlock !== false && <CtaBandK content={content} layout={layout} />}
  <FooterK layout={layout} content={content} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !document.hidden) {
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      } else {
        document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in'); });
      }
      var hdr = document.querySelector('header.nav');
      if (hdr) {
        var onScroll = function () { if (window.scrollY > 16) hdr.classList.add('scrolled'); else hdr.classList.remove('scrolled'); };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
      // Salonspa Leaflet boot — accepts (lat, lng, label) from LocationK.
      // Works for both build-time-geocoded coords AND client-side Nominatim
      // fallback coords (LocationK calls this with whatever it resolves).
      window.__salonspaInitMap = function (lat, lng, label) {
        if (!window.L) return;
        var el = document.getElementById('map'); if (!el) return;
        // Clear any previous fallback content so the map can mount cleanly.
        el.innerHTML = '';
        var map = L.map('map', { scrollWheelZoom: false }).setView([lat, lng], 15);
        L.tileLayer('https://basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19 }).addTo(map);
        var icon = L.divIcon({ className: '', html: '<div style="width:22px;height:22px;background:#b08a57;border:3px solid #33291f;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 3px 8px rgba(0,0,0,.25);"></div>', iconSize: [22, 22], iconAnchor: [11, 22] });
        L.marker([lat, lng], { icon: icon }).addTo(map).bindPopup('<b>' + label + '</b>');
      };
    })();
  </script>
</body>
</html>
