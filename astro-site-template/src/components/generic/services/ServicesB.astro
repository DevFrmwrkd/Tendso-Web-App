---
interface Props { content: any; }
const { content } = Astro.props;
const services = content.services || {};
const tag = services.tag || 'What we offer';
const headline = services.headline || 'Ways to <em>practice</em> with us.';
const items = Array.isArray(services.items) && services.items.length ? services.items : [];
---
<section class="sec" id="classes" style="padding-top:0;">
  <div class="wrap">
    <div class="sec-head">
      <p class="sec-tag reveal" data-field="services.tag">{tag}</p>
      <h2 class="reveal" data-field="services.headline" set:html={headline}></h2>
    </div>
    <div class="zig">
      {items.map((it: any, i: number) => (
        <div class="zrow">
          <div class="zimg reveal">
            <div class="img" data-image-field={`services.items.${i}.image`} style={it.image ? `background-image:url('${it.image}');` : ''}></div>
          </div>
          <div class="reveal">
            <div class="znum" data-field={`services.items.${i}.num`}>{it.num}</div>
            <h3 data-field={`services.items.${i}.title`}>{it.title || it.name}</h3>
            <p data-field={`services.items.${i}.desc`}>{it.desc || it.description}</p>
            <div class="meta" data-field={`services.items.${i}.meta`}>{it.meta || ''}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .zig { display: flex; flex-direction: column; gap: 72px; margin-top: 64px; }
  .zrow { display: grid; grid-template-columns: 1fr 1fr; gap: 58px; align-items: center; }
  .zrow:nth-child(even) .zimg { order: 2; }
  .zimg { border-radius: 340px 340px 32px 32px; overflow: hidden; }
  .zrow:nth-child(even) .zimg { border-radius: 32px 32px 340px 340px; }
  .zimg .img { width: 100%; height: 380px; background-size: cover; background-position: center; background-color: var(--teal-soft); }
  .znum { font-family: var(--serif); font-style: italic; font-size: 24px; color: var(--peach); }
  .zrow h3 { font-size: clamp(32px, 3.6vw, 48px); font-weight: 400; margin-top: 6px; }
  .zrow p { margin-top: 16px; color: var(--ink-soft); font-size: 17px; max-width: 46ch; }
  .zrow .meta { margin-top: 18px; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--teal); font-weight: 700; }
  @media (max-width: 820px) {
    .zrow { grid-template-columns: 1fr; gap: 24px; }
    .zrow:nth-child(even) .zimg { order: 0; }
    .zimg, .zrow:nth-child(even) .zimg { border-radius: 200px 200px 28px 28px; }
    .zimg .img { height: 300px; }
  }
</style>
