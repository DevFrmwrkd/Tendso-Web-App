---
interface Props { content: any; }
const { content } = Astro.props;
const services = content.services || {};
const tag = services.tag || 'What we do';
const headline = services.headline || 'From bare dirt to <em>finished grounds.</em>';
const items: Array<{ num?: string; title: string; desc: string }> = Array.isArray(services.items) && services.items.length ? services.items : [];
---
<section class="sec" id="services" style="padding-top:0;">
  <div class="wrap">
    <span class="sec-tag reveal" data-field="services.tag">{tag}</span>
    <h2 class="reveal" data-field="services.headline" set:html={headline}></h2>
    <div class="board reveal">
      <div class="board-in">
        {items.map((it: any, i: number) => (
          <div class="brow">
            <span class="bn" data-field={`services.items.${i}.num`}>{it.num || String(i + 1).padStart(2, '0')}</span>
            <span class="bt" data-field={`services.items.${i}.title`}>{it.title || it.name}</span>
            <span class="leader"></span>
            <span class="bd" data-field={`services.items.${i}.desc`}>{it.desc || it.description}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
<style>
  .board { background: var(--forest); color: var(--paper-2); border: 2px solid var(--ink); box-shadow: 10px 10px 0 var(--ink); margin-top: 50px; }
  .board-in { padding: 18px 40px; }
  .brow { display: flex; align-items: baseline; gap: 14px; padding: 26px 0; border-bottom: 1px dashed rgba(var(--paper-rgb), .3); }
  .brow:last-child { border-bottom: none; }
  .brow .bn { font-family: var(--disp); font-size: 22px; color: var(--amber); }
  .brow .bt { font-family: var(--disp); font-size: clamp(26px, 3vw, 38px); white-space: nowrap; }
  .brow .leader { flex: 1; border-bottom: 2px dotted rgba(var(--paper-rgb), .4); transform: translateY(-6px); }
  .brow .bd { font-size: 14px; color: rgba(var(--paper-rgb), .78); max-width: 34ch; text-align: right; }
  @media (max-width: 760px) {
    .board-in { padding: 10px 22px; }
    .brow { flex-wrap: wrap; }
    .brow .leader { display: none; }
    .brow .bd { text-align: left; width: 100%; }
  }
</style>
