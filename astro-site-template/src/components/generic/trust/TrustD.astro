---
interface Props { content: any; }
const { content } = Astro.props;
const cells = (content.trust?.cells && content.trust.cells.length > 0) ? content.trust.cells : [];
---
<section class="trust">
  <div class="wrap trust-grid">
    {cells.map((cell: any, i: number) => (
      <div class="kv reveal" style={i > 0 ? `transition-delay:.${i * 8}s;` : ''}>
        <div class="k" data-field={`trust.cells.${i}.key`}>{cell.key || cell.label}</div>
        <div class="v" data-field={`trust.cells.${i}.value`} set:html={cell.value || cell.num}></div>
      </div>
    ))}
  </div>
</section>
<style>
  .trust { padding: 64px 0; }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid var(--line); border-radius: 14px; overflow: hidden; max-width: var(--wrap); margin: 0 auto; }
  .kv { padding: 30px 28px; border-left: 1px solid var(--line); background: var(--panel); }
  .kv:first-child { border-left: none; }
  .kv .k { font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
  .kv .v { font-family: var(--disp); font-size: 46px; font-weight: 700; margin-top: 8px; }
  .kv .v :global(em) { font-style: normal; color: var(--lime); }
  @media (max-width: 820px) {
    .trust-grid { grid-template-columns: 1fr 1fr; }
    .kv:nth-child(3) { border-left: none; }
    .kv:nth-child(n+3) { border-top: 1px solid var(--line); }
  }
</style>
