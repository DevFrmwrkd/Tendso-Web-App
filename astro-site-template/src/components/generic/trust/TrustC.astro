---
interface Props { content: any; }
const { content } = Astro.props;
const cells = (content.trust?.cells && content.trust.cells.length > 0) ? content.trust.cells : [];
---
<section class="trust">
  <div class="wrap trust-row">
    {cells.map((cell: any, i: number) => (
      <div class="tblock reveal" style={i > 0 ? `transition-delay:.${i * 8}s;` : ''}>
        <div class="num" data-field={`trust.cells.${i}.num`}>{cell.num}</div>
        <div class="lbl" data-field={`trust.cells.${i}.label`}>{cell.label}</div>
      </div>
    ))}
  </div>
</section>
<style>
  .trust { padding: 70px 0; }
  .trust-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; max-width: var(--wrap); margin: 0 auto; padding: 0 30px; }
  .tblock { background: var(--card); border: 2px solid var(--ink); box-shadow: var(--shadow); padding: 26px; }
  .tblock .num { font-family: var(--disp); font-size: 54px; line-height: .9; color: var(--forest); }
  .tblock .lbl { margin-top: 8px; font-size: 13px; font-weight: 600; letter-spacing: .04em; color: var(--ink-soft); text-transform: uppercase; }
  @media (max-width: 820px) { .trust-row { grid-template-columns: 1fr 1fr; } }
</style>
