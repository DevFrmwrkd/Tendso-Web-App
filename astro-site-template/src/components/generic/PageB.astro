---
/**
 * generic / PageB — Stillwater Studio template wrapper.
 * Teal + peach, Instrument Serif + Figtree. Yoga studio aesthetic.
 */
import HeaderB from './header/HeaderB.astro';
import HeroB from './hero/HeroB.astro';
import MarqueeB from './marquee/MarqueeB.astro';
import TrustB from './trust/TrustB.astro';
import AboutB from './about/AboutB.astro';
import ServicesB from './services/ServicesB.astro';
import WhyB from './why/WhyB.astro';
import HowB from './how/HowB.astro';
import TestimonialsB from './testimonials/TestimonialsB.astro';
import GalleryB from './gallery/GalleryB.astro';
import FaqB from './faq/FaqB.astro';
import AreaB from './area/AreaB.astro';
import LocationB from './location/LocationB.astro';
import CtaBandB from './ctaBand/CtaBandB.astro';
import FooterB from './footer/FooterB.astro';
import { resolveTheme, buildFontHref, buildOverrideCss } from '../../lib/genericThemeOverrides';

interface Props { siteData: any; }
const { siteData } = Astro.props;
const layout = siteData.layout ?? {};
const content = siteData.content ?? {};
const visibility = siteData.visibility ?? {};
const title = layout.businessName
  ? `${layout.businessName}${layout.tagline ? ' — ' + layout.tagline : ''}`
  : 'Welcome';
const { scheme: __themeScheme, pairing: __themePairing } = resolveTheme(layout, (content as any).business_type);
const __overrideCss = buildOverrideCss(__themeScheme, __themePairing);
const __fontHref = buildFontHref(__themePairing);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {content.description && <meta name="description" content={content.description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  {layout.favicon && <link rel="icon" href={layout.favicon} />}
  {(layout.ogImage || layout.favicon) && <meta property="og:image" content={layout.ogImage || layout.favicon} />}
  <style is:global>
    :root {
      --paper: #ECEEE8; --paper-2: #F5F6F1; --card: #E1E6DD;
      --ink: #1C3A37; --ink-soft: #586E69; --line: #D2D9CF;
      --teal: #2E6E69; --teal-deep: #214F4B;
      --peach: #E29B73; --peach-soft: #F2D8C5; --teal-soft: #D8E5E0;
      --paper-rgb: 236,238,232; --ink-rgb: 28,58,55; --accent-rgb: 46,110,105;
      --serif: "Instrument Serif", Georgia, serif;
      --sans: "Figtree", system-ui, sans-serif;
      --wrap: 1180px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0; background: var(--paper); color: var(--ink);
      font-family: var(--sans); font-size: 17px; font-weight: 400;
      line-height: 1.62; -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3, h4 { margin: 0; font-family: var(--serif); font-weight: 400; line-height: 1.02; letter-spacing: 0; }
    p { margin: 0; }
    .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 30px; }
    .eyebrow { font-size: 12px; letter-spacing: .28em; text-transform: uppercase; color: var(--teal); font-weight: 600; }
    em { font-family: var(--serif); font-style: italic; color: var(--peach); }
    section { position: relative; }
    .btn {
      display: inline-flex; align-items: center; gap: 9px;
      font-size: 14px; letter-spacing: .04em; font-weight: 600;
      padding: 15px 28px; min-height: 50px;
      border: 1.5px solid var(--teal); border-radius: 40px;
      transition: transform .3s ease, background .3s ease, color .3s ease;
      cursor: pointer;
    }
    .btn-primary { background: var(--teal); border-color: var(--teal); color: var(--paper-2); }
    .btn-primary:hover { transform: translateY(-3px); background: var(--teal-deep); }
    .btn-ghost { background: transparent; color: var(--ink); border-color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--paper-2); transform: translateY(-3px); }
    .reveal { opacity: 1; transform: none; }
    body.reveal-on .reveal {
      opacity: 0; transform: translateY(28px);
      transition: opacity .9s cubic-bezier(.19,1,.22,1), transform .9s cubic-bezier(.19,1,.22,1);
    }
    body.reveal-on .reveal.in { opacity: 1; transform: none; }
    .sec { padding: 100px 0; }
    .sec-head { text-align: center; max-width: 24ch; margin: 0 auto; }
    .sec h2 { font-size: clamp(40px, 5.6vw, 76px); font-weight: 400; }
    .sec h2 em { color: var(--teal); }
    .sec-tag { font-size: 12px; letter-spacing: .26em; text-transform: uppercase; color: var(--teal); font-weight: 600; margin-bottom: 16px; }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; }
      .reveal { opacity: 1 !important; transform: none !important; }
      html { scroll-behavior: auto; }
    }
  </style>
  {__fontHref && <link href={__fontHref} rel="stylesheet" />}
  <style is:global set:html={__overrideCss}></style>
</head>
<body>
  <HeaderB layout={layout} content={content} />
  <main id="top">
    {visibility.heroSection !== false && <HeroB content={content} />}
    <MarqueeB content={content} />
    {visibility.trustBlock !== false && <TrustB content={content} />}
    {visibility.aboutSection !== false && <AboutB content={content} />}
    {visibility.servicesSection !== false && <ServicesB content={content} />}
    {visibility.whyUsBlock !== false && <WhyB content={content} />}
    {visibility.howItWorksBlock !== false && <HowB content={content} />}
    {visibility.testimonialsBlock !== false && <TestimonialsB content={content} />}
    {visibility.gallerySection !== false && <GalleryB content={content} />}
    {visibility.faqBlock !== false && <FaqB content={content} />}
    {visibility.serviceAreaBlock !== false && <AreaB content={content} />}
    {visibility.locationBlock !== false && <LocationB content={content} layout={layout} />}
  </main>
  {visibility.ctaBandBlock !== false && <CtaBandB content={content} layout={layout} />}
  <FooterB layout={layout} content={content} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !document.hidden) {
        document.body.classList.add('reveal-on');
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      }
      window.__genericInitMap = function (lat, lng, label) {
        if (!window.L) return;
        var el = document.getElementById('map');
        if (!el) return;
        var ll = [lat, lng];
        var map = L.map('map', { scrollWheelZoom: false }).setView(ll, 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19,
        }).addTo(map);
        var icon = L.divIcon({
          className: '',
          html: '<div style="width:22px;height:22px;background:#2E6E69;border:3px solid #F5F6F1;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 3px 8px rgba(0,0,0,.3);"></div>',
          iconSize: [22, 22], iconAnchor: [11, 22],
        });
        L.marker(ll, { icon: icon }).addTo(map).bindPopup('<b>' + label + '</b>');
      };
    })();
  </script>
</body>
</html>
