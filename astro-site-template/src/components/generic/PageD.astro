---
/**
 * generic / PageD — Northpoint IT template wrapper.
 * Dark grid + lime + JetBrains Mono. Tech / IT services aesthetic.
 */
import HeaderD from './header/HeaderD.astro';
import HeroD from './hero/HeroD.astro';
import MarqueeD from './marquee/MarqueeD.astro';
import TrustD from './trust/TrustD.astro';
import AboutD from './about/AboutD.astro';
import ServicesD from './services/ServicesD.astro';
import WhyD from './why/WhyD.astro';
import HowD from './how/HowD.astro';
import TestimonialsD from './testimonials/TestimonialsD.astro';
import GalleryD from './gallery/GalleryD.astro';
import FaqD from './faq/FaqD.astro';
import AreaD from './area/AreaD.astro';
import LocationD from './location/LocationD.astro';
import CtaBandD from './ctaBand/CtaBandD.astro';
import FooterD from './footer/FooterD.astro';
import { resolveTheme, buildFontHref, buildOverrideCss } from '../../lib/genericThemeOverrides';

interface Props { siteData: any; }
const { siteData } = Astro.props;
const layout = siteData.layout ?? {};
const content = siteData.content ?? {};
const visibility = siteData.visibility ?? {};
const title = layout.businessName ? `${layout.businessName}${layout.tagline ? ' — ' + layout.tagline : ''}` : 'Welcome';
const { scheme: __themeScheme, pairing: __themePairing } = resolveTheme(layout, (content as any).business_type);
const __overrideCss = buildOverrideCss(__themeScheme, __themePairing);
const __fontHref = buildFontHref(__themePairing);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {content.description && <meta name="description" content={content.description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  {layout.favicon && <link rel="icon" href={layout.favicon} />}
  {(layout.ogImage || layout.favicon) && <meta property="og:image" content={layout.ogImage || layout.favicon} />}
  <style is:global>
    :root {
      --bg: #0C0F14; --bg-2: #111722; --panel: #141B27; --panel-2: #18212F;
      --ink: #E8EDF3; --muted: #8A95A6; --line: #232E3D;
      --lime: #C9F24E; --lime-2: #D9F87A; --blue: #5AA9FF;
      --ink-rgb: 232,237,243; --bg-rgb: 12,15,20; --accent-rgb: 201,242,78;
      --disp: "Bricolage Grotesque", system-ui, sans-serif;
      --sans: "Space Grotesk", system-ui, sans-serif;
      --mono: "JetBrains Mono", monospace;
      --wrap: 1280px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--bg); color: var(--ink); font-family: var(--sans); font-size: 17px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3, h4 { margin: 0; font-family: var(--disp); font-weight: 700; line-height: 1; letter-spacing: -.02em; }
    p { margin: 0; }
    .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 30px; }
    .eyebrow { font-family: var(--mono); font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--lime); }
    .mono { font-family: var(--mono); }
    section { position: relative; }
    .btn { display: inline-flex; align-items: center; gap: 9px; font-family: var(--mono); font-size: 13px; letter-spacing: .04em; padding: 15px 24px; min-height: 48px; border: 1px solid var(--line); border-radius: 8px; cursor: pointer; transition: transform .2s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease; }
    .btn-primary { background: var(--lime); border-color: var(--lime); color: #0C0F14; font-weight: 600; }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(var(--accent-rgb), .25); }
    .btn-ghost { background: transparent; color: var(--ink); }
    .btn-ghost:hover { border-color: var(--lime); color: var(--lime); transform: translateY(-3px); }
    .reveal { opacity: 1; transform: none; }
    body.reveal-on .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s cubic-bezier(.2,.8,.2,1), transform .7s cubic-bezier(.2,.8,.2,1); }
    body.reveal-on .reveal.in { opacity: 1; transform: none; }
    .sec { padding: 100px 0; }
    .sec-tag { font-family: var(--mono); font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--lime); margin-bottom: 18px; }
    .sec-tag::before { content: "// "; color: var(--muted); }
    .sec h2 { font-size: clamp(34px, 4.6vw, 60px); max-width: 18ch; }
    .sec h2 em { font-style: normal; color: var(--lime); }
    .sec .lead { margin-top: 18px; color: var(--muted); max-width: 54ch; font-size: 18px; }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; }
      .reveal { opacity: 1 !important; transform: none !important; }
      html { scroll-behavior: auto; }
    }
  </style>
  {__fontHref && <link href={__fontHref} rel="stylesheet" />}
  <style is:global set:html={__overrideCss}></style>
</head>
<body>
  <HeaderD layout={layout} content={content} />
  <main id="top">
    {visibility.heroSection !== false && <HeroD content={content} />}
    <MarqueeD content={content} />
    {visibility.trustBlock !== false && <TrustD content={content} />}
    {visibility.aboutSection !== false && <AboutD content={content} />}
    {visibility.servicesSection !== false && <ServicesD content={content} />}
    {visibility.whyUsBlock !== false && <WhyD content={content} />}
    {visibility.howItWorksBlock !== false && <HowD content={content} />}
    {visibility.testimonialsBlock !== false && <TestimonialsD content={content} />}
    {visibility.gallerySection !== false && <GalleryD content={content} />}
    {visibility.faqBlock !== false && <FaqD content={content} />}
    {visibility.serviceAreaBlock !== false && <AreaD content={content} />}
    {visibility.locationBlock !== false && <LocationD content={content} layout={layout} />}
  </main>
  {visibility.ctaBandBlock !== false && <CtaBandD content={content} layout={layout} />}
  <FooterD layout={layout} content={content} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !document.hidden) {
        document.body.classList.add('reveal-on');
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      }
      window.__genericInitMap = function (lat, lng, label) {
        if (!window.L) return;
        var el = document.getElementById('map'); if (!el) return;
        var ll = [lat, lng];
        var map = L.map('map', { scrollWheelZoom: false }).setView(ll, 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19 }).addTo(map);
        var icon = L.divIcon({ className: '', html: '<div style="width:20px;height:20px;background:#C9F24E;border:3px solid #0C0F14;border-radius:5px;transform:rotate(45deg);box-shadow:0 0 14px rgba(201,242,78,.7);"></div>', iconSize: [20, 20], iconAnchor: [10, 18] });
        L.marker(ll, { icon: icon }).addTo(map).bindPopup('<b>' + label + '</b>');
      };
    })();
  </script>
</body>
</html>
