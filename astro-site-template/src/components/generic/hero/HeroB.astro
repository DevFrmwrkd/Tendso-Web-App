---
interface Props { content: any; }
const { content } = Astro.props;
const hero = content.hero || {};
const heroImage = hero.image || (hero.photos && hero.photos[0]) || (content.photos && content.photos[0]) || '';

const kicker = hero.kicker || hero.badge_text || '';
const headlineLines = Array.isArray(hero.headlineLines) && hero.headlineLines.length > 0 ? hero.headlineLines
  : [];
const sub = hero.sub || hero.description ||
  '';
const trustLine = hero.trustLine || '★★★★★ &nbsp;loved by students · ratings kept live on Google';
const cta1Text = hero.cta1?.text || hero.cta_label || '';
const cta1Href = hero.cta1?.href || hero.cta_link || '#visit';
const cta2Text = hero.cta2?.text || 'See the schedule';
const cta2Href = hero.cta2?.href || '#classes';

const showreel = Array.isArray(hero.showreel) && hero.showreel.length
  ? hero.showreel
  : [];
const reelDoubled = [...showreel, ...showreel];
---
<section class="hero">
  <div class="bg">
    <div class="bg-img" data-image-field="hero.image" style={heroImage ? `background-image:url('${heroImage}');` : ''}></div>
  </div>
  <div class="scrim"></div>
  <div class="wrap hero-in">
    <p class="hero-kicker" data-field="hero.kicker">{kicker}</p>
    <h1 class="giant">
      {headlineLines.map((line: string, i: number) => (
        <span class="ln" data-line={i + 1}><span data-field={`hero.headlineLines.${i}`} set:html={line}></span></span>
      ))}
    </h1>
    <div class="hero-foot">
      <div>
        <p class="hero-sub" data-field="hero.sub">{sub}</p>
        <p class="hero-trust" data-field="hero.trustLine" set:html={trustLine}></p>
      </div>
      <div class="hero-cta">
        <a href={cta1Href} class="btn btn-primary" data-field="hero.cta1.text" data-href-field="hero.cta1.href">{cta1Text}</a>
        <a href={cta2Href} class="btn btn-ghost" data-field="hero.cta2.text" data-href-field="hero.cta2.href">{cta2Text}</a>
      </div>
    </div>
  </div>
  <div class="showreel" aria-hidden="true">
    <div class="sh-track">
      {reelDoubled.map((tile: any, i: number) => (
        <div class="sh-tile">
          <div class="sh-img" data-image-field={`hero.showreel.${i % showreel.length}.image`} style={tile.image ? `background-image:url('${tile.image}');` : ''}></div>
          <span class="lab" data-field={`hero.showreel.${i % showreel.length}.label`}>{tile.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .hero { position: relative; min-height: 90vh; display: flex; flex-direction: column; background: var(--teal); color: var(--paper-2); overflow: hidden; }
  .bg, .bg-img { position: absolute; inset: 0; }
  .bg-img { background-size: cover; background-position: center; opacity: .3; }
  .scrim { position: absolute; inset: 0; z-index: 1; pointer-events: none; background: radial-gradient(120% 95% at 72% 0%, transparent, rgba(28, 58, 55, .45)), linear-gradient(180deg, rgba(28, 58, 55, .38), rgba(28, 58, 55, .8)); }
  .hero-in { position: relative; z-index: 2; flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 120px 0 26px; }
  .hero-kicker { font-size: 13px; letter-spacing: .22em; text-transform: uppercase; color: var(--peach); font-weight: 600; }
  .giant { font-family: var(--serif); font-weight: 400; text-transform: uppercase; line-height: .9; letter-spacing: -.005em; font-size: clamp(58px, 12.5vw, 202px); margin-top: 18px; }
  .giant .ln { display: block; }
  .giant .ln > span { display: inline-block; transform: translateY(0); opacity: 1; }
  :global(body.reveal-on) .giant .ln > span { animation: grise 1.1s cubic-bezier(.19, 1, .22, 1) both; }
  :global(body.reveal-on) .giant .ln[data-line="2"] > span { animation-delay: .12s; }
  :global(body.reveal-on) .giant .ln[data-line="3"] > span { animation-delay: .24s; }
  @keyframes grise { from { transform: translateY(46%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .giant :global(em) { font-family: var(--serif); font-style: italic; text-transform: none; color: var(--peach); }
  .hero-foot { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-end; gap: 24px 40px; margin-top: 40px; }
  .hero-sub { max-width: 42ch; font-size: 19px; color: rgba(255, 255, 255, .86); }
  .hero-trust { margin-top: 16px; font-size: 13px; color: rgba(255, 255, 255, .7); }
  .hero-trust :global(.stars) { color: var(--peach); letter-spacing: 1px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; }
  .hero-cta :global(.btn-primary) { background: var(--peach); border-color: var(--peach); color: var(--ink); }
  .hero-cta :global(.btn-primary:hover) { background: var(--paper-2); border-color: var(--paper-2); }
  .hero-cta :global(.btn-ghost) { color: var(--paper-2); border-color: rgba(255, 255, 255, .5); }
  .hero-cta :global(.btn-ghost:hover) { background: var(--paper-2); color: var(--ink); border-color: var(--paper-2); }
  .showreel { position: relative; z-index: 2; padding-bottom: 26px; overflow: hidden; -webkit-mask: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); mask: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); }
  .sh-track { display: flex; gap: 16px; width: max-content; padding: 0 16px; animation: reel 42s linear infinite; }
  .hero:hover .sh-track { animation-play-state: paused; }
  .sh-tile { position: relative; flex: none; width: 250px; height: 150px; border-radius: 18px; overflow: hidden; border: 1px solid rgba(255, 255, 255, .2); background: #102e2b; }
  .sh-img { width: 100%; height: 100%; background-size: cover; background-position: center; }
  .sh-tile .lab { position: absolute; left: 0; right: 0; bottom: 0; padding: 18px 14px 10px; background: linear-gradient(to top, rgba(28, 58, 55, .9), transparent); font-size: 11px; letter-spacing: .06em; text-transform: uppercase; color: var(--paper-2); }
  @keyframes reel { to { transform: translateX(-50%); } }
  @media (max-width: 680px) { .sh-tile { width: 188px; height: 116px; } .hero-in { padding-top: 100px; } }
</style>
