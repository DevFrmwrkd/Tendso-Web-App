---
/**
 * generic / PageC — Cedar & Stone template wrapper.
 * Paper + amber + forest, hard-shadow neo-brutalist for landscape / build trades.
 */
import HeaderC from './header/HeaderC.astro';
import HeroC from './hero/HeroC.astro';
import MarqueeC from './marquee/MarqueeC.astro';
import TrustC from './trust/TrustC.astro';
import AboutC from './about/AboutC.astro';
import ServicesC from './services/ServicesC.astro';
import WhyC from './why/WhyC.astro';
import HowC from './how/HowC.astro';
import TestimonialsC from './testimonials/TestimonialsC.astro';
import GalleryC from './gallery/GalleryC.astro';
import FaqC from './faq/FaqC.astro';
import AreaC from './area/AreaC.astro';
import LocationC from './location/LocationC.astro';
import CtaBandC from './ctaBand/CtaBandC.astro';
import FooterC from './footer/FooterC.astro';
import { resolveTheme, buildFontHref, buildOverrideCss } from '../../lib/genericThemeOverrides';

interface Props { siteData: any; }
const { siteData } = Astro.props;
const layout = siteData.layout ?? {};
const content = siteData.content ?? {};
const visibility = siteData.visibility ?? {};
const title = layout.businessName ? `${layout.businessName}${layout.tagline ? ' — ' + layout.tagline : ''}` : 'Welcome';
const { scheme: __themeScheme, pairing: __themePairing } = resolveTheme(layout, (content as any).business_type);
const __overrideCss = buildOverrideCss(__themeScheme, __themePairing);
const __fontHref = buildFontHref(__themePairing);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {content.description && <meta name="description" content={content.description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  {layout.favicon && <link rel="icon" href={layout.favicon} />}
  {(layout.ogImage || layout.favicon) && <meta property="og:image" content={layout.ogImage || layout.favicon} />}
  <style is:global>
    :root {
      --paper: #E9E5DB; --paper-2: #F2EFE8; --card: #FFFFFF;
      --ink: #1A241D; --ink-soft: #46544A; --stone: #BDB6A6; --line: #1A241D;
      --forest: #21482F; --forest-2: #2E5C3D; --amber: #E9A718; --amber-2: #F4B826;
      --paper-rgb: 233,229,219; --ink-rgb: 26,36,29; --accent-rgb: 233,167,24;
      --disp: "Anton", Impact, sans-serif;
      --sans: "Archivo", system-ui, sans-serif;
      --wrap: 1280px; --shadow: 6px 6px 0 var(--ink);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--sans); font-size: 17px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3, h4 { margin: 0; font-family: var(--disp); font-weight: 400; line-height: .94; text-transform: uppercase; letter-spacing: .005em; }
    p { margin: 0; }
    .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 30px; }
    .eyebrow { font-family: var(--sans); font-size: 12px; font-weight: 700; letter-spacing: .22em; text-transform: uppercase; color: var(--amber); }
    section { position: relative; }
    .btn { display: inline-flex; align-items: center; gap: 9px; font-family: var(--sans); font-size: 13px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 16px 26px; min-height: 48px; border: 2px solid var(--ink); cursor: pointer; transition: transform .18s ease, box-shadow .18s ease; }
    .btn-primary { background: var(--amber); color: var(--ink); box-shadow: var(--shadow); }
    .btn-primary:hover { transform: translate(-3px, -3px); box-shadow: 9px 9px 0 var(--ink); }
    .btn-ghost { background: transparent; color: var(--ink); }
    .btn-ghost:hover { background: var(--ink); color: var(--paper-2); }
    .btn-light { background: var(--paper-2); color: var(--ink); border-color: var(--paper-2); box-shadow: 6px 6px 0 rgba(0,0,0,.45); }
    .btn-light:hover { transform: translate(-3px, -3px); }
    .reveal { opacity: 1; transform: none; }
    body.reveal-on .reveal { opacity: 0; transform: translateY(30px); transition: opacity .7s cubic-bezier(.2,.8,.2,1), transform .7s cubic-bezier(.2,.8,.2,1); }
    body.reveal-on .reveal.in { opacity: 1; transform: none; }
    .sec { padding: 100px 0; }
    .sec-tag { font-size: 12px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--amber); background: var(--ink); display: inline-block; padding: 6px 12px; margin-bottom: 20px; }
    .sec h2 { font-size: clamp(40px, 6vw, 80px); max-width: 16ch; }
    .sec h2 em { font-style: normal; color: var(--forest); }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; }
      .reveal { opacity: 1 !important; transform: none !important; }
      html { scroll-behavior: auto; }
    }
  </style>
  {__fontHref && <link href={__fontHref} rel="stylesheet" />}
  <style is:global set:html={__overrideCss}></style>
</head>
<body>
  <HeaderC layout={layout} content={content} />
  <main id="top">
    {visibility.heroSection !== false && <HeroC content={content} />}
    <MarqueeC content={content} />
    {visibility.trustBlock !== false && <TrustC content={content} />}
    {visibility.aboutSection !== false && <AboutC content={content} />}
    {visibility.servicesSection !== false && <ServicesC content={content} />}
    {visibility.whyUsBlock !== false && <WhyC content={content} />}
    {visibility.howItWorksBlock !== false && <HowC content={content} />}
    {visibility.testimonialsBlock !== false && <TestimonialsC content={content} />}
    {visibility.gallerySection !== false && <GalleryC content={content} />}
    {visibility.faqBlock !== false && <FaqC content={content} />}
    {visibility.serviceAreaBlock !== false && <AreaC content={content} />}
    {visibility.locationBlock !== false && <LocationC content={content} layout={layout} />}
  </main>
  {visibility.ctaBandBlock !== false && <CtaBandC content={content} layout={layout} />}
  <FooterC layout={layout} content={content} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !document.hidden) {
        document.body.classList.add('reveal-on');
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      }
      window.__genericInitMap = function (lat, lng, label) {
        if (!window.L) return;
        var el = document.getElementById('map'); if (!el) return;
        var ll = [lat, lng];
        var map = L.map('map', { scrollWheelZoom: false }).setView(ll, 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 19 }).addTo(map);
        var icon = L.divIcon({ className: '', html: '<div style="width:24px;height:24px;background:#E9A718;border:3px solid #1A241D;transform:rotate(45deg);box-shadow:0 3px 8px rgba(0,0,0,.4);"></div>', iconSize: [24, 24], iconAnchor: [12, 22] });
        L.marker(ll, { icon: icon }).addTo(map).bindPopup('<b>' + label + '</b>');
      };
    })();
  </script>
</body>
</html>
