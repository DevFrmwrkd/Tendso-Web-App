---
interface Props { layout: any; content: any; }
const { layout, content } = Astro.props;
const brand = layout.businessName || 'Your Business';
const navLinks = (layout.navLinks && layout.navLinks.length) ? layout.navLinks : [];
const phone = layout.contact?.phone || content.contact?.phone || '';
const phoneDigits = phone.replace(/[^0-9+]/g, '');
const ctaText = content.navCtaText || 'Get a quote';
const ctaHref = content.navCtaHref || '#visit';
---
<header class="nav">
  <div class="wrap nav-in">
    <a href="#top" class="brand"><span class="mk"></span><span data-field="nav.brand">{brand}</span></a>
    <div class="nav-links">
      {navLinks.map((link: any, i: number) => (
        <a href={link.href} data-field={`nav.links.${i}.label`} data-href-field={`nav.links.${i}.href`}>{link.label}</a>
      ))}
    </div>
    <div class="nav-right">
      {phone && <a href={`tel:${phoneDigits}`} class="nav-phone" data-field="nav.phone" data-href-field="nav.phone.href">{phone}</a>}
      <a href={ctaHref} class="nav-cta" data-field="nav.cta.text" data-href-field="nav.cta.href">{ctaText}</a>
    </div>
  </div>
</header>
<style>
  header.nav { position: sticky; top: 0; z-index: 1000; background: var(--forest); border-bottom: 3px solid var(--amber); }
  .nav-in { display: flex; align-items: center; justify-content: space-between; gap: 20px; height: 76px; }
  .brand { font-family: var(--disp); font-size: 26px; color: var(--paper-2); letter-spacing: .02em; display: flex; align-items: center; gap: 10px; }
  .brand .mk { width: 14px; height: 24px; background: var(--amber); clip-path: polygon(50% 0, 100% 100%, 0 100%); }
  .nav-links { display: flex; gap: 26px; font-size: 12.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
  .nav-links a { position: relative; color: rgba(var(--paper-rgb), .78); padding: 4px 0; }
  .nav-links a::after { content: ""; position: absolute; left: 0; bottom: 0; height: 2px; width: 0; background: var(--amber); transition: .25s; }
  .nav-links a:hover { color: var(--paper-2); }
  .nav-links a:hover::after { width: 100%; }
  .nav-right { display: flex; align-items: center; gap: 16px; }
  .nav-phone { font-size: 14px; font-weight: 700; color: var(--paper-2); }
  .nav-cta { font-family: var(--sans); font-size: 12.5px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; background: var(--amber); color: var(--ink); padding: 12px 18px; border: 2px solid var(--amber); }
  @media (max-width: 980px) { .nav-links, .nav-phone { display: none; } }
</style>
