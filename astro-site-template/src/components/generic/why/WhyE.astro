---
interface Props { content: any; }
const { content } = Astro.props;
const why = content.why || content.whyUs || {};
const tag = why.tag || 'Why us';
const headline = why.headline || '';
const items = Array.isArray(why.items) && why.items.length > 0 ? why.items : [];
const iconPaths = [
  '<path d="M21 12a9 9 0 1 1-3-6.7M21 4v5h-5"/>',
  '<path d="M3 7h18M6 7l1 12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-12M10 4h4"/>',
  '<path d="M12 1v22M5 5l14 14M5 19L19 5"/>',
  '<path d="M12 21s-7-4.4-9.3-9C1.2 8.3 3 5 6.5 5 9 5 12 8 12 8s3-3 5.5-3C21 5 22.8 8.3 21.3 12 19 16.6 12 21 12 21z"/>',
];
---
<section class="sec why-sec" id="why">
  <div class="wrap">
    <p class="sec-tag reveal" data-field="why.tag">{tag}</p>
    <h2 class="reveal" data-field="why.headline" set:html={headline}></h2>
    <div class="why-grid">
      {items.map((it: any, i: number) => (
        <div class="why-cell reveal" style={i > 0 ? `transition-delay:.${i * 8}s;` : ''}>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={iconPaths[i] || iconPaths[0]}></svg></div>
          <h3 data-field={`why.items.${i}.title`}>{it.title}</h3>
          <p data-field={`why.items.${i}.body`}>{it.body || it.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .why-sec { background: var(--paper-2); }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 46px; }
  .why-cell { border-radius: 24px; padding: 30px; }
  .why-cell:nth-child(1) { background: var(--blue-soft); }
  .why-cell:nth-child(2) { background: var(--mint-soft); }
  .why-cell:nth-child(3) { background: var(--yellow-soft); }
  .why-cell:nth-child(4) { background: #F0EAFB; }
  .why-cell .ic { width: 50px; height: 50px; border-radius: 14px; background: var(--paper-2); display: flex; align-items: center; justify-content: center; }
  .why-cell svg { width: 26px; height: 26px; stroke: var(--blue); fill: none; stroke-width: 1.9; }
  .why-cell h3 { font-size: 21px; margin-top: 18px; }
  .why-cell p { margin-top: 10px; color: var(--ink-soft); font-size: 14.5px; }
  @media (max-width: 860px) { .why-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .why-grid { grid-template-columns: 1fr; } }
</style>
