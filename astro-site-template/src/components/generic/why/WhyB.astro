---
interface Props { content: any; }
const { content } = Astro.props;
const why = content.why || content.whyUs || {};
const tag = why.tag || 'Why us';
const headline = why.headline || '';
const items = Array.isArray(why.items) && why.items.length > 0 ? why.items : [];
const iconPaths = [
  '<circle cx="12" cy="12" r="9"/><path d="M12 7a5 5 0 0 0 0 10 5 5 0 0 1 0-10z"/>',
  '<path d="M12 21s-7-4.4-9.3-9C1.2 8.3 3 5 6.5 5 9 5 12 8 12 8s3-3 5.5-3C21 5 22.8 8.3 21.3 12 19 16.6 12 21 12 21z"/>',
  '<path d="M3 12h4l2-7 4 14 2-7h6"/>',
];
---
<section class="sec why-sec" id="why">
  <div class="wrap">
    <div class="sec-head">
      <p class="sec-tag reveal" data-field="why.tag">{tag}</p>
      <h2 class="reveal" data-field="why.headline" set:html={headline}></h2>
    </div>
    <div class="why-grid">
      {items.map((it: any, i: number) => (
        <div class="why-cell reveal" style={i > 0 ? `transition-delay:.${i}s;` : ''}>
          <div class="badge">
            <svg viewBox="0 0 24 24" set:html={iconPaths[i] || iconPaths[0]}></svg>
          </div>
          <h3 data-field={`why.items.${i}.title`}>{it.title}</h3>
          <p data-field={`why.items.${i}.body`}>{it.body || it.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .why-sec { background: var(--teal-soft); }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px; margin-top: 60px; text-align: center; }
  .why-cell .badge { width: 84px; height: 84px; border-radius: 50%; background: var(--paper-2); border: 1.5px solid var(--teal); display: flex; align-items: center; justify-content: center; margin: 0 auto 22px; }
  .why-cell svg { width: 34px; height: 34px; stroke: var(--teal); fill: none; stroke-width: 1.2; }
  .why-cell h3 { font-size: 30px; font-weight: 400; }
  .why-cell p { margin-top: 12px; color: var(--ink-soft); font-size: 16px; }
  @media (max-width: 760px) { .why-grid { grid-template-columns: 1fr; gap: 40px; } }
</style>
