---
interface Props { content: any; }
const { content } = Astro.props;
const t = content.testimonials || {};
const tag = t.tag || 'Happy customers';
const headline = t.headline || 'Seattle keeps coming back.';
const source = t.source || '★ Ratings & reviews kept live on our Google Business profile';
const items: Array<{ quote: string; av: string; who: string }> = Array.isArray(t.items) && t.items.length > 0 ? t.items : [];
---
<section class="sec testi-sec" id="reviews">
  <div class="wrap">
    <p class="sec-tag reveal" data-field="testimonials.tag">{tag}</p>
    <h2 class="reveal" data-field="testimonials.headline" set:html={headline}></h2>
    <div class="testi-grid">
      {items.map((it: any, i: number) => (
        <div class="bubble reveal" style={i > 0 ? `transition-delay:.${i}s;` : ''}>
          <div class="stars">★★★★★</div>
          <p data-field={`testimonials.items.${i}.quote`} set:html={it.quote}></p>
          <div class="who">
            <span class="av" data-field={`testimonials.items.${i}.av`}>{it.av}</span>
            <span data-field={`testimonials.items.${i}.who`}>{it.who}</span>
          </div>
        </div>
      ))}
    </div>
    <p class="tsrc" data-field="testimonials.source">{source}</p>
  </div>
</section>
<style>
  .testi-sec { background: var(--paper-2); }
  .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; margin-top: 50px; }
  .bubble { background: var(--paper-2); border-radius: 24px; padding: 28px; position: relative; box-shadow: 0 10px 30px rgba(var(--ink-rgb), .08); }
  .bubble::after { content: ""; position: absolute; left: 34px; bottom: -14px; width: 28px; height: 28px; background: var(--paper-2); border-radius: 0 0 0 8px; transform: rotate(45deg) skew(-6deg, -6deg); box-shadow: -6px 6px 12px rgba(var(--ink-rgb), .04); }
  .bubble .stars { color: var(--yellow); -webkit-text-stroke: .5px var(--ink); letter-spacing: 1px; }
  .bubble p { margin-top: 12px; font-size: 17px; line-height: 1.5; font-weight: 500; }
  .bubble .who { margin-top: 18px; display: flex; align-items: center; gap: 12px; }
  .bubble .av { width: 38px; height: 38px; border-radius: 50%; background: var(--blue-soft); display: flex; align-items: center; justify-content: center; font-family: var(--disp); font-weight: 800; color: var(--blue); }
  .bubble .who span:last-child { font-size: 12px; color: var(--ink-soft); }
  .tsrc { text-align: center; margin-top: 40px; font-family: var(--mono); font-size: 13px; color: var(--ink-soft); }
  @media (max-width: 860px) { .testi-grid { grid-template-columns: 1fr; } }
</style>
