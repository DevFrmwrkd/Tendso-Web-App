---
/**
 * generic / TestimonialsA — ink-band with big pullquote + 3 cards.
 *
 * Editable hooks:
 *   testimonials.tag, testimonials.bigQuote, testimonials.source,
 *   testimonials.items[i].quote, testimonials.items[i].who
 */
interface Props { content: any; }
const { content } = Astro.props;
const t = content.testimonials || {};

const tag       = t.tag       || 'What regulars say';
const bigQuote  = t.bigQuote  || '"The only place I\'ll walk past three other cafés to get to. The <em>house blend ruined</em> every other cup for me."';
const sourceTag = t.source    || '★ Ratings & reviews kept live on our Google Business profile';

const items = Array.isArray(t.items) && t.items.length > 0 ? t.items
  : [];
---

<section class="sec testi">
  <div class="wrap">
    <p class="sec-tag reveal" data-field="testimonials.tag">{tag}</p>
    <p class="testi-big reveal" data-field="testimonials.bigQuote" set:html={bigQuote}></p>
    <div class="testi-cards">
      {items.map((it: any, i: number) => (
        <div class="tc reveal" style={i > 0 ? `transition-delay:.${i}s;` : ''}>
          <div class="stars">★★★★★</div>
          <p data-field={`testimonials.items.${i}.quote`} set:html={it.quote}></p>
          <div class="who" data-field={`testimonials.items.${i}.who`}>{it.who || it.name || ''}</div>
        </div>
      ))}
    </div>
    <p class="testi-src" data-field="testimonials.source">{sourceTag}</p>
  </div>
</section>

<style>
  .testi {
    background: var(--ink);
    color: var(--paper);
  }
  .testi :global(.sec-tag) {
    color: var(--gold);
  }
  .testi-big {
    font-family: var(--disp);
    font-weight: 700;
    font-size: clamp(30px, 4.2vw, 52px);
    line-height: 1.12;
    max-width: 20ch;
    margin-top: 20px;
    letter-spacing: -.02em;
  }
  .testi-big :global(em) {
    color: var(--gold);
    font-style: normal;
  }
  .testi-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 54px;
  }
  .tc {
    border: 2px solid rgba(var(--paper-rgb), .22);
    border-radius: 16px;
    padding: 28px;
  }
  .tc .stars {
    color: var(--gold);
    letter-spacing: 2px;
  }
  .tc p {
    margin-top: 14px;
    font-size: 18px;
    line-height: 1.5;
  }
  .tc .who {
    margin-top: 18px;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: .04em;
    color: rgba(var(--paper-rgb), .66);
  }
  .testi-src {
    margin-top: 30px;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(var(--paper-rgb), .55);
  }
  @media (max-width: 820px) {
    .testi-cards { grid-template-columns: 1fr; }
  }
</style>
