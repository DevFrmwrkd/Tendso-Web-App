---
interface Props { content: any; }
const { content } = Astro.props;
const t = content.testimonials || {};
const tag = t.tag || 'In their words';
const headline = t.headline || 'What students <em>say.</em>';
const source = t.source || '★ ratings & reviews kept live on our Google Business profile';
const items = Array.isArray(t.items) && t.items.length ? t.items : [];
---
<section class="sec testi-sec" id="reviews">
  <div class="wrap">
    <div class="sec-head">
      <p class="sec-tag reveal" data-field="testimonials.tag">{tag}</p>
      <h2 class="reveal" data-field="testimonials.headline" set:html={headline}></h2>
    </div>
    <div class="tcards">
      {items.map((it: any, i: number) => (
        <div class="tcard reveal">
          <div class="stars">★★★★★</div>
          <p data-field={`testimonials.items.${i}.quote`} set:html={it.quote}></p>
          <div class="who" data-field={`testimonials.items.${i}.who`}>{it.who || it.name || ''}</div>
        </div>
      ))}
    </div>
    <p class="tsrc" data-field="testimonials.source">{source}</p>
  </div>
</section>
<style>
  .testi-sec { background: var(--card); }
  .tcards { columns: 2; column-gap: 28px; margin-top: 56px; }
  .tcard { break-inside: avoid; margin-bottom: 28px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 24px; padding: 32px 34px; }
  .tcard .stars { color: var(--peach); letter-spacing: 1px; }
  .tcard p { margin-top: 14px; font-family: var(--serif); font-size: 26px; line-height: 1.32; }
  .tcard .who { margin-top: 16px; font-size: 13px; color: var(--ink-soft); }
  .tsrc { text-align: center; margin-top: 34px; font-size: 12px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-soft); }
  @media (max-width: 760px) { .tcards { columns: 1; } }
</style>
