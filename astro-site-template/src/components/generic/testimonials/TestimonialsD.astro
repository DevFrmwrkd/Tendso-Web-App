---
interface Props { content: any; }
const { content } = Astro.props;
const t = content.testimonials || {};
const tag = t.tag || 'client_reviews';
const headline = t.headline || 'Trusted by Austin businesses.';
const source = t.source || '// Ratings & reviews kept live on our Google Business profile';
const bigQuote = t.bigQuote || '"They migrated our whole office to the cloud over a weekend. Monday morning everything just worked — and when one laptop hiccupped, a tech had it fixed in ten minutes."';
const bigWho = t.bigWho || '// Review kept live on Google';
const small: Array<{ quote: string; who: string }> = Array.isArray(t.items) && t.items.length > 0 ? t.items : [];
---
<section class="sec testi-sec" id="reviews">
  <div class="wrap">
    <p class="sec-tag reveal" data-field="testimonials.tag">{tag}</p>
    <h2 class="reveal" data-field="testimonials.headline" set:html={headline}></h2>
    <div class="testi-grid">
      <div class="tbig reveal">
        <div class="stars">★★★★★</div>
        <p data-field="testimonials.bigQuote" set:html={bigQuote}></p>
        <div class="who" data-field="testimonials.bigWho">{bigWho}</div>
      </div>
      <div class="tcol">
        {small.map((it: any, i: number) => (
          <div class="tsm reveal" style={i > 0 ? `transition-delay:.${i}s;` : ''}>
            <div class="stars">★★★★★</div>
            <p data-field={`testimonials.items.${i}.quote`} set:html={it.quote}></p>
            <div class="who" data-field={`testimonials.items.${i}.who`}>{it.who}</div>
          </div>
        ))}
      </div>
    </div>
    <p class="tsrc" data-field="testimonials.source">{source}</p>
  </div>
</section>
<style>
  .testi-sec { background: var(--bg-2); }
  .testi-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 22px; margin-top: 50px; }
  .tbig { background: var(--panel); border: 1px solid var(--line); border-radius: 18px; padding: 42px; display: flex; flex-direction: column; justify-content: center; }
  .tbig .stars { color: var(--lime); font-size: 20px; letter-spacing: 2px; }
  .tbig p { margin-top: 18px; font-family: var(--disp); font-size: clamp(24px, 2.6vw, 34px); font-weight: 600; line-height: 1.25; letter-spacing: -.01em; }
  .tbig .who { margin-top: 22px; font-family: var(--mono); font-size: 13px; color: var(--muted); }
  .tcol { display: flex; flex-direction: column; gap: 22px; }
  .tsm { background: var(--panel); border: 1px solid var(--line); border-radius: 18px; padding: 28px; }
  .tsm .stars { color: var(--lime); letter-spacing: 2px; }
  .tsm p { margin-top: 12px; font-size: 17px; line-height: 1.5; }
  .tsm .who { margin-top: 14px; font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .tsrc { margin-top: 28px; font-family: var(--mono); font-size: 12px; color: var(--muted); }
  @media (max-width: 820px) { .testi-grid { grid-template-columns: 1fr; } }
</style>
