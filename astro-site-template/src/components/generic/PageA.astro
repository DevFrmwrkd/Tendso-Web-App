---
/**
 * generic / PageA — Ironwood Coffee template wrapper.
 *
 * Composes all 13 sections of letter A in order. Defines the template's
 * paper + gold color tokens, fonts, and shared bits (reveal-on-scroll +
 * Leaflet boot) once at the top of the page so individual section
 * components stay focused on layout.
 *
 * Render this from index.astro when any customization style matches
 * `generic:A`. Bypasses BaseLayout's color-scheme machinery — each
 * generic template carries its own cohesive visual identity.
 */
import HeaderA from './header/HeaderA.astro';
import HeroA from './hero/HeroA.astro';
import MarqueeA from './marquee/MarqueeA.astro';
import TrustA from './trust/TrustA.astro';
import AboutA from './about/AboutA.astro';
import ServicesA from './services/ServicesA.astro';
import WhyA from './why/WhyA.astro';
import HowA from './how/HowA.astro';
import TestimonialsA from './testimonials/TestimonialsA.astro';
import GalleryA from './gallery/GalleryA.astro';
import FaqA from './faq/FaqA.astro';
import AreaA from './area/AreaA.astro';
import LocationA from './location/LocationA.astro';
import CtaBandA from './ctaBand/CtaBandA.astro';
import FooterA from './footer/FooterA.astro';
import { resolveTheme, buildFontHref, buildOverrideCss } from '../../lib/genericThemeOverrides';

interface Props {
  siteData: any;
}

const { siteData } = Astro.props;
const layout = siteData.layout ?? {};
const content = siteData.content ?? {};
const visibility = siteData.visibility ?? {};

const title = layout.businessName
  ? `${layout.businessName}${layout.tagline ? ' — ' + layout.tagline : ''}`
  : 'Welcome';
const { scheme: __themeScheme, pairing: __themePairing } = resolveTheme(layout, (content as any).business_type);
const __overrideCss = buildOverrideCss(__themeScheme, __themePairing);
const __fontHref = buildFontHref(__themePairing);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {content.description && <meta name="description" content={content.description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  {layout.favicon && <link rel="icon" href={layout.favicon} />}
  {(layout.ogImage || layout.favicon) && <meta property="og:image" content={layout.ogImage || layout.favicon} />}
  <style is:global>
    :root {
      --paper: #F1ECE0;
      --paper-2: #FAF5EA;
      --card: #E7DECB;
      --ink: #1B1613;
      --ink-soft: #5C5044;
      --line: #D6CBB5;
      --gold: #C8881A;
      --gold-deep: #A56C0F;
      --olive: #3C4A2C;
      --paper-rgb: 241,236,224;
      --ink-rgb: 27,22,19;
      --accent-rgb: 200,136,26;
      --disp: "Helvetica Neue", Helvetica, Arial, sans-serif;
      --sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
      --mono: "Space Mono", monospace;
      --wrap: 1280px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3, h4 {
      margin: 0;
      font-family: var(--disp);
      font-weight: 700;
      line-height: 1;
      letter-spacing: -.022em;
    }
    p { margin: 0; }
    .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 30px; }
    .eyebrow {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold-deep);
    }
    .mono { font-family: var(--mono); }
    section { position: relative; }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: .02em;
      padding: 15px 26px;
      min-height: 50px;
      border: 2px solid var(--ink);
      border-radius: 40px;
      cursor: pointer;
      transition: transform .24s ease, background .24s ease, color .24s ease;
    }
    .btn-primary {
      background: var(--gold);
      border-color: var(--gold);
      color: var(--ink);
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      background: var(--gold-deep);
      border-color: var(--gold-deep);
      color: var(--paper-2);
    }
    .btn-ghost {
      background: transparent;
      color: var(--ink);
    }
    .btn-ghost:hover {
      transform: translateY(-3px);
      background: var(--ink);
      color: var(--paper-2);
    }
    .reveal { opacity: 1; transform: none; }
    body.reveal-on .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity .8s cubic-bezier(.2,.8,.2,1),
        transform .8s cubic-bezier(.2,.8,.2,1);
    }
    body.reveal-on .reveal.in {
      opacity: 1;
      transform: none;
    }
    .sec { padding: 100px 0; }
    .sec-tag {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--gold-deep);
      margin-bottom: 18px;
    }
    .sec h2 {
      font-size: clamp(38px, 5.2vw, 72px);
      max-width: 16ch;
    }
    .sec h2 em {
      font-style: normal;
      color: var(--gold-deep);
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; }
      .reveal { opacity: 1 !important; transform: none !important; }
      html { scroll-behavior: auto; }
    }
  </style>
  {__fontHref && <link href={__fontHref} rel="stylesheet" />}
  <style is:global set:html={__overrideCss}></style>
</head>
<body>
  <HeaderA layout={layout} content={content} />

  <main id="top">
    {visibility.heroSection !== false && <HeroA content={content} />}
    <MarqueeA content={content} />
    {visibility.trustBlock !== false && <TrustA content={content} />}
    {visibility.aboutSection !== false && <AboutA content={content} />}
    {visibility.servicesSection !== false && <ServicesA content={content} />}
    {visibility.whyUsBlock !== false && <WhyA content={content} />}
    {visibility.howItWorksBlock !== false && <HowA content={content} />}
    {visibility.testimonialsBlock !== false && <TestimonialsA content={content} />}
    {visibility.gallerySection !== false && <GalleryA content={content} layout={layout} />}
    {visibility.faqBlock !== false && <FaqA content={content} />}
    {visibility.serviceAreaBlock !== false && <AreaA content={content} />}
    {visibility.locationBlock !== false && <LocationA content={content} layout={layout} />}
  </main>

  {visibility.ctaBandBlock !== false && <CtaBandA content={content} layout={layout} />}
  <FooterA layout={layout} content={content} />

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    (function () {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !document.hidden) {
        document.body.classList.add('reveal-on');
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
      }
      // Map boot — initialized by LocationA when it has lat/lng. We set up
      // a global stub so the section can lazily attach when leaflet loads.
      window.__genericInitMap = function (lat, lng, label) {
        if (!window.L) return;
        var el = document.getElementById('map');
        if (!el) return;
        var ll = [lat, lng];
        var map = L.map('map', { scrollWheelZoom: false }).setView(ll, 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; OpenStreetMap &copy; CARTO',
          maxZoom: 19,
        }).addTo(map);
        var icon = L.divIcon({
          className: '',
          html: '<div style="width:22px;height:22px;background:#C8881A;border:3px solid #1B1613;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 3px 8px rgba(0,0,0,.35);"></div>',
          iconSize: [22, 22],
          iconAnchor: [11, 22],
        });
        L.marker(ll, { icon: icon }).addTo(map).bindPopup('<b>' + label + '</b>');
      };
    })();
  </script>
</body>
</html>
