---
/**
 * generic / FooterA — 4-col ink footer with brand, visit, links, hours.
 *
 * Editable hooks:
 *   footer.brand, footer.blurb,
 *   footer.visit.lines[i],
 *   footer.explore.links[i] (text + href),
 *   footer.hours[i].day / footer.hours[i].time,
 *   footer.social[i] (platform + url) — see comment below,
 *   footer.notes[i]
 *
 * Social-link rows are surfaced as `data-href-field` + `data-platform-field`
 * for the editor bridge. The current Ironwood markup uses ASCII platform
 * names in the text node and a real href, so the same convention works:
 * the platform string is both the label and the dropdown selector value.
 */
interface Props {
  layout: any;
  content: any;
}
const { layout, content } = Astro.props;
const f = content.footer || {};

const brand = f.brand   || layout.businessName || 'Your Business';
const blurb = f.blurb   || f.brand_blurb
  || 'A brief one-line description of what this business does. Edit in the Footer section.';

const visitLines: string[] = Array.isArray(f.visit?.lines) && f.visit.lines.length
  ? f.visit.lines
  : [];

const explore: Array<{ text: string; href: string }> = Array.isArray(f.explore?.links) && f.explore.links.length
  ? f.explore.links
  : [];

const hoursRows: Array<{ day: string; time: string }> = Array.isArray(f.hours) && f.hours.length
  ? f.hours
  : [];

const social: Array<{ platform: string; url: string }> = Array.isArray(f.social) && f.social.length
  ? f.social
  : (Array.isArray(layout.socialLinks) ? layout.socialLinks : []);

const notes: string[] = Array.isArray(f.notes) && f.notes.length
  ? f.notes
  : [];

const phone = layout.contact?.phone || '';
const phoneDigits = phone.replace(/[^0-9+]/g, '');
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="brand" data-field="footer.brand"><span class="dot"></span>{brand}</div>
        <p class="blurb" data-field="footer.blurb">{blurb}</p>
        {social.length > 0 && (
          <div class="foot-social">
            {social.map((s: any, i: number) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                data-field={`footer.social.${i}.platform`}
                data-href-field={`footer.social.${i}.url`}
                data-platform-field={`footer.social.${i}.platform`}
              >{s.platform}</a>
            ))}
          </div>
        )}
      </div>
      <div class="foot-col">
        <h4>Visit</h4>
        <ul>
          {visitLines.map((line: string, i: number) => (
            line === phone && phone
              ? <li><a href={`tel:${phoneDigits}`} data-field={`footer.visit.lines.${i}`} data-href-field={`footer.visit.lines.${i}.href`}>{line}</a></li>
              : <li data-field={`footer.visit.lines.${i}`}>{line}</li>
          ))}
        </ul>
      </div>
      <div class="foot-col">
        <h4>Explore</h4>
        <ul>
          {explore.map((l: any, i: number) => (
            <li>
              <a
                href={l.href}
                data-field={`footer.explore.links.${i}.text`}
                data-href-field={`footer.explore.links.${i}.href`}
              >{l.text}</a>
            </li>
          ))}
        </ul>
      </div>
      <div class="foot-col foot-hours">
        <h4>Hours · live on Google</h4>
        {hoursRows.map((row: any, i: number) => (
          <div>
            <span data-field={`footer.hours.${i}.day`}>{row.day}</span>
            <span data-field={`footer.hours.${i}.time`}>{row.time}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="foot-note">
      {notes.map((n: string, i: number) => (
        <span data-field={`footer.notes.${i}`}>{n}</span>
      ))}
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--ink);
    color: var(--paper);
    padding: 74px 0 36px;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.3fr;
    gap: 36px;
  }
  footer .brand {
    color: var(--paper-2);
    font-family: var(--disp);
    font-size: 25px;
    font-weight: 800;
    letter-spacing: -.03em;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  footer .brand .dot {
    width: 14px;
    height: 14px;
    background: var(--gold);
    border-radius: 50%;
  }
  footer .blurb {
    margin-top: 16px;
    color: rgba(var(--paper-rgb), .6);
    max-width: 34ch;
    font-size: 15px;
  }
  .foot-social {
    margin-top: 18px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .foot-social a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: rgba(var(--paper-rgb), .72);
    border: 1px solid rgba(var(--paper-rgb), .2);
    padding: 6px 12px;
    border-radius: 999px;
    transition: color .2s, border-color .2s;
  }
  .foot-social a:hover {
    color: var(--gold);
    border-color: var(--gold);
  }
  .foot-col h4 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(var(--paper-rgb), .5);
  }
  .foot-col ul {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .foot-col a, .foot-col li {
    color: rgba(var(--paper-rgb), .82);
    font-size: 15px;
  }
  .foot-col a:hover { color: var(--gold); }
  .foot-hours div {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: rgba(var(--paper-rgb), .82);
    padding: 5px 0;
    border-bottom: 1px solid rgba(var(--paper-rgb), .12);
  }
  .foot-note {
    margin-top: 48px;
    padding-top: 22px;
    border-top: 1px solid rgba(var(--paper-rgb), .14);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: rgba(var(--paper-rgb), .5);
  }
  @media (max-width: 820px) {
    .foot-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
