---
interface Props { content: any; }
const { content } = Astro.props;
const area = content.area || content.serviceArea || {};
const tag = area.tag || 'coverage';
const headline = area.headline || 'Serving greater Austin.';
const body = area.body || 'Describe the area you serve. Edit in the Service area section.';
const places: string[] = Array.isArray(area.places) && area.places.length ? area.places : [];
const creds = content.credentials || {};
const credTag = creds.tag || 'credentials';
const credHeadline = creds.headline || 'Certified & vetted.';
const credBody = creds.body || 'Our technicians hold current industry certifications and we carry full coverage.';
const credItems = Array.isArray(creds.items) && creds.items.length ? creds.items : [];
const credIconPaths = [
  '<path d="M12 3l8 4v6c0 5-4 7-8 8-4-1-8-3-8-8V7z"/>',
  '<rect x="3" y="4" width="18" height="14" rx="2"/>',
  '<path d="M12 2l3 6 6 .5-4.5 4 1.5 6L12 15l-6 3.5 1.5-6L3 8.5 9 8z"/>',
  '<path d="M4 7h16M4 12h16M4 17h10"/>',
];
---
<section class="sec" id="area">
  <div class="wrap split2">
    <div>
      <p class="sec-tag reveal" data-field="area.tag">{tag}</p>
      <h2 class="reveal" data-field="area.headline" style="font-size:clamp(30px,3.6vw,46px);">{headline}</h2>
      <p class="lead reveal" data-field="area.body">{body}</p>
      <div class="area-tags reveal">
        {places.map((p: string, i: number) => (
          <span data-field={`area.places.${i}`}>{p}</span>
        ))}
      </div>
    </div>
    <div>
      <p class="sec-tag reveal" data-field="credentials.tag">{credTag}</p>
      <h2 class="reveal" data-field="credentials.headline" style="font-size:clamp(30px,3.6vw,46px);">{credHeadline}</h2>
      <p class="lead reveal" data-field="credentials.body">{credBody}</p>
      <div class="cred-chips reveal">
        {credItems.map((it: any, i: number) => (
          <span class="cred-chip">
            <svg viewBox="0 0 24 24" set:html={credIconPaths[i % credIconPaths.length]}></svg>
            <span data-field={`credentials.items.${i}.label`}>{it.label || it.title}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
<style>
  .split2 { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; }
  @media (max-width: 820px) { .split2 { grid-template-columns: 1fr; gap: 46px; } }
  .area-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .area-tags span { font-family: var(--mono); font-size: 13px; border: 1px solid var(--line); border-radius: 8px; padding: 9px 14px; color: var(--muted); }
  .area-tags span::before { content: "› "; color: var(--lime); }
  .cred-chips { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .cred-chip { display: flex; align-items: center; gap: 10px; border: 1px solid var(--line); border-radius: 10px; padding: 14px 18px; background: var(--panel); font-family: var(--mono); font-size: 13px; }
  .cred-chip svg { width: 18px; height: 18px; stroke: var(--lime); fill: none; stroke-width: 1.8; }
</style>
