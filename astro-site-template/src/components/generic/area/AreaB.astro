---
interface Props { content: any; }
const { content } = Astro.props;
const area = content.area || content.serviceArea || {};
const tag = area.tag || 'Who we welcome';
const headline = area.headline || 'Students from across <em>Portland.</em>';
const body = area.body || 'Describe the area you serve. Edit in the Service area section.';
const places: string[] = Array.isArray(area.places) && area.places.length ? area.places : [];

const creds = content.credentials || {};
const credTag = creds.tag || 'Credentials';
const credHeadline = creds.headline || 'Trained & <em>certified.</em>';
const credBody = creds.body || 'Every teacher on the schedule holds current certifications and first-aid training.';
const credItems: Array<{ label: string }> = Array.isArray(creds.items) && creds.items.length ? creds.items : [];
const credIconPaths = [
  '<path d="M12 3l8 4v6c0 5-4 7-8 8-4-1-8-3-8-8V7z"/>',
  '<circle cx="12" cy="12" r="9"/><path d="M8 12l2.5 2.5L16 9"/>',
  '<path d="M12 21s-7-4.4-9.3-9C1.2 8.3 3 5 6.5 5 9 5 12 8 12 8z"/>',
  '<path d="M4 7h16M4 12h16M4 17h10"/>',
];
---
<section class="sec area-sec" id="area">
  <div class="wrap split2">
    <div>
      <p class="sec-tag reveal" data-field="area.tag">{tag}</p>
      <h2 class="reveal" data-field="area.headline" style="font-size:clamp(32px,4vw,52px);" set:html={headline}></h2>
      <p class="reveal area-body" data-field="area.body">{body}</p>
      <div class="area-chips reveal">
        {places.map((p: string, i: number) => (
          <span data-field={`area.places.${i}`}>{p}</span>
        ))}
      </div>
    </div>
    <div>
      <p class="sec-tag reveal" data-field="credentials.tag">{credTag}</p>
      <h2 class="reveal" data-field="credentials.headline" style="font-size:clamp(32px,4vw,52px);" set:html={credHeadline}></h2>
      <p class="reveal area-body" data-field="credentials.body">{credBody}</p>
      <div class="creds reveal">
        {credItems.map((it: any, i: number) => (
          <span class="cred-pill">
            <svg viewBox="0 0 24 24" set:html={credIconPaths[i % credIconPaths.length]}></svg>
            <span data-field={`credentials.items.${i}.label`}>{it.label || it.title || ''}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
<style>
  .area-sec { background: var(--card); }
  .split2 { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  @media (max-width: 820px) { .split2 { grid-template-columns: 1fr; gap: 46px; } }
  .area-body { margin-top: 18px; color: var(--ink-soft); max-width: 42ch; }
  .area-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .area-chips span { font-size: 13px; border: 1.5px solid var(--line); padding: 10px 20px; border-radius: 40px; background: var(--paper-2); font-weight: 500; }
  .creds { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .cred-pill { display: flex; align-items: center; gap: 10px; background: var(--teal-soft); border-radius: 40px; padding: 13px 22px; font-size: 13px; font-weight: 600; color: var(--teal-deep); }
  .cred-pill svg { width: 18px; height: 18px; stroke: var(--teal); fill: none; stroke-width: 1.8; }
</style>
