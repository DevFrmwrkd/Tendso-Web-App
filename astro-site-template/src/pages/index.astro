const ContactComponent = contactComponents[siteData.customizations.contactStyle] || ContactA;

// Visibility shortcuts
const vis = siteData.visibility;
---

<BaseLayout
  businessName={siteData.layout.businessName}
  tagline={siteData.layout.tagline}
  navLinks={siteData.layout.navLinks}
  socialLinks={siteData.layout.socialLinks}
  colorScheme={siteData.layout.colorScheme}
  fontPairing={siteData.layout.fontPairing}
  contact={siteData.layout.contact}
  navbarStyle={siteData.customizations.heroStyle}
>
  {vis.heroSection !== false && (
    <HeroComponent {...siteData.hero} />
  )}

  {vis.aboutSection !== false && (
    <AboutComponent {...siteData.about} />
  )}

  {vis.servicesSection !== false && (
    <ServicesComponent {...siteData.services} />
  )}

  {vis.gallerySection !== false && (
    <GalleryComponent {...siteData.gallery} />
  )}

  {vis.contactSection !== false && (
    <ContactComponent {...siteData.contact} />
  )}
</BaseLayout>
